---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import MobileMenu from "../components/MobileMenu.astro";
import { SITE } from "../consts";
// Hashed URLs for the two paint-critical font files (display + body), so we
// can preload them — text is the LCP on most pages, and early font arrival
// also shrinks the swap-shift window (§4 CLS).
import frauncesWoff2 from "@fontsource-variable/fraunces/files/fraunces-latin-opsz-normal.woff2?url";
import dmSansWoff2 from "@fontsource-variable/dm-sans/files/dm-sans-latin-wght-normal.woff2?url";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Adventure Storytelling Media — Sindbad Horizon, The StorySmith." } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// Absolute URLs for social scrapers (they don't resolve relative paths).
// Astro.site is parameterized in astro.config.mjs (staging github.io vs the
// apex domain at cutover), so these flip automatically with DEPLOY_TARGET.
const abs = (path: string) => new URL(`${base}${path}`, Astro.site).href;
// strip the base prefix (if present) then re-join — avoids the double-slash
// a naive string replace produces on the root path
const pagePath = Astro.url.pathname.startsWith(base)
  ? Astro.url.pathname.slice(base.length) || "/"
  : Astro.url.pathname;
const canonical = new URL(`${base}${pagePath}`, Astro.site).href;
// Staging (github.io) must never compete with the live domain in search.
const isStaging = (Astro.site?.href ?? "").includes("github.io");

// JSON-LD (BUILD-ORDERS Task 9) — a solo StorySmith. Values come ONLY from the
// SITE consts (no composed facts). Person + ProfessionalService (provider is the
// Person — a solo practice, NOT an Organization-with-employees). Socials wire in
// as `sameAs` only for the entries that actually exist on SITE.socials.
const siteBase = new URL(base || "/", Astro.site).href.replace(/\/$/, "");
const sameAs = Object.values(SITE.socials);
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteBase}/#person`,
      name: SITE.person,
      alternateName: SITE.persona,
      email: `mailto:${SITE.email}`,
      url: `${siteBase}/`,
      ...(sameAs.length ? { sameAs } : {}),
    },
    {
      "@type": "ProfessionalService",
      "@id": `${siteBase}/#service`,
      name: SITE.name,
      provider: { "@id": `${siteBase}/#person` },
      areaServed: SITE.location,
      email: `mailto:${SITE.email}`,
      url: `${siteBase}/`,
    },
  ],
};
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="preload" as="font" type="font/woff2" href={frauncesWoff2} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={dmSansWoff2} crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {isStaging && <meta name="robots" content="noindex" />}

    <!-- Open Graph / Twitter (og.jpg = the brand endcard: mark over the sting scene) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={abs("/media/og.jpg")} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={abs("/media/og.jpg")} />

    <!-- JSON-LD: solo StorySmith (Person + ProfessionalService). Values only
         from SITE consts — no composed facts (BUILD-ORDERS Task 9). -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    <script is:inline>
      document.documentElement.classList.replace("no-js", "js");
    </script>

    <!-- Privacy-respecting analytics (GoatCounter: no cookies, no personal
         data, aggregate counts only). DISABLED until SITE.analytics is set to
         a real GoatCounter code — requires Sindbad to create the (free)
         account; see /privacy. Nothing loads while it's empty. -->
    {
      SITE.analytics && (
        <script
          is:inline
          data-goatcounter={`https://${SITE.analytics}.goatcounter.com/count`}
          async
          src="https://gc.zgo.at/count.js"
        />
      )
    }
  </head>
  <body class="min-h-screen">
    <a href="#main" class="sr-only focus:not-sr-only">Skip to content</a>
    <Nav />
    <MobileMenu />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // Reveal engine + watchdog (v1 KEEP architecture, research-brief §7):
      // [data-reveal] elements are hidden only under html.js (CSS), revealed
      // on approach, force-revealed by a 4s watchdog so nothing can stay
      // hidden, and skipped entirely under reduced motion.
      (() => {
        const els = document.querySelectorAll("[data-reveal]");
        if (!els.length) return;
        const revealAll = () => els.forEach((el) => el.classList.add("is-revealed"));
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches || !("IntersectionObserver" in window)) {
          revealAll();
          return;
        }
        // DIRECTION §1.1 P3: 70ms stagger between siblings (proof-band legend
        // items opt into 40ms via data-reveal-stagger). Siblings entering in the
        // same IO batch get an incremental --reveal-delay so a heading/body/CTA
        // group arrives as a staged sequence, then settles (once: true — the
        // element is unobserved after it reveals, so it never re-animates).
        const io = new IntersectionObserver(
          (entries) => {
            const arriving = entries.filter((e) => e.isIntersecting);
            // group by parent so only true siblings stagger together
            const seq = new Map();
            for (const entry of arriving) {
              const el = entry.target;
              const parent = el.parentElement;
              const step = Number(el.getAttribute("data-reveal-stagger")) || 70;
              const n = seq.get(parent) ?? 0;
              seq.set(parent, n + 1);
              el.style.setProperty("--reveal-delay", `${n * step}ms`);
              el.classList.add("is-revealed");
              io.unobserve(el);
            }
          },
          { rootMargin: "0px 0px -12% 0px", threshold: 0.05 },
        );
        els.forEach((el) => io.observe(el));
        setTimeout(revealAll, 4000); // watchdog — nothing stays hidden
      })();
    </script>
    <script>
      // Site-wide Lenis smooth scroll (v1 KEEP). Singleton; no-ops under
      // reduced motion. Scroll-animation islands share this same instance.
      import { ensureSmoothScroll } from "../lib/smooth-scroll";
      void ensureSmoothScroll();
    </script>
  </body>
</html>
