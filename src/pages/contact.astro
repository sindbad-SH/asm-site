---
/**
 * Form structure only. The live endpoint (SITE.formEndpoint) is [confirm] —
 * wiring it to a real service is a separate Phase 3 task (BUILD-PLAN.md §6.3
 * "Contact page + live form wiring"). Until then the form has no `action`,
 * so it can't silently POST to a placeholder URL. Field styling is the
 * system voice (§3 component library): elevated ground, hairline border,
 * mono labels, accent focus ring.
 */
import Base from "../layouts/Base.astro";
import { PAGES, SITE } from "../consts";

const p = PAGES.contact;
const formReady = SITE.formEndpoint !== "[confirm]";
---

<Base title={p.meta.title} description={p.meta.description}>
  <section class="mx-auto max-w-xl space-y-6 p-8">
    <h1 class="text-3xl font-bold">{p.headline}</h1>
    <p>{p.body}</p>

    {
      !formReady && (
        <p class="hud-label border border-dashed border-current/30 bg-current/5 p-3 normal-case">
          Form endpoint [confirm] — not wired yet (BUILD-PLAN.md §5A S9). Use email below in the
          meantime.
        </p>
      )
    }

    <form method="post" action={formReady ? SITE.formEndpoint : undefined} class="space-y-4">
      <div>
        <label for="name" class="field">Name</label>
        <input id="name" name="name" type="text" required class="field-input" />
      </div>
      <div>
        <label for="email" class="field">Email</label>
        <input id="email" name="email" type="email" required class="field-input" />
      </div>
      <div>
        <label for="message" class="field">What are you building?</label>
        <textarea id="message" name="message" required rows="5" class="field-input" />
      </div>
      <button type="submit" disabled={!formReady} class="btn">Send</button>
    </form>

    <div class="border-t border-hairline pt-6 text-sm">
      <p>
        Prefer email? <a href={`mailto:${p.email}`} class="link">{p.email}</a>
      </p>
      <p class="mt-1">
        Book a call: {SITE.bookACall === "[confirm]" ? <span class="hud-label normal-case opacity-60">[confirm] — S10</span> : <a href={SITE.bookACall} class="link">{SITE.bookACall}</a>}
      </p>
    </div>
  </section>
</Base>
