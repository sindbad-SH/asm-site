---
/**
 * Form structure only. The live endpoint (SITE.formEndpoint) is [confirm] —
 * wiring it to a real service is a separate Phase 3 task (BUILD-PLAN.md §6.3
 * "Contact page + live form wiring"). Until then the form has no `action`,
 * so it can't silently POST to a placeholder URL. Field styling is the
 * system voice (§3 component library): elevated ground, hairline border,
 * mono labels, accent focus ring.
 */
import Base from "../layouts/Base.astro";
import { PAGES, SITE } from "../consts";

const p = PAGES.contact;
const formReady = SITE.formEndpoint !== "[confirm]";
---

<Base title={p.meta.title} description={p.meta.description}>
  <section class="mx-auto max-w-xl space-y-6 p-8">
    {
      /* P5 — mono eyebrow + DECODE, same grammar as /about's location line.
         No new copy: SITE.location is the existing hud-label string the
         Footer already renders site-wide, reused here as the top-section
         kicker (seasoning, not surgery — the page structure is untouched).
         data-reveal + data-tableau-content: same wiring as about.astro, so
         decode fires off the site-wide reveal engine, no new JS needed. */
    }
    <p class="hud-label" data-reveal data-tableau-content>
      <span data-decode>{SITE.location}</span>
    </p>
    <h1 class="text-3xl font-bold">{p.headline}</h1>
    <p>{p.body}</p>

    <!-- Primary action (DIRECTION §2.9 / COPY.md §9): booking = the primary CTA;
         the brand contract's only sanctioned CTA label. Opens Calendly. -->
    <div class="pt-1">
      <a href={SITE.bookACall} class="btn" rel="noopener">Book a Strategy Call</a>
    </div>

    <!-- The form remains present but visually secondary; it stays inert until
         SITE.formEndpoint resolves (operator task — the form's existing
         designed behavior). While inert, an honest pending marker names the
         reserved endpoint (this is the "formEndpoint-driven form state" the
         production gate is expected to catch — BUILD-ORDERS Task 10/11). -->
    <div class="space-y-4 border-t border-hairline pt-6">
      <p class="hud-label normal-case text-ink-muted">Or send a note</p>

      {
        !formReady && (
          <p class="hud-label border border-dashed border-current/30 bg-current/5 p-3 normal-case text-ink-muted">
            The form is inert until its endpoint is wired ({SITE.formEndpoint}). Use the booking
            button or email below in the meantime.
          </p>
        )
      }

    <form method="post" action={formReady ? SITE.formEndpoint : undefined} class="space-y-4">
      <div>
        <label for="name" class="field">Name</label>
        <input id="name" name="name" type="text" required class="field-input" />
      </div>
      <div>
        <label for="email" class="field">Email</label>
        <input id="email" name="email" type="email" required class="field-input" />
      </div>
      <div>
        <label for="message" class="field">What are you building?</label>
        <textarea id="message" name="message" required rows="5" class="field-input" />
      </div>
      <button type="submit" disabled={!formReady} class="btn-quiet border border-hairline px-4 py-2">Send</button>
    </form>

      {
        /* Inert-form email line (COPY.md §9) — shown ONLY while the form is
           inert (formReady === false). Remove-once-live is automatic: the line
           disappears the moment SITE.formEndpoint resolves. */
        !formReady && (
          <p class="text-sm text-ink-muted">
            Prefer email? <a href={`mailto:${p.email}`} class="link">{p.email}</a> — or book a call
            above.
          </p>
        )
      }
    </div>
  </section>
</Base>

<script>
  // P5 — mount the chapter-slate DECODE effect (the one [data-decode] eyebrow
  // above the headline). Same idle-window mount as Tableaux.astro/about.astro:
  // off the LCP path, no-op under reduced motion (decode-text.ts's own gate).
  const mountDecodeLabels = () => import("../lib/decode-text").then(({ mountDecode }) => mountDecode(document));
  if ("requestIdleCallback" in window) requestIdleCallback(mountDecodeLabels, { timeout: 3000 });
  else setTimeout(mountDecodeLabels, 1500);
</script>
