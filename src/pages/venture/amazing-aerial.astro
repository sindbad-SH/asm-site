---
/**
 * /venture/amazing-aerial — P13g: the agency story. UNLIKE the coverage
 * articles (whose prose is assembled from the operator's _ABOUT.md files),
 * this one was WRITTEN BY THE ORCHESTRATOR in the operator's voice at his
 * explicit direction ("feel free to just kind of use my voice that you kind
 * of have identified over us building stuff and just go ahead with it").
 *
 * ⚠ OPERATOR READ-APPROVAL REQUIRED — every sentence in ARTICLE below is
 * new copy. Staging-only until he reads it. Fact base he supplied
 * (2026-07-08): first conversation with founder Paul came through LinkedIn
 * in June 2024; about a month of talking; an official agent by mid-2024
 * ("they're my agency"). Everything else stays inside the LOCKED permitted
 * phrasing: contributor/licensed-through — never "represented exclusively",
 * never ownership.
 *
 * Media: the article reuses the EXISTING licensed adventure-gallery exports
 * (the dual-brand AA+ASM watermarked teasers) — the watermarks aren't a
 * compromise here, they ARE the story: this is what agency licensing looks
 * like. The funnel runs both directions: their site, his portfolio, and
 * back into /adventure.
 */
import Base from "../../layouts/Base.astro";
import LegendMark from "../../components/LegendMark.astro";
import { PAGES } from "../../consts";
import { existsSync } from "node:fs";
import { join } from "node:path";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const aa = PAGES.adventure.licensed; // the locked licensed-relationship block
const AA_PORTFOLIO = PAGES.adventure.aaFunnel.cta.href;

// three licensed teaser frames from the existing gallery exports (gated)
const g = join(process.cwd(), "public", "media", "adventure", "gallery");
const shots = ["matterhorn-zermatt-01", "flatirons-chautauqua-03", "castel-toblino-01"]
  .filter((s) => existsSync(join(g, `${s}-800.avif`)))
  .map((s) => ({
    avif: `${base}/media/adventure/gallery/${s}-800.avif`,
    webp: `${base}/media/adventure/gallery/${s}-800.webp`,
  }));

// ── THE ARTICLE (all new sentences — see the approval note above) ──
const ARTICLE = {
  slate: "AMAZING AERIAL AGENCY · SINCE MID-2024",
  title: "The agency that takes my aerials to market.",
  paragraphs: [
    "In June 2024, a LinkedIn conversation with Amazing Aerial's founder, Paul, turned into a month of talking — and by mid-2024 I was an official agent with the collection.",
    "The arrangement is simple and honest: I chase the frames, from the Front Range to the Alps, and Amazing Aerial licenses them to the people who need them. The aerial work you see across my adventure pages lives with them.",
    "It's the quiet engine behind the adventure lane — every expedition feeds the collection, and the collection funds the next one.",
  ],
  ctas: [
    { label: "License my work →", href: AA_PORTFOLIO, external: true },
    { label: "About the agency →", href: "https://www.amazingaerial.com/", external: true },
    { label: "See the adventure lane →", href: `${base}/adventure`, external: false },
  ],
};
---

<Base title="Amazing Aerial — the agency story" description="How my aerial work reaches the market: an official agent with Amazing Aerial Agency since mid-2024.">
  <main class="aa-story">
    <article class="aa-inner">
      <a href={`${base}/entertainment`} class="link aa-back">← Venture</a>
      <p class="hud-label aa-slate" data-reveal data-tableau-content>
        <span data-decode>{ARTICLE.slate}</span>
      </p>
      <h1 class="aa-title" data-reveal>{ARTICLE.title}</h1>
      <div class="aa-proof" data-reveal>
        <LegendMark proof={aa.proof} />
      </div>
      {ARTICLE.paragraphs.map((para) => <p class="aa-para" data-reveal>{para}</p>)}

      {
        shots.length > 0 && (
          <div class="aa-shots" data-reveal>
            {shots.map((s) => (
              <figure class="aa-shot">
                <picture>
                  <source srcset={s.avif} type="image/avif" />
                  <img src={s.webp} alt="" loading="lazy" decoding="async" />
                </picture>
              </figure>
            ))}
          </div>
        )
      }
      <nav class="aa-ctas" data-reveal>
        {
          ARTICLE.ctas.map((c) => (
            <a href={c.href} class="link" rel={c.external ? "noopener" : undefined} target={c.external ? "_blank" : undefined}>
              {c.label}
            </a>
          ))
        }
      </nav>
      <a href={`${base}/entertainment`} class="link aa-back">← Venture</a>
    </article>
  </main>
</Base>

<style>
  .aa-story {
    background: #10141f; /* the venture rooms ground — this is a rooms story */
    min-height: 100svh;
  }
  .aa-inner {
    max-width: 46rem;
    margin-inline: auto;
    padding: 7rem 2rem 6rem;
    display: grid;
    gap: 1.5rem;
  }
  .aa-back {
    justify-self: start;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .aa-slate {
    letter-spacing: 0.26em;
    color: color-mix(in srgb, #d9f2ec 75%, transparent);
  }
  .aa-title {
    font-family: var(--font-display);
    font-weight: 560;
    font-style: italic;
    font-size: clamp(2rem, 4.2vw, 3.4rem);
    line-height: 1.12;
    color: #f2f4f8;
  }
  .aa-para {
    font-family: var(--font-sans);
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.65;
    color: color-mix(in srgb, #eef2f5 86%, transparent);
  }
  .aa-shots {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 0.6rem;
  }
  .aa-shot {
    margin: 0;
    border-radius: 6px;
    overflow: hidden;
  }
  .aa-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 3 / 2;
  }
  .aa-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    border-top: 1px solid color-mix(in srgb, #ffffff 12%, transparent);
    padding-top: 1.4rem;
  }
  @media (max-width: 640px) {
    .aa-shots {
      grid-template-columns: 1fr;
    }
    .aa-shot img {
      aspect-ratio: 16 / 10;
    }
  }
</style>

<script>
  const mountDecodeLabels = () => import("../../lib/decode-text").then(({ mountDecode }) => mountDecode(document));
  if ("requestIdleCallback" in window) requestIdleCallback(mountDecodeLabels, { timeout: 3000 });
  else setTimeout(mountDecodeLabels, 1500);
</script>
