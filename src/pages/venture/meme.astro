---
/**
 * /venture/meme — P14b: the MEME story. Sibling to /venture/amazing-aerial
 * (same venture-article grammar: slate, italic title, LegendMark proof, short
 * paragraphs, external + back links). Typographic only — NO photos exist for
 * this relationship yet, so the page carries a ghost "M E M E" letter motif
 * (entertainment.astro's grammar) in place of a media collage.
 *
 * ⚠ OPERATOR READ-APPROVAL REQUIRED — the ARTICLE prose below is new copy,
 * ADAPTED from the operator's own published bio at meme.ngo/meet-the-team
 * (operator-approved source, 2026-07-12: "reference what it says on the
 * website", reasonable copy adaptation allowed). Staging-only until he reads
 * it. Fact base (verbatim from that page): title "Member At-Large"; role
 * "Strategic Liaison and Scout … first point of contact for new talent";
 * self-description "a StorySmith, adventurer, and market strategist dedicated
 * to the art of audience discovery"; founded Adventure Storytelling Media;
 * cinematic drone work in Switzerland and Italy; the Boulder startup scene.
 * Org: Makeshift Entertainment Media Education (MEME), a Colorado nonprofit.
 *
 * The relationship claim itself renders ONLY through LegendMark, from the
 * LOCKED permitted phrasing in consts (RELATIONSHIPS "meme" → "Member
 * At-Large, MEME …, a Colorado nonprofit"). Never overstated to Board Chair
 * (that is Amber MacPherson — see the honesty note in consts.ts).
 */
import Base from "../../layouts/Base.astro";
import LegendMark from "../../components/LegendMark.astro";
import { PAGES } from "../../consts";
import { existsSync, statSync } from "node:fs";
import { join } from "node:path";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const meme = PAGES.entertainment.meme; // proof = { relationshipId: "meme" }

// ghost letterforms — the page's own subject, scattered as faint backdrop
// (presentational; assembles under the engine, sits still with no-JS).
const ghost = ["M", "E", "M", "E"];

// ── the operator's MEME logo animatic (scripts/make-meme-loop.sh) — an
// ambient, always-looping moment: the org's own animated mark, muted, sitting
// between the proof block and the article text. Existence-gated + cache-busted
// like the rest of the site's build-time media checks (see Tableaux.astro,
// ko-law-workshops.astro).
const loopDir = join(process.cwd(), "public", "media", "venture", "meme");
const lv = (file: string) => {
  try {
    return `?v=${Math.round(statSync(join(loopDir, file)).mtimeMs).toString(36)}`;
  } catch {
    return "";
  }
};
const loop = existsSync(join(loopDir, "meme-loop.mp4"))
  ? {
      mp4: `${base}/media/venture/meme/meme-loop.mp4${lv("meme-loop.mp4")}`,
      posterAvif: `${base}/media/venture/meme/meme-poster.avif${lv("meme-poster.avif")}`,
      posterWebp: `${base}/media/venture/meme/meme-poster.webp${lv("meme-poster.webp")}`,
    }
  : undefined;

// ── THE ARTICLE (all new sentences — see the approval note above) ──
const ARTICLE = {
  slate: "MEME · MAKESHIFT ENTERTAINMENT MEDIA EDUCATION",
  title: "The most formal role I hold in this world.",
  paragraphs: [
    "MEME — Makeshift Entertainment Media Education — is a Colorado nonprofit, and it holds the most formal title I carry anywhere: Member At-Large.",
    "The work is to be a Strategic Liaison and Scout — often the first point of contact for new talent. I look for storytellers worth backing, and help them find a way in.",
    // ⚠ OPERATOR READ-APPROVAL REQUIRED — new copy (source: his LinkedIn post
    // "Joined MEME as Member at Large", ~Apr 2026: "a nonprofit dedicated to
    // supporting entertainment professionals through education and workforce
    // development, and building a stronger independent film community right here
    // in Colorado … exactly the kind of infrastructure Colorado's creative
    // community needs"). Staging-only until read. His own descriptor "(Strategic
    // Liaison and Scout)" already renders above, verbatim from that post.
    "The organization exists to support entertainment professionals through education and workforce development, and to build a stronger independent film community right here in Colorado. That mission is the reason this role matters to me.",
    "It runs on the same instinct as everything else I make: a StorySmith's read on what an audience will feel, and a market strategist's read on who that audience actually is.",
    "The cinematic drone work over Switzerland and Italy, the founders I meet around the Boulder startup scene, and this role at MEME are one practice — pointed at the same question: whose story is this, and who is it for?",
  ],
  ctas: [
    { label: "About the organization →", href: "https://www.meme.ngo", external: true },
    { label: "See the venture lane →", href: `${base}/entertainment`, external: false },
  ],
};
---

<Base title="MEME — a venture story" description="Member At-Large at MEME (Makeshift Entertainment Media Education), a Colorado nonprofit: Strategic Liaison and Scout for new storytellers.">
  <main class="meme-story">
    <div class="meme-ghosts" aria-hidden="true">
      {ghost.map((ch, i) => <span class="meme-ghost" data-im-ghost style={`--gi:${i}`}>{ch}</span>)}
    </div>
    <article class="meme-inner">
      <a href={`${base}/entertainment`} class="link meme-back">← Venture</a>
      <p class="hud-label meme-slate" data-reveal data-tableau-content>
        <span data-decode>{ARTICLE.slate}</span>
      </p>
      <h1 class="meme-title" data-reveal>{ARTICLE.title}</h1>
      <div class="meme-proof" data-reveal>
        <LegendMark proof={meme.proof} />
      </div>

      {
        loop && (
          <figure class="meme-loop-wrap" data-reveal>
            <picture>
              <source type="image/avif" srcset={loop.posterAvif} />
              <img class="meme-loop-poster" src={loop.posterWebp} alt="The MEME logo — a filmstrip-lettered M, on a deep blue textured ground." loading="lazy" decoding="async" />
            </picture>
            <video
              class="meme-loop-vid"
              data-meme-loop
              muted
              loop
              playsinline
              preload="metadata"
              poster={loop.posterWebp}
              aria-hidden="true"
            >
              <source src={loop.mp4} type="video/mp4" />
            </video>
            {/* ⚠ OPERATOR READ-APPROVAL REQUIRED — new copy, staging-only until read. */}
            <figcaption class="hud-label meme-loop-cap">MEME's own animated mark, in motion</figcaption>
          </figure>
        )
      }

      {ARTICLE.paragraphs.map((para) => <p class="meme-para" data-reveal>{para}</p>)}

      <nav class="meme-ctas" data-reveal>
        {
          ARTICLE.ctas.map((c) => (
            <a href={c.href} class="link" rel={c.external ? "noopener" : undefined} target={c.external ? "_blank" : undefined}>
              {c.label}
            </a>
          ))
        }
      </nav>
      <a href={`${base}/entertainment`} class="link meme-back">← Venture</a>
    </article>
  </main>
</Base>

<style>
  .meme-story {
    position: relative;
    background: #0e2230; /* entertainment chapter 03 (MEME) ground — same room */
    min-height: 100svh;
    overflow: clip;
  }
  .meme-inner {
    position: relative;
    z-index: 1;
    max-width: 46rem;
    margin-inline: auto;
    padding: 7rem 2rem 6rem;
    display: grid;
    gap: 1.5rem;
  }
  .meme-back {
    justify-self: start;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .meme-slate {
    letter-spacing: 0.24em;
    color: color-mix(in srgb, #d9f2ec 75%, transparent);
  }
  .meme-title {
    font-family: var(--font-display);
    font-weight: 560;
    font-style: italic;
    font-size: clamp(2rem, 4.2vw, 3.4rem);
    line-height: 1.12;
    color: #f2f4f8;
  }
  .meme-para {
    font-family: var(--font-sans);
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.65;
    color: color-mix(in srgb, #eef2f5 86%, transparent);
  }

  /* ambient logo loop — a framed moment between the proof and the article,
     the org's own animated mark, always playing (never a hover trigger).
     Native 16:9 source, so aspect-ratio + object-fit:cover crops nothing.
     Poster image is the permanent base layer (no-JS / reduced-motion /
     autoplay-refused all land here); the video fades in over it once JS
     confirms motion is allowed and the figure is on-screen. */
  .meme-loop-wrap {
    position: relative;
    margin: 0.2rem 0 0;
    border: 1px solid color-mix(in srgb, #ffffff 14%, transparent);
    border-radius: 8px;
    overflow: hidden;
    background: color-mix(in srgb, #ffffff 4%, transparent);
    box-shadow: 0 0 32px -12px color-mix(in srgb, var(--color-accent, #38f8ec) 35%, transparent);
  }
  .meme-loop-poster {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .meme-loop-vid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 600ms var(--ease-survey, ease);
  }
  .meme-loop-wrap.is-playing .meme-loop-vid {
    opacity: 1;
  }
  .meme-loop-cap {
    position: absolute;
    left: 0.9rem;
    bottom: 0.8rem;
    margin: 0;
    letter-spacing: 0.18em;
    color: color-mix(in srgb, #f4fbfa 88%, transparent);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
  }
  @media (prefers-reduced-motion: reduce) {
    .meme-loop-vid {
      transition: none;
    }
  }
  .meme-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    border-top: 1px solid color-mix(in srgb, #ffffff 12%, transparent);
    padding-top: 1.4rem;
    margin-top: 0.6rem;
  }

  /* ghost "M E M E" — faint letterforms behind the column (no-JS = at rest) */
  .meme-ghosts {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .meme-ghost {
    position: absolute;
    font-family: var(--font-sans);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(6rem, 18vw, 16rem);
    line-height: 1;
    color: color-mix(in srgb, #ffffff 5%, transparent);
  }
  .meme-ghost:nth-child(1) { left: 4%; top: 12%; }
  .meme-ghost:nth-child(2) { right: 8%; top: 30%; }
  .meme-ghost:nth-child(3) { left: 10%; bottom: 18%; }
  .meme-ghost:nth-child(4) { right: 4%; bottom: 8%; }

  @media (max-width: 640px) {
    .meme-ghost { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .meme-ghost { transform: none !important; }
  }
</style>

<script>
  // enhancement only: decode the slate label, and let the ghost letters drift
  // in and settle (their resting positions already live in CSS, so no-JS and
  // reduced-motion see the final, correct layout).
  const mountDecode = () => import("../../lib/decode-text").then(({ mountDecode }) => mountDecode(document));
  if ("requestIdleCallback" in window) requestIdleCallback(mountDecode, { timeout: 3000 });
  else setTimeout(mountDecode, 1500);

  (async () => {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    if (window.matchMedia("(max-width: 640px)").matches) return;
    const { gsap } = await import("gsap");
    document.querySelectorAll<HTMLElement>("[data-im-ghost]").forEach((g, i) => {
      const dx = (i % 2 ? 1 : -1) * (36 + (i % 3) * 24);
      gsap.fromTo(
        g,
        { x: dx, y: 48, opacity: 0 },
        {
          x: 0,
          y: 0,
          opacity: 1,
          duration: 1.1,
          ease: "power3.out",
          delay: i * 0.08,
          onComplete: () => {
            gsap.to(g, {
              y: (i % 2 ? -1 : 1) * 10,
              duration: 5 + (i % 3) * 1.5,
              ease: "sine.inOut",
              yoyo: true,
              repeat: -1,
            });
          },
        },
      );
    });
  })();

  // ambient logo loop (P14b) — plays only when motion is allowed and the
  // figure is actually on-screen; the poster image underneath is the
  // permanent base layer, so reduced-motion / no-JS / autoplay-refused all
  // just show the still. Mirrors HeroVideo.astro's poster-first contract:
  // no native `autoplay`/`src`-at-parse-time, JS decides, muted always.
  (() => {
    const wrap = document.querySelector<HTMLElement>(".meme-loop-wrap");
    const video = wrap?.querySelector<HTMLVideoElement>("[data-meme-loop]");
    if (!wrap || !video) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (conn?.saveData) return;

    video.addEventListener("playing", () => wrap.classList.add("is-playing"));

    const io = new IntersectionObserver(
      ([entry]) => {
        if (!entry) return;
        if (entry.isIntersecting) video.play().catch(() => {}); // refusal → poster stands
        else video.pause();
      },
      { threshold: 0.2 },
    );
    io.observe(wrap);
    window.addEventListener("pagehide", () => io.disconnect(), { once: true });
  })();
</script>
