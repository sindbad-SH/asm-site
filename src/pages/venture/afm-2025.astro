---
/**
 * Venture story · American Film Market 2025 — built on the P12.8 pilot pattern
 * (seriesfest-2026.astro). Mono slate, mixed-face headline, native-aspect collage,
 * AFM LegendMark near the top.
 *
 * HONESTY: the only status claim is the AFM LegendMark (tier `attended`), rendered
 * near the top from consts — verbatim, never upgraded. The prose is the operator's
 * OWN words (see the read-approval block). Attendance ≠ affiliation.
 */
import Base from "../../layouts/Base.astro";
import LegendMark from "../../components/LegendMark.astro";
import { PAGES } from "../../consts";
import { existsSync } from "node:fs";
import { join } from "node:path";
import sharp from "sharp";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const STORY = "afm-2025";
const mediaDir = join(process.cwd(), "public", "media", "venture", STORY);

async function aspectOf(file: string): Promise<string | undefined> {
  try {
    const { width, height } = await sharp(file).metadata();
    return width && height ? `${width} / ${height}` : undefined;
  } catch {
    return undefined;
  }
}
async function shot(slug: string, alt: string) {
  const webp900 = join(mediaDir, `${slug}-900.webp`);
  if (!existsSync(webp900)) return undefined;
  const url = (w: number, ext: string) => `${base}/media/venture/${STORY}/${slug}-${w}.${ext}`;
  return {
    alt,
    ar: await aspectOf(webp900),
    avif: `${url(900, "avif")} 900w, ${url(1600, "avif")} 1600w`,
    webp: `${url(900, "webp")} 900w, ${url(1600, "webp")} 1600w`,
    fallback: url(900, "webp"),
  };
}

const [hero, ...gallery] = await Promise.all([
  shot("hero", "An AFM Sessions panel on the blue AFM-branded stage."),
  shot("venue-signage", "The market venue interior with lit AFM signage."),
  shot("panel-stage", "Panelists on stools with microphones on the AFM stage."),
  shot("podium-speaker", "A speaker presenting at the podium during a session."),
  shot("step-and-repeat", "The blue AFM-branded step-and-repeat backdrop."),
  shot("panel-mics", "A session panel seated with microphones."),
  shot("podium-lectern", "A speaker at the lectern during an AFM session."),
  shot("step-and-repeat-2", "The branded AFM backdrop at the market."),
  shot("panel-seated", "A seated panel on the AFM stage."),
  shot("podium-address", "A speaker addressing the session from the stage."),
].map((p) => p));

const spans = [3, 3, 2, 2, 2, 3, 3, 2, 2];

// The AFM proof line — imported from consts, rendered VERBATIM. This is the only
// status claim on the page (tier `attended`), and it sits up top.
const afmRoom = PAGES.entertainment.rooms.items.find(
  (r) => r.proof.relationshipId === "afm",
);

const meta = {
  title: "American Film Market 2025 — a venture story",
  description:
    "American Film Market 2025 in Los Angeles, California — The AFM Sessions panels on the branded stage and the market environment, from a week of relationship-building attendance.",
};
---

<Base title={meta.title} description={meta.description}>
  <main class="vs" data-lane="venture" style="--ground:#10141f">
    <section class="vs-head">
      <a href={`${base}/entertainment`} class="link vs-back"><span class="arrow" aria-hidden="true">←</span> Venture</a>

      <p class="hud-label vs-slate" data-reveal>American Film Market · Nov 8–15, 2025 · Los Angeles, CA</p>

      <h1 class="vs-headline" data-reveal>
        <span class="vs-line">AFM</span>
        <span class="vs-line vs-line--push"><span class="vs-turn">Los Angeles,</span> 2025</span>
      </h1>

      {afmRoom && (
        <div class="vs-proof" data-reveal>
          <LegendMark proof={afmRoom.proof} />
        </div>
      )}
    </section>

    {hero && (
      <figure class="vs-hero" data-reveal>
        <picture>
          <source type="image/avif" srcset={hero.avif} sizes="(max-width: 900px) 100vw, 78rem" />
          <source type="image/webp" srcset={hero.webp} sizes="(max-width: 900px) 100vw, 78rem" />
          <img src={hero.fallback} alt={hero.alt} style={`--ar:${hero.ar}`} loading="eager" decoding="async" />
        </picture>
      </figure>
    )}

    <!--
      ⚠ OPERATOR READ-APPROVAL REQUIRED — new copy (source: his LinkedIn AFM 2025
      posts, ~Nov 2025), staging-only until read. Three threads chosen, per his
      own posts:
        · P1–P2 — his AFM kickoff post (energizing/grounding; first Waymo ride;
          drone cinematography + story-driven brand strategy; "visual and
          emotional altitude").
        · P3–P4 — his AFM Pitch Conference post (2-minute pitches; the film-vs-
          startup mirror; "the story tells us why we care, the strategy tells us
          why it works … an invitation"). PitchBoulder referenced generally only.
        · P5–P6 — his indie-action-films panel post (FLIP Creative; indie ≠ low
          quality; betting on a team; "the relationships are the infrastructure";
          vision vs viability).
      Named entities only as he named them; no relationship claims.
    -->
    <section class="vs-prose" data-reveal>
      <p>
        Kicking off my week at the American Film Market was energizing and
        grounding at once — a place where creativity feels tangible and every
        conversation holds a spark of possibility. Even getting around Los Angeles
        was an adventure: my first ride in a Waymo, one of those quietly
        futuristic moments that reminded me how fast storytelling and technology
        are converging.
      </p>
      <p>
        The connections I was most excited to explore were around drone
        cinematography and story-driven brand strategy — helping ideas find both
        their visual and emotional altitude.
      </p>
      <p>
        A highlight was the AFM Pitch Conference, where dozens of filmmakers had
        two minutes each to distill a project into a snapshot. As someone who sits
        in pitch rooms every week at PitchBoulder, it played like a mirror image:
        in film, creators lead with the story; in startups, founders lead with the
        business — but the truth is both sides need both.
      </p>
      <p>
        The story tells us why we care. The strategy tells us why it works. When
        those two come together, a pitch stops feeling like a presentation and
        starts feeling like an invitation — to invest, to collaborate, or simply
        to believe.
      </p>
      <p>
        On the indie-action-films panel presented by FLIP Creative, the
        throughline was honesty about the miracle of getting a film made — and how
        that miracle becomes a business model when you do it right. Indie no
        longer means low quality; you're not just buying a movie, you're betting
        on a team; and the people who keep working together across projects prove
        the real point — the relationships are the infrastructure.
      </p>
      <p>
        Different industries, different vocabulary, the same tension: how do you
        blend vision and viability, the engine and the soul of an idea? That
        intersection is where a lot of future opportunity lives. The AFM Sessions,
        American Film Market, Los Angeles, California, November 8–15, 2025.
      </p>
    </section>

    <section class="vs-gallery" aria-label="American Film Market 2025 — frames">
      {gallery.map((g, i) =>
        g ? (
          <figure class="vs-card" style={`--span:${spans[i] ?? 2}`} data-reveal data-reveal-stagger="70">
            <picture>
              <source type="image/avif" srcset={g.avif} sizes="(max-width: 760px) 100vw, 40rem" />
              <source type="image/webp" srcset={g.webp} sizes="(max-width: 760px) 100vw, 40rem" />
              <img src={g.fallback} alt={g.alt} style={`--ar:${g.ar}`} loading="lazy" decoding="async" />
            </picture>
          </figure>
        ) : null,
      )}
    </section>

    <section class="vs-foot">
      <a href={`${base}/entertainment`} class="link"><span class="arrow" aria-hidden="true">←</span> Venture</a>
    </section>
  </main>
</Base>

<style>
  .vs {
    background: var(--ground);
    min-height: 100svh;
    padding: 6rem clamp(1.25rem, 5vw, 6rem) 5rem;
    display: grid;
    gap: clamp(2.5rem, 5vw, 4rem);
    max-width: 90rem;
    margin-inline: auto;
  }

  .vs-head {
    display: grid;
    gap: 1.1rem;
    justify-items: start;
  }
  .vs-back {
    margin-bottom: 0.4rem;
  }
  .vs-slate {
    letter-spacing: 0.28em;
    color: color-mix(in srgb, var(--color-peak) 72%, transparent);
  }

  .vs-headline {
    font-family: var(--font-sans);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.94;
    letter-spacing: 0.006em;
    color: #f2f4f8;
    font-size: clamp(2.8rem, 9vw, 8.5rem);
    display: grid;
    gap: 0.03em;
  }
  .vs-turn {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    color: #eef1f6;
    font-size: 0.44em;
    vertical-align: 0.2em;
    margin-inline: 0.1em;
  }
  .vs-line {
    display: block;
  }
  .vs-line--push {
    transform: translateX(5vw);
  }
  .vs-proof {
    margin-top: 0.4rem;
    max-width: 42rem;
  }

  .vs-hero {
    margin: 0;
    max-width: 78rem;
    width: 100%;
    justify-self: center;
    border: 1px solid color-mix(in srgb, var(--color-peak) 16%, transparent);
    padding: 0.4rem;
    background: var(--color-elevated);
  }
  .vs-hero img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: var(--ar, 1 / 1);
    object-fit: cover;
  }

  .vs-prose {
    max-width: 44rem;
    display: grid;
    gap: 1.1rem;
    font-size: clamp(1.05rem, 1.5vw, 1.3rem);
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-ink) 92%, transparent);
    justify-self: center;
  }

  .vs-gallery {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: clamp(0.6rem, 1.4vw, 1.1rem);
    align-items: start;
  }
  .vs-card {
    grid-column: span var(--span, 2);
    margin: 0;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-peak) 14%, transparent);
    background: var(--color-elevated);
  }
  .vs-card img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: var(--ar, 1 / 1);
    object-fit: cover;
    transition: transform var(--dur-hover, 180ms) var(--ease-swift, ease);
  }
  .vs-card:hover img {
    transform: scale(1.03);
  }

  .vs-foot {
    justify-self: start;
    padding-top: 1rem;
    border-top: 1px solid var(--color-hairline);
    width: 100%;
  }

  @media (max-width: 760px) {
    .vs-line--push { transform: none; }
    .vs-gallery { grid-template-columns: repeat(2, 1fr); }
    .vs-card { grid-column: span 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .vs-card img { transition: none; }
    .vs-card:hover img { transform: none; }
  }
</style>
