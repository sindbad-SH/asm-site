---
/**
 * /field-notes/[slug] — P19 · a LOCATION SPOTLIGHT.
 *
 * The Super Mario 64 destination: click a floating painting on /adventure and
 * land here, inside that place. A large lead frame, the place in the display
 * voice, a mono territory/date survey slate, the operator's observational prose
 * VERBATIM from the markdown, an optional band of the best 3–5 frames (only the
 * ones that actually exist — no invented media), and then the funnel that is the
 * whole point: "want more from this place?" → license the full collection
 * through Amazing Aerial. A held-open FUTURE slot waits for the other content
 * the operator will make about each place (AI Adventures, etc.).
 *
 * HONESTY: the prose is the operator's own words, carried verbatim (already
 * flagged for read-approval in the md files). The only authored strings here are
 * labels + the LOCKED Amazing Aerial phrasing reused verbatim from consts. The
 * meta description is a template string (flagged once, below).
 *
 * STATIC PATHS: one page per NON-DRAFT note; drafts are never routable. Ordered
 * newest-first so each page can link its prev/next neighbours (keeps a reader
 * moving through the gallery instead of bouncing).
 *
 * Fallbacks: no-JS / reduced-motion → everything visible at rest; the frame is a
 * plain link target, no motion required.
 */
import Base from "../../layouts/Base.astro";
import { PAGES } from "../../consts";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { existsSync } from "node:fs";
import { join } from "node:path";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Orientation-aware export widths (matches adventure.astro): landscape frames
// export 800/1400/2200 (3:2), vertical 800/1120/1600 (4:5). A responsive
// <picture> renders only when the export set actually exists on disk.
const GALLERY_WIDTHS = {
  landscape: [800, 1400, 2200],
  vertical: [800, 1120, 1600],
} as const;
function galleryMedia(slug: string, orientation: "landscape" | "vertical") {
  const g = join(process.cwd(), "public", "media", "adventure", "gallery");
  if (!existsSync(join(g, `${slug}-800.avif`))) return undefined;
  const widths = GALLERY_WIDTHS[orientation];
  return {
    avif: widths.map((w) => `${base}/media/adventure/gallery/${slug}-${w}.avif ${w}w`).join(", "),
    webp: widths.map((w) => `${base}/media/adventure/gallery/${slug}-${w}.webp ${w}w`).join(", "),
    src: `${base}/media/adventure/gallery/${slug}-800.webp`,
  };
}

export async function getStaticPaths() {
  // Newest-first — the same order as the /field-notes log, so prev/next read
  // chronologically.
  const notes = (await getCollection("fieldNotes", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );
  return notes.map((note, i) => ({
    params: { slug: note.id },
    props: {
      note,
      // Neighbours as bare {id,title} so the page needn't re-query. "prev" is
      // the newer note, "next" the older — a natural forward walk through time.
      prev: i > 0 ? { id: notes[i - 1].id, title: notes[i - 1].data.title } : null,
      next: i < notes.length - 1 ? { id: notes[i + 1].id, title: notes[i + 1].data.title } : null,
    },
  }));
}

type Neighbour = { id: string; title: string } | null;
type Props = {
  note: CollectionEntry<"fieldNotes">;
  prev: Neighbour;
  next: Neighbour;
};
const { note, prev, next } = Astro.props;
const { Content } = await render(note);
const p = PAGES.adventure;

const fmtDate = (d: Date) =>
  `${d.getUTCFullYear()}.${String(d.getUTCMonth() + 1).padStart(2, "0")}.${String(d.getUTCDate()).padStart(2, "0")}`;

const photos = note.data.photos ?? [];
const lead = photos[0];
const leadMedia = lead ? galleryMedia(lead.slug, lead.orientation) : undefined;

// M2b (2026-07-22) — the location REEL: a clean vertical drone loop for this
// place, if one has been baked to public/media/field-notes/<slug>/. Existence-
// gated per note, poster-first + IO-gated (same contract as the story-page
// showcase loop). Presented as a portrait "reel from the field" after the head.
// M3 — deterministic per-page layout variety (operator: the location pages
// all read the same). A tiny slug-derived seed flips which side the reel
// hangs on and which side the first floating frame takes, so neighbouring
// pages compose differently without any randomness at runtime.
const seed = [...note.id].reduce((a, c) => a + c.charCodeAt(0), 0);
const reelDir = join(process.cwd(), "public", "media", "field-notes", note.id);
const reel = existsSync(join(reelDir, "loop.mp4"))
  ? {
      src: `${base}/media/field-notes/${note.id}/loop.mp4`,
      poster: existsSync(join(reelDir, "poster.avif"))
        ? `${base}/media/field-notes/${note.id}/poster.avif`
        : undefined,
    }
  : undefined;

// Supporting frames (the lead already headlines) → resolved to their export
// sets once, dropping any whose files aren't on disk. They FLOAT around the
// prose (P22): the first two bracket the story left/right, any beyond stagger
// in a row beneath it. Same gallery-frame treatment as the paintings wall.
const supporting = photos
  .slice(1)
  .map((ph) => ({ ph, m: galleryMedia(ph.slug, ph.orientation) }))
  .filter((x): x is { ph: (typeof photos)[number]; m: NonNullable<ReturnType<typeof galleryMedia>> } => !!x.m);
const bracketFloats = supporting.slice(0, 2);
const restFloats = supporting.slice(2);

// Funnel filmstrip: up to three tiny frames from THIS place (lead first) — a
// "more of the collection" cue that reuses already-baked frames, no new assets.
const filmstrip = [lead, ...photos.slice(1)]
  .filter((ph): ph is NonNullable<typeof ph> => !!ph)
  .map((ph) => ({ ph, m: galleryMedia(ph.slug, ph.orientation) }))
  .filter((x): x is { ph: (typeof photos)[number]; m: NonNullable<ReturnType<typeof galleryMedia>> } => !!x.m)
  .slice(0, 3);

const heroSizes = "(min-width: 1100px) 1000px, (min-width: 768px) 88vw, 100vw";
const floatSizes = "(min-width: 880px) 17rem, (min-width: 560px) 42vw, 80vw";

// LOCKED — reused verbatim from consts/this template; NOT new copy.
const AA_LICENSED_LINE = "Licensed through Amazing Aerial Agency";

const meta = {
  title: `${note.data.title} — Field Notes`,
  // ⚠ OPERATOR READ-APPROVAL REQUIRED — new copy (meta description template,
  // staging-only until read). Composed only from the note's own place data.
  description: note.data.location
    ? `Field note — ${note.data.title}, ${note.data.location}.`
    : `Field note — ${note.data.title}.`,
};
---

<Base title={meta.title} description={meta.description}>
  <div data-lane="adventure">
    <article class="spotlight">
      <p class="spotlight-back" data-reveal>
        <a class="link" href={`${base}/adventure`}>← All territories</a>
      </p>

      {
        leadMedia ? (
          <figure class={`spotlight-hero ${lead!.orientation === "vertical" ? "spotlight-hero--tall" : ""}`} data-reveal aria-hidden="true">
            <div class="spotlight-hero-frame">
              <picture>
                <source type="image/avif" srcset={leadMedia.avif} sizes={heroSizes} />
                <source type="image/webp" srcset={leadMedia.webp} sizes={heroSizes} />
                <img
                  src={leadMedia.src}
                  alt={lead!.alt}
                  loading="eager"
                  decoding="async"
                  style={`aspect-ratio:${lead!.orientation === "vertical" ? "4/5" : "3/2"};object-fit:cover`}
                />
              </picture>
            </div>
          </figure>
        ) : (
          note.data.cover && (
            <figure class="spotlight-hero" data-reveal aria-hidden="true">
              <div class="spotlight-hero-frame">
                <img src={`${base}${note.data.cover}`} alt="" loading="eager" decoding="async" />
              </div>
            </figure>
          )
        )
      }

      <header class="spotlight-head">
        {/* M2 — the Field Notes masthead eyebrow: reads each location as an
            issue of the same editorial series (magazine grammar). */}
        <p class="hud-label spotlight-masthead" data-reveal>
          <span class="spotlight-masthead-word">Field Notes</span>
          <span class="spotlight-sep" aria-hidden="true">·</span>
          <span>Adventure Storytelling Media</span>
        </p>
        <p class="hud-label spotlight-slate" data-reveal>
          {note.data.territory && (
            <>
              <span class="spotlight-terr">{note.data.territory}</span>
              <span class="spotlight-sep" aria-hidden="true">·</span>
            </>
          )}
          <span>{fmtDate(note.data.date)}</span>
          {note.data.location && (
            <>
              <span class="spotlight-sep" aria-hidden="true">·</span>
              <span class="spotlight-loc">{note.data.location}</span>
            </>
          )}
        </p>
        <h1 class="spotlight-title" data-reveal>{note.data.title}</h1>
        {note.data.deck && <p class="spotlight-deck" data-reveal>{note.data.deck}</p>}
        {
          note.data.tags && note.data.tags.length > 0 && (
            <ul class="spotlight-tags" data-reveal>
              {note.data.tags.map((tag) => (
                <li class="hud-label spotlight-tag">{tag}</li>
              ))}
            </ul>
          )
        }
      </header>

      {/* THE REEL — a portrait drone loop for this place (M2b), the first
          motion after the head. Poster-first + IO-gated: reduced-motion / no-JS
          / Save-Data / autoplay-refused all hold the still. */}
      {
        reel && (
          <figure class={`spotlight-reel ${seed % 2 ? "spotlight-reel--left" : ""}`} data-reveal>
            <div class="spotlight-reel-frame">
              {reel.poster && <img class="spotlight-reel-poster" src={reel.poster} alt="" loading="lazy" decoding="async" />}
              <video
                class="spotlight-reel-loop"
                data-reel-loop
                data-loop-src={reel.src}
                muted
                loop
                playsinline
                preload="none"
                aria-hidden="true"
              />
            </div>
            <figcaption class="spotlight-reel-cap hud-label">From the field · {note.data.location ?? note.data.title}</figcaption>
          </figure>
        )
      }

      {/* THE STORY — the operator's prose with the supporting frames FLOATING
          around it (P22). The first two bracket the reading column (one ragged
          right, one ragged left) and the prose flows between and past them; any
          further frames stagger in a loose row beneath. Each frame is a hung
          gallery print — slim mat, hairline, drop shadow, desynced ambient float
          — and carries the LOCKED Amazing Aerial caption chip. */}
      <div class={`spotlight-story ${bracketFloats.length ? "has-floats" : ""}`}>
        {bracketFloats.map(({ ph, m }, i) => (
          <figure
            class={`spotlight-float ${(i + seed) % 2 === 0 ? "is-right" : "is-left"} ${ph.orientation === "vertical" ? "is-tall" : ""}`}
            data-reveal
          >
            <div class="spotlight-float-frame">
              <picture>
                <source type="image/avif" srcset={m.avif} sizes={floatSizes} />
                <source type="image/webp" srcset={m.webp} sizes={floatSizes} />
                <img
                  src={m.src}
                  alt={ph.alt}
                  loading="lazy"
                  decoding="async"
                  style={`aspect-ratio:${ph.orientation === "vertical" ? "4/5" : "3/2"};object-fit:cover`}
                />
              </picture>
            </div>
            <figcaption class="spotlight-float-chip hud-label">{AA_LICENSED_LINE}</figcaption>
          </figure>
        ))}

        <div class="spotlight-prose" data-reveal>
          <Content />
        </div>
      </div>

      {
        restFloats.length > 0 && (
          <section class="spotlight-float-row" data-reveal aria-label="More frames from this place">
            {restFloats.map(({ ph, m }) => (
              <figure class={`spotlight-float is-loose ${ph.orientation === "vertical" ? "is-tall" : ""}`}>
                <div class="spotlight-float-frame">
                  <picture>
                    <source type="image/avif" srcset={m.avif} sizes={floatSizes} />
                    <source type="image/webp" srcset={m.webp} sizes={floatSizes} />
                    <img
                      src={m.src}
                      alt={ph.alt}
                      loading="lazy"
                      decoding="async"
                      style={`aspect-ratio:${ph.orientation === "vertical" ? "4/5" : "3/2"};object-fit:cover`}
                    />
                  </picture>
                </div>
                <figcaption class="spotlight-float-chip hud-label">{AA_LICENSED_LINE}</figcaption>
              </figure>
            ))}
          </section>
        )
      }

      {/* THE FUNNEL — the point of the spotlight. "Want more from this place?"
          energy built ONLY from the LOCKED Amazing Aerial phrasing (reused
          verbatim from consts) + the logo mark + the portfolio CTA. Shown only
          when the note's frames are licensed (adventure work); personal notes
          leave license:false and skip it. */}
      {
        note.data.license && (
          <aside class="spotlight-funnel">
            <div class="panel aa-band spotlight-funnel-panel" data-reveal>
              {/* Decorative survey ground: a faint graticule + a slow ambient
                  shimmer, so the funnel reads as part of the page's map/atmosphere
                  grammar rather than a plain box. Both are aria-hidden and killed
                  under reduced motion. */}
              <span class="spotlight-funnel-grid" aria-hidden="true" />
              <span class="spotlight-funnel-shimmer" aria-hidden="true" />

              <div class="spotlight-funnel-inner">
                {/* AA lockup — the mark as a unit with the LOCKED phrasing on a
                    hairline rule (verbatim; not new copy). */}
                <div class="spotlight-funnel-lockup">
                  <img
                    src={`${base}/media/adventure/aa-logo.png`}
                    alt="Amazing Aerial Agency"
                    class="aa-funnel-logo"
                    width="480"
                    height="158"
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="spotlight-funnel-rule" aria-hidden="true" />
                  <p class="hud-label spotlight-funnel-kicker">Licensed through Amazing Aerial Agency</p>
                </div>

                <h2 class="spotlight-funnel-heading">{p.aaFunnel.heading}</h2>
                {/* M2 — editorial-use framing (operator rule 2026-07-22): this
                    coverage is registered for editorial licensing on AA. */}
                <p class="hud-label spotlight-funnel-editorial">Available for editorial licensing</p>
                <p class="spotlight-funnel-body">{p.aaFunnel.body}</p>

                {/* Mini filmstrip — three tiny frames from THIS place, a "more of
                    the collection" cue. Decorative (the frames are described
                    above); reuses already-baked exports, no new assets. */}
                {filmstrip.length > 1 && (
                  <div class="spotlight-filmstrip" aria-hidden="true">
                    {filmstrip.map(({ ph, m }) => (
                      <span class="spotlight-filmstrip-cell">
                        <picture>
                          <source type="image/avif" srcset={m.avif} sizes="140px" />
                          <source type="image/webp" srcset={m.webp} sizes="140px" />
                          <img
                            src={m.src}
                            alt=""
                            loading="lazy"
                            decoding="async"
                            style={`aspect-ratio:${ph.orientation === "vertical" ? "4/5" : "3/2"};object-fit:cover`}
                          />
                        </picture>
                      </span>
                    ))}
                  </div>
                )}

                <a
                  href={p.aaFunnel.cta.href}
                  class="btn spotlight-funnel-cta"
                  target="_blank"
                  rel="noopener"
                >
                  <span>{p.aaFunnel.cta.label}</span>
                  <span class="arrow" aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </aside>
        )
      }

      {/* ── FUTURE SLOT — held open, renders nothing today (see header note). ──
          When the operator makes other content about this place (AI Adventures,
          a film cut, a deeper photo set), drop it in here — the section is
          styled and ready, so it lands without reworking the page. Kept as an
          HTML comment so it ships zero markup until then.

          <section class="spotlight-more" data-reveal aria-label="More about this place">
            <p class="hud-label spotlight-more-label">More from this place</p>
            … drop-in cards / embeds …
          </section>
      */}

      <footer class="spotlight-foot">
        <nav class="spotlight-nav" aria-label="Nearby field notes" data-reveal>
          {
            prev ? (
              <a class="spotlight-nav-link spotlight-nav-prev" href={`${base}/field-notes/${prev.id}`}>
                <span class="hud-label">← Previous</span>
                <span class="spotlight-nav-title">{prev.title}</span>
              </a>
            ) : (
              <span />
            )
          }
          {
            next ? (
              <a class="spotlight-nav-link spotlight-nav-next" href={`${base}/field-notes/${next.id}`}>
                <span class="hud-label">Next →</span>
                <span class="spotlight-nav-title">{next.title}</span>
              </a>
            ) : (
              <span />
            )
          }
        </nav>
        <p class="spotlight-back spotlight-back--foot" data-reveal>
          <a class="link" href={`${base}/adventure`}>← All territories</a>
        </p>
      </footer>
    </article>
  </div>
</Base>

<style>
  .spotlight {
    max-width: 60rem;
    margin-inline: auto;
    padding: 6.5rem clamp(1.5rem, 6vw, 3rem) 6rem;
  }

  .spotlight-back {
    margin: 0 0 1.75rem;
  }
  .spotlight-back--foot {
    margin: 2.25rem 0 0;
  }

  /* ── hero: the lead frame, large, hung in a slim gallery frame ── */
  .spotlight-hero {
    margin: 0 0 2.5rem;
  }
  .spotlight-hero--tall {
    max-width: 34rem;
    margin-inline: auto;
  }
  .spotlight-hero-frame {
    position: relative;
    padding: clamp(0.5rem, 1vw, 0.9rem);
    border-radius: 4px;
    background: linear-gradient(
      158deg,
      color-mix(in srgb, var(--color-peak) 9%, var(--color-elevated)) 0%,
      var(--color-elevated) 48%,
      color-mix(in srgb, var(--color-base) 45%, var(--color-elevated)) 100%
    );
    border: 1px solid color-mix(in srgb, var(--color-peak) 15%, transparent);
    box-shadow:
      0 30px 64px -28px rgba(0, 0, 0, 0.66),
      inset 0 1px 0 color-mix(in srgb, var(--color-peak) 12%, transparent);
  }
  .spotlight-hero-frame img {
    display: block;
    width: 100%;
    border: 1px solid color-mix(in srgb, var(--color-peak) 18%, transparent);
    border-radius: 1px;
  }

  /* ── Field Notes masthead eyebrow (M2) — the series signature above each
        issue's slate. The wordmark in the condensed display face, small. ── */
  .spotlight-masthead {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    letter-spacing: 0.22em;
    color: var(--color-ink-muted);
    margin-bottom: 0.6rem;
  }
  .spotlight-masthead-word {
    font-family: var(--font-display-condensed);
    font-size: 0.95rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-peak);
  }

  /* ── survey slate + serif title ── */
  .spotlight-slate {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    letter-spacing: 0.2em;
  }
  /* deck — the standfirst under the headline (magazine grammar) */
  .spotlight-deck {
    margin-top: 0.9rem;
    max-width: 40ch;
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-style: italic;
    font-weight: 450;
    font-size: clamp(1.15rem, 2.2vw, 1.5rem);
    line-height: 1.4;
    color: color-mix(in srgb, var(--color-peak) 82%, transparent);
  }
  .spotlight-sep {
    opacity: 0.5;
  }
  .spotlight-terr {
    color: var(--color-adventure-warm);
  }
  .spotlight-loc {
    color: color-mix(in srgb, var(--color-peak) 62%, transparent);
  }
  .spotlight-title {
    margin-top: 0.7rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.1rem, 5.5vw, 3.6rem);
    line-height: 1.06;
    color: var(--color-peak);
  }
  .spotlight-tags {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }
  .spotlight-tag {
    letter-spacing: 0.16em;
    color: var(--color-ink-muted);
  }

  /* ── prose: the operator's words, verbatim, in the reading type ── */
  .spotlight-prose {
    max-width: 42rem;
    font-size: clamp(1.08rem, 1.5vw, 1.24rem);
    line-height: 1.72;
    color: color-mix(in srgb, var(--color-ink) 92%, transparent);
  }
  .spotlight-prose :global(p) {
    margin: 0 0 1.35em;
  }
  /* drop cap on the opening paragraph (magazine grammar, M2) */
  .spotlight-prose :global(p:first-of-type::first-letter) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 3.1em;
    line-height: 0.82;
    float: left;
    padding: 0.02em 0.12em 0 0;
    color: var(--color-accent);
  }
  .spotlight-prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    line-height: 1.2;
    color: var(--color-peak);
    margin: 2.4rem 0 0.9rem;
  }
  .spotlight-prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .spotlight-prose :global(blockquote) {
    margin: 1.6em 0;
    padding-left: 1.1em;
    border-left: 2px solid var(--color-accent-deep);
    color: color-mix(in srgb, var(--color-ink) 80%, transparent);
    font-style: italic;
  }

  /* ── the reel: a portrait drone loop, hung like a phone-shot field clip.
        Slim gallery mat to match the frames, centered, capped narrow. ── */
  .spotlight-reel {
    margin: 2.75rem auto 0;
    width: min(20rem, 78%);
  }
  .spotlight-reel-frame {
    position: relative;
    aspect-ratio: 9 / 16;
    overflow: hidden;
    border-radius: 4px;
    padding: clamp(0.4rem, 0.9vw, 0.62rem);
    background: linear-gradient(
      158deg,
      color-mix(in srgb, var(--color-peak) 9%, var(--color-elevated)) 0%,
      var(--color-elevated) 48%,
      color-mix(in srgb, var(--color-base) 45%, var(--color-elevated)) 100%
    );
    border: 1px solid color-mix(in srgb, var(--color-peak) 15%, transparent);
    box-shadow: 0 22px 50px -24px rgba(0, 0, 0, 0.64);
  }
  .spotlight-reel-poster,
  .spotlight-reel-loop {
    position: absolute;
    inset: clamp(0.4rem, 0.9vw, 0.62rem);
    width: auto;
    height: auto;
    inline-size: calc(100% - 2 * clamp(0.4rem, 0.9vw, 0.62rem));
    block-size: calc(100% - 2 * clamp(0.4rem, 0.9vw, 0.62rem));
    object-fit: cover;
    border-radius: 1px;
  }
  .spotlight-reel-loop {
    opacity: 0;
    transition: opacity 500ms ease;
    pointer-events: none;
  }
  .spotlight-reel-frame.is-playing .spotlight-reel-loop {
    opacity: 1;
  }
  .spotlight-reel-cap {
    display: block;
    margin: 0.6rem 0 0;
    text-align: center;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    color: color-mix(in srgb, var(--color-peak) 52%, transparent);
  }
  @media (min-width: 880px) {
    /* on desktop, hang the reel beside the opening prose so it doesn't eat a
       full-width band — side varies per page (M3 slug-seed). */
