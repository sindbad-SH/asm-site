  /* slow ambient light-sweep (reduced-motion safe) */
  .spotlight-funnel-shimmer {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    border-radius: 4px;
  }
  .spotlight-funnel-shimmer::before {
    content: "";
