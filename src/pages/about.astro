---
/**
 * /about — the single-arc StorySmith narrative (BUILD-PLAN.md §1.6). First
 * person throughout (verifiable facts only, per research-brief §1). Closes
 * by turning the honesty-legend device into an explicit trust statement,
 * backed by the actual visible LegendKey so the claim is demonstrable, not
 * just asserted.
 */
import Base from "../layouts/Base.astro";
import LegendKey from "../components/LegendKey.astro";
import { PAGES } from "../consts";

const p = PAGES.about;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Personal socials (COPY.md §6) — Sindbad's own channels (personal socials
// belong on About per operator directive). Text links, Space Mono label style,
// no brand-colored icons. Order is operator-provided (2026-07-04).
const personalSocials = [
  { label: "LinkedIn", href: "https://www.linkedin.com/in/sindbad-horizon-b19b4a264" },
  { label: "YouTube", href: "https://www.youtube.com/@SindbadSightsAndStories" },
  { label: "Instagram", href: "https://www.instagram.com/sindbad_sights_and_stories/" },
  { label: "TikTok", href: "https://www.tiktok.com/@sindbadsightsandstories" },
] as const;
---

<Base title={p.meta.title} description={p.meta.description}>
  <section class="mx-auto max-w-3xl space-y-6 p-8">
    <!-- The develop (R3.10 §3.5): on reveal the portrait goes grayscale→none
         over 900ms (a darkroom develop — the one sanctioned filter animation);
         the frame then drifts at amp 0.5 (barely alive). data-reveal + data-develop
         share .is-revealed; reduced motion forces the filter off and shows it. -->
    <figure
      class="map-inset about-portrait mx-auto max-w-sm"
      style="overflow:clip"
      data-reveal
      data-develop
      data-drift
      data-drift-amp="0.5"
    >
      <picture>
        <source type="image/avif" srcset={`${base}/media/about/portrait.avif`} />
        <img
          src={`${base}/media/about/portrait.webp`}
          alt="Sindbad Horizon, The StorySmith"
          class="block w-full"
          style="aspect-ratio:4/5;object-fit:cover"
          width="1600"
          height="2000"
          loading="eager"
          decoding="async"
        />
      </picture>
    </figure>
    <div class="text-center">
      <h1 class="text-3xl font-bold">
        {p.bio.name} — {p.bio.persona}
      </h1>
      <p class="hud-label mt-1">{p.bio.location}</p>
    </div>

    <div class="mx-auto max-w-2xl space-y-5 text-lg text-ink">
      {p.narrative.map((paragraph) => <p data-reveal data-reveal-stagger="90">{paragraph}</p>)}
    </div>

    <!-- Personal socials row (COPY.md §6 / DIRECTION §2.8) — "Find me in the
         field": Sindbad's personal channels. Text links, Space Mono label,
         styled like the existing label rows (no new component archetype). -->
    <div class="mx-auto max-w-2xl space-y-2 border-t border-hairline pt-6">
      <p class="hud-label">FIND ME IN THE FIELD</p>
      <p class="text-ink">The business lives here. I live on these:</p>
      <ul class="flex flex-wrap gap-x-5 gap-y-1.5 pt-1">
        {
          personalSocials.map((s) => (
            <li>
              <a href={s.href} class="link" rel="me noopener">
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Legend-key explainer close: the honesty device stated as trust, backed
       by the real, visible key — not just a claim. On reveal the LegendKey
       symbols ping in sequence (R3.10 §3.5, 100ms apart, once). -->
  <section class="about-legend mx-auto max-w-2xl space-y-4 border-t border-hairline p-8 text-center" data-about-legend>
    <p class="text-lg italic text-ink" data-reveal>{p.legendLine}</p>
    <div class="flex justify-center" data-reveal>
      <LegendKey />
    </div>
  </section>
</Base>

<script>
  // R3.10 §3.5 — About page signature moments.
  import { ensureSmoothScroll } from "../lib/smooth-scroll";

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Drift on the portrait figure (amp 0.5) — the engine self-gates off under
  // reduced motion / <=640px; mount at idle so it never touches the LCP path.
  if (!reduce) {
    void ensureSmoothScroll();
    const mountAmbient = () =>
      import("../lib/drift-engine").then(({ mountDrift }) => mountDrift(document));
    if ("requestIdleCallback" in window) requestIdleCallback(mountAmbient, { timeout: 3000 });
    else setTimeout(mountAmbient, 1500);
  }

  // Legend-key symbol ping-in on reveal (100ms apart, once). The symbols are the
  // LegendKey <span>s; a scoped .ping-once class runs the survey-ping keyframe.
  const legendSection = document.querySelector<HTMLElement>("[data-about-legend]");
  if (legendSection && !reduce && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          const symbols = legendSection.querySelectorAll<HTMLElement>(".legend-key li > span:first-child");
          symbols.forEach((s, i) => setTimeout(() => s.classList.add("ping-once"), i * 100));
          obs.disconnect();
        }
      },
      { rootMargin: "0px 0px -12% 0px", threshold: 0.05 },
    );
    io.observe(legendSection);
  }
</script>
