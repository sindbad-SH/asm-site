---
import Base from "../layouts/Base.astro";
import LegendMark from "../components/LegendMark.astro";
import LegendKey from "../components/LegendKey.astro";
import Testimonial from "../components/Testimonial.astro";
import PortalHero from "../components/PortalHero.astro";
import Tableaux from "../components/Tableaux.astro";
import TrailJourney from "../components/TrailJourney.astro";
import { COPY, PAGES } from "../consts";

const p = PAGES.home;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title={p.meta.title} description={p.meta.description}>
  <!-- Ambient "you-are-here" survey trail (§3.3) — fixed behind content,
       threads the three pillar sections. Desktop-only, degrades to static. -->
  <TrailJourney />

  <!-- H1 — the Portal Hero (§9.2): the mark as a window, A→B→A. Content
       paints first (LCP) over the void; the dissolve-through plays behind it
       and reverses on scroll-out as the handoff into the tableaux. -->
  <PortalHero>
    <p class="hud-label">{COPY.hero.kicker}</p>
    <h1 class="text-4xl font-bold sm:text-6xl">{COPY.hero.headline}</h1>
    <p class="mx-auto max-w-2xl text-lg text-ink">{COPY.hero.subline}</p>
    <a href={`${base}/forge-the-saga`} class="btn">
      {COPY.paths[0].label}
    </a>
  </PortalHero>

  <!-- H2 — paths band -->
  <nav aria-label="Explore by intent" class="border-t border-current/20 p-8">
    <ul class="mx-auto flex max-w-3xl flex-wrap justify-center gap-6">
      {
        COPY.paths.map((path) => (
          <li>
            <a href={`${base}${path.href}`} class="link">
              {path.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- H3 — three-pillar scroll tableaux engine (§2b) -->
  <Tableaux />

  <!-- H4 — proof band -->
  <section class="mx-auto max-w-3xl space-y-6 border-t border-current/20 p-8">
    <h2 class="text-2xl font-bold">{p.proof.heading}</h2>
    <p>{p.proof.intro}</p>
    <Testimonial testimonialId={p.proof.testimonialId} />
    <ul class="space-y-3">
      {
        p.proof.tiered.map((relationshipId) => (
          <li>
            <LegendMark proof={{ relationshipId }} />
          </li>
        ))
      }
    </ul>
    <LegendKey />
  </section>

  <!-- H5 — Forge the Saga teaser -->
  <section class="mx-auto max-w-3xl space-y-4 border-t border-current/20 p-8">
    <h2 class="text-2xl font-bold">{p.forgeTeaser.heading}</h2>
    <p>{p.forgeTeaser.body}</p>
    <p class="italic opacity-80">{p.forgeTeaser.anchor}</p>
    <a href={`${base}${p.forgeTeaser.cta.href}`} class="inline-block rounded border border-current px-4 py-2">
      {p.forgeTeaser.cta.label}
    </a>
  </section>

  <!-- H6 — About teaser -->
  <section class="mx-auto max-w-3xl space-y-4 border-t border-current/20 p-8">
    <p>{p.aboutTeaser.body}</p>
    <p class="italic opacity-80">{p.aboutTeaser.anchor}</p>
    <a href={`${base}${p.aboutTeaser.link.href}`} class="link">{p.aboutTeaser.link.label} <span class="arrow" aria-hidden="true">→</span></a>
  </section>

  <!-- H7 — contact CTA band -->
  <section class="mx-auto max-w-3xl space-y-4 border-t border-current/20 p-8 text-center">
    <h2 class="text-2xl font-bold">{p.contactBand.headline}</h2>
    <p>{p.contactBand.body}</p>
    <a href={`${base}${p.contactBand.cta.href}`} class="inline-block rounded border border-current px-4 py-2">
      {p.contactBand.cta.label}
    </a>
  </section>
</Base>
