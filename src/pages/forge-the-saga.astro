---
/**
 * /forge-the-saga — P9 (V1-UPGRADE-PLAN): rebuilt to the Disal Consulting
 * services grammar (disalconsulting.com/en/cosa-facciamo), the operator's
 * chosen reference for this page. Their grammar, his method:
 *
 *   - the SPLIT HERO: a saturated statement panel beside a calm panel where
 *     a single continuous LINE draws itself (their telescope man → our
 *     ridge contours, straight from the Contour Survey identity)
 *   - a row of tall DUOTONE cards with hover-rise reveals (their three
 *     service pillars → his three "who it's for" scenarios)
 *   - a saturated BAND with fine contour-line texture holding a horizontal
 *     carousel of artifacts (their OUR PAPERS → his FIVE STAGES, each
 *     stage as a paper-white method card with deliverable + price)
 *   - a calm band with the proof artifact + pill CTA (their books/DISCOVER
 *     → his PitchBoulder proof + See the work)
 *
 * Palette adaptation ("vibed by him"): their cobalt-on-paper daylight
 * becomes survey cobalt (#14406b) on dark stone — the site stays cinematic
 * while the two-tone split reads immediately as the reference.
 *
 * HONESTY: all copy verbatim from consts (hero/whoFor/stages/proof/pricing/
 * cta + SAGA_STAGES fields). Prices are the OD-4 exact "from $X" values.
 * The Echo Panel pretest stays shelved (F4, rendered:false). Proof still
 * renders through LegendMark + Testimonial.
 *
 * Fallbacks: no-JS/reduced-motion → lines fully drawn, cards static with
 * meta visible, carousel is native scroll-snap (no JS required at all).
 */
import Base from "../layouts/Base.astro";
import LegendMark from "../components/LegendMark.astro";
import Testimonial from "../components/Testimonial.astro";
import { PAGES, SAGA_STAGES } from "../consts";
import { existsSync } from "node:fs";
import { join } from "node:path";

const p = PAGES.forge;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// duotone card art — the market cluster frames (existence-gated, cwd-anchored)
const clusterDir = join(process.cwd(), "public", "media", "home", "market", "cluster");
const cardArt = ["lake", "ridge", "valley"].map((name) =>
  existsSync(join(clusterDir, `${name}.avif`))
    ? {
        avif: `${base}/media/home/market/cluster/${name}.avif`,
        webp: `${base}/media/home/market/cluster/${name}.webp`,
      }
    : undefined,
);

// the ridge contour paths — the same line family as the home hero's SVG
// ridge, so the self-drawing line is OUR line, not a borrowed illustration
const contours = [
  "M0,150 L110,96 L205,132 L320,72 L430,120 L540,58 L660,110 L780,76 L900,124 L1020,88 L1140,128",
  "M0,196 L95,152 L210,184 L330,132 L470,176 L610,120 L750,168 L890,136 L1030,178 L1140,150",
];
---

<Base title={p.meta.title} description={p.meta.description}>
  <main class="fs">
    <!-- ═══ F1 · the split hero — statement panel + self-drawing ridge ═══ -->
    <section class="fs-hero">
      <div class="fs-hero-panel">
        <h1 class="fs-headline" data-reveal>{p.hero.headline}</h1>
        <p class="fs-sub" data-reveal>{p.hero.subline}</p>
        <a href={`${base}${p.hero.cta.href}`} class="fs-pill" data-reveal>{p.hero.cta.label}</a>
      </div>
      <div class="fs-hero-canvas" aria-hidden="true">
        <svg class="fs-lines" viewBox="0 0 1140 260" preserveAspectRatio="xMidYMid meet" fill="none">
          {contours.map((d) => <path class="fs-line" data-fs-line d={d} stroke="var(--color-accent, #38f8ec)" stroke-opacity="0.5" stroke-width="1.6" stroke-linecap="round" />)}
        </svg>
      </div>
    </section>

    <!-- ═══ F2 · who it's for — the three duotone scenario cards ═══ -->
    <section class="fs-sec fs-who">
      <h2 class="fs-h2" data-reveal>{p.whoFor.heading}</h2>
      <p class="fs-body" data-reveal>{p.whoFor.body}</p>
      <div class="fs-cards">
        {
          p.whoFor.items.map((item, i) => (
            <article class="fs-card" data-reveal data-reveal-stagger="90">
              {cardArt[i] && (
                <picture class="fs-card-art" aria-hidden="true">
                  <source srcset={cardArt[i]!.avif} type="image/avif" />
                  <img src={cardArt[i]!.webp} alt="" loading="lazy" decoding="async" />
                </picture>
              )}
              <span class="fs-card-no" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
              <p class="fs-card-line">{item}</p>
            </article>
          ))
        }
      </div>
    </section>

    <!-- ═══ F3 · the five stages — the cobalt band + method carousel ═══ -->
    <section class="fs-sec fs-band">
      <svg class="fs-band-texture" viewBox="0 0 1440 600" preserveAspectRatio="none" aria-hidden="true" fill="none">
        <path d="M-60,420 Q 320,180 760,340 T 1500,260" stroke="#ffffff" stroke-opacity="0.07" stroke-width="1.4" />
        <path d="M-60,520 Q 400,300 860,440 T 1500,380" stroke="#ffffff" stroke-opacity="0.05" stroke-width="1.4" />
        <path d="M-60,180 Q 380,60 820,190 T 1500,110" stroke="#ffffff" stroke-opacity="0.06" stroke-width="1.4" />
      </svg>
      <!-- the LOCKED heading, split in the reference's serif+sans manner -->
      <h2 class="fs-band-title" data-reveal>
        <span class="fs-band-serif">The five</span>
        <span class="fs-band-caps">STAGES</span>
      </h2>
      <p class="fs-body fs-band-intro" data-reveal>{p.stages.body}</p>

      <div class="fs-rail" data-fs-rail tabindex="0" aria-label="The five stages of Forge the Saga">
        {
          SAGA_STAGES.map((stage) => (
            <article class="fs-stage" data-reveal data-reveal-stagger="70">
              <header class="fs-stage-head">
                <span class="fs-stage-no">{stage.no}</span>
                <h3 class="fs-stage-name">{stage.name}</h3>
                <p class="hud-label fs-stage-sub" data-tableau-content>
                  <span data-decode>{stage.sub}</span>
                </p>
              </header>
              <p class="fs-stage-process">{stage.process}</p>
              <dl class="fs-stage-meta">
                <div>
                  <dt class="hud-label">Deliverable</dt>
                  <dd>{stage.deliverable}</dd>
                </div>
                <div>
                  <dt class="hud-label">Best for</dt>
                  <dd>{stage.bestFor}</dd>
                </div>
              </dl>
              <p class="fs-stage-price">{stage.price}</p>
              {stage.no === "04" && <p class="fs-stage-anchor">{p.stages.anchor}</p>}
            </article>
          ))
        }
      </div>

      <div class="fs-pricing" data-reveal>
        <h3 class="fs-h3">{p.pricing.heading}</h3>
        <p class="fs-body">{p.pricing.body}</p>
        <p class="fs-note">{p.pricing.note}</p>
      </div>
    </section>

    <!-- ═══ F5 · proof — the calm artifact band ═══ -->
    <section class="fs-sec fs-proof">
      <h2 class="fs-h2 fs-h2--serif" data-reveal>{p.proof.heading}</h2>
      <div class="fs-proof-card" data-reveal>
        <LegendMark proof={p.proof.anchor} />
        <Testimonial testimonialId={p.proof.testimonialId} showProof={false} />
        <a href={`${base}/work/pitchboulder`} class="fs-pill fs-pill--quiet">
          See the work <span aria-hidden="true">→</span>
        </a>
      </div>
      <p class="fs-note" data-reveal>{p.proof.note}</p>
    </section>

    <!-- ═══ F7 · the close — statement panel again, one CTA ═══ -->
    <section class="fs-sec fs-cta">
      <h2 class="fs-headline fs-headline--close" data-reveal>{p.cta.headline}</h2>
      <p class="fs-sub" data-reveal>{p.cta.body}</p>
      <a href={`${base}${p.cta.cta.href}`} class="fs-pill" data-reveal>{p.cta.cta.label}</a>
    </section>
  </main>
</Base>

<style>
  .fs {
    /* the two working grounds: survey cobalt + dark stone (the reference's
       cobalt + paper, brought into the site's night) */
    --fs-cobalt: #14406b;
    --fs-stone: #191a17;
    --fs-paper: #edece4; /* stage cards keep the reference's paper */
    background: var(--fs-stone);
  }
  .fs-sec {
    position: relative;
    overflow: clip;
  }

  /* ── F1 split hero ── */
  .fs-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    min-height: 86svh;
  }
  .fs-hero-panel {
    background: var(--fs-cobalt);
    display: grid;
    align-content: center;
    justify-items: start;
    gap: 1.4rem;
    padding: clamp(2.5rem, 7vw, 7rem);
  }
  .fs-headline {
    font-family: var(--font-display);
    font-weight: 560;
    font-size: clamp(2.1rem, 3.6vw, 3.4rem);
    line-height: 1.12;
    color: #f4f7fa;
    max-width: 16ch;
  }
  .fs-sub {
    font-family: var(--font-sans);
    font-size: clamp(1.02rem, 1.35vw, 1.2rem);
    line-height: 1.55;
    color: color-mix(in srgb, #f4f7fa 88%, transparent);
    max-width: 44ch;
  }
  .fs-pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #071018;
    background: var(--color-accent, #38f8ec);
    border-radius: 999px;
    padding: 0.85rem 1.7rem;
    transition: transform 240ms var(--ease-swift, ease-out);
  }
  .fs-pill:hover {
    transform: translateY(-2px);
  }
  .fs-pill--quiet {
    background: transparent;
    color: var(--color-accent, #38f8ec);
    border: 1px solid color-mix(in srgb, var(--color-accent, #38f8ec) 55%, transparent);
  }
  .fs-hero-canvas {
    display: grid;
    align-items: center;
    background: var(--fs-stone);
    padding: clamp(1.5rem, 4vw, 4rem);
  }
  .fs-lines {
    width: 100%;
    height: auto;
  }
  /* the self-draw: dash values are set by JS from real path lengths; without
     JS (or under reduced motion) the lines are simply fully drawn */
  .fs-line {
    stroke-dasharray: none;
  }

  /* ── F2 who it's for — duotone cards ── */
  .fs-who {
    padding: 6rem clamp(1.5rem, 6vw, 7rem);
    display: grid;
    gap: 1.2rem;
    max-width: 88rem;
    margin-inline: auto;
  }
  .fs-h2 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.6rem, 2.4vw, 2.2rem);
    color: #eef2f5;
  }
  .fs-h2--serif {
    font-family: var(--font-display);
    font-weight: 520;
    font-style: italic;
  }
  .fs-h3 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.25rem;
    color: #eef2f5;
  }
  .fs-body {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.6;
    color: color-mix(in srgb, #eef2f5 82%, transparent);
    max-width: 56ch;
  }
  .fs-note {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: color-mix(in srgb, #eef2f5 62%, transparent);
    max-width: 60ch;
  }
  .fs-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.9rem, 1.6vw, 1.5rem);
    margin-top: 1.8rem;
  }
  .fs-card {
    position: relative;
    min-height: clamp(340px, 44vw, 520px);
    border-radius: 8px;
    overflow: hidden;
    background: var(--fs-cobalt);
    isolation: isolate;
  }
  .fs-card-art {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .fs-card-art img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* the duotone: desaturated art under a cobalt wash (their exact move) */
    filter: grayscale(1) contrast(1.05);
    opacity: 0.5;
    transition:
      opacity 500ms var(--ease-survey, ease),
      transform 900ms var(--ease-survey, ease);
  }
  .fs-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--fs-cobalt) 92%, #000) 0%,
      color-mix(in srgb, var(--fs-cobalt) 55%, transparent) 60%
    );
    z-index: 0;
  }
  .fs-card-no {
    position: absolute;
    top: 18px;
    left: 20px;
    z-index: 1;
    font-family: var(--font-sans);
    font-size: 2rem;
    font-weight: 300;
    color: #ffffff;
    /* thin-stroke numeral — the line-art icon slot, drawn with type */
    -webkit-text-stroke: 1px #fff;
    -webkit-text-fill-color: transparent;
    opacity: 0.9;
  }
  .fs-card-line {
    position: absolute;
    inset-inline: 20px;
    bottom: 20px;
    z-index: 1;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(1.05rem, 1.5vw, 1.3rem);
    line-height: 1.4;
    color: #f4f7fa;
    transition: transform 420ms var(--ease-survey, ease);
  }
  @media (hover: hover) {
    .fs-card:hover .fs-card-line {
      transform: translateY(-8px);
    }
    .fs-card:hover .fs-card-art img {
      opacity: 0.68;
      transform: scale(1.03);
    }
  }

  /* ── F3 the band + stage carousel ── */
  .fs-band {
    background: var(--fs-cobalt);
    padding: 6rem clamp(1.5rem, 6vw, 7rem) 5rem;
  }
  .fs-band-texture {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .fs-band-title {
    position: relative;
    display: grid;
    line-height: 0.95;
    margin-bottom: 1.4rem;
  }
  .fs-band-serif {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(2rem, 4vw, 3.6rem);
    color: #f4f7fa;
  }
  .fs-band-caps {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.6rem, 5.4vw, 5rem);
    letter-spacing: 0.02em;
    color: #f4f7fa;
  }
  .fs-band-intro {
    position: relative;
    margin-bottom: 2.6rem;
  }
  .fs-rail {
    position: relative;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: clamp(280px, 30vw, 380px);
    gap: 1.2rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 1.2rem;
    scrollbar-width: thin;
  }
  .fs-stage {
    scroll-snap-align: start;
    background: var(--fs-paper);
    color: #17181c;
    border-radius: 6px;
    padding: 1.6rem 1.5rem 1.4rem;
    display: grid;
    gap: 0.9rem;
    align-content: start;
    box-shadow: 0 18px 50px -22px rgba(0, 0, 0, 0.5);
  }
  .fs-stage-no {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 1.7rem;
    color: var(--fs-cobalt);
    -webkit-text-stroke: 1px var(--fs-cobalt);
    -webkit-text-fill-color: transparent;
  }
  .fs-stage-name {
    font-family: var(--font-sans);
    font-weight: 650;
    font-size: 1.3rem;
    margin-top: 0.2rem;
  }
  .fs-stage-sub {
    color: color-mix(in srgb, #17181c 62%, transparent);
    letter-spacing: 0.18em;
  }
  .fs-stage-process {
    font-size: 0.95rem;
    line-height: 1.55;
    color: color-mix(in srgb, #17181c 84%, transparent);
  }
  .fs-stage-meta {
    display: grid;
    gap: 0.7rem;
    margin: 0;
    border-top: 1px solid color-mix(in srgb, #17181c 14%, transparent);
    padding-top: 0.9rem;
  }
  .fs-stage-meta dt {
    color: color-mix(in srgb, #17181c 55%, transparent);
    letter-spacing: 0.16em;
  }
  .fs-stage-meta dd {
    margin: 0.15rem 0 0;
    font-size: 0.95rem;
    line-height: 1.45;
  }
  .fs-stage-price {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    color: var(--fs-cobalt);
  }
  .fs-stage-anchor {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.98rem;
    color: color-mix(in srgb, #17181c 72%, transparent);
    border-left: 2px solid var(--fs-cobalt);
    padding-left: 0.8rem;
  }
  .fs-pricing {
    position: relative;
    margin-top: 2.6rem;
    display: grid;
    gap: 0.6rem;
  }

  /* ── F5 proof ── */
  .fs-proof {
    padding: 6rem clamp(1.5rem, 6vw, 7rem);
    max-width: 60rem;
    margin-inline: auto;
    display: grid;
    gap: 1.4rem;
  }
  .fs-proof-card {
    display: grid;
    gap: 1.1rem;
    border: 1px solid color-mix(in srgb, #ffffff 14%, transparent);
    border-radius: 8px;
    padding: 1.8rem;
    background: color-mix(in srgb, #ffffff 3%, transparent);
  }

  /* ── F7 close ── */
  .fs-cta {
    background: var(--fs-cobalt);
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 1.3rem;
    padding: 6.5rem clamp(1.5rem, 6vw, 7rem);
  }
  .fs-headline--close {
    max-width: 22ch;
  }
  .fs-cta .fs-sub {
    max-width: 50ch;
  }

  /* ── small screens ── */
  @media (max-width: 860px) {
    .fs-hero {
      grid-template-columns: 1fr;
    }
    .fs-hero-canvas {
      min-height: 34svh;
    }
    .fs-cards {
      grid-template-columns: 1fr;
    }
    .fs-card {
      min-height: 260px;
    }
  }
</style>

<script>
  // P9 enhancement: the self-drawing contour lines (their continuous-line
  // signature). Real path lengths measured at runtime; reduced motion and
  // no-JS leave the lines fully drawn (CSS default).
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ensureSmoothScroll } from "../lib/smooth-scroll";

  async function init() {
    const idle = (fn: () => void) =>
      "requestIdleCallback" in window ? requestIdleCallback(fn, { timeout: 3000 }) : setTimeout(fn, 1500);
    idle(() => {
      void import("../lib/decode-text").then(({ mountDecode }) => mountDecode(document));
    });

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    gsap.registerPlugin(ScrollTrigger);
    const lenis = await ensureSmoothScroll();
    if (lenis) lenis.on("scroll", () => ScrollTrigger.update());

    document.querySelectorAll<SVGPathElement>("[data-fs-line]").forEach((path, i) => {
      const L = path.getTotalLength();
      path.style.strokeDasharray = String(L);
      gsap.fromTo(
        path,
        { strokeDashoffset: L },
        {
          strokeDashoffset: 0,
          duration: 2.2,
          delay: 0.4 + i * 0.5,
          ease: "power2.inOut",
          scrollTrigger: { trigger: path.closest("section"), start: "top 75%", once: true },
          onComplete: () => {
            // once drawn, the ridge breathes — a slow vertical drift
            gsap.to(path, { y: i % 2 ? -4 : 4, duration: 6 + i, ease: "sine.inOut", yoyo: true, repeat: -1 });
          },
        },
      );
    });
  }
  void init();
</script>
