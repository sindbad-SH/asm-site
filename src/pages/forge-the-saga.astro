---
/**
 * Forge the Saga — the primary lane (BUILD-PLAN.md §1.2). The whole page runs
 * the Forge & Anneal dialect via data-lane="forge" (the sanctioned synthesis:
 * Forge treatment scoped to the Consulting lane inside the Contour Survey
 * shell — orange never escapes this scope, §6).
 *
 * F3 is the horizontal temper-line stepper (§3.3): a gradient temper line
 * (orange → aqua = the thermal progression of forging) with 5 stage nodes.
 * Interactive tablist when enhanced; the stacked panels are the accessible
 * tabular fallback (no-JS / narrow / reduced-motion-safe).
 */
import Base from "../layouts/Base.astro";
import Testimonial from "../components/Testimonial.astro";
import Card from "../components/Card.astro";
import { PAGES, SAGA_STAGES, WORK } from "../consts";

const p = PAGES.forge;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const deliveredWork = WORK.filter((item) => p.proof.deliveredWorkSlugs.includes(item.slug));
const n = SAGA_STAGES.length;

// Each node's temperature tint: stage 01 sits at the hot (orange) working end,
// stage 05 at the set (aqua) end — the forging progression made literal.
const nodeColor = (i: number) =>
  `color-mix(in srgb, var(--color-forge-heat) ${Math.round((1 - i / (n - 1)) * 100)}%, var(--color-accent))`;

// Split a "from $X …" price so the numeric part can count up (real data, §OD-4).
function parsePrice(price: string) {
  const m = price.match(/\$([\d,]+)/);
  if (!m) return { pre: price, num: "", val: 0, suf: "" };
  const idx = price.indexOf(m[0]);
  return {
    pre: price.slice(0, idx + 1), // through the "$"
    num: m[1],
    val: Number(m[1].replace(/,/g, "")),
    suf: price.slice(idx + m[0].length),
  };
}
---

<Base title={p.meta.title} description={p.meta.description}>
  <div data-lane="forge">
    <!-- F1 ember (R3.8) — a fixed radial ember glow breathing behind the page.
         Orange is SANCTIONED in the forge lane; CSS-only, compositor (opacity). -->
    <div class="forge-ember" aria-hidden="true"></div>

    <!-- F1 — belief hero. Telemetry eyebrow (Ascent camp grammar) + headline at
         the Ascent scale, generous air. Headline reveals via masked-line rise
         (splitLines). -->
    <section class="mx-auto max-w-3xl space-y-7 p-8 pt-16 text-center sm:pt-24">
      <p class="hud-label ch-no" data-decode data-reveal>THE FORGE</p>
      <h1 class="tableau-headline mx-auto" data-forge-h1>{p.hero.headline}</h1>
      <p class="mx-auto max-w-xl text-lg text-ink" data-reveal>{p.hero.subline}</p>
      <a href={`${base}${p.hero.cta.href}`} class="btn" data-reveal>{p.hero.cta.label}</a>
    </section>

    <!-- F2 — who it's for -->
    <section class="mx-auto max-w-3xl space-y-5 border-t border-hairline p-10 sm:p-16">
      <p class="hud-label ch-no" data-decode data-reveal>01 · WHO IT'S FOR</p>
      <h2 class="text-2xl font-bold" data-reveal>{p.whoFor.heading}</h2>
      <p class="text-ink" data-reveal>{p.whoFor.body}</p>
      <ul class="grid gap-3 sm:grid-cols-3">
        {
          p.whoFor.items.map((item) => (
            <li class="panel p-4 text-sm text-ink" data-reveal data-reveal-stagger="70">{item}</li>
          ))
        }
      </ul>
    </section>

    <!-- F3 — the five stages: horizontal temper-line stepper -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-10 sm:p-16">
      <p class="hud-label ch-no" data-decode data-reveal>02 · THE FIVE STAGES</p>
      <h2 class="text-2xl font-bold" data-reveal>{p.stages.heading}</h2>
      <p class="text-ink" data-reveal>{p.stages.body}</p>
      <p class="hud-label text-accent-deep" data-reveal>{p.stages.anchor}</p>

      <div class="temper mt-4" data-temper>
        <!-- track: hidden until JS + wide viewport enable the stepper -->
        <div class="temper-track" data-temper-track hidden>
          {
            SAGA_STAGES.map((stage, i) => (
              <button type="button" class="temper-node" data-tab={i} style={`--node-color:${nodeColor(i)}`}>
                <span class="no">{stage.no}</span>
                <span class="dot" aria-hidden="true" />
                <span class="node-name">{stage.name}</span>
              </button>
            ))
          }
          <div class="temper-line" aria-hidden="true"></div>
        </div>

        <!-- panels: all visible = the accessible tabular fallback -->
        <div class="temper-panels">
          {
            SAGA_STAGES.map((stage, i) => {
              const price = parsePrice(stage.price);
              return (
                <div
                  class="temper-panel"
                  data-panel={i}
                  id={`forge-stage-${stage.no}`}
                  style={`--node-color:${nodeColor(i)}`}
                >
                  <p class="hud-label">
                    <span class="marker" aria-hidden="true">◆</span> {stage.no} · {stage.sub}
                  </p>
                  <h3 class="heat is-cold mt-1 text-2xl font-bold">{stage.name}</h3>
                  <p class="mt-2 text-ink">{stage.process}</p>
                  <dl class="temper-detail">
                    <div>
                      <dt>Deliverable</dt>
                      <dd>{stage.deliverable}</dd>
                    </div>
                    <div>
                      <dt>Investment</dt>
                      <dd class="temper-price">
                        {price.pre}
                        <span data-price data-value={price.val}>{price.num}</span>
                        {price.suf}
                      </dd>
                    </div>
                    <div>
                      <dt>Best for</dt>
                      <dd>{stage.bestFor}</dd>
                    </div>
                  </dl>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>

    <!--
      F4 — pretest section. RESERVED SLOT, launches as VARIANT B (OD-2): Echo
      Panel is off the site. Nothing renders here by design — the pretest idea
      already lives honestly in Stage 04 above ("curated human panels, AI
      audience simulations, or both"). Variant A copy sits unrendered in
      PAGES.forge.pretestShelved; to lift it back in, render a <section> here
      from that data. Do not remove this anchor — it keeps F5 numbering + the
      page's honest structure intact.
    -->

    <!-- F5 — proof: PitchBoulder case + delivered-work cards (honest labels) -->
    <section class="mx-auto max-w-3xl space-y-6 border-t border-hairline p-10 sm:p-16">
      <p class="hud-label ch-no" data-decode data-reveal>03 · PROOF</p>
      <h2 class="text-2xl font-bold" data-reveal>{p.proof.heading}</h2>
      <Testimonial testimonialId={p.proof.testimonialId} class="panel p-5" />
      <div class="grid gap-5 sm:grid-cols-2">
        {
          deliveredWork.map((item) => (
            <Card
              href={item.href ? `${base}${item.href}` : undefined}
              eyebrow={item.engagement}
              title={`For ${item.forOrg} · ${item.what}`}
              proof={item.relationshipId ? { relationshipId: item.relationshipId } : undefined}
              ctaLabel={item.href ? "See the work" : undefined}
              reveal
              revealStagger={70}
            />
          ))
        }
      </div>
      <p class="text-sm text-ink-muted">{p.proof.note}</p>
    </section>

    <!-- F6 — pricing (OD-4: exact "from $X"; per-stage figures live in F3) -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-10 sm:p-16">
      <p class="hud-label ch-no" data-decode data-reveal>04 · PRICING</p>
      <h2 class="text-2xl font-bold" data-reveal>{p.pricing.heading}</h2>
      <p class="text-lg text-ink" data-reveal>{p.pricing.body}</p>
      <p class="text-sm text-ink-muted" data-reveal>{p.pricing.note}</p>
    </section>

    <!-- F7 — CTA -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-10 pb-24 text-center sm:p-16 sm:pb-28">
      <h2 class="text-3xl font-bold" data-reveal>{p.cta.headline}</h2>
      <p class="mx-auto max-w-xl text-ink" data-reveal>{p.cta.body}</p>
      <a href={`${base}${p.cta.cta.href}`} class="btn">{p.cta.cta.label}</a>
    </section>
  </div>
</Base>

<script>
  // F3 temper-line stepper controller. Progressive enhancement: the stacked
  // panels are the accessible fallback; this upgrades them to a WAI-ARIA
  // tablist on wide viewports only. Reduced motion → no count-up; hidden tab →
  // price resting value stays correct (rAF may not fire).
  // R3.8 — lazily-loaded GSAP (shared by the panel crossfade + the temper-line
  // ignition). Loaded once when the stepper first goes interactive on wide.
  let gsapRef: typeof import("gsap").gsap | null = null;
  let ignited = false;

  const root = document.querySelector<HTMLElement>("[data-temper]");
  if (root) init(root);

  // R3.8 — F1 headline masked-line reveal (splitLines util). Runs regardless of
  // the stepper; reduced motion / no-JS show the plain heading (CSS-gated).
  // V-4: same 4s watchdog as Tableaux.astro — .tableau-headline is hidden under
  // html.js until .is-split lands; if the async chunk 404s or throws, force it
  // visible so the hero headline can never stay invisible.
  setTimeout(() => {
    const h1 = document.querySelector<HTMLElement>("[data-forge-h1]");
    if (h1 && !h1.classList.contains("is-split")) h1.classList.add("is-split");
  }, 4000);
  (async () => {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const h1 = document.querySelector<HTMLElement>("[data-forge-h1]");
    if (!h1) return;
    if (document.fonts?.ready) await document.fonts.ready;
    const { splitLines } = await import("../lib/split-lines");
    splitLines(h1);
    // reveal after a short beat so the mask-rise reads (matches §3.3)
    setTimeout(() => h1.classList.add("is-revealed"), 300);
  })();

  // R3.8 — the temper-line ignition: on first entry of F3 the line draws
  // scaleX 0→1, then the 5 nodes ignite in sequence with a one-time glow flare.
  // Once only (never re-fires on tab switches). Requires the interactive stepper
  // (wide + JS); the stacked fallback never dims and needs no ignition.
  async function ignite(temper: HTMLElement) {
    if (ignited || window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    ignited = true;
    if (!gsapRef) gsapRef = (await import("gsap")).gsap;
    const { ScrollTrigger } = await import("gsap/ScrollTrigger");
    gsapRef.registerPlugin(ScrollTrigger);
    ScrollTrigger.create({
      trigger: temper,
      start: "top 70%",
      once: true,
      onEnter: () => {
        const line = temper.querySelector(".temper-line");
        const nodes = temper.querySelectorAll(".temper-node");
        const dots = temper.querySelectorAll(".temper-node .dot");
        const tl = gsapRef!.timeline({
          // once the reveal completes, hand opacity back to CSS (.is-ignited)
          // and clear the inline styles GSAP set, so nothing lingers.
          onComplete: () => {
            temper.classList.add("is-ignited");
            gsapRef!.set(nodes, { clearProps: "opacity" });
          },
        });
        if (line)
          tl.fromTo(
            line,
            { scaleX: 0 },
            { scaleX: 1, duration: 1.2, ease: "expo.out", transformOrigin: "left center" },
          );
        tl.to(nodes, { opacity: 1, duration: 0.4, stagger: 0.09, ease: "power2.out" }, "-=0.55");
        tl.fromTo(
          dots,
          { boxShadow: "0 0 0 0 transparent" },
          {
            boxShadow: "0 0 14px 2px var(--node-color)",
            duration: 0.35,
            stagger: 0.09,
            yoyo: true,
            repeat: 1,
            ease: "power2.out",
          },
          "<",
        );
      },
    });
  }

  function init(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>("[data-temper-track]");
    const nodes = [...root.querySelectorAll<HTMLElement>("[data-tab]")];
    const panels = [...root.querySelectorAll<HTMLElement>("[data-panel]")];
    if (!track || nodes.length === 0 || nodes.length !== panels.length) return;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const wide = window.matchMedia("(min-width: 768px)");
    const fmt = (v: number) => v.toLocaleString("en-US");
    const easeOut = (k: number) => 1 - Math.pow(1 - k, 3);

    let selected = 0;

    function countUp(panel: HTMLElement) {
      const el = panel.querySelector<HTMLElement>("[data-price]");
      if (!el) return;
      const target = Number(el.getAttribute("data-value")) || 0;
      el.textContent = fmt(target); // correct resting value, always
      if (reduce || document.visibilityState !== "visible" || !target) return;
      const dur = 480;
      let start = -1;
      const step = (t: number) => {
        if (start < 0) start = t;
        const k = Math.min(1, (t - start) / dur);
        el.textContent = fmt(Math.round(target * (0.12 + 0.88 * easeOut(k))));
        if (k < 1) requestAnimationFrame(step);
        else el.textContent = fmt(target);
      };
      requestAnimationFrame(step);
    }

    function select(i: number, focusNode = false) {
      selected = i;
      nodes.forEach((node, j) => {
        const on = j === i;
        node.setAttribute("aria-selected", String(on));
        node.tabIndex = on ? 0 : -1;
        if (on && focusNode) node.focus();
      });
      panels.forEach((panel, j) => {
        panel.hidden = j !== i;
        const name = panel.querySelector(".heat");
        name?.classList.remove("is-cold", "is-hot", "is-set");
        // hot at the working (early) end, set (aqua) at the finished end
        name?.classList.add(j !== i ? "is-cold" : i < 3 ? "is-hot" : "is-set");
        if (j === i) {
          countUp(panel);
          // R3.8 — 240ms opacity crossfade on the newly visible panel (skipped
          // under reduced motion; keyboard tab-switching stays instant otherwise
          // — opacity only, no layout tax). Lazy GSAP; CSS heat-flash unchanged.
          if (!reduce && gsapRef) {
            gsapRef.fromTo(panel, { opacity: 0 }, { opacity: 1, duration: 0.24, ease: "power2.out" });
          }
        }
      });
    }

    track.addEventListener("keydown", (e) => {
      let next = -1;
      if (e.key === "ArrowRight" || e.key === "ArrowDown") next = (selected + 1) % nodes.length;
      else if (e.key === "ArrowLeft" || e.key === "ArrowUp") next = (selected - 1 + nodes.length) % nodes.length;
      else if (e.key === "Home") next = 0;
      else if (e.key === "End") next = nodes.length - 1;
      if (next >= 0) {
        e.preventDefault();
        select(next, true);
      }
    });
    nodes.forEach((node, i) => node.addEventListener("click", () => select(i)));

    function enable() {
      root.setAttribute("data-interactive", "true");
      track!.hidden = false;
      // R3.8 — load GSAP for the crossfade + fire the temper-line ignition once.
      if (!reduce) {
        void (async () => {
          if (!gsapRef) gsapRef = (await import("gsap")).gsap;
          void ignite(root);
        })();
        // Watchdog: if the ignition never runs (chunk 404 / F3 never scrolled to
        // / a throw), force the nodes to full so they can't stay dimmed forever.
        setTimeout(() => {
          if (!root.classList.contains("is-ignited")) root.classList.add("is-ignited");
        }, 4000);
      }
      // ARIA tablist wiring — only meaningful (and only present) while
      // interactive, so disable() can strip it cleanly on resize back to narrow.
      track!.setAttribute("role", "tablist");
      track!.setAttribute("aria-label", "Forge the Saga stages");
      nodes.forEach((node, i) => {
        const panel = panels[i]!;
        node.setAttribute("role", "tab");
        node.setAttribute("aria-controls", panel.id);
        panel.setAttribute("role", "tabpanel");
        panel.setAttribute("aria-labelledby", (node.id ||= `temper-tab-${i}`));
        panel.setAttribute("tabindex", "0");
      });
      select(selected);
    }
    function disable() {
      root.removeAttribute("data-interactive");
      track!.hidden = true;
      // strip the tablist semantics — otherwise screen readers see tabs and
      // tabpanels layered over the now-static, all-visible stacked panels.
      track!.removeAttribute("role");
      track!.removeAttribute("aria-label");
      nodes.forEach((node) => {
        node.removeAttribute("role");
        node.removeAttribute("aria-controls");
        node.removeAttribute("aria-selected");
        node.removeAttribute("tabindex");
      });
      // fallback: every panel visible, no tab semantics, no heat state, resting prices
      panels.forEach((panel) => {
        panel.removeAttribute("role");
        panel.removeAttribute("aria-labelledby");
        panel.removeAttribute("tabindex");
        panel.hidden = false;
        const name = panel.querySelector(".heat");
        name?.classList.remove("is-hot", "is-set");
        name?.classList.add("is-cold");
        const el = panel.querySelector<HTMLElement>("[data-price]");
        if (el) el.textContent = fmt(Number(el.getAttribute("data-value")) || 0);
      });
    }
    const sync = () => (wide.matches ? enable() : disable());
    wide.addEventListener("change", sync);
    window.addEventListener("resize", sync); // belt-and-suspenders (MQL change alone can miss)
    sync();
  }
</script>
