---
/**
 * /forge-the-saga — P11 "THE TEMPERING" (V1-UPGRADE-PLAN): the operator
 * asked for an ORIGINAL page ("go nuts") after the Disal-grammar P9 read
 * too basic. This one is built from the brand's own metaphor instead of a
 * reference: the page IS the method.
 *
 *   A story is forged down the page. THE TEMPER LINE — a glowing stroke —
 *   runs through the five stations. It starts white-hot and wandering
 *   (raw research), gets hammered straighter and COOLER at every stage
 *   (the v1 heat→aqua thermal progression, resurrected with meaning), and
 *   at the end bends into the AURORA-S OF THE LOGO: the raw material
 *   becomes the saga, and the saga is literally the mark.
 *
 *   - smithy ground: near-black ember dark; a lightweight 2D-canvas ember
 *     field drifts upward in the hero (living at rest; desktop, idle-
 *     mounted, paused off-screen, absent under reduced motion/save-data)
 *   - the spine: an SVG temper line drawn by scroll (scrubbed dash), its
 *     gradient running forge-heat → brand aqua top to bottom, wandering
 *     early and straightening late (forged as you read)
 *   - five stations along the spine: ember-glass stage cards, node FLARES
 *     + a small spark burst as each station arrives (the hammer strike)
 *   - finale: the cooled line draws into the brand S-curve (the same S
 *     the home page draws at #talk) and hands off to the one CTA
 *
 * HONESTY: all copy verbatim from consts (hero/whoFor/stages/SAGA_STAGES/
 * proof/pricing/cta; OD-4 exact prices). Echo Panel STAYS SHELVED (OD-2,
 * F4 rendered:false) — the operator mentioned it in passing but has not
 * reversed the shelf decision; stage 04's own copy carries the idea.
 *
 * Fallbacks: no-JS / reduced motion → the temper line renders FULLY
 * FORGED (solid, final state), stations all visible via the reveal
 * engine's watchdog, no canvas, no flares. The page reads perfectly cold.
 *
 * P12.5: below 760px the desktop .fg-spine SVG is display:none (the
 * two-column grid collapses to one), which used to leave mobile with no
 * temper line at all — the page's whole signature gone on the phone the
 * operator actually reviews on. Mobile now gets its own rail: a static
 * heat→aqua gradient painted as a background-image on .fg-stations (spans
 * the list's real rendered height automatically, no JS measuring needed)
 * plus a small node tick beside each card in that station's own --heat.
 * Pure CSS, always fully drawn — nothing to fail open on.
 */
import Base from "../layouts/Base.astro";
import LegendMark from "../components/LegendMark.astro";
import Testimonial from "../components/Testimonial.astro";
import { PAGES, SAGA_STAGES } from "../consts";

const p = PAGES.forge;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const n = SAGA_STAGES.length;

// Each station's temper color — the v1 thermal progression, hot working end
// to set aqua end. Used for node cores, card accents, and price marks.
const temper = (i: number) => `color-mix(in srgb, var(--color-forge-heat, #ff9d45) ${Math.round((1 - i / (n - 1)) * 100)}%, var(--color-accent, #38f8ec))`;

/**
 * The spine path: wanders hard between early stations (raw story), then
 * straightens as it cools (forged story). Stations sit at even vertical
 * intervals in a 200×2000 viewBox; the x-wobble decays per segment.
 * Coordinates are hand-tuned so node dots (at the station rows' anchor
 * points) land ON the line.
 */
const SPINE = "M100,0 C 40,90 168,150 96,240 C 30,320 176,370 104,460 C 52,530 152,590 100,660 C 68,720 136,790 100,860 C 84,920 116,990 100,1060 C 92,1120 108,1190 100,1260 C 96,1330 104,1400 100,1470 C 98,1540 102,1620 100,1700 C 100,1780 100,1900 100,2000";
// node anchor Ys in the same viewBox space (5 stations, even-ish spacing)
const NODE_Y = [240, 660, 1060, 1470, 1860];
---

<Base title={p.meta.title} description={p.meta.description}>
  <main class="fg" data-fg>
    <!-- ═══ T1 · THE SMITHY — ember dark, one belief ═══ -->
    <section class="fg-hero" data-fg-hero>
      <canvas class="fg-embers" data-fg-embers aria-hidden="true"></canvas>
      <div class="fg-hero-glow" aria-hidden="true"></div>
      <div class="fg-hero-inner">
        <p class="hud-label fg-kicker" data-reveal data-tableau-content>
          <span data-decode>{p.stages.heading}</span>
        </p>
        <h1 class="fg-headline" data-reveal>{p.hero.headline}</h1>
        <p class="fg-sub" data-reveal>{p.hero.subline}</p>
        <a href={`${base}${p.hero.cta.href}`} class="fg-pill" data-reveal>{p.hero.cta.label}</a>
      </div>
    </section>

    <!-- ═══ T2 · WHO IT'S FOR — three ember chips before the anvil ═══ -->
    <section class="fg-sec fg-who">
      <h2 class="fg-h2" data-reveal>{p.whoFor.heading}</h2>
      <p class="fg-body" data-reveal>{p.whoFor.body}</p>
      <ul class="fg-chips">
        {
          p.whoFor.items.map((item, i) => (
            <li class="fg-chip" data-reveal data-reveal-stagger="90" style={`--chip-heat:${temper(Math.min(i, n - 1))}`}>
              <span class="fg-chip-no" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
              {item}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- ═══ T3 · THE TEMPERING — the spine + five stations ═══ -->
    <section class="fg-sec fg-anvil" data-fg-anvil>
      <p class="fg-body fg-anvil-intro" data-reveal>{p.stages.body}</p>

      <div class="fg-forge">
        <!-- the temper line: drawn by scroll, hot→aqua, wander→straight -->
        <svg class="fg-spine" viewBox="0 0 200 2000" preserveAspectRatio="xMidYMax meet" aria-hidden="true" fill="none">
          <defs>
            <linearGradient id="fg-temper" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="var(--color-forge-heat, #ff9d45)" />
              <stop offset="0.55" stop-color="#c9b26a" />
              <stop offset="1" stop-color="var(--color-accent, #38f8ec)" />
            </linearGradient>
          </defs>
          <!-- the unforged ghost: where the story is going -->
          <path d={SPINE} stroke="#ffffff" stroke-opacity="0.07" stroke-width="1.5" stroke-dasharray="3 7" />
          <!-- the forged line: scrub-drawn over the ghost -->
          <path data-fg-spine d={SPINE} stroke="url(#fg-temper)" stroke-width="2.5" stroke-linecap="round" />
          {NODE_Y.map((y, i) => <circle class="fg-node" data-fg-node cx="100" cy={y} r="7" fill="#0f0d0b" stroke={temper(i)} stroke-width="2.5" />)}
        </svg>

        <ol class="fg-stations">
          {
            SAGA_STAGES.map((stage, i) => (
              <li class="fg-station" data-fg-station style={`--heat:${temper(i)}`}>
                <article class="fg-card" data-reveal>
                  <header class="fg-card-head">
                    <span class="fg-no" aria-hidden="true">{stage.no}</span>
                    <h3 class="fg-name">{stage.name}</h3>
                    <p class="hud-label fg-sublabel" data-tableau-content>
                      <span data-decode>{stage.sub}</span>
                    </p>
                  </header>
                  <p class="fg-process">{stage.process}</p>
                  <dl class="fg-meta">
                    <div>
                      <dt class="hud-label">Deliverable</dt>
                      <dd>{stage.deliverable}</dd>
                    </div>
                    <div>
                      <dt class="hud-label">Best for</dt>
                      <dd>{stage.bestFor}</dd>
                    </div>
                  </dl>
                  <p class="fg-price">{stage.price}</p>
                  {stage.no === "04" && <p class="fg-anchor">{p.stages.anchor}</p>}
                </article>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="fg-pricing" data-reveal>
        <h3 class="fg-h3">{p.pricing.heading}</h3>
        <p class="fg-body">{p.pricing.body}</p>
        <p class="fg-note">{p.pricing.note}</p>
      </div>
    </section>

    <!-- ═══ T4 · PROOF — one ember-glass artifact ═══ -->
    <section class="fg-sec fg-proof">
      <h2 class="fg-h2 fg-h2--serif" data-reveal>{p.proof.heading}</h2>
      <div class="fg-proof-card" data-reveal>
        <LegendMark proof={p.proof.anchor} />
        <Testimonial testimonialId={p.proof.testimonialId} showProof={false} />
        <a href={`${base}/work/pitchboulder`} class="fg-pill fg-pill--quiet">
          See the work <span aria-hidden="true">→</span>
        </a>
      </div>
      <p class="fg-note" data-reveal>{p.proof.note}</p>
    </section>

    <!-- ═══ T5 · THE SAGA — the cooled line becomes the mark ═══ -->
    <section class="fg-sec fg-saga" data-fg-saga>
      <svg class="fg-s" viewBox="0 0 400 800" fill="none" aria-hidden="true">
        <path
          data-fg-s
          d="M330 46 C 110 130, 110 330, 255 400 C 400 470, 400 670, 170 754"
          stroke="var(--color-accent, #38f8ec)"
          stroke-opacity="0.5"
          stroke-width="3"
          stroke-linecap="round"></path>
      </svg>
      <div class="fg-saga-inner">
        <h2 class="fg-headline fg-headline--close" data-reveal>{p.cta.headline}</h2>
        <p class="fg-sub" data-reveal>{p.cta.body}</p>
        <a href={`${base}${p.cta.cta.href}`} class="fg-pill" data-reveal>{p.cta.cta.label}</a>
      </div>
    </section>
  </main>
</Base>

<style>
  .fg {
    /* the smithy: near-black with an ember undertone — darker and warmer
       than the site base, so the lane has its own air without leaving the
       night. Heat is scarce and always MEANS temperature. */
    --fg-ground: #100d0b;
    --fg-glass: color-mix(in srgb, #ffffff 4%, transparent);
    background: var(--fg-ground);
  }
  .fg-sec {
    position: relative;
    overflow: clip;
  }

  /* ── T1 the smithy ── */
  .fg-hero {
    position: relative;
    min-height: 92svh;
    display: grid;
    align-content: center;
    overflow: clip;
  }
  .fg-embers {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  /* the forge glow: breathes at rest (living portrait rule) — a low warm
     light from below the frame, as if the forge is just out of shot */
  .fg-hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      90% 55% at 50% 108%,
      color-mix(in srgb, var(--color-forge-heat, #ff9d45) 22%, transparent),
      transparent 70%
    );
    animation: fg-breathe 7s ease-in-out infinite alternate;
  }
  @keyframes fg-breathe {
    from {
      opacity: 0.55;
    }
    to {
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .fg-hero-glow {
      animation: none;
    }
  }
  .fg-hero-inner {
    position: relative;
    display: grid;
    gap: 1.4rem;
    justify-items: start;
    max-width: 64rem;
    margin-inline: auto;
    padding: 7rem clamp(1.5rem, 6vw, 4rem) 5rem;
  }
  .fg-kicker {
    letter-spacing: 0.3em;
    color: color-mix(in srgb, var(--color-forge-heat, #ff9d45) 75%, #fff);
  }
  .fg-headline {
    font-family: var(--font-display);
    font-weight: 560;
    font-size: clamp(2.4rem, 5vw, 4.6rem);
    line-height: 1.06;
    color: #f6f2ec;
    max-width: 15ch;
    /* lit by the forge: a warm underglow on the type itself */
    text-shadow: 0 6px 40px color-mix(in srgb, var(--color-forge-heat, #ff9d45) 30%, transparent);
  }
  .fg-sub {
    font-family: var(--font-sans);
    font-size: clamp(1.02rem, 1.35vw, 1.2rem);
    line-height: 1.55;
    color: color-mix(in srgb, #f6f2ec 85%, transparent);
    max-width: 46ch;
  }
  .fg-pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #140f0a;
    background: linear-gradient(100deg, var(--color-forge-heat, #ff9d45), var(--color-accent, #38f8ec) 160%);
    border-radius: 999px;
    padding: 0.9rem 1.8rem;
    transition: transform 240ms var(--ease-swift, ease-out);
  }
  .fg-pill:hover {
    transform: translateY(-2px);
  }
  .fg-pill--quiet {
    background: transparent;
    color: var(--color-accent, #38f8ec);
    border: 1px solid color-mix(in srgb, var(--color-accent, #38f8ec) 55%, transparent);
  }

  /* ── shared type ── */
  .fg-h2 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.6rem, 2.4vw, 2.2rem);
    color: #f0ece6;
  }
  .fg-h2--serif {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 520;
  }
  .fg-h3 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.25rem;
    color: #f0ece6;
  }
  .fg-body {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.6;
    color: color-mix(in srgb, #f0ece6 82%, transparent);
    max-width: 56ch;
  }
  .fg-note {
    font-size: 0.92rem;
    color: color-mix(in srgb, #f0ece6 60%, transparent);
    max-width: 60ch;
  }

  /* ── T2 who it's for ── */
  .fg-who {
    max-width: 64rem;
    margin-inline: auto;
    padding: 4rem clamp(1.5rem, 6vw, 4rem);
    display: grid;
    gap: 1.1rem;
  }
  .fg-chips {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: grid;
    gap: 0.8rem;
  }
  .fg-chip {
    position: relative;
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.5;
    color: #f0ece6;
    background: var(--fg-glass);
    border: 1px solid color-mix(in srgb, #ffffff 9%, transparent);
    border-left: 2px solid var(--chip-heat);
    border-radius: 8px;
    padding: 1.1rem 1.3rem 1.1rem 3.4rem;
  }
  .fg-chip-no {
    position: absolute;
    left: 1.2rem;
    top: 1.15rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--chip-heat);
  }

  /* ── T3 the tempering ── */
  .fg-anvil {
    padding: 4rem clamp(1.5rem, 6vw, 4rem) 5rem;
    max-width: 74rem;
    margin-inline: auto;
  }
  .fg-anvil-intro {
    margin-bottom: 3rem;
  }
  .fg-forge {
    display: grid;
    grid-template-columns: clamp(90px, 14vw, 200px) minmax(0, 1fr);
    gap: clamp(0.5rem, 3vw, 2.5rem);
  }
  .fg-spine {
    width: 100%;
    height: 100%;
    min-height: 100%;
  }
  /* no-JS / reduced motion: the line is FULLY FORGED (final state). The
     engine sets the dash bookkeeping only when it's actually going to draw. */
  [data-fg-spine] {
    stroke-dasharray: none;
  }
  .fg-node {
    filter: drop-shadow(0 0 4px color-mix(in srgb, currentcolor 60%, transparent));
  }
  .fg-stations {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: clamp(3rem, 8vh, 6rem);
  }
  .fg-card {
    background: var(--fg-glass);
    border: 1px solid color-mix(in srgb, #ffffff 9%, transparent);
    border-radius: 10px;
    padding: 1.7rem 1.6rem 1.5rem;
    display: grid;
    gap: 0.95rem;
    max-width: 40rem;
    /* each card sits in its own heat: a faint left glow in station color */
    box-shadow: inset 3px 0 0 var(--heat);
  }
  .fg-no {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 1.8rem;
    color: var(--heat);
    -webkit-text-stroke: 1px var(--heat);
    -webkit-text-fill-color: transparent;
  }
  .fg-name {
    font-family: var(--font-sans);
    font-weight: 650;
    font-size: 1.35rem;
    color: #f4f0ea;
    margin-top: 0.15rem;
  }
  .fg-sublabel {
    letter-spacing: 0.18em;
    color: color-mix(in srgb, #f0ece6 60%, transparent);
  }
  .fg-process {
    font-size: 0.97rem;
    line-height: 1.55;
    color: color-mix(in srgb, #f0ece6 85%, transparent);
  }
  .fg-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.9rem;
    margin: 0;
    border-top: 1px solid color-mix(in srgb, #ffffff 9%, transparent);
    padding-top: 0.95rem;
  }
  .fg-meta dt {
    color: color-mix(in srgb, #f0ece6 52%, transparent);
    letter-spacing: 0.16em;
  }
  .fg-meta dd {
    margin: 0.2rem 0 0;
    font-size: 0.95rem;
    line-height: 1.45;
    color: color-mix(in srgb, #f0ece6 88%, transparent);
  }
  .fg-price {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    color: var(--heat);
  }
  .fg-anchor {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1rem;
    color: color-mix(in srgb, #f0ece6 75%, transparent);
    border-left: 2px solid var(--heat);
    padding-left: 0.85rem;
  }
  .fg-pricing {
    margin-top: 3.5rem;
    display: grid;
    gap: 0.6rem;
  }

  /* ── T4 proof ── */
  .fg-proof {
    padding: 3rem clamp(1.5rem, 6vw, 4rem) 5rem;
    max-width: 60rem;
    margin-inline: auto;
    display: grid;
    gap: 1.3rem;
  }
  .fg-proof-card {
    display: grid;
    gap: 1.1rem;
    background: var(--fg-glass);
    border: 1px solid color-mix(in srgb, #ffffff 10%, transparent);
    border-radius: 10px;
    padding: 1.8rem;
  }

  /* ── T5 the saga (the S finale) ── */
  .fg-saga {
    min-height: 88svh;
    display: grid;
    align-content: center;
    padding: 6rem clamp(1.5rem, 6vw, 4rem);
  }
  .fg-s {
    position: absolute;
    right: 3%;
    top: 50%;
    height: 82%;
    transform: translateY(-50%);
    pointer-events: none;
    filter: drop-shadow(0 0 14px color-mix(in srgb, var(--color-accent, #38f8ec) 35%, transparent));
  }
  [data-fg-s] {
    stroke-dasharray: none; /* fully drawn without the engine */
  }
  .fg-saga-inner {
    position: relative;
    display: grid;
    gap: 1.3rem;
    justify-items: start;
    max-width: 64rem;
    margin-inline: auto;
    width: 100%;
  }
  .fg-headline--close {
    max-width: 18ch;
  }

  /* ── small screens: spine hides, stations stack clean ── */
  @media (max-width: 760px) {
    .fg-forge {
      grid-template-columns: 1fr;
    }
    .fg-spine {
      display: none;
    }
    .fg-s {
      opacity: 0.35;
      right: -12%;
    }

    /* P12.5 — mobile's own temper spine. A background-gradient rail on
       the list (heat → mid → aqua, the same stops as #fg-temper) hugs
       the stations column's left edge; it covers the ul's full box
       automatically, so it stays correct no matter how tall any one
       card's copy makes it. Each station gets a node tick — a small
       dot in its own --heat — laid out in normal flow beside the card
       so the tick and the rail line up without any absolute-position
       math. Static, no scrub: fully drawn with no JS and no motion. */
    .fg-stations {
      background: linear-gradient(180deg, var(--color-forge-heat, #ff9d45), #c9b26a 55%, var(--color-accent, #38f8ec)) no-repeat 4px 0 /
        2px 100%;
    }
    .fg-station {
      display: flex;
      align-items: flex-start;
      gap: 0.85rem;
    }
    .fg-station::before {
      content: "";
      flex: none;
      width: 10px;
      height: 10px;
      margin-top: 1.7rem;
      border-radius: 50%;
      background: var(--heat);
      box-shadow:
        0 0 0 3px var(--fg-ground),
        0 0 6px color-mix(in srgb, var(--heat) 65%, transparent);
    }
    .fg-card {
      flex: 1 1 auto;
      min-width: 0;
    }
  }
</style>

<script>
  // P11 enhancement — the tempering. Everything below rides over a page
  // that is already fully forged without JS.
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ensureSmoothScroll } from "../lib/smooth-scroll";

  async function init() {
    const idle = (fn: () => void) =>
      "requestIdleCallback" in window ? requestIdleCallback(fn, { timeout: 3000 }) : setTimeout(fn, 1500);
    idle(() => {
      void import("../lib/decode-text").then(({ mountDecode }) => mountDecode(document));
    });

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) return;
    gsap.registerPlugin(ScrollTrigger);
    const lenis = await ensureSmoothScroll();
    if (lenis) lenis.on("scroll", () => ScrollTrigger.update());

    // ── the temper line: scrub-drawn down the anvil's transit ──
    const spine = document.querySelector<SVGPathElement>("[data-fg-spine]");
    const anvil = document.querySelector<HTMLElement>("[data-fg-anvil]");
    if (spine && anvil) {
      const L = spine.getTotalLength();
      spine.style.strokeDasharray = String(L);
      gsap.fromTo(
        spine,
        { strokeDashoffset: L },
        {
          strokeDashoffset: 0,
          ease: "none",
          scrollTrigger: { trigger: anvil, start: "top 60%", end: "bottom 75%", scrub: 0.6 },
        },
      );
    }

    // ── station arrivals: the hammer strike — node flare + card settle ──
    document.querySelectorAll<HTMLElement>("[data-fg-station]").forEach((station, i) => {
      const node = document.querySelectorAll<SVGCircleElement>("[data-fg-node]")[i];
      ScrollTrigger.create({
        trigger: station,
        start: "top 70%",
        once: true,
        onEnter: () => {
          if (node) {
            gsap.fromTo(
              node,
              { attr: { r: 7 }, opacity: 0.6 },
              { attr: { r: 11 }, opacity: 1, duration: 0.18, ease: "power3.out", yoyo: true, repeat: 1 },
            );
          }
          // one soft strike on the card — a 6px drop that settles, never clips
          const card = station.querySelector(".fg-card");
          if (card) {
            gsap.fromTo(card, { y: -6 }, { y: 0, duration: 0.5, ease: "power3.out" });
          }
        },
      });
    });

    // ── the finale S: draws as the saga section arrives (the home page's
    // #talk gesture, completing the arc: forged line → the mark) ──
    const sPath = document.querySelector<SVGPathElement>("[data-fg-s]");
    const saga = document.querySelector<HTMLElement>("[data-fg-saga]");
    if (sPath && saga) {
      const L = sPath.getTotalLength();
      sPath.style.strokeDasharray = String(L);
      gsap.fromTo(
        sPath,
        { strokeDashoffset: L },
        {
          strokeDashoffset: 0,
          ease: "none",
          scrollTrigger: { trigger: saga, start: "top 85%", end: "center 45%", scrub: 0.5 },
        },
      );
    }

    // ── the embers: a featherweight 2D canvas field in the hero. Rises,
    // flickers, pauses off-screen and in hidden tabs. Wide viewports only;
    // never under Save-Data. (~70 particles, transform-free, one pass.) ──
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (conn?.saveData || !window.matchMedia("(min-width: 768px)").matches) return;
    const canvas = document.querySelector<HTMLCanvasElement>("[data-fg-embers]");
    const hero = document.querySelector<HTMLElement>("[data-fg-hero]");
    if (!canvas || !hero) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const DPR = Math.min(window.devicePixelRatio || 1, 2);
    let W = 0;
    let H = 0;
    const fit = () => {
      W = hero.clientWidth;
      H = hero.clientHeight;
      canvas.width = W * DPR;
      canvas.height = H * DPR;
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
    };
    fit();
    new ResizeObserver(fit).observe(hero);

    type Ember = { x: number; y: number; r: number; v: number; sway: number; ph: number; a: number; hot: boolean };
    const embers: Ember[] = Array.from({ length: 70 }, () => ({
      x: Math.random() * 1, // normalized; scaled by W each frame
      y: Math.random() * 1,
      r: 0.6 + Math.random() * 1.7,
      v: 8 + Math.random() * 22, // px/s upward
      sway: 6 + Math.random() * 18,
      ph: Math.random() * Math.PI * 2,
      a: 0.1 + Math.random() * 0.4,
      hot: Math.random() < 0.75, // most embers warm, a few already cooled aqua
    }));

    let running = false;
    let raf = 0;
    let last = 0;
    let t = 0;
    const tick = (now: number) => {
      if (!running) return;
      raf = requestAnimationFrame(tick);
      const dt = Math.min(0.05, (now - last) / 1000);
      last = now;
      t += dt;
      ctx.clearRect(0, 0, W, H);
      for (const e of embers) {
        e.y -= (e.v * dt) / H;
        if (e.y < -0.02) {
          e.y = 1.02;
          e.x = Math.random();
        }
        const x = e.x * W + Math.sin(t * 0.7 + e.ph) * e.sway;
        const y = e.y * H;
        const flicker = 0.65 + 0.35 * Math.sin(t * 2.3 + e.ph * 3);
        ctx.globalAlpha = e.a * flicker;
        ctx.fillStyle = e.hot ? "#ffb066" : "#59e6da";
        ctx.beginPath();
        ctx.arc(x, y, e.r, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
    };
    const setRunning = (v: boolean) => {
      if (v === running) return;
      running = v;
      if (v) {
        last = performance.now();
        raf = requestAnimationFrame(tick);
      } else {
        cancelAnimationFrame(raf);
      }
    };
    // run only while the hero is on screen and the tab is visible
    new IntersectionObserver(([entry]) => setRunning(entry.isIntersecting && !document.hidden), {
      threshold: 0.05,
    }).observe(hero);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) setRunning(false);
      else if (hero.getBoundingClientRect().bottom > 0) setRunning(true);
    });
  }
  void init();
</script>
