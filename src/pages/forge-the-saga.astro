---
import Base from "../layouts/Base.astro";
import Testimonial from "../components/Testimonial.astro";
import { PAGES, SAGA_STAGES, WORK } from "../consts";

const p = PAGES.forge;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const deliveredWork = WORK.filter((item) => p.proof.deliveredWorkSlugs.includes(item.slug));
---

<Base title={p.meta.title} description={p.meta.description}>
  <!-- F1 — belief hero -->
  <section class="mx-auto max-w-3xl space-y-4 p-8 text-center">
    <h1 class="text-3xl font-bold sm:text-5xl">{p.hero.headline}</h1>
    <p class="text-lg">{p.hero.subline}</p>
    <a href={`${base}${p.hero.cta.href}`} class="inline-block rounded border border-current px-4 py-2">
      {p.hero.cta.label}
    </a>
  </section>

  <!-- F2 — who it's for -->
  <section class="mx-auto max-w-3xl space-y-4 border-t border-current/20 p-8">
    <h2 class="text-2xl font-bold">{p.whoFor.heading}</h2>
    <p>{p.whoFor.body}</p>
    <ul class="list-inside list-disc space-y-1">
      {p.whoFor.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <!-- F3 — the five stages (temper-line walkthrough is a Phase 2/3 build, §2/§3.3;
       tabular fallback shown here as the accessible baseline) -->
  <section class="mx-auto max-w-3xl space-y-6 border-t border-current/20 p-8">
    <h2 class="text-2xl font-bold">{p.stages.heading}</h2>
    <p>{p.stages.body}</p>
    <ol class="space-y-6">
      {
        SAGA_STAGES.map((stage) => (
          <li class="space-y-1 border-l-2 border-current/30 pl-4">
            <p class="text-sm uppercase tracking-widest opacity-70">
              {stage.no} · {stage.sub}
            </p>
            <h3 class="text-xl font-bold">{stage.name}</h3>
            <p>{stage.process}</p>
            <p class="text-sm opacity-80">
              Deliverable: {stage.deliverable} · {stage.price}
            </p>
            <p class="text-sm italic opacity-70">Best for: {stage.bestFor}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <!--
    F4 — pretest section. LAUNCHES AS VARIANT B (OD-2): Echo Panel is off the
    site. Nothing renders here by design — the pretest idea already lives
    honestly in Stage 04 above ("curated human panels, AI audience
    simulations, or both"). Variant A copy sits unrendered in
    PAGES.forge.pretestShelved and lifts back in without rework if the
    service proves out.
  -->

  <!-- F5 — proof -->
  <section class="mx-auto max-w-3xl space-y-6 border-t border-current/20 p-8">
    <h2 class="text-2xl font-bold">{p.proof.heading}</h2>
    <Testimonial testimonialId={p.proof.testimonialId} />
    <ul class="space-y-4">
      {
        deliveredWork.map((item) => (
          <li class="space-y-2">
            <p class="font-bold">
              For {item.forOrg} · {item.what}
            </p>
            <p class="text-sm opacity-70">{item.engagement}</p>
            {item.href && (
              <a href={`${base}${item.href}`} class="hover:underline">
                See the work →
              </a>
            )}
          </li>
        ))
      }
    </ul>
    <p class="text-sm opacity-70">{p.proof.note}</p>
  </section>

  <!-- F6 — pricing (OD-4: exact "from $X" — see the per-stage prices above) -->
  <section class="mx-auto max-w-3xl space-y-4 border-t border-current/20 p-8">
    <h2 class="text-2xl font-bold">{p.pricing.heading}</h2>
    <p>{p.pricing.body}</p>
    <p class="text-sm opacity-70">{p.pricing.note}</p>
  </section>

  <!-- F7 — CTA -->
  <section class="mx-auto max-w-3xl space-y-4 border-t border-current/20 p-8 text-center">
    <h2 class="text-2xl font-bold">{p.cta.headline}</h2>
    <p>{p.cta.body}</p>
    <a href={`${base}${p.cta.cta.href}`} class="inline-block rounded border border-current px-4 py-2">
      {p.cta.cta.label}
    </a>
  </section>
</Base>
