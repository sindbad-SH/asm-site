---
/**
 * /forge-the-saga — P12.x "THE SERVICES" repackage (operator-directed).
 *
 * The page stopped selling a numbered "secret sauce" process and now sells the
 * SERVICES you can hire a StorySmith for, in the operator's own two classes:
 *
 *   ENGAGEMENTS  — long-span / retainer ("if you want me in it with you")
 *   DELIVERABLES — "one specific thing I do all the time", priced at a floor
 *
 * Cards come from FORGE_SERVICES (researched market floors, "Starts at $X").
 * The five-stage method is DEMOTED, not deleted: it survives as a quiet
 * names-only strip inside the flagship engagement (SAGA_STAGES stays the
 * source of those names; home H5 still maps them; per-stage prices die).
 *
 * SIGNATURE (evolved, not multiplied): the temper line lives on as ONE
 * continuous vertical rail down the services column — a heat→aqua gradient
 * hairline threading both classes, with a node tick beside every card in that
 * card's own temper color. It's painted in pure CSS (spans the column's real
 * height automatically), so it's always fully drawn with nothing to fail open
 * on — no fragile per-station coordinate math. The hero keeps its living
 * ember field + forge glow, and the closing section keeps the S-finale (the
 * cooled line drawing into the brand mark). Motion is reveal staggers only.
 *
 * HONESTY: services copy is NEW (⚠ operator read-approval, flagged in consts).
 * whoFor / proof / pricing.note / cta are KEPT. The Aerial card renders the
 * VERBATIM Ledger phrasing "Aerial work licensed through Amazing Aerial
 * Agency" from FORGE_SERVICES[].note. Echo Panel STAYS SHELVED.
 *
 * Fallbacks: no-JS / reduced motion → the whole page reads cold. The rail is
 * CSS-only (always drawn); reveals fail open via the engine's watchdog; the
 * hero canvas + the S draw are enhancement-only.
 */
import Base from "../layouts/Base.astro";
import LegendMark from "../components/LegendMark.astro";
import Testimonial from "../components/Testimonial.astro";
import { PAGES, SAGA_STAGES, FORGE_SERVICES } from "../consts";

const p = PAGES.forge;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const engagements = FORGE_SERVICES.filter((s) => s.klass === "engagement");
const deliverables = FORGE_SERVICES.filter((s) => s.klass === "deliverable");
const total = FORGE_SERVICES.length;

// Each card's temper color — the v1 thermal progression across ALL services,
// hot working end (first engagement) → set aqua end (last deliverable). Keyed
// by the card's global position so the rail and the ticks agree.
const temper = (i: number) =>
  `color-mix(in srgb, var(--color-forge-heat, #ff9d45) ${Math.round((1 - i / (total - 1)) * 100)}%, var(--color-accent, #38f8ec))`;
const heatOf = (svc: (typeof FORGE_SERVICES)[number]) => temper(FORGE_SERVICES.indexOf(svc));

// PRICE TYPOGRAPHY split (operator: "make the pricing bigger + a nicer font").
// This is a purely TYPOGRAPHIC split — NOT a copy edit. The three captured
// parts concatenate back to the exact source string (pre + amt + unit ===
// svc.price, byte-for-byte), so the operator's read-approved price strings are
// untouched; we only let Fraunces carry the dollar numerals while "Starts at"
// and "/ mo" · "/ day" stay as small Space Mono labels around them.
const priceParts = (price: string) => {
  const m = price.match(/^(Starts at\s+)?(\$[\d,]+)(\s*\/\s*\S+)?$/);
  return m ? { pre: m[1] ?? "", amt: m[2], unit: m[3] ?? "" } : { pre: "", amt: price, unit: "" };
};
---

<Base title={p.meta.title} description={p.meta.description}>
  <main class="fg" data-fg>
    <!-- ═══ T1 · THE SMITHY — ember dark, the definition move ═══ -->
    <section class="fg-hero" data-fg-hero>
      <canvas class="fg-embers" data-fg-embers aria-hidden="true"></canvas>
      <div class="fg-hero-glow" aria-hidden="true"></div>
      <div class="fg-hero-inner">
        <p class="hud-label fg-kicker" data-reveal data-tableau-content>
          <span data-decode>{p.hero.kicker}</span>
        </p>
        <h1 class="fg-headline" data-reveal>{p.hero.headline}</h1>
        <p class="fg-sub" data-reveal>{p.hero.subline}</p>
        <a href={`${base}${p.hero.cta.href}`} class="btn fg-cta" data-reveal>
          <span>{p.hero.cta.label}</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    <!-- ═══ T2 · WHO IT'S FOR — three ember chips before the anvil ═══ -->
    <section class="fg-sec fg-who">
      <h2 class="fg-h2" data-reveal>{p.whoFor.heading}</h2>
      <p class="fg-body" data-reveal>{p.whoFor.body}</p>
      <ul class="fg-chips">
        {
          p.whoFor.items.map((item, i) => (
            <li class="fg-chip" data-reveal data-reveal-stagger="90" style={`--chip-heat:${temper(Math.min(i, total - 1))}`}>
              <span class="fg-chip-no" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
              {item}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- ═══ T3 · THE SERVICES — two classes, one temper rail ═══ -->
    <section class="fg-sec fg-services" data-fg-services>
      <h2 class="fg-h2 fg-services-head" data-reveal>{p.classes.heading}</h2>

      <div class="fg-services-inner">
        <span class="fg-rail" aria-hidden="true"></span>

        <!-- ENGAGEMENTS — long-span, "in it with you" -->
        <div class="fg-class fg-class--engage">
          <header class="fg-class-head" data-reveal>
            <span class="hud-label fg-class-label">{p.classes.engagements.label}</span>
            <p class="fg-class-tag">{p.classes.engagements.tagline}</p>
            <span class="fg-class-rule" aria-hidden="true"></span>
          </header>
          <ol class="fg-cards">
            {
              engagements.map((svc) => {
                const pp = priceParts(svc.price);
                return (
                <li class="fg-svc" style={`--heat:${heatOf(svc)}`}>
                  <article class="fg-card" data-reveal data-reveal-stagger="80">
                    <header class="fg-card-head">
                      <h3 class="fg-name">{svc.name}</h3>
                      {/* one line, tags adjacent — no whitespace text nodes, so
                          the rendered text stays byte-identical to svc.price */}
                      <p class="fg-price">{pp.pre && <span class="fg-price-lead">{pp.pre}</span>}<span class="fg-price-amt">{pp.amt}</span>{pp.unit && <span class="fg-price-unit">{pp.unit}</span>}</p>
                    </header>
                    <p class="fg-blurb">{svc.blurb}</p>
                    {svc.flagship && (
                      <div class="fg-strip">
                        <p class="hud-label fg-strip-label">{p.flagshipStrip.label}</p>
                        <span class="fg-strip-line" aria-hidden="true"></span>
                        <ol class="fg-strip-stages">
                          {SAGA_STAGES.map((s) => (
                            <li class="fg-strip-stage">{s.name}</li>
                          ))}
                        </ol>
                        <p class="fg-strip-note">{p.flagshipStrip.note}</p>
                      </div>
                    )}
                  </article>
                </li>
                );
              })
            }
          </ol>
        </div>

        <!-- DELIVERABLES — one specific thing, a floor -->
        <div class="fg-class fg-class--deliver">
          <header class="fg-class-head" data-reveal>
            <span class="hud-label fg-class-label">{p.classes.deliverables.label}</span>
            <p class="fg-class-tag">{p.classes.deliverables.tagline}</p>
            <span class="fg-class-rule" aria-hidden="true"></span>
          </header>
          <ol class="fg-cards fg-cards--grid">
            {
              deliverables.map((svc) => {
                const pp = priceParts(svc.price);
                return (
                <li class="fg-svc" style={`--heat:${heatOf(svc)}`}>
                  <article class="fg-card" data-reveal data-reveal-stagger="80">
                    <header class="fg-card-head">
                      <h3 class="fg-name">{svc.name}</h3>
                      {/* one line, tags adjacent — no whitespace text nodes, so
                          the rendered text stays byte-identical to svc.price */}
                      <p class="fg-price">{pp.pre && <span class="fg-price-lead">{pp.pre}</span>}<span class="fg-price-amt">{pp.amt}</span>{pp.unit && <span class="fg-price-unit">{pp.unit}</span>}</p>
                    </header>
                    <p class="fg-blurb">{svc.blurb}</p>
                    {svc.note && <p class="fg-ledger">{svc.note}</p>}
                  </article>
                </li>
                );
              })
            }
          </ol>
        </div>
      </div>

      <div class="fg-pricing" data-reveal>
        <h3 class="fg-h3">{p.pricing.heading}</h3>
        <p class="fg-body">{p.pricing.body}</p>
        <p class="fg-note">{p.pricing.note}</p>
      </div>
    </section>

    <!-- ═══ T4 · PROOF — one ember-glass artifact ═══ -->
    <section class="fg-sec fg-proof">
      <h2 class="fg-h2 fg-h2--serif" data-reveal>{p.proof.heading}</h2>
      <div class="fg-proof-card" data-reveal>
        <LegendMark proof={p.proof.anchor} />
        <Testimonial testimonialId={p.proof.testimonialId} showProof={false} />
        <a href={`${base}/work/pitchboulder`} class="fg-pill--quiet">
          See the work <span aria-hidden="true">→</span>
        </a>
      </div>
      <p class="fg-note" data-reveal>{p.proof.note}</p>
    </section>

    <!-- ═══ T5 · THE SAGA — the cooled line becomes the mark ═══ -->
    <section class="fg-sec fg-saga" data-fg-saga>
      <svg class="fg-s" viewBox="0 0 400 800" fill="none" aria-hidden="true">
        <path
          data-fg-s
          d="M330 46 C 110 130, 110 330, 255 400 C 400 470, 400 670, 170 754"
          stroke="var(--color-accent, #38f8ec)"
          stroke-opacity="0.5"
          stroke-width="3"
          stroke-linecap="round"></path>
      </svg>
      <div class="fg-saga-inner">
        <h2 class="fg-headline fg-headline--close" data-reveal>{p.cta.headline}</h2>
        <p class="fg-sub" data-reveal>{p.cta.body}</p>
        <a href={`${base}${p.cta.cta.href}`} class="btn fg-cta" data-reveal>
          <span>{p.cta.cta.label}</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </main>
</Base>

<style>
  .fg {
    /* the smithy: near-black with an ember undertone — darker and warmer than
       the site base, so the lane has its own air without leaving the night.
       Heat is scarce and always MEANS temperature. */
    --fg-ground: #100d0b;
    --fg-glass: color-mix(in srgb, #ffffff 4%, transparent);
    --fg-hair: color-mix(in srgb, #ffffff 9%, transparent);
    background: var(--fg-ground);
  }
  .fg-sec {
    position: relative;
    overflow: clip;
  }

  /* ── T1 the smithy ── */
  .fg-hero {
    position: relative;
    min-height: 84svh;
    display: grid;
    align-content: center;
    overflow: clip;
  }
  .fg-embers {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  /* the forge glow: breathes at rest (living portrait rule) — a low warm light
     from below the frame, as if the forge is just out of shot */
  .fg-hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      90% 55% at 50% 108%,
      color-mix(in srgb, var(--color-forge-heat, #ff9d45) 22%, transparent),
      transparent 70%
    );
    animation: fg-breathe 7s ease-in-out infinite alternate;
  }
  @keyframes fg-breathe {
    from {
      opacity: 0.55;
    }
    to {
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .fg-hero-glow {
      animation: none;
    }
  }
  .fg-hero-inner {
    position: relative;
    display: grid;
    gap: 1.3rem;
    justify-items: start;
    max-width: 64rem;
    margin-inline: auto;
    padding: 6rem clamp(1.5rem, 6vw, 4rem) 4rem;
  }
  .fg-kicker {
    letter-spacing: 0.3em;
    color: color-mix(in srgb, var(--color-forge-heat, #ff9d45) 75%, #fff);
  }
  .fg-headline {
    font-family: var(--font-display);
    font-weight: 560;
    font-size: clamp(2.3rem, 4.8vw, 4.4rem);
    line-height: 1.07;
    color: #f6f2ec;
    max-width: 18ch;
    /* lit by the forge: a warm underglow on the type itself */
    text-shadow: 0 6px 40px color-mix(in srgb, var(--color-forge-heat, #ff9d45) 30%, transparent);
  }
  .fg-sub {
    font-family: var(--font-sans);
    font-size: clamp(1.02rem, 1.35vw, 1.2rem);
    line-height: 1.55;
    color: color-mix(in srgb, #f6f2ec 85%, transparent);
    max-width: 52ch;
  }

  /* ── the CTA: the site's button grammar (1px accent border, mono caps, ≥44px)
     with the shared 6px arrow slide. Warm-tinted at rest so it reads on the
     ember ground; goes full accent on hover. ── */
  .fg-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 44px;
    padding: 0.7rem 1.4rem;
    color: #f6f2ec;
  }
  .fg-cta .arrow {
    display: inline-block;
    transition: transform var(--dur-hover, 160ms) var(--ease-swift, ease-out);
  }
  .fg-cta:hover .arrow,
  .fg-cta:focus-visible .arrow {
    transform: translateX(6px);
  }
  @media (prefers-reduced-motion: reduce) {
    .fg-cta .arrow {
      transition: none;
    }
  }
  .fg-pill--quiet {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent, #38f8ec);
    transition: color var(--dur-hover, 160ms) var(--ease-swift, ease-out);
  }
  .fg-pill--quiet:hover {
    color: color-mix(in srgb, var(--color-accent, #38f8ec) 80%, #fff);
  }

  /* ── shared type ── */
  .fg-h2 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.6rem, 2.4vw, 2.2rem);
    color: #f0ece6;
  }
  .fg-h2--serif {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 520;
  }
  .fg-h3 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.25rem;
    color: #f0ece6;
  }
  .fg-body {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.6;
    color: color-mix(in srgb, #f0ece6 82%, transparent);
    max-width: 56ch;
  }
  .fg-note {
    font-size: 0.92rem;
    color: color-mix(in srgb, #f0ece6 60%, transparent);
    max-width: 60ch;
  }

  /* ── T2 who it's for ── */
  .fg-who {
    max-width: 64rem;
    margin-inline: auto;
    padding: 3.5rem clamp(1.5rem, 6vw, 4rem);
    display: grid;
    gap: 1rem;
  }
  .fg-chips {
    list-style: none;
    padding: 0;
    margin: 0.8rem 0 0;
    display: grid;
    gap: 0.7rem;
  }
  .fg-chip {
    position: relative;
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.3vw, 1.12rem);
    line-height: 1.5;
    color: #f0ece6;
    background: var(--fg-glass);
    border: 1px solid var(--fg-hair);
    border-left: 2px solid var(--chip-heat);
    border-radius: 8px;
    padding: 1rem 1.3rem 1rem 3.4rem;
  }
  .fg-chip-no {
    position: absolute;
    left: 1.2rem;
    top: 1.05rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--chip-heat);
  }

  /* ── T3 the services ── */
  .fg-services {
    max-width: 74rem;
    margin-inline: auto;
    padding: 3.5rem clamp(1.5rem, 6vw, 4rem) 4.5rem;
  }
  .fg-services-head {
    margin-bottom: 2.2rem;
  }
  /* the inner holds the temper rail + both classes; the rail hugs its left
     gutter and spans the whole services column automatically. */
  .fg-services-inner {
    position: relative;
    padding-left: clamp(1.4rem, 3vw, 2.4rem);
    display: grid;
    gap: 3rem;
  }
  .fg-rail {
    position: absolute;
    left: 3px;
    top: 0.35rem;
    bottom: 0.35rem;
    width: 2px;
    border-radius: 2px;
    background: linear-gradient(
      180deg,
      var(--color-forge-heat, #ff9d45),
      #c9b26a 52%,
      var(--color-accent, #38f8ec)
    );
    opacity: 0.9;
    /* the rail DRAWS with scroll: JS scrubs --rail-progress (0→1) as the
       services column passes through the viewport, and this clip reveals the
       gutter line from the top down. Default 1 = fully drawn — no-JS and
       reduced motion (the script bails before it ever sets the var) both get
       the complete rail, so it can never fail invisible. */
    clip-path: inset(0 0 calc((1 - var(--rail-progress, 1)) * 100%) 0);
    will-change: clip-path;
  }
  .fg-class {
    display: grid;
    gap: 1.1rem;
  }
  .fg-class-head {
    display: grid;
    gap: 0.35rem;
  }
  .fg-class-label {
    letter-spacing: 0.24em;
    color: color-mix(in srgb, #f0ece6 66%, transparent);
  }
  .fg-class-tag {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.05rem, 1.5vw, 1.3rem);
    line-height: 1.35;
    color: color-mix(in srgb, #f0ece6 88%, transparent);
    max-width: 44ch;
  }
  /* class-header temper hairline — a heat→aqua rule that DRAWS in (scaleX) as
     the header reveals, echoing the gutter rail. Fail-open convention: fully
     drawn by default; hidden only while JS is live AND the header hasn't
     revealed yet (the reveal engine's 4s watchdog guarantees .is-revealed
     lands, so it can't stay collapsed). */
  .fg-class-rule {
    display: block;
    height: 2px;
    margin-top: 0.5rem;
    width: min(52%, 15rem);
    border-radius: 2px;
    transform-origin: left;
    background: linear-gradient(
      to right,
      var(--color-forge-heat, #ff9d45),
      var(--color-accent, #38f8ec)
    );
  }
  html.js .fg-class-head[data-reveal]:not(.is-revealed) .fg-class-rule {
    transform: scaleX(0);
  }
  html.js .fg-class-head.is-revealed .fg-class-rule {
    transform: scaleX(1);
    transition: transform 900ms var(--ease-survey, ease-out);
  }
  .fg-cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.1rem;
  }
  /* deliverables read as a scannable grid of floors; engagements stay full
     width so the flagship + its strip have room to breathe. */
  @media (min-width: 720px) {
    .fg-cards--grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .fg-svc {
    position: relative;
  }
  /* every card gets a node tick sitting ON the rail, in its own temper heat */
  .fg-svc::before {
    content: "";
    position: absolute;
    left: calc(-1 * clamp(1.4rem, 3vw, 2.4rem) - 5px);
    top: 1.7rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--heat);
    box-shadow:
      0 0 0 3px var(--fg-ground),
      0 0 7px color-mix(in srgb, var(--heat) 65%, transparent);
  }
  /* each node tick IGNITES once as the drawing rail reaches it — JS adds
     .is-lit on scroll (enhancement only; the tick's resting dot above is always
     rendered, so nothing depends on this firing). */
  @keyframes fg-tick-ignite {
    0% {
      transform: scale(1);
      box-shadow:
        0 0 0 3px var(--fg-ground),
        0 0 7px color-mix(in srgb, var(--heat) 65%, transparent);
    }
    34% {
      transform: scale(1.85);
      box-shadow:
        0 0 0 3px var(--fg-ground),
        0 0 20px color-mix(in srgb, var(--heat) 95%, transparent);
    }
    100% {
      transform: scale(1);
      box-shadow:
        0 0 0 3px var(--fg-ground),
        0 0 7px color-mix(in srgb, var(--heat) 65%, transparent);
    }
  }
  .fg-svc.is-lit::before {
    animation: fg-tick-ignite 640ms var(--ease-swift, ease-out) 1;
  }
  .fg-card {
    height: 100%;
    background: var(--fg-glass);
    border: 1px solid var(--fg-hair);
    border-radius: 10px;
    padding: 1.5rem 1.5rem 1.4rem;
    display: grid;
    gap: 0.85rem;
    align-content: start;
    /* each card sits in its own heat: a faint inset edge in station color */
    box-shadow: inset 3px 0 0 var(--heat);
  }
  /* index numbers dropped (operator) — the head is now just name over price,
     stacked, so nothing looks amputated where 01–06 used to sit. */
  .fg-card-head {
    display: grid;
    gap: 0.55rem;
  }
  .fg-name {
    font-family: var(--font-sans);
    font-weight: 650;
    font-size: 1.3rem;
    line-height: 1.2;
    color: #f4f0ea;
  }
  /* PRICE — the strongest thing on the card after the name (operator: bigger,
     nicer face). The dollar amount is set in the display serif (Fraunces) at
     large size with its handsome lining numerals; "Starts at" rides above as a
     small mono kicker and "/ mo" · "/ day" trails inline as a small mono unit. */
  .fg-price {
    display: block;
    color: var(--heat);
  }
  .fg-price-lead {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: color-mix(in srgb, #f0ece6 52%, transparent);
    margin-bottom: 0.2rem;
  }
  .fg-price-amt {
    font-family: var(--font-display);
    font-weight: 560;
    font-size: clamp(2rem, 3.4vw, 2.55rem);
    line-height: 1;
    letter-spacing: -0.01em;
    font-variant-numeric: lining-nums tabular-nums;
    color: var(--heat);
  }
  .fg-price-unit {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, #f0ece6 62%, transparent);
    white-space: nowrap;
  }
  .fg-blurb {
    font-size: 0.97rem;
    line-height: 1.55;
    color: color-mix(in srgb, #f0ece6 85%, transparent);
  }
  .fg-ledger {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    color: color-mix(in srgb, #f0ece6 55%, transparent);
    padding-top: 0.2rem;
    border-top: 1px solid var(--fg-hair);
  }

  /* the demoted method — a quiet, names-only strip inside the flagship card */
  .fg-strip {
    margin-top: 0.3rem;
    padding-top: 0.95rem;
    border-top: 1px solid var(--fg-hair);
    display: grid;
    gap: 0.5rem;
  }
  /* the five-stage strip's connecting line — the same subtle scaleX draw-in,
     keyed to the flagship card's reveal (fail-open by the same rule). */
  .fg-strip-line {
    display: block;
    height: 1px;
    width: 100%;
    transform-origin: left;
    background: linear-gradient(
      to right,
      color-mix(in srgb, var(--color-forge-heat, #ff9d45) 60%, transparent),
      color-mix(in srgb, var(--color-accent, #38f8ec) 55%, transparent),
      transparent
    );
  }
  html.js .fg-card[data-reveal]:not(.is-revealed) .fg-strip-line {
    transform: scaleX(0);
  }
  html.js .fg-card.is-revealed .fg-strip-line {
    transform: scaleX(1);
    transition: transform 1100ms var(--ease-survey, ease-out) 120ms;
  }
  .fg-strip-label {
    letter-spacing: 0.18em;
    color: color-mix(in srgb, #f0ece6 55%, transparent);
  }
  .fg-strip-stages {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.55rem;
  }
  .fg-strip-stage {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, #f0ece6 78%, transparent);
  }
  .fg-strip-stage:not(:last-child)::after {
    content: "→";
    margin-left: 0.55rem;
    color: color-mix(in srgb, var(--color-accent, #38f8ec) 55%, transparent);
  }
  .fg-strip-note {
    font-size: 0.86rem;
    line-height: 1.45;
    color: color-mix(in srgb, #f0ece6 60%, transparent);
  }

  .fg-pricing {
    margin-top: 3rem;
    display: grid;
    gap: 0.55rem;
  }

  /* ── T4 proof ── */
  .fg-proof {
    padding: 3rem clamp(1.5rem, 6vw, 4rem) 4.5rem;
    max-width: 60rem;
    margin-inline: auto;
    display: grid;
    gap: 1.2rem;
  }
  .fg-proof-card {
    display: grid;
    gap: 1.1rem;
    background: var(--fg-glass);
    border: 1px solid color-mix(in srgb, #ffffff 10%, transparent);
    border-radius: 10px;
    padding: 1.8rem;
  }

  /* ── T5 the saga (the S finale) ── */
  .fg-saga {
    min-height: 78svh;
    display: grid;
    align-content: center;
    padding: 5rem clamp(1.5rem, 6vw, 4rem);
  }
  .fg-s {
    position: absolute;
    right: 3%;
    top: 50%;
    height: 80%;
    transform: translateY(-50%);
    pointer-events: none;
    filter: drop-shadow(0 0 14px color-mix(in srgb, var(--color-accent, #38f8ec) 35%, transparent));
  }
  [data-fg-s] {
    stroke-dasharray: none; /* fully drawn without the engine */
  }
  .fg-saga-inner {
    position: relative;
    display: grid;
    gap: 1.2rem;
    justify-items: start;
    max-width: 64rem;
    margin-inline: auto;
    width: 100%;
  }
  .fg-headline--close {
    max-width: 18ch;
  }

  /* ── small screens ── */
  @media (max-width: 720px) {
    .fg-s {
      opacity: 0.35;
      right: -12%;
    }
  }

  /* ── reduced motion: the scroll animatics are enhancement only. The rail JS
     bails before it ever sets --rail-progress (rail stays fully drawn), ticks
     never get .is-lit. The two CSS draw-in lines are force-revealed by the
     engine, so pin them to their final state with no transition/animation. ── */
  @media (prefers-reduced-motion: reduce) {
    html.js .fg-class-head.is-revealed .fg-class-rule,
    html.js .fg-card.is-revealed .fg-strip-line {
      transform: scaleX(1);
      transition: none;
    }
    .fg-svc.is-lit::before {
      animation: none;
    }
  }
</style>

<script>
  // P12.x enhancement — everything below rides over a page that is already
  // fully forged (and fully readable) without JS. The temper rail renders fully
  // drawn in CSS by default; the enhancements here are the hero ember field, the
  // S-finale draw, and the scroll-scrubbed rail draw + node-tick ignition.
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ensureSmoothScroll } from "../lib/smooth-scroll";

  async function init() {
    const idle = (fn: () => void) =>
      "requestIdleCallback" in window ? requestIdleCallback(fn, { timeout: 3000 }) : setTimeout(fn, 1500);
    idle(() => {
      void import("../lib/decode-text").then(({ mountDecode }) => mountDecode(document));
    });

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) return;
    gsap.registerPlugin(ScrollTrigger);
    const lenis = await ensureSmoothScroll();
    if (lenis) lenis.on("scroll", () => ScrollTrigger.update());

    // ── the finale S: draws as the saga section arrives (the home page's
    // #talk gesture, completing the arc: forged services → the mark) ──
    const sPath = document.querySelector<SVGPathElement>("[data-fg-s]");
    const saga = document.querySelector<HTMLElement>("[data-fg-saga]");
    if (sPath && saga) {
      const L = sPath.getTotalLength();
      sPath.style.strokeDasharray = String(L);
      gsap.fromTo(
        sPath,
        { strokeDashoffset: L },
        {
          strokeDashoffset: 0,
          ease: "none",
          scrollTrigger: { trigger: saga, start: "top 85%", end: "center 45%", scrub: 0.5 },
        },
      );
    }

    // ── the temper rail DRAWS with scroll (operator: "I still like the lines
    // that move"). One scrubbed --rail-progress (0→1) grows the gutter gradient
    // down the services column as it passes the viewport; each card's node tick
    // ignites once as the drawing tip reaches it. Fail-open: on any error the
    // rail is restored to fully drawn — it can never be left half-painted. ──
    const services = document.querySelector<HTMLElement>("[data-fg-services]");
    const railBox = services?.querySelector<HTMLElement>(".fg-services-inner");
    if (services && railBox) {
      try {
        // scrub over the rail's OWN box (not the section, which trails a pricing
        // footer below the rail) so progress maps tightly to the drawn line
        gsap.fromTo(
          railBox,
          { "--rail-progress": 0 },
          {
            "--rail-progress": 1,
            ease: "none",
            scrollTrigger: { trigger: railBox, start: "top 78%", end: "bottom 62%", scrub: 0.6 },
          },
        );
        // each tick fires once, ~when the drawing rail tip passes its card
        services.querySelectorAll<HTMLElement>(".fg-svc").forEach((svc) => {
          ScrollTrigger.create({
            trigger: svc,
            start: "top 72%",
            once: true,
            onEnter: () => svc.classList.add("is-lit"),
          });
        });
      } catch {
        railBox.style.setProperty("--rail-progress", "1"); // never fail invisible
      }
    }

    // ── the embers: a featherweight 2D canvas field in the hero. Rises,
    // flickers, pauses off-screen and in hidden tabs. Wide viewports only;
    // never under Save-Data. (~70 particles, transform-free, one pass.) ──
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (conn?.saveData || !window.matchMedia("(min-width: 768px)").matches) return;
    const canvas = document.querySelector<HTMLCanvasElement>("[data-fg-embers]");
    const hero = document.querySelector<HTMLElement>("[data-fg-hero]");
    if (!canvas || !hero) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const DPR = Math.min(window.devicePixelRatio || 1, 2);
    let W = 0;
    let H = 0;
    const fit = () => {
      W = hero.clientWidth;
      H = hero.clientHeight;
      canvas.width = W * DPR;
      canvas.height = H * DPR;
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
    };
    fit();
    new ResizeObserver(fit).observe(hero);

    type Ember = { x: number; y: number; r: number; v: number; sway: number; ph: number; a: number; hot: boolean };
    const embers: Ember[] = Array.from({ length: 70 }, () => ({
      x: Math.random() * 1, // normalized; scaled by W each frame
      y: Math.random() * 1,
      r: 0.6 + Math.random() * 1.7,
      v: 8 + Math.random() * 22, // px/s upward
      sway: 6 + Math.random() * 18,
      ph: Math.random() * Math.PI * 2,
      a: 0.1 + Math.random() * 0.4,
      hot: Math.random() < 0.75, // most embers warm, a few already cooled aqua
    }));

    let running = false;
    let raf = 0;
    let last = 0;
    let t = 0;
    const tick = (now: number) => {
      if (!running) return;
      raf = requestAnimationFrame(tick);
      const dt = Math.min(0.05, (now - last) / 1000);
      last = now;
      t += dt;
      ctx.clearRect(0, 0, W, H);
      for (const e of embers) {
        e.y -= (e.v * dt) / H;
        if (e.y < -0.02) {
          e.y = 1.02;
          e.x = Math.random();
        }
        const x = e.x * W + Math.sin(t * 0.7 + e.ph) * e.sway;
        const y = e.y * H;
        const flicker = 0.65 + 0.35 * Math.sin(t * 2.3 + e.ph * 3);
        ctx.globalAlpha = e.a * flicker;
        ctx.fillStyle = e.hot ? "#ffb066" : "#59e6da";
        ctx.beginPath();
        ctx.arc(x, y, e.r, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
    };
    const setRunning = (v: boolean) => {
      if (v === running) return;
      running = v;
      if (v) {
        last = performance.now();
        raf = requestAnimationFrame(tick);
      } else {
        cancelAnimationFrame(raf);
      }
    };
    // run only while the hero is on screen and the tab is visible
    new IntersectionObserver(([entry]) => setRunning(entry.isIntersecting && !document.hidden), {
      threshold: 0.05,
    }).observe(hero);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) setRunning(false);
      else if (hero.getBoundingClientRect().bottom > 0) setRunning(true);
    });
  }
  void init();
</script>
