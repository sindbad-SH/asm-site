---
/**
 * Entertainment — P7 (V1-UPGRADE-PLAN): REBUILT to the irinamoi.com grammar,
 * Sindbad's chosen reference for this lane. Her grammar, his world:
 *
 *   - GIANT single-weight grotesque caps INTERLEAVED with an elegant serif
 *     italic for the connective words (her FoundersGrotesk × Romie → our
 *     DM Sans × Fraunces italic — brand faces in the reference's two roles)
 *   - scattered ghost letterforms that assemble as a section arrives
 *   - a CONTINUOUS background-color morph between scroll chapters (her
 *     burgundy→mauve→black→blue ride → our dark cinematic jewel tones)
 *   - numbered work chapters: serif index corners (01 … /02), mono client
 *     kicker, giant two-line OFFSET title, serif italic type-tag, and a
 *     collage of overlapping media cards with slight scroll parallax
 *   - the playground's scattered-letters + confetti as "The rooms"
 *
 * HONESTY (unchanged contract): every sentence is verbatim from consts —
 * the mixed-face emphasis inside them is presentational only. Every
 * relationship still renders through LegendMark; LegendKey still decodes
 * the tiers; the Pebble Beach quote stays the car owner's, never the
 * Concours'. The pebble-beach proof line moves from the rooms list into
 * work chapter 02 (same strings, same device, richer stage).
 *
 * Fallbacks: no-JS/reduced motion → every section keeps its own static
 * ground color, letters sit in their final positions, collages render as
 * plain stacked media. The morph/assembly/parallax are enhancement-only.
 */
import Base from "../layouts/Base.astro";
import LegendMark from "../components/LegendMark.astro";
import LegendKey from "../components/LegendKey.astro";
import Testimonial from "../components/Testimonial.astro";
import { PAGES, WORK } from "../consts";
import { existsSync } from "node:fs";
import { join } from "node:path";

const p = PAGES.entertainment;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// build-time media gating (cwd-anchored, per repo convention): a card only
// renders when its file shipped. avif+webp pairs preferred; lone files
// (e.g. the .mp4 loops) ride as-is via media().
const mediaRoot = join(process.cwd(), "public", "media");
const media = (rel: string) => (existsSync(join(mediaRoot, ...rel.split("/"))) ? `${base}/media/${rel}` : undefined);
const pair = (relBase: string) => {
  const avif = media(`${relBase}.avif`);
  const webp = media(`${relBase}.webp`);
  return avif || webp ? { avif, webp } : undefined;
};

// chapter 01 — PitchBoulder (E3, the primary proof anchor)
const pbPoster = pair("work/pitchboulder/hook-poster");
const pbContext = pair("work/pitchboulder/context");
const pbLoop = media("work/pitchboulder/loop.mp4"); // P13c — hover-video on the tall card
// chapter 02 — the restored Shelby (WORK item; proof = pebble-beach room).
// P13c — real stills replace the frame-grabs: on-set (crew filming the car,
// the storytelling card) rides the wide card + hover-video; dawn-flare + heritage
// fill the tall/small cards. All from the width-suffixed photos/ exports.
const shelby = WORK.find((w) => w.slug === "shelby-pebble-beach");
const shHref = shelby?.href ?? "/work/shelby-pebble-beach";
const shOnSet = pair("work/shelby-pebble-beach/photos/on-set-1600");
const shDawn = pair("work/shelby-pebble-beach/photos/dawn-flare-900");
const shHeritage = pair("work/shelby-pebble-beach/photos/heritage-900");
const shLoop = media("work/shelby-pebble-beach/loop.mp4"); // P13c — hover-video on the wide card
// the rooms — honest published event frames (SeriesFest carpet, AFM panel)
const roomSeries = pair("home/industry/background");
const roomAfm = pair("home/industry/midground");

// the pebble-beach proof (with its owner-endorsement context) relocates from
// the rooms list to chapter 02; the remaining rooms keep the list.
const pebbleRoom = p.rooms.items.find((r) => r.proof.relationshipId === "pebble-beach");
const otherRooms = p.rooms.items.filter((r) => r.proof.relationshipId !== "pebble-beach");

// scattered ghost letters are drawn FROM the page's own words (presentational
// letterforms, not new copy): the hero scatters PULSE, the rooms scatter ROOMS.
const heroGhost = ["S", "T", "O", "R", "Y"]; // P12.3 — from "business stories"
const roomsGhost = ["R", "O", "O", "M", "S"];

// P13c — the coverage index: editorial tiles to the published venture stories.
// slate + title strings are COPIED VERBATIM from each article page's own
// frontmatter/markup (already operator-flagged there) — reuse adds no new copy.
const coverage = [
  { href: "/venture/seriesfest-2026", slate: "SeriesFest · May 7–8, 2026 · Denver, CO", title: "SeriesFest 2026 — a venture story" },
  { href: "/venture/seriesfest-2025", slate: "SeriesFest · Apr 30 – May 4, 2025 · Denver, CO", title: "SeriesFest 2025 — a venture story" },
  { href: "/venture/seriesfest-2026-fashion-in-focus", slate: "SeriesFest · Fashion in Focus · Mar 7, 2026 · Denver, CO", title: "SeriesFest 2026 · Fashion in Focus — a venture story" },
  { href: "/venture/seriesfest-2026-soul-power", slate: "SeriesFest · Soul Power ABA Premiere · Feb 18, 2026 · Denver, CO", title: "SeriesFest 2026 · Soul Power ABA Premiere — a venture story" },
  { href: "/venture/afm-2025", slate: "American Film Market · Nov 8–15, 2025 · Los Angeles, CA", title: "American Film Market 2025 — a venture story" },
  { href: "/venture/amazing-aerial", slate: "AMAZING AERIAL AGENCY · SINCE MID-2024", title: "The agency that takes my aerials to market." },
];

// chapter ground colors — the reference's jewel-tone ride, our dark family.
// P13c — meme ground removed (the S2 statement is now chapter 03); ch03 added.
const GROUNDS = {
  intro: "#101020",
  ch01: "#191031",
  ch02: "#261118",
  ch03: "#0e2230",
  rooms: "#10141f",
  handoff: "#0f1118",
};
---

<Base title={p.meta.title} description={p.meta.description}>
  <!-- the morphing ground: fixed behind everything; the engine animates its
       color between chapters. Until the engine mounts (adds .im-live), each
       section paints its OWN ground — no-JS never sees a wrong color. -->
  <div class="im-ground" data-im-ground aria-hidden="true" style={`background:${GROUNDS.intro}`}></div>

  <main class="im" data-im>
    <!-- ═══ S1 · INTRODUCTION — the typographic collage hero ═══ -->
    <section class="im-sec im-intro" data-im-section data-ground={GROUNDS.intro} style={`--sec-ground:${GROUNDS.intro}`}>
      <div class="im-ghosts" aria-hidden="true">
        {heroGhost.map((ch, i) => <span class="im-ghost" data-im-ghost style={`--gi:${i}`}>{ch}</span>)}
      </div>
      <p class="hud-label im-kicker" data-reveal>{p.hero.eyebrow}</p>
      <!-- P12.3 — the VENTURE headline, composed in the reference's two
           voices: "The venture in adventure." — the pun carried by the caps,
           the connectives by the serif italic. Copy from consts (pending
           operator read-approval; see the review block there). -->
      <h1 class="im-headline" data-reveal>
        <span class="im-line"><span class="im-turn">The</span> VENTURE</span>
        <span class="im-line im-line--push"><span class="im-turn">in</span> ADVENTURE.</span>
      </h1>
      <p class="im-turn im-intro-sub" data-reveal>{p.hero.subline}</p>
    </section>

    <!-- ═══ S3 · THE WORK CHAPTERS — numbered, grounded, collaged ═══
         P13c — the old S2 MEME statement moved into chapter 03 below (no dup). -->

    <section class="im-sec im-chapter" data-im-section data-ground={GROUNDS.ch01} style={`--sec-ground:${GROUNDS.ch01}`}>
      <span class="im-index im-turn" aria-hidden="true">01</span>
      <span class="im-index im-index--of im-turn" aria-hidden="true">/03</span>
      <div class="im-chapter-stage">
        <div class="im-collage" aria-hidden="true">
          {
            pbPoster && (
              // P13c — the tall card is a clickable hover-video link to the case page
              <a
                class="im-card im-card--tall im-card--link"
                href={`${base}/work/pitchboulder`}
                data-im-card
                data-depth="1.4"
                tabindex="-1"
              >
                <picture>
                  {pbPoster.avif && <source srcset={pbPoster.avif} type="image/avif" />}
                  <img src={pbPoster.webp ?? pbPoster.avif} alt="" loading="lazy" decoding="async" />
                </picture>
                {pbLoop && <video class="im-loop" data-im-loop data-loop-src={pbLoop} muted loop playsinline preload="none" />}
              </a>
            )
          }
          {
            pbContext && (
              <figure class="im-card im-card--wide" data-im-card data-depth="0.7">
                <picture>
                  {pbContext.avif && <source srcset={pbContext.avif} type="image/avif" />}
                  <img src={pbContext.webp ?? pbContext.avif} alt="" loading="lazy" decoding="async" />
                </picture>
              </figure>
            )
          }
        </div>
        <div class="im-chapter-type">
          <!-- heading "PitchBoulder", split at its own seam — her TWIN/MOTION -->
          <h2 class="im-title" data-reveal>
            <span class="im-line">PITCH</span>
            <span class="im-line im-line--push">BOULDER</span>
          </h2>
          <p class="im-turn im-tag" data-reveal>{p.pitchboulder.proof.context}</p>
        </div>
        <div class="im-chapter-meta" data-reveal>
          <LegendMark proof={p.pitchboulder.proof} />
          <div class="im-quote">
            <Testimonial testimonialId={p.pitchboulder.testimonialId} showProof={false} />
          </div>
          <a href={`${base}${p.pitchboulder.link.href}`} class="link">
            {p.pitchboulder.link.label} <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <section class="im-sec im-chapter" data-im-section data-ground={GROUNDS.ch02} style={`--sec-ground:${GROUNDS.ch02}`}>
      <span class="im-index im-turn" aria-hidden="true">02</span>
      <span class="im-index im-index--of im-turn" aria-hidden="true">/03</span>
      <div class="im-chapter-stage">
        <div class="im-collage" aria-hidden="true">
          {
            shOnSet && (
              // P13c — real on-set still (crew filming the car); wide card is the
              // clickable hover-video link to the case page
              <a
                class="im-card im-card--wide im-card--link"
                href={`${base}${shHref}`}
                data-im-card
                data-depth="1.2"
                tabindex="-1"
              >
                <picture>
                  {shOnSet.avif && <source srcset={shOnSet.avif} type="image/avif" />}
                  <img src={shOnSet.webp ?? shOnSet.avif} alt="" loading="lazy" decoding="async" />
                </picture>
                {shLoop && <video class="im-loop" data-im-loop data-loop-src={shLoop} muted loop playsinline preload="none" />}
              </a>
            )
          }
          {shDawn && (
            <figure class="im-card im-card--tall" data-im-card data-depth="0.6">
              <picture>
                {shDawn.avif && <source srcset={shDawn.avif} type="image/avif" />}
                <img src={shDawn.webp ?? shDawn.avif} alt="" loading="lazy" decoding="async" />
              </picture>
            </figure>
          )}
          {shHeritage && (
            <figure class="im-card im-card--small" data-im-card data-depth="1.8">
              <picture>
                {shHeritage.avif && <source srcset={shHeritage.avif} type="image/avif" />}
                <img src={shHeritage.webp ?? shHeritage.avif} alt="" loading="lazy" decoding="async" />
              </picture>
            </figure>
          )}
        </div>
        <div class="im-chapter-type">
          <!-- the WORK item's title verbatim, giant word carried by the caps:
               "A restored Shelby at Pebble Beach" -->
          <h2 class="im-title" data-reveal>
            <span class="im-line"><span class="im-turn">A restored</span> SHELBY</span>
            <span class="im-line im-line--push"><span class="im-turn">at</span> PEBBLE BEACH</span>
          </h2>
          {pebbleRoom && <p class="im-turn im-tag" data-reveal>{pebbleRoom.proof.context}</p>}
        </div>
        <div class="im-chapter-meta" data-reveal>
          {pebbleRoom && <LegendMark proof={pebbleRoom.proof} />}
          {
            shelby?.href && (
              <a href={`${base}${shelby.href}`} class="link">
                {p.pitchboulder.link.label} <span class="arrow" aria-hidden="true">→</span>
              </a>
            )
          }
        </div>
      </div>
    </section>

    <!-- ═══ CHAPTER 03 · MEME — typographic (no collage); the S2 statement,
         now numbered into the chapter sequence. Title lockup + tag + proof. ═══ -->
    <section class="im-sec im-chapter im-chapter--type" data-im-section data-ground={GROUNDS.ch03} style={`--sec-ground:${GROUNDS.ch03}`}>
      <span class="im-index im-turn" aria-hidden="true">03</span>
      <span class="im-index im-index--of im-turn" aria-hidden="true">/03</span>
      <div class="im-chapter-stage">
        <div class="im-chapter-type">
          <h2 class="im-title" data-reveal>
            <span class="im-line">MEME</span>
          </h2>
          <!-- meme.body verbatim: "The role I hold most formally in this world." -->
          <p class="im-turn im-tag" data-reveal>{p.meme.body}</p>
        </div>
        <div class="im-chapter-meta" data-reveal>
          <LegendMark proof={p.meme.proof} />
          <a href="https://www.meme.ngo" rel="noopener" target="_blank" class="link">
            About the organization <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ S4 · THE ROOMS — her playground, his honest list ═══ -->
    <section class="im-sec im-rooms" data-im-section data-ground={GROUNDS.rooms} style={`--sec-ground:${GROUNDS.rooms}`}>
      <div class="im-ghosts im-ghosts--rooms" aria-hidden="true">
        {roomsGhost.map((ch, i) => <span class="im-ghost im-ghost--room" data-im-ghost style={`--gi:${i}`}>{ch}</span>)}
        <span class="im-confetti" data-im-confetti style="--ci:0"></span>
        <span class="im-confetti" data-im-confetti style="--ci:1"></span>
        <span class="im-confetti" data-im-confetti style="--ci:2"></span>
        <span class="im-confetti" data-im-confetti style="--ci:3"></span>
      </div>
      <p class="hud-label im-kicker" data-reveal>{p.rooms.heading}</p>
      <p class="im-turn im-rooms-intro" data-reveal>{p.rooms.intro}</p>
      <div class="im-rooms-stage">
        <ul class="im-rooms-list">
          {
            otherRooms.map((room) => (
              <li class="im-room" data-reveal data-reveal-stagger="80">
                <LegendMark proof={room.proof} />
              </li>
            ))
          }
        </ul>
        <div class="im-rooms-photos" aria-hidden="true">
          {
            roomSeries && (
              <figure class="im-card im-card--wide" data-im-card data-depth="0.8">
                <picture>
                  {roomSeries.avif && <source srcset={roomSeries.avif} type="image/avif" />}
                  <img src={roomSeries.webp ?? roomSeries.avif} alt="" loading="lazy" decoding="async" />
                </picture>
              </figure>
            )
          }
          {
            roomAfm && (
              <figure class="im-card im-card--small" data-im-card data-depth="1.5">
                <picture>
                  {roomAfm.avif && <source srcset={roomAfm.avif} type="image/avif" />}
                  <img src={roomAfm.webp ?? roomAfm.avif} alt="" loading="lazy" decoding="async" />
                </picture>
              </figure>
            )
          }
        </div>
      </div>
      <!-- P13c — the coverage index: editorial tiles to the published venture
           stories, replacing the P12.8 one-off seriesfest link. -->
      <nav class="im-coverage" aria-label="Venture coverage">
        {
          coverage.map((c) => (
            <a class="im-cov" href={`${base}${c.href}`} data-reveal data-reveal-stagger="60">
              <span class="im-cov-slate hud-label">{c.slate}</span>
              <span class="im-cov-title im-turn">{c.title}</span>
              <span class="im-cov-arrow arrow" aria-hidden="true">→</span>
            </a>
          ))
        }
      </nav>
      <div class="im-key" data-reveal><LegendKey /></div>
    </section>

    <!-- ═══ S5 · HANDOFF — one soft exit, back to base ground ═══ -->
    <section class="im-sec im-handoff" data-im-section data-ground={GROUNDS.handoff} style={`--sec-ground:${GROUNDS.handoff}`}>
      <p class="im-turn im-handoff-line" data-reveal>{p.handoff.body}</p>
      <a href={`${base}${p.handoff.cta.href}`} class="btn" data-reveal>{p.handoff.cta.label}</a>
    </section>
  </main>
</Base>

<style>
  /* ── the morphing ground ── */
  .im-ground {
    position: fixed;
    inset: 0;
    z-index: -1;
    transition: none; /* GSAP owns the morph; CSS must not fight it */
  }
  .im-sec {
    position: relative;
    background: var(--sec-ground); /* static fallback ground per section */
    overflow: clip;
  }
  /* once the engine is live, sections go clear and the fixed ground shows
     through — the color RIDES between chapters instead of cutting */
  :global(html.js) .im-live .im-sec {
    background: transparent;
  }

  /* ── the two reference voices, our faces ── */
  .im-headline,
  .im-statement,
  .im-title {
    font-family: var(--font-sans);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.96;
    letter-spacing: 0.008em;
    color: #f2f4f8;
  }
  .im-turn {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    color: #eef1f6;
  }
  .im-kicker {
    letter-spacing: 0.3em;
    color: color-mix(in srgb, #e8f6f3 78%, transparent);
  }

  /* ── S1 intro ── */
  .im-intro {
    min-height: 92svh;
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 1.6rem;
    padding: 7rem 2rem 6rem;
    text-align: center;
  }
  .im-headline {
    font-size: clamp(3rem, 9.5vw, 9.5rem);
    display: grid;
    gap: 0.05em;
  }
  .im-headline .im-turn,
  .im-title .im-turn {
    font-size: 0.42em;
    vertical-align: 0.22em;
    margin-inline: 0.12em;
  }
  .im-line {
    display: block;
  }
  .im-line--push {
    transform: translateX(6vw);
  }
  .im-intro-sub {
    max-width: 34rem;
    font-size: clamp(1.15rem, 1.7vw, 1.5rem);
    line-height: 1.45;
    justify-self: end;
    text-align: right;
    margin-top: 1.5rem;
  }
  /* ghost letters: final resting places are set here (no-JS = already home);
     the engine only ADDS the scatter-and-assemble journey */
  .im-ghosts {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .im-ghost {
    position: absolute;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(6rem, 16vw, 15rem);
    color: color-mix(in srgb, #ffffff 7%, transparent);
    line-height: 1;
  }
  .im-ghost:nth-child(1) { left: 6%; top: 14%; }
  .im-ghost:nth-child(2) { left: 26%; top: 62%; }
  .im-ghost:nth-child(3) { left: 48%; top: 8%; }
  .im-ghost:nth-child(4) { left: 68%; top: 58%; }
  .im-ghost:nth-child(5) { left: 86%; top: 22%; }

  /* ── S3 chapters ── */
  .im-chapter {
    min-height: 130svh;
    padding: 10rem clamp(1.5rem, 6vw, 7rem);
  }
  .im-index {
    position: sticky;
    top: 5.5rem;
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    float: left;
    color: color-mix(in srgb, #ffffff 85%, transparent);
  }
  .im-index--of {
    float: right;
    top: 70vh;
  }
  .im-chapter-stage {
    position: relative;
    max-width: 78rem;
    margin-inline: auto;
    min-height: 90svh;
    display: grid;
    align-content: center;
  }
  .im-collage {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .im-card {
    position: absolute;
    margin: 0;
    overflow: hidden;
    border-radius: 6px;
    box-shadow: 0 24px 80px -24px rgba(0, 0, 0, 0.55);
  }
  .im-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* P13c — the two case cards are clickable hover-video links: pointer-events
     back on (the collage is otherwise none), and a muted loop fades over the
     still on hover. Mounts on first pointerenter (see the hover-life script). */
  .im-card--link {
    display: block;
    pointer-events: auto;
    cursor: pointer;
    text-decoration: none;
  }
  .im-loop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 500ms var(--ease-survey, ease);
    pointer-events: none;
  }
  .im-card--link.is-looping .im-loop {
    opacity: 1;
  }
  .im-card--tall { width: clamp(160px, 22vw, 320px); aspect-ratio: 9 / 14; left: 4%; top: 6%; }
  .im-card--wide { width: clamp(240px, 34vw, 520px); aspect-ratio: 16 / 10; right: 2%; top: 14%; }
  .im-card--small { width: clamp(130px, 16vw, 240px); aspect-ratio: 4 / 3; left: 18%; bottom: 4%; }
  .im-chapter-type {
    position: relative;
    z-index: 2;
    text-align: center;
  }
  .im-title {
    font-size: clamp(2.6rem, 8vw, 8rem);
    display: grid;
    gap: 0.04em;
  }
  .im-tag {
    margin-top: 0.8rem;
    font-size: clamp(1.05rem, 1.5vw, 1.35rem);
    text-align: right;
    margin-inline: auto;
    max-width: 60rem;
    padding-right: clamp(0rem, 6vw, 5rem);
  }
  .im-chapter-meta {
    position: relative;
    z-index: 2;
    margin-top: 3.5rem;
    max-width: 34rem;
    display: grid;
    gap: 1rem;
  }
  .im-quote {
    font-style: italic;
  }

  /* ── S4 rooms ── */
  .im-rooms {
    min-height: 100svh;
    padding: 9rem clamp(2rem, 7vw, 8rem);
    display: grid;
    align-content: center;
    gap: 1.6rem;
  }
  .im-ghost--room {
    font-size: clamp(4.5rem, 11vw, 10rem);
    color: color-mix(in srgb, #ffffff 6%, transparent);
  }
  .im-ghosts--rooms .im-ghost:nth-child(1) { left: 8%; top: 10%; }
  .im-ghosts--rooms .im-ghost:nth-child(2) { left: 30%; top: 20%; }
  .im-ghosts--rooms .im-ghost:nth-child(3) { left: 52%; top: 8%; }
  .im-ghosts--rooms .im-ghost:nth-child(4) { left: 70%; top: 18%; }
  .im-ghosts--rooms .im-ghost:nth-child(5) { left: 86%; top: 10%; }
  .im-confetti {
    position: absolute;
    width: clamp(34px, 4vw, 64px);
    aspect-ratio: 1;
    background: var(--color-accent, #38f8ec);
    opacity: 0.14;
    border-radius: 4px;
  }
  .im-confetti:nth-of-type(1) { left: 14%; top: 40%; }
  .im-confetti:nth-of-type(2) { left: 44%; top: 34%; background: #0da79b; }
  .im-confetti:nth-of-type(3) { left: 66%; top: 44%; background: #8fb7d8; }
  .im-confetti:nth-of-type(4) { left: 88%; top: 36%; }
  .im-rooms-intro {
    font-size: clamp(1.3rem, 2vw, 1.7rem);
  }
  .im-rooms-stage {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: start;
    margin-top: 1.5rem;
  }
  .im-rooms-list {
    display: grid;
    gap: 1.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .im-room {
    border-top: 1px solid color-mix(in srgb, #ffffff 14%, transparent);
    padding-top: 1.1rem;
  }
  .im-room-story {
    display: inline-block;
    margin-top: 0.5rem;
  }
  .im-rooms-photos {
    position: relative;
    min-height: 380px;
  }
  .im-rooms-photos .im-card--wide { width: 100%; right: 0; top: 0; position: absolute; }
  .im-rooms-photos .im-card--small { left: -6%; bottom: -8%; }
  .im-key {
    margin-top: 2rem;
  }

  /* ── P13c coverage index — editorial tiles, im- voice, hover lift ── */
  .im-coverage {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 22rem), 1fr));
    gap: 1rem;
  }
  .im-cov {
    position: relative;
    display: grid;
    gap: 0.5rem;
    padding: 1.3rem 1.4rem;
    border: 1px solid color-mix(in srgb, #ffffff 14%, transparent);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition:
      transform 380ms var(--ease-survey, ease),
      border-color 380ms ease,
      background 380ms ease;
  }
  .im-cov:hover,
  .im-cov:focus-visible {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, #ffffff 30%, transparent);
    background: color-mix(in srgb, #ffffff 4%, transparent);
  }
  .im-cov-slate {
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    color: color-mix(in srgb, #e8f6f3 72%, transparent);
  }
  .im-cov-title {
    font-size: clamp(1.15rem, 1.7vw, 1.45rem);
    line-height: 1.22;
  }
  .im-cov-arrow {
    color: var(--color-accent, #38f8ec);
    font-size: 0.9rem;
  }

  /* ── S5 handoff ── */
  .im-handoff {
    min-height: 60svh;
    display: grid;
    place-content: center;
    gap: 2rem;
    text-align: center;
    padding: 6rem 2rem;
  }
  .im-handoff-line {
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    max-width: 30ch;
  }

  /* ── small screens: collages stack, pushes relax ── */
  @media (max-width: 760px) {
    .im-line--push { transform: none; }
    .im-intro-sub { justify-self: center; text-align: center; }
    .im-collage { position: relative; inset: auto; display: grid; gap: 0.8rem; grid-template-columns: 1fr 1fr; margin-bottom: 2rem; pointer-events: auto; }
    .im-card, .im-rooms-photos .im-card--wide { position: relative; inset: auto; width: 100%; }
    .im-chapter { min-height: 0; padding-top: 6rem; }
    .im-chapter-stage { min-height: 0; }
    .im-rooms-stage { grid-template-columns: 1fr; }
    .im-rooms-photos { min-height: 0; display: grid; gap: 0.8rem; }
    .im-ghost { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .im-ghost,
    .im-confetti,
    .im-card {
      transform: none !important;
    }
    .im-loop,
    .im-cov {
      transition: none;
    }
  }
</style>

<script>
  // P7 enhancement layer: ground morph, ghost assembly, collage parallax.
  // Everything below only ADDS motion to an already-correct static page.
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ensureSmoothScroll } from "../lib/smooth-scroll";

  async function init() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const im = document.querySelector<HTMLElement>("[data-im]");
    const ground = document.querySelector<HTMLElement>("[data-im-ground]");
    if (!im || !ground) return;

    gsap.registerPlugin(ScrollTrigger);
    const lenis = await ensureSmoothScroll();
    if (lenis) lenis.on("scroll", () => ScrollTrigger.update());

    // ── the ground morph: sections hand their color to the fixed layer as
    // they enter (0.8s ride, the reference's signature). .im-live flips the
    // sections transparent only now — if this script never runs, the static
    // per-section grounds were already correct. ──
    im.classList.add("im-live");
    document.querySelectorAll<HTMLElement>("[data-im-section]").forEach((sec) => {
      const color = sec.dataset.ground!;
      ScrollTrigger.create({
        trigger: sec,
        start: "top 55%",
        end: "bottom 55%",
        onEnter: () => gsap.to(ground, { backgroundColor: color, duration: 0.8, ease: "power2.out" }),
        onEnterBack: () => gsap.to(ground, { backgroundColor: color, duration: 0.8, ease: "power2.out" }),
      });
    });

    // ── ghost letters: scatter-in assembly on their section's arrival, then
    // a slow idle float (living at rest). Final positions live in CSS. ──
    document.querySelectorAll<HTMLElement>("[data-im-ghost]").forEach((g, i) => {
      const dx = (i % 2 ? 1 : -1) * (40 + (i % 3) * 30);
      gsap.fromTo(
        g,
        { x: dx, y: 60 + (i % 3) * 30, opacity: 0, rotation: (i % 2 ? 1 : -1) * 6 },
        {
          x: 0,
          y: 0,
          opacity: 1,
          rotation: 0,
          duration: 1.1,
          ease: "power3.out",
          delay: i * 0.07,
          scrollTrigger: { trigger: g.parentElement, start: "top 75%", once: true },
          onComplete: () => {
            gsap.to(g, {
              y: (i % 2 ? -1 : 1) * 10,
              duration: 5 + (i % 3) * 1.5,
              ease: "sine.inOut",
              yoyo: true,
              repeat: -1,
            });
          },
        },
      );
    });

    // ── confetti drift (the playground's shapes, kept quiet) ──
    document.querySelectorAll<HTMLElement>("[data-im-confetti]").forEach((c, i) => {
      gsap.to(c, {
        y: (i % 2 ? -1 : 1) * 18,
        rotation: (i % 2 ? 1 : -1) * 14,
        duration: 6 + i * 1.3,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
      });
    });

    // ── collage parallax: cards ride at different depths across their
    // chapter's transit (her overlapping-cards feel, transform-only) ──
    if (!window.matchMedia("(max-width: 760px)").matches) {
      document.querySelectorAll<HTMLElement>("[data-im-card]").forEach((card) => {
        const depth = Number(card.dataset.depth ?? 1);
        const sec = card.closest("[data-im-section]");
        if (!sec) return;
        gsap.fromTo(
          card,
          { yPercent: 8 * depth },
          {
            yPercent: -8 * depth,
            ease: "none",
            scrollTrigger: { trigger: sec, start: "top bottom", end: "bottom top", scrub: true },
          },
        );
      });
    }
  }
  void init();

  // P13c hover-life: the two case-chapter cards (PB tall, Shelby wide) play
  // their loop on hover — the video mounts on FIRST pointerenter (preload="none"
  // keeps the initial load still-only), fades in over its poster, pauses on
  // leave. Fine pointers only; never under reduced motion or Save-Data.
  (() => {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fine = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (reduce || !fine || conn?.saveData) return;
    document.querySelectorAll<HTMLVideoElement>("[data-im-loop]").forEach((video) => {
      const card = video.closest<HTMLElement>(".im-card--link");
      if (!card) return;
      card.addEventListener("pointerenter", () => {
        if (!video.src) video.src = video.dataset.loopSrc!;
        video.play().catch(() => {}); // autoplay refusal → the poster stands
        card.classList.add("is-looping");
      });
      card.addEventListener("pointerleave", () => {
        card.classList.remove("is-looping");
        if (!video.paused) video.pause();
      });
    });
  })();
</script>
