---
/**
 * Entertainment — P7 (V1-UPGRADE-PLAN): REBUILT to the irinamoi.com grammar,
 * Sindbad's chosen reference for this lane. Her grammar, his world:
 *
 *   - GIANT single-weight grotesque caps INTERLEAVED with an elegant serif
 *     italic for the connective words (her FoundersGrotesk × Romie → our
 *     DM Sans × Fraunces italic — brand faces in the reference's two roles)
 *   - scattered ghost letterforms that assemble as a section arrives
 *   - a CONTINUOUS background-color morph between scroll chapters (her
 *     burgundy→mauve→black→blue ride → our dark cinematic jewel tones)
 *   - numbered work chapters: serif index corners (01 … /02), mono client
 *     kicker, giant two-line OFFSET title, serif italic type-tag, and a
 *     collage of overlapping media cards with slight scroll parallax
 *   - the playground's scattered-letters + confetti as "The rooms"
 *
 * HONESTY (unchanged contract): every sentence is verbatim from consts —
 * the mixed-face emphasis inside them is presentational only. Every
 * relationship still renders through LegendMark (P23 — its VISIBLE tier
 * symbol is retired site-wide; the phrasing WORDING is unchanged and each
 * line still states its true status in words); the Pebble Beach quote stays
 * the car owner's, never the Concours'. The pebble-beach proof line moves
 * from the rooms list into work chapter 02 (same strings, richer stage).
 *
 * Fallbacks: no-JS/reduced motion → every section keeps its own static
 * ground color, letters sit in their final positions, collages render as
 * plain stacked media. The morph/assembly/parallax are enhancement-only.
 */
import Base from "../layouts/Base.astro";
import LegendMark from "../components/LegendMark.astro";
import Testimonial from "../components/Testimonial.astro";
import { PAGES, WORK, FORGE_SERVICES, SAGA_STAGES, SITE } from "../consts";
import { existsSync, statSync } from "node:fs";
import { join } from "node:path";

const p = PAGES.entertainment;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// P29 — CTA hrefs may be external (Calendly direct); only prefix internal routes.
const href = (h: string) => (h.startsWith("http") ? h : `${base}${h}`);
// P29 — the E1b services block prices resolve VERBATIM from their existing
// staged floors (FORGE_SERVICES by `serviceNo`, SAGA_STAGES by `stageIdx`) —
// single-sourced, never restated as new numbers.
const svcPrice = (item: (typeof p.services.items)[number]) =>
  item.serviceNo
    ? FORGE_SERVICES.find((s) => s.no === item.serviceNo)!.price
    : SAGA_STAGES[item.stageIdx!].price;

// build-time media gating (cwd-anchored, per repo convention): a card only
// renders when its file shipped. avif+webp pairs preferred; lone files
// (e.g. the .mp4 loops) ride as-is via media().
const mediaRoot = join(process.cwd(), "public", "media");
const media = (rel: string) => (existsSync(join(mediaRoot, ...rel.split("/"))) ? `${base}/media/${rel}` : undefined);
const pair = (relBase: string) => {
  const avif = media(`${relBase}.avif`);
  const webp = media(`${relBase}.webp`);
  return avif || webp ? { avif, webp } : undefined;
};

// chapter 01 — PitchBoulder (E3, the primary proof anchor)
const pbPoster = pair("work/pitchboulder/hook-poster");
const pbLoop = media("work/pitchboulder/loop.mp4"); // P21b — hover-video on the landscape video card
// chapter 02 — the restored Shelby (WORK item; proof = pebble-beach room).
// P13c — real stills replace the frame-grabs: on-set (crew filming the car,
// the storytelling card) rides the wide card + hover-video; dawn-flare + heritage
// fill the tall/small cards. All from the width-suffixed photos/ exports.
// P21b — operator: "pretty good but could use a couple more photos — 3 is too
// light." TWO complementary frames join from the SAME already-baked photos/ set
// (no new export — reused, not re-cut): engine (an engine-bay DETAIL, hands at
// work) + lawn (an elevated CROWD/CONTEXT frame — the Cobra, period-dressed
// spectators, and the coastline). Five frames now, chosen to not repeat an angle.
const shelby = WORK.find((w) => w.slug === "shelby-pebble-beach");
const shHref = shelby?.href ?? "/work/shelby-pebble-beach";
const shOnSet = pair("work/shelby-pebble-beach/photos/on-set-1600");
const shDawn = pair("work/shelby-pebble-beach/photos/dawn-flare-900");
const shHeritage = pair("work/shelby-pebble-beach/photos/heritage-900");
const shEngine = pair("work/shelby-pebble-beach/photos/engine-900"); // P21b — engine-bay detail
const shLawn = pair("work/shelby-pebble-beach/photos/lawn-1600"); // P21b — elevated crowd + coastline
const shLoop = media("work/shelby-pebble-beach/loop.mp4"); // P13c — hover-video on the wide card
// mtime cache-bust (same mechanism as PortalHero/Tableaux) so a returning
// browser pulls fresh crops instead of a cached stale one.
const mtimeV = (rel: string) => {
  try {
    return `?v=${Math.round(statSync(join(mediaRoot, ...rel.split("/"))).mtimeMs).toString(36)}`;
  } catch {
    return "";
  }
};
const bust = (relBase: string, p: ReturnType<typeof pair>) =>
  p
    ? {
        avif: p.avif ? p.avif + mtimeV(`${relBase}.avif`) : undefined,
        webp: p.webp ? p.webp + mtimeV(`${relBase}.webp`) : undefined,
      }
    : undefined;

// P21b — chapter 01 collage, REBUILT for a VENUE MIX (operator: "you're using
// all the photos from the Boulder Chamber [one room] — I wanted a mix", and
// "I don't like the large vertical photo above the video"). The hover-video now
// rides a LANDSCAPE card (hook-poster/loop are native 16:9 — the old tall 9:14
// crop was the vertical the operator flagged), ringed by three frames spanning
// two venues + two capture styles: a Boulder Chamber brand moment (presenter at
// the "Follow Us!" slide, square phone frame) and TWO professionally-edited
// frames from the Jan-28 co-working room — a wide crowd-energy frame and a
// presenter mid-talk. The old same-room room-wide/podium picks are retired.
// Exported by scripts/make-pitchboulder-collage.mjs, cache-busted like the
// rooms photos so a returning browser pulls fresh crops.
const pbPresenter = bust("work/pitchboulder/presenter-logo-1600", pair("work/pitchboulder/presenter-logo-1600"));
const pbCrowd = bust("work/pitchboulder/coworking-crowd-1600", pair("work/pitchboulder/coworking-crowd-1600"));
const pbTalk = bust("work/pitchboulder/coworking-presenter-1600", pair("work/pitchboulder/coworking-presenter-1600"));

// P21b — chapter 03 (MEME) gains the org's own logo animatic as an AMBIENT
// framed card (operator: "you can use the video I gave you"). It is the SAME
// processed loop the /venture/meme article carries — reused here, existence-
// gated + cache-busted. Poster-first (no-JS / reduced-motion / Save-Data land on
// the still); the video fades in and plays ONLY while on-screen (the ambient-loop
// script below, mirroring /venture/meme.astro's gating). The static AI brand PNG
// the operator offered as a fallback is intentionally NOT added: it is the same
// wordmark art this loop already animates, so a second still card would only
// duplicate the loop (verdict recorded in the P21b report).
const memeLoop = media("venture/meme/meme-loop.mp4")
  ? {
      mp4: `${base}/media/venture/meme/meme-loop.mp4${mtimeV("venture/meme/meme-loop.mp4")}`,
      poster: bust("venture/meme/meme-poster", pair("venture/meme/meme-poster")),
    }
  : undefined;

// the pebble-beach proof (with its owner-endorsement context) relocates from
// the rooms list to chapter 02. P12-KO — workshop-coverage (KO Law) ALSO leaves
// this list: it now has its own venture story + a linked rail card above, so the
// card carries that proof instead of an unlinked line here (the same claim is
// never rendered twice on this page).
const pebbleRoom = p.rooms.items.find((r) => r.proof.relationshipId === "pebble-beach");
const HANDLED_ELSEWHERE = new Set(["pebble-beach", "workshop-coverage"]);
const otherRooms = p.rooms.items.filter((r) => !HANDLED_ELSEWHERE.has(r.proof.relationshipId));

// scattered ghost letters are drawn FROM the page's own words (presentational
// letterforms, not new copy): the hero scatters STORY.
const heroGhost = ["S", "T", "O", "R", "Y"]; // P12.3 — from "business stories"

// P13c — the coverage index: editorial tiles to the published venture stories.
// slate + title strings are COPIED VERBATIM from each article page's own
// frontmatter/markup (already operator-flagged there) — reuse adds no new copy.
const coverage = [
  { href: "/venture/seriesfest-2026", slate: "SeriesFest · May 7–8, 2026 · Denver, CO", title: "SeriesFest 2026 — a venture story" },
  { href: "/venture/seriesfest-2025", slate: "SeriesFest · Apr 30 – May 4, 2025 · Denver, CO", title: "SeriesFest 2025 — a venture story" },
  { href: "/venture/seriesfest-2026-fashion-in-focus", slate: "SeriesFest · Fashion in Focus · Mar 7, 2026 · Denver, CO", title: "SeriesFest 2026 · Fashion in Focus — a venture story" },
  { href: "/venture/seriesfest-2026-soul-power", slate: "SeriesFest · Soul Power ABA Premiere · Feb 18, 2026 · Denver, CO", title: "SeriesFest 2026 · Soul Power ABA Premiere — a venture story" },
  { href: "/venture/afm-2025", slate: "American Film Market · Nov 8–15, 2025 · Los Angeles, CA", title: "American Film Market 2025 — a venture story" },
  // P12-KO — the KO Law workshops venture story. slate + title copied VERBATIM
  // from the article page's own ARTICLE block (already operator-flagged there;
  // reuse adds no new copy here). Card image resolves as venture/<slug>/hero-900.
  { href: "/venture/ko-law-workshops", slate: "KO LAW · STARTUP WORKSHOP SERIES · 2026", title: "Four startup workshops, on camera." },
  { href: "/venture/amazing-aerial", slate: "AMAZING AERIAL AGENCY · SINCE MID-2024", title: "The agency that takes my aerials to market." },
  // P14b — the MEME venture story (slate + title copied verbatim from the
  // article page's own frontmatter; reuse adds no new copy here).
  { href: "/venture/meme", slate: "MEME · MAKESHIFT ENTERTAINMENT MEDIA EDUCATION", title: "The most formal role I hold in this world." },
];

// P12.6b — the STORY RAIL cards: the coverage stories PLUS the emerging film
// venture, as one user-driven horizontal carousel (operator's idea — no
// auto-rotate). Each card resolves its own hero frame; the conceptual cards
// (amazing-aerial, MEME, and the film venture) have no event export, so they
// render as ghost-letter cards in the chapter-03 typographic style.
const railGhosts: Record<string, string> = {
  "amazing-aerial": "AERIAL",
  meme: "MEME",
  "makeshift-film-group": "MAKESHIFT",
};
// The film-venture card mirrors its page's HELD-FROM-PUBLISH interlock (see
// /venture/makeshift-film-group.astro): that page builds as a redirect until
// the operator (1) updates the honesty ledger and (2) builds with
// PUBLISH_MFG=true — so the card only renders under the SAME condition, else
// its "Read the story" button would bounce visitors back to this page.
const PUBLISH_MFG = import.meta.env.DEV || process.env.PUBLISH_MFG === "true";
const mfgCard = PUBLISH_MFG
  ? [
      // ⚠ OPERATOR READ-APPROVAL REQUIRED — new copy, staging-only until read.
      // HONESTY NOTE: the entity's full name is a hard-excluded audit term
      // (scripts/audit-lib.mjs FORBIDDEN_TERMS), so the visible slate + title
      // deliberately avoid it; only the hyphenated href (audit-safe) carries
      // the route. Operator to confirm the naming and whether that exclusion lifts.
      { href: "/venture/makeshift-film-group", slate: "MAKESHIFT", title: "A film venture, taking shape." },
    ]
  : [];
const railCards = [...coverage, ...mfgCard].map((c) => {
  const slug = c.href.replace(/^\/venture\//, "");
  return { ...c, slug, img: bust(`venture/${slug}/hero-900`, pair(`venture/${slug}/hero-900`)), ghost: railGhosts[slug] };
});

// chapter ground colors — the reference's jewel-tone ride, our dark family.
// P13c — meme ground removed (the S2 statement is now chapter 03); ch03 added.
const GROUNDS = {
  intro: "#101020",
  hire: "#12182b", // P29 — the E1b services/floors chapter
  ch01: "#191031",
  ch02: "#261118",
  ch03: "#0e2230",
  rooms: "#10141f",
  handoff: "#0f1118",
};
---

<Base title={p.meta.title} description={p.meta.description}>
  <!-- the morphing ground: fixed behind everything; the engine animates its
       color between chapters. Until the engine mounts (adds .im-live), each
       section paints its OWN ground — no-JS never sees a wrong color. -->
  <div class="im-ground" data-im-ground aria-hidden="true" style={`background:${GROUNDS.intro}`}></div>

  <main class="im" data-im>
    <!-- ═══ S1 · INTRODUCTION — the typographic collage hero ═══ -->
    <section class="im-sec im-intro" data-im-section data-ground={GROUNDS.intro} style={`--sec-ground:${GROUNDS.intro}`}>
      <div class="im-ghosts" aria-hidden="true">
        {heroGhost.map((ch, i) => <span class="im-ghost" data-im-ghost style={`--gi:${i}`}>{ch}</span>)}
      </div>
      <p class="hud-label im-kicker" data-reveal>{p.hero.eyebrow}</p>
      <!-- P12.3 — the VENTURE headline, composed in the reference's two
           voices: "The venture in adventure." — the pun carried by the caps,
           the connectives by the serif italic. Copy from consts (pending
           operator read-approval; see the review block there). -->
      <h1 class="im-headline" data-reveal>
        <span class="im-line"><span class="im-turn">The</span> VENTURE</span>
        <span class="im-line im-line--push"><span class="im-turn">in</span> ADVENTURE.</span>
      </h1>
      <p class="im-turn im-intro-sub" data-reveal>{p.hero.subline}</p>
    </section>

    <!-- ═══ E1b · HIRE THIS LANE (P29 money-now) — the corporate-storytelling
         services + floors, ahead of the portfolio chapters so a buyer gets
         numbers and a booking link before the art. Prices resolve verbatim
         from existing staged floors (see frontmatter); trust lines from
         SITE.trust (⚠ OPERATOR-CONFIRM flags in consts). ═══ -->
    <section class="im-sec im-hire" data-im-section data-ground={GROUNDS.hire} style={`--sec-ground:${GROUNDS.hire}`}>
      <p class="hud-label im-kicker" data-reveal>{p.services.kicker}</p>
      <h2 class="im-title im-hire-title" data-reveal>
        <span class="im-line"><span class="im-turn">Hire</span> THIS LANE</span>
      </h2>
      <p class="im-turn im-hire-intro" data-reveal>{p.services.intro}</p>
      <div class="im-hire-grid">
        {
          p.services.items.map((item) => (
            <article class="im-hire-card" data-reveal data-reveal-stagger="80">
              <h3 class="im-hire-name">{item.name}</h3>
              <p class="im-hire-price">{svcPrice(item)}</p>
              <p class="im-hire-scope">scoped per engagement</p>
              <p class="im-hire-line im-turn">{item.line}</p>
            </article>
          ))
        }
      </div>
      <p class="im-hire-note im-turn" data-reveal>{p.services.note}</p>
      <div class="im-hire-actions" data-reveal>
        <a href={href(p.services.cta.href)} class="im-cta" rel="noopener">
          <span class="im-cta-label">{p.services.cta.label}</span>
          <span class="im-cta-arrow" aria-hidden="true">→</span>
        </a>
        <p class="im-hire-trust hud-label">
          {SITE.trust.response} · {SITE.trust.base} · {SITE.trust.travel}
        </p>
      </div>
    </section>

    <!-- ═══ S3 · THE WORK CHAPTERS — numbered, grounded, collaged ═══
         P13c — the old S2 MEME statement moved into chapter 03 below (no dup). -->

    <section class="im-sec im-chapter" data-im-section data-ground={GROUNDS.ch01} style={`--sec-ground:${GROUNDS.ch01}`}>
      <span class="im-index im-turn" aria-hidden="true">01</span>
      <span class="im-index im-index--of im-turn" aria-hidden="true">/03</span>
      <div class="im-chapter-stage">
        <div class="im-collage im-collage--pb" aria-hidden="true">
          {
            pbPoster && (
              // P21b — the hover-video now rides a LANDSCAPE card (its poster/loop
              // are native 16:9; the old tall 9:14 crop was the vertical the
              // operator flagged). Still a clickable hover-video link to the case
              // page — Boulder Chamber room energy, the collage's anchor.
              <a
                class="im-card im-pb-video im-card--link"
                href={`${base}/work/pitchboulder`}
                data-im-card
                data-depth="1.15"
                tabindex="-1"
              >
                <picture>
                  {pbPoster.avif && <source srcset={pbPoster.avif} type="image/avif" />}
                  <img src={pbPoster.webp ?? pbPoster.avif} alt="" loading="lazy" decoding="async" />
                </picture>
                {pbLoop && <video class="im-loop" data-im-loop data-loop-src={pbLoop} muted loop playsinline preload="none" />}
              </a>
            )
          }
          {
            /* P21b — three frames ring the video across TWO venues: a wide
               co-working crowd-energy frame (Venue B, top-right), a Boulder
               Chamber brand moment (Venue A, square, lower-left), and a
               co-working presenter mid-talk (Venue B, lower-right). */
          }
          {
            pbCrowd && (
              <figure class="im-card im-pb-crowd" data-im-card data-depth="0.65">
                <picture>
                  {pbCrowd.avif && <source srcset={pbCrowd.avif} type="image/avif" />}
                  <img src={pbCrowd.webp ?? pbCrowd.avif} alt="" loading="lazy" decoding="async" />
                </picture>
              </figure>
            )
          }
          {
            pbPresenter && (
              <figure class="im-card im-pb-brand" data-im-card data-depth="1.7">
                <picture>
                  {pbPresenter.avif && <source srcset={pbPresenter.avif} type="image/avif" />}
                  <img src={pbPresenter.webp ?? pbPresenter.avif} alt="" loading="lazy" decoding="async" />
                </picture>
              </figure>
            )
          }
          {
            pbTalk && (
              <figure class="im-card im-pb-talk" data-im-card data-depth="1.1">
                <picture>
                  {pbTalk.avif && <source srcset={pbTalk.avif} type="image/avif" />}
                  <img src={pbTalk.webp ?? pbTalk.avif} alt="" loading="lazy" decoding="async" />
                </picture>
              </figure>
            )
          }
        </div>
        <div class="im-chapter-type">
          <!-- heading "PitchBoulder", split at its own seam — her TWIN/MOTION -->
          <h2 class="im-title" data-reveal>
            <span class="im-line">PITCH</span>
            <span class="im-line im-line--push">BOULDER</span>
          </h2>
          <p class="im-turn im-tag" data-reveal>{p.pitchboulder.proof.context}</p>
        </div>
        <div class="im-chapter-meta" data-reveal>
          <LegendMark proof={p.pitchboulder.proof} />
          <div class="im-quote">
            <Testimonial testimonialId={p.pitchboulder.testimonialId} showProof={false} />
          </div>
          {/* P12.6b — the unmissable story CTA (operator: the old links were
              "so buried people just scroll past"). ⚠ OPERATOR READ-APPROVAL
              REQUIRED — new copy "Read the full story", staging-only until read. */}
          <a href={`${base}/work/pitchboulder`} class="im-cta">
            <span class="im-cta-label">Read the full story</span>
            <span class="im-cta-arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <section class="im-sec im-chapter" data-im-section data-ground={GROUNDS.ch02} style={`--sec-ground:${GROUNDS.ch02}`}>
      <span class="im-index im-turn" aria-hidden="true">02</span>
      <span class="im-index im-index--of im-turn" aria-hidden="true">/03</span>
      <div class="im-chapter-stage">
        <div class="im-collage im-collage--sh" aria-hidden="true">
          {
            shOnSet && (
              // P13c — real on-set still (crew filming the car); wide card is the
              // clickable hover-video link to the case page
              <a
                class="im-card im-sh-onset im-card--link"
                href={`${base}${shHref}`}
                data-im-card
                data-depth="1.2"
                tabindex="-1"
              >
                <picture>
                  {shOnSet.avif && <source srcset={shOnSet.avif} type="image/avif" />}
                  <img src={shOnSet.webp ?? shOnSet.avif} alt="" loading="lazy" decoding="async" />
                </picture>
                {shLoop && <video class="im-loop" data-im-loop data-loop-src={shLoop} muted loop playsinline preload="none" />}
              </a>
            )
          }
          {shDawn && (
            <figure class="im-card im-sh-dawn" data-im-card data-depth="0.6">
              <picture>
                {shDawn.avif && <source srcset={shDawn.avif} type="image/avif" />}
                <img src={shDawn.webp ?? shDawn.avif} alt="" loading="lazy" decoding="async" />
              </picture>
            </figure>
          )}
          {shLawn && (
            <figure class="im-card im-sh-lawn" data-im-card data-depth="1.5">
              <picture>
                {shLawn.avif && <source srcset={shLawn.avif} type="image/avif" />}
                <img src={shLawn.webp ?? shLawn.avif} alt="" loading="lazy" decoding="async" />
              </picture>
            </figure>
          )}
          {shHeritage && (
            <figure class="im-card im-sh-heritage" data-im-card data-depth="1.8">
              <picture>
                {shHeritage.avif && <source srcset={shHeritage.avif} type="image/avif" />}
                <img src={shHeritage.webp ?? shHeritage.avif} alt="" loading="lazy" decoding="async" />
              </picture>
            </figure>
          )}
          {shEngine && (
            <figure class="im-card im-sh-engine" data-im-card data-depth="1.0">
              <picture>
                {shEngine.avif && <source srcset={shEngine.avif} type="image/avif" />}
                <img src={shEngine.webp ?? shEngine.avif} alt="" loading="lazy" decoding="async" />
              </picture>
            </figure>
          )}
        </div>
        <div class="im-chapter-type">
          <!-- the WORK item's title verbatim, giant word carried by the caps:
               "A restored Shelby at Pebble Beach" -->
          <h2 class="im-title" data-reveal>
            <span class="im-line"><span class="im-turn">A restored</span> SHELBY</span>
            <span class="im-line im-line--push"><span class="im-turn">at</span> PEBBLE BEACH</span>
          </h2>
          {pebbleRoom && <p class="im-turn im-tag" data-reveal>{pebbleRoom.proof.context}</p>}
        </div>
        <div class="im-chapter-meta" data-reveal>
          {pebbleRoom && <LegendMark proof={pebbleRoom.proof} />}
          {/* P29 — the Jack Bell testimonial, ACTIVATED per operator (consts
              TESTIMONIALS[1]): the owner's own words beside the owner's story. */}
          {
            pebbleRoom?.testimonialId && (
              <div class="im-quote">
                <Testimonial testimonialId={pebbleRoom.testimonialId} showProof={false} />
              </div>
            )
          }
          {
            shelby?.href && (
              /* P12.6b — same unmissable story CTA. ⚠ OPERATOR READ-APPROVAL
                 REQUIRED — new copy "Read the full story", staging-only. */
              <a href={`${base}${shelby.href}`} class="im-cta">
                <span class="im-cta-label">Read the full story</span>
                <span class="im-cta-arrow" aria-hidden="true">→</span>
              </a>
            )
          }
        </div>
      </div>
    </section>

    <!-- ═══ CHAPTER 03 · MEME — typographic (no collage); the S2 statement,
         now numbered into the chapter sequence. Title lockup + tag + proof. ═══ -->
    <section class="im-sec im-chapter im-chapter--type" data-im-section data-ground={GROUNDS.ch03} style={`--sec-ground:${GROUNDS.ch03}`}>
      <span class="im-index im-turn" aria-hidden="true">03</span>
      <span class="im-index im-index--of im-turn" aria-hidden="true">/03</span>
      <div class="im-chapter-stage">
        <div class="im-chapter-type">
          <h2 class="im-title" data-reveal>
            <span class="im-line">MEME</span>
          </h2>
          <!-- meme.body verbatim: "The role I hold most formally in this world." -->
          <p class="im-turn im-tag" data-reveal>{p.meme.body}</p>
        </div>
        {
          /* P21b — the org's own logo animatic joins this typographic chapter as
             an AMBIENT framed card (operator: "you can use the video I gave you").
             Poster-first (the still is the permanent base layer — no-JS / reduced-
             motion / Save-Data all land here); the muted loop fades in over it and
             plays ONLY while on-screen (the ambient-loop script below, gated like
             /venture/meme.astro). No caption — it sits as the mark, in motion,
             inside the composition; the typography above/below is untouched. */
        }
        {
          memeLoop && (
            <figure class="im-meme-loop" data-reveal>
              <picture>
                {memeLoop.poster?.avif && <source type="image/avif" srcset={memeLoop.poster.avif} />}
                <img
                  class="im-meme-loop-poster"
                  src={memeLoop.poster?.webp ?? memeLoop.poster?.avif}
                  alt="The MEME logo — a filmstrip-lettered M, on a deep blue textured ground."
                  loading="lazy"
                  decoding="async"
                />
              </picture>
              <video
                class="im-loop im-meme-loop-vid"
                data-im-amb
                data-loop-src={memeLoop.mp4}
                muted
                loop
                playsinline
                preload="none"
                aria-hidden="true"
              ></video>
            </figure>
          )
        }
        <div class="im-chapter-meta" data-reveal>
          <LegendMark proof={p.meme.proof} />
          {/* P12.6b — MEME gets the primary story CTA (→ its venture story) plus
              a secondary text link out to the org. ⚠ OPERATOR READ-APPROVAL
              REQUIRED — new copy "Read the full story", staging-only until read. */}
          <a href={`${base}/venture/meme`} class="im-cta">
            <span class="im-cta-label">Read the full story</span>
            <span class="im-cta-arrow" aria-hidden="true">→</span>
          </a>
          <a href="https://www.meme.ngo" rel="noopener" target="_blank" class="link im-cta-secondary">
            About the organization <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ S4 · THE STORY RAIL — the venture stories as a user-driven carousel
         (operator's idea; no auto-rotate). Native overflow-x + scroll-snap works
         with ZERO JS (native swipe on touch); a pointer-drag enhancement and a
         "drag →" affordance layer on top for fine pointers. Replaces the retired
         "rooms" list + coverage grid — the same stories, one honest rail. ═══ -->
    <section class="im-sec im-rail-sec" data-im-section data-ground={GROUNDS.rooms} style={`--sec-ground:${GROUNDS.rooms}`}>
      <div class="im-ghosts im-ghosts--rooms" aria-hidden="true">
        <span class="im-confetti" data-im-confetti style="--ci:0"></span>
        <span class="im-confetti" data-im-confetti style="--ci:1"></span>
        <span class="im-confetti" data-im-confetti style="--ci:2"></span>
        <span class="im-confetti" data-im-confetti style="--ci:3"></span>
      </div>
      {/* ⚠ OPERATOR READ-APPROVAL REQUIRED — new copy (kicker + intro),
          staging-only until read. */}
      <p class="hud-label im-kicker" data-reveal>More venture stories</p>
      <p class="im-turn im-rail-intro" data-reveal>
        More of the industry I stay close to — each one marked at exactly what it is.
      </p>

      <div class="im-rail-wrap">
        <p class="im-rail-hint hud-label" aria-hidden="true">drag →</p>
        <ul class="im-rail" data-im-rail>
          {
            railCards.map((c) => (
              <li class="im-rail-card">
                <a class="im-rail-link" href={`${base}${c.href}`} data-reveal data-reveal-stagger="55">
                  <span class="im-rail-media">
                    {c.img ? (
                      <picture>
                        {c.img.avif && <source srcset={c.img.avif} type="image/avif" />}
                        <img src={c.img.webp ?? c.img.avif} alt="" loading="lazy" decoding="async" />
                      </picture>
                    ) : (
                      <span class="im-rail-ghost">{c.ghost ?? ""}</span>
                    )}
                  </span>
                  <span class="im-rail-slate hud-label">{c.slate}</span>
                  <span class="im-rail-title im-turn">{c.title}</span>
                  {/* decorative — the WHOLE card is the link. ⚠ OPERATOR
                      READ-APPROVAL REQUIRED — new copy "Read the story". */}
                  <span class="im-cta im-cta--sm im-rail-cta">
                    <span class="im-cta-label">Read the story</span>
                    <span class="im-cta-arrow" aria-hidden="true">→</span>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- the honesty proofs that lived in the rooms list: seriesfest + afm
           folded here as a compact list. (pebble-beach moved to chapter 02;
           workshop-coverage / KO Law now has its own linked story card in the
           rail above, so it left this list — the claim renders once, on the
           card's article.) Verbatim permittedPhrasing via LegendMark. -->
      <ul class="im-rail-proofs" aria-label="How close each relationship is">
        {
          otherRooms.map((room) => (
            <li data-reveal data-reveal-stagger="70">
              <LegendMark proof={room.proof} />
            </li>
          ))
        }
      </ul>
    </section>

    <!-- ═══ S5 · HANDOFF — P29: closes on this lane's OWN buyer action
         (Calendly direct), not a consulting handoff. ═══ -->
    <section class="im-sec im-handoff" data-im-section data-ground={GROUNDS.handoff} style={`--sec-ground:${GROUNDS.handoff}`}>
      <p class="im-turn im-handoff-line" data-reveal>{p.handoff.body}</p>
      <a href={href(p.handoff.cta.href)} class="btn" data-reveal rel="noopener">{p.handoff.cta.label}</a>
    </section>
  </main>
</Base>

<style>
  /* ── the morphing ground ── */
  .im-ground {
    position: fixed;
    inset: 0;
    z-index: -1;
    transition: none; /* GSAP owns the morph; CSS must not fight it */
  }
  .im-sec {
    position: relative;
    background: var(--sec-ground); /* static fallback ground per section */
    overflow: clip;
  }
  /* once the engine is live, sections go clear and the fixed ground shows
     through — the color RIDES between chapters instead of cutting */
  :global(html.js) .im-live .im-sec {
    background: transparent;
  }

  /* ── the two reference voices, our faces ── */
  .im-headline,
  .im-statement,
  .im-title {
    font-family: var(--font-sans);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.96;
    letter-spacing: 0.008em;
    color: #f2f4f8;
  }
  .im-turn {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    color: #eef1f6;
  }
  .im-kicker {
    letter-spacing: 0.3em;
    color: color-mix(in srgb, #e8f6f3 78%, transparent);
  }

  /* ── S1 intro ── */
  .im-intro {
    min-height: 92svh;
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 1.6rem;
    padding: 7rem 2rem 6rem;
    text-align: center;
  }
  .im-headline {
    font-size: clamp(3rem, 9.5vw, 9.5rem);
    display: grid;
    gap: 0.05em;
  }
  .im-headline .im-turn,
  .im-title .im-turn {
    font-size: 0.42em;
    vertical-align: 0.22em;
    margin-inline: 0.12em;
  }
  .im-line {
    display: block;
  }
  .im-line--push {
    transform: translateX(6vw);
  }
  .im-intro-sub {
    max-width: 34rem;
    font-size: clamp(1.15rem, 1.7vw, 1.5rem);
    line-height: 1.45;
    justify-self: end;
    text-align: right;
    margin-top: 1.5rem;
  }
  /* ghost letters: final resting places are set here (no-JS = already home);
     the engine only ADDS the scatter-and-assemble journey */
  .im-ghosts {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .im-ghost {
    position: absolute;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(6rem, 16vw, 15rem);
    color: color-mix(in srgb, #ffffff 7%, transparent);
    line-height: 1;
  }
  .im-ghost:nth-child(1) { left: 6%; top: 14%; }
  .im-ghost:nth-child(2) { left: 26%; top: 62%; }
  .im-ghost:nth-child(3) { left: 48%; top: 8%; }
  .im-ghost:nth-child(4) { left: 68%; top: 58%; }
  .im-ghost:nth-child(5) { left: 86%; top: 22%; }

  /* ── P29 · E1b hire this lane — floors + booking in the page's own plate
     grammar: jewel-ground section, near-solid plate cards (AA-safe over the
     morphing ground), Fraunces numerals for the floors. ── */
  .im-hire {
    padding: 5.5rem clamp(1.5rem, 6vw, 8rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-content: center;
    gap: 1.2rem;
  }
  .im-hire-title {
    font-size: clamp(2.2rem, 6vw, 5.5rem);
  }
  .im-hire-intro {
    font-size: clamp(1.15rem, 1.7vw, 1.5rem);
    line-height: 1.45;
    max-width: 44rem;
  }
  .im-hire-grid {
    display: grid;
    gap: 1rem;
    margin-top: 0.8rem;
  }
  @media (min-width: 860px) {
    .im-hire-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .im-hire-card {
    display: grid;
    gap: 0.45rem;
    align-content: start;
    padding: 1.4rem 1.5rem;
    background: color-mix(in srgb, var(--sec-ground, #12182b) 90%, #000 10%);
    border: 1px solid color-mix(in srgb, #ffffff 9%, transparent);
    border-radius: 10px;
    box-shadow: 0 22px 60px -30px rgba(0, 0, 0, 0.7);
  }
  .im-hire-name {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.05rem;
    line-height: 1.25;
    color: #f2f4f8;
  }
  .im-hire-price {
    font-family: var(--font-display);
    font-weight: 560;
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    line-height: 1.1;
    font-variant-numeric: lining-nums tabular-nums;
    color: var(--color-accent, #38f8ec);
  }
  .im-hire-scope {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, #e8f6f3 55%, transparent);
  }
  .im-hire-line {
    font-size: 1.02rem;
    line-height: 1.45;
  }
  .im-hire-note {
    font-size: 1.05rem;
    color: color-mix(in srgb, #eef1f6 80%, transparent);
  }
  .im-hire-actions {
    display: grid;
    gap: 0.8rem;
    justify-items: start;
    margin-top: 0.4rem;
  }
  .im-hire-trust {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    color: color-mix(in srgb, #e8f6f3 62%, transparent);
  }

  /* ── S3 chapters ──
     P23 — dead air deliberately compressed: the section was 130svh tall with
     10rem end-padding and a 90svh stage, which stacked into large empty voids
     above and below the (already dramatic) titles. The giant title scale is
     UNTOUCHED — only the surrounding air is removed. */
  .im-chapter {
    min-height: 96svh;
    padding: 5.5rem clamp(1.5rem, 6vw, 7rem);
  }
  .im-index {
    position: sticky;
    top: 5.5rem;
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    float: left;
    color: color-mix(in srgb, #ffffff 85%, transparent);
  }
  .im-index--of {
    float: right;
    top: 70vh;
  }
  .im-chapter-stage {
    position: relative;
    max-width: 78rem;
    margin-inline: auto;
    min-height: 72svh;
    display: grid;
    align-content: center;
    gap: 0.4rem;
  }
  .im-collage {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .im-card {
    position: absolute;
    margin: 0;
    overflow: hidden;
    border-radius: 6px;
    box-shadow: 0 24px 80px -24px rgba(0, 0, 0, 0.55);
  }
  .im-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* P13c — the two case cards are clickable hover-video links: pointer-events
     back on (the collage is otherwise none), and a muted loop fades over the
     still on hover. Mounts on first pointerenter (see the hover-life script). */
  .im-card--link {
    display: block;
    pointer-events: auto;
    cursor: pointer;
    text-decoration: none;
  }
  .im-loop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 500ms var(--ease-survey, ease);
    pointer-events: none;
  }
  .im-card--link.is-looping .im-loop {
    opacity: 1;
  }

  /* ── P21b · chapter-01 (PitchBoulder) collage geometry — a venue MIX ringing
     the LANDSCAPE hover-video (no tall 9:14 vertical anymore). Varied aspect
     ratios that still fit the .im-card grammar: 16:10 video, 3:2 crowd, 1:1
     brand, 4:3 talk. ── */
  .im-pb-video { width: clamp(240px, 33vw, 500px); aspect-ratio: 16 / 10; left: 1%; top: 5%; }
  .im-pb-crowd { width: clamp(210px, 28vw, 430px); aspect-ratio: 3 / 2; right: 1%; top: 8%; }
  .im-pb-brand { width: clamp(140px, 17vw, 260px); aspect-ratio: 1 / 1; left: 5%; bottom: 5%; }
  .im-pb-talk  { width: clamp(180px, 22vw, 350px); aspect-ratio: 4 / 3; right: 4%; bottom: 6%; }

  /* ── P21b · chapter-02 (Shelby) collage geometry — FIVE frames scattered so
     they ring the centered title without crowding it: the on-set hover-video
     (16:10) top-right, a dawn tall (9:14) at the left edge, an elevated lawn/
     coast frame (16:10) bottom-left, a heritage frame (4:3) bottom-right, and a
     small engine-detail accent (4:3) tucked into the upper-center gap. ── */
  .im-sh-onset    { width: clamp(240px, 31vw, 460px); aspect-ratio: 16 / 10; right: 1%; top: 6%; }
  .im-sh-dawn     { width: clamp(150px, 18vw, 280px); aspect-ratio: 9 / 14; left: 1%; top: 4%; }
  .im-sh-lawn     { width: clamp(210px, 26vw, 400px); aspect-ratio: 16 / 10; left: 3%; bottom: 5%; }
  .im-sh-heritage { width: clamp(150px, 17vw, 260px); aspect-ratio: 4 / 3; right: 4%; bottom: 6%; }
  .im-sh-engine   { width: clamp(120px, 14vw, 210px); aspect-ratio: 4 / 3; left: 30%; top: 3%; }
  .im-chapter-type {
    position: relative;
    z-index: 2;
    text-align: center;
  }
  .im-title {
    font-size: clamp(2.6rem, 8vw, 8rem);
    display: grid;
    gap: 0.04em;
  }
  /* P23 — the short context line (ch01 PitchBoulder summary, ch02 the car
     owner's endorsement) used to float as small italic directly over the busy
     collage — the operator flagged it as unreadable. It now sits on a real,
     near-solid plate in the chapter's own ground color (fully occludes the
     imagery behind it → AA-safe light-on-dark), a notch larger, right-aligned
     as a caption block under the title. --sec-ground is the per-section inline
     var, so the plate keeps the jewel tone even after the ground morphs. */
  .im-tag {
    width: fit-content;
    max-width: min(92%, 42rem);
    margin: 1.3rem 0 0 auto;
    padding: 0.72rem 1.15rem;
    font-size: clamp(1.15rem, 1.7vw, 1.55rem);
    line-height: 1.42;
    text-align: right;
    background: color-mix(in srgb, var(--sec-ground, #191031) 90%, #000 10%);
    border: 1px solid color-mix(in srgb, #ffffff 9%, transparent);
    border-radius: 8px;
    box-shadow: 0 18px 50px -26px rgba(0, 0, 0, 0.7);
  }
  /* P23 — the proof line + testimonial + CTA also lifted onto a plate so none
     of the small type ever fights the collage underneath. */
  .im-chapter-meta {
    position: relative;
    z-index: 2;
    margin-top: 2.2rem;
    max-width: 36rem;
    display: grid;
    gap: 1rem;
    padding: 1.4rem 1.5rem;
    background: color-mix(in srgb, var(--sec-ground, #191031) 90%, #000 10%);
    border: 1px solid color-mix(in srgb, #ffffff 9%, transparent);
    border-radius: 10px;
    box-shadow: 0 22px 60px -30px rgba(0, 0, 0, 0.7);
  }
  .im-quote {
    font-style: italic;
  }

  /* ── P21b · chapter-03 (MEME) ambient logo loop — a framed 16:9 moment set
     into the typographic chapter (title + tag above, proof + CTAs below). The
     poster is the permanent base layer; the muted video reuses .im-loop and
     fades in over it while on-screen. Mirrors /venture/meme.astro's framing so
     the two pages read as one room. ── */
  .im-meme-loop {
    position: relative;
    z-index: 2;
    width: min(100%, 30rem);
    margin: 2.4rem auto 0.4rem;
    border: 1px solid color-mix(in srgb, #ffffff 14%, transparent);
    border-radius: 10px;
    overflow: hidden;
    background: color-mix(in srgb, #ffffff 4%, transparent);
    box-shadow: 0 0 34px -12px color-mix(in srgb, var(--color-accent, #38f8ec) 38%, transparent);
  }
  .im-meme-loop-poster {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .im-meme-loop.is-playing .im-loop {
    opacity: 1;
  }

  /* ── P12.6b · the shared "story CTA" — one bold, unmissable treatment used
     below every chapter's text block and (smaller) on every rail card. Space
     Mono caps, ≥44px tall, arrow slides 6px + subtle accent fill on hover. ── */
  .im-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 44px;
    width: fit-content;
    padding: 0.85rem 1.5rem;
    border: 1px solid color-mix(in srgb, #ffffff 32%, transparent);
    border-radius: 4px;
    /* P23 — the same chamfered corner as the global .btn kit, so the venture
       story CTAs read as one family with the rest of the site. */
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%);
    background: color-mix(in srgb, #ffffff 3%, transparent);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #f2f4f8;
    text-decoration: none;
    transition:
      background 320ms var(--ease-survey, ease),
      border-color 320ms ease,
      filter 320ms ease;
  }
  .im-cta:hover,
  .im-cta:focus-visible {
    background: color-mix(in srgb, var(--color-accent, #38f8ec) 16%, transparent);
    border-color: color-mix(in srgb, var(--color-accent, #38f8ec) 62%, transparent);
    /* glow follows the chamfer (drop-shadow, not box-shadow) */
    filter: drop-shadow(0 0 16px color-mix(in srgb, var(--color-accent, #38f8ec) 42%, transparent));
  }
  .im-cta-arrow {
    color: var(--color-accent, #38f8ec);
    font-size: 1.05em;
    transition: transform 320ms var(--ease-survey, ease);
  }
  .im-cta:hover .im-cta-arrow,
  .im-cta:focus-visible .im-cta-arrow {
    transform: translateX(6px);
  }
  /* the MEME secondary link sits quiet under its primary button */
  .im-cta-secondary {
    font-size: 0.9rem;
    justify-self: start;
  }
  /* smaller scale for the story-rail cards */
  .im-cta--sm {
    min-height: 40px;
    padding: 0.55rem 1rem;
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    gap: 0.7rem;
  }

  /* ── P12.6b · S4 THE STORY RAIL — the coverage stories as a user-driven
     horizontal carousel. Native overflow-x + scroll-snap (no-JS baseline);
     pointer-drag + "drag →" hint enhance on top. ── */
  .im-rail-sec {
    min-height: 100svh;
    padding: 9rem clamp(1.5rem, 6vw, 8rem);
    display: grid;
    /* minmax(0, 1fr) is load-bearing: without the 0 min-track, the flex rail's
       content width (all cards) would blow the column — and the page — wide.
       This pins the column to the section width so the rail scrolls instead. */
    grid-template-columns: minmax(0, 1fr);
    align-content: center;
    gap: 1.4rem;
  }
  .im-rail-intro {
    font-size: clamp(1.3rem, 2vw, 1.7rem);
    max-width: 44rem;
  }
  .im-rail-wrap {
    position: relative;
    margin-top: 0.6rem;
    min-width: 0; /* let the wrap shrink to the column, so overflow-x can scroll */
  }
  .im-rail-hint {
    position: absolute;
    right: 0.2rem;
    top: -1.7rem;
    font-size: 0.6rem;
    letter-spacing: 0.24em;
    color: color-mix(in srgb, #e8f6f3 55%, transparent);
  }
  .im-rail {
    display: flex;
    gap: 1.1rem;
    list-style: none;
    margin: 0;
    padding: 0 0 1.4rem;
    overflow-x: auto;
    scroll-snap-type: x proximity;
    overscroll-behavior-x: contain;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: color-mix(in srgb, #ffffff 22%, transparent) transparent;
  }
  /* JS marks the rail draggable on fine pointers (grab cursor); dragging kills
     snap so the throw feels direct. */
  .im-rail.is-draggable { cursor: grab; }
  .im-rail.is-dragging { cursor: grabbing; scroll-snap-type: none; user-select: none; }
  .im-rail-card {
    flex: 0 0 clamp(240px, 78vw, 336px); /* one card + a peek on ~390px screens */
    scroll-snap-align: start;
  }
  .im-rail-link {
    display: grid;
    gap: 0.7rem;
    height: 100%;
    align-content: start;
    padding: 0.9rem;
    border: 1px solid color-mix(in srgb, #ffffff 13%, transparent);
    border-radius: 10px;
    background: color-mix(in srgb, #ffffff 2.5%, transparent);
    text-decoration: none;
    color: inherit;
    transition:
      transform 380ms var(--ease-survey, ease),
      border-color 380ms ease,
      background 380ms ease;
  }
  .im-rail-link:hover,
  .im-rail-link:focus-visible {
    transform: translateY(-5px);
    border-color: color-mix(in srgb, #ffffff 30%, transparent);
    background: color-mix(in srgb, #ffffff 5%, transparent);
  }
  .im-rail-media {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 16 / 10;
    border-radius: 6px;
    overflow: hidden;
    background: color-mix(in srgb, #ffffff 6%, transparent);
  }
  .im-rail-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* typographic (ghost-letter) card — chapter-03 style for the conceptual
     stories that have no event photo (AERIAL / MEME / the film venture). */
  .im-rail-ghost {
    font-family: var(--font-sans);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(1.8rem, 5.5vw, 2.9rem);
    letter-spacing: 0.04em;
    line-height: 1;
    color: color-mix(in srgb, #ffffff 16%, transparent);
  }
  .im-rail-slate {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: color-mix(in srgb, #e8f6f3 72%, transparent);
  }
  .im-rail-title {
    font-size: clamp(1.1rem, 1.5vw, 1.32rem);
    line-height: 1.24;
  }
  .im-rail-cta {
    margin-top: 0.2rem;
    pointer-events: none; /* decorative; the card <a> owns the click */
  }
  /* the card-link hover drives its decorative CTA (fill + 6px arrow slide) */
  .im-rail-link:hover .im-cta,
  .im-rail-link:focus-visible .im-cta {
    background: color-mix(in srgb, var(--color-accent, #38f8ec) 16%, transparent);
    border-color: color-mix(in srgb, var(--color-accent, #38f8ec) 62%, transparent);
  }
  .im-rail-link:hover .im-cta-arrow,
  .im-rail-link:focus-visible .im-cta-arrow {
    transform: translateX(6px);
  }
  .im-rail-proofs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem 2.2rem;
    list-style: none;
    padding: 0;
    margin: 1.6rem 0 0;
  }

  /* ── S4 story-rail ambient: confetti drift (abstract shapes, kept quiet —
     the retired "rooms" ghost letters + list/coverage styles are gone). ── */
  .im-confetti {
    position: absolute;
    width: clamp(34px, 4vw, 64px);
    aspect-ratio: 1;
    background: var(--color-accent, #38f8ec);
    opacity: 0.14;
    border-radius: 4px;
  }
  .im-confetti:nth-of-type(1) { left: 14%; top: 40%; }
  .im-confetti:nth-of-type(2) { left: 44%; top: 34%; background: #0da79b; }
  .im-confetti:nth-of-type(3) { left: 66%; top: 44%; background: #8fb7d8; }
  .im-confetti:nth-of-type(4) { left: 88%; top: 36%; }
  .im-key {
    margin-top: 2rem;
  }

  /* ── S5 handoff ── */
  .im-handoff {
    min-height: 60svh;
    display: grid;
    place-content: center;
    gap: 2rem;
    text-align: center;
    padding: 6rem 2rem;
  }
  .im-handoff-line {
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    max-width: 30ch;
  }

  /* ── small screens: collages stack, pushes relax ── */
  @media (max-width: 760px) {
    .im-line--push { transform: none; }
    .im-intro-sub { justify-self: center; text-align: center; }
    .im-collage { position: relative; inset: auto; display: grid; gap: 0.7rem; grid-template-columns: 1fr 1fr; margin-bottom: 1.6rem; pointer-events: auto; }
    .im-card { position: relative; inset: auto; width: 100%; }
    /* P23 — mobile chapters were min-height:0 with a lone 6rem top pad but the
       10rem base bottom pad still applied; now the base is tighter and mobile
       pins both ends so chapters read compressed-but-uncrowded on ~390px. */
    .im-chapter { min-height: 0; padding: 4.5rem clamp(1.25rem, 6vw, 7rem) 3.5rem; }
    .im-chapter-stage { min-height: 0; gap: 0; }
    /* the caption plate reads better centered under a stacked collage on phones */
    .im-tag { margin-inline: auto; max-width: 100%; text-align: center; }
    .im-chapter-meta { margin-top: 1.8rem; max-width: 100%; }
    .im-ghost { display: none; }
  }
  /* mobile: the rail cards give a touch more peek on the smallest screens */
  @media (max-width: 480px) {
    .im-rail-card { flex-basis: 82vw; }
  }
  @media (prefers-reduced-motion: reduce) {
    .im-ghost,
    .im-confetti,
    .im-card {
      transform: none !important;
    }
    .im-loop,
    .im-cta,
    .im-cta-arrow,
    .im-rail-link {
      transition: none;
    }
    .im-cta:hover .im-cta-arrow,
    .im-rail-link:hover .im-cta-arrow {
      transform: none;
    }
  }
</style>

<script>
  // P7 enhancement layer: ground morph, ghost assembly, collage parallax.
  // Everything below only ADDS motion to an already-correct static page.
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ensureSmoothScroll } from "../lib/smooth-scroll";

  async function init() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const im = document.querySelector<HTMLElement>("[data-im]");
    const ground = document.querySelector<HTMLElement>("[data-im-ground]");
    if (!im || !ground) return;

    gsap.registerPlugin(ScrollTrigger);
    const lenis = await ensureSmoothScroll();
    if (lenis) lenis.on("scroll", () => ScrollTrigger.update());

    // ── the ground morph: sections hand their color to the fixed layer as
    // they enter (0.8s ride, the reference's signature). .im-live flips the
    // sections transparent only now — if this script never runs, the static
    // per-section grounds were already correct. ──
    im.classList.add("im-live");
    document.querySelectorAll<HTMLElement>("[data-im-section]").forEach((sec) => {
      const color = sec.dataset.ground!;
      ScrollTrigger.create({
        trigger: sec,
        start: "top 55%",
        end: "bottom 55%",
        onEnter: () => gsap.to(ground, { backgroundColor: color, duration: 0.8, ease: "power2.out" }),
        onEnterBack: () => gsap.to(ground, { backgroundColor: color, duration: 0.8, ease: "power2.out" }),
      });
    });

    // ── ghost letters: scatter-in assembly on their section's arrival, then
    // a slow idle float (living at rest). Final positions live in CSS. ──
    document.querySelectorAll<HTMLElement>("[data-im-ghost]").forEach((g, i) => {
      const dx = (i % 2 ? 1 : -1) * (40 + (i % 3) * 30);
      gsap.fromTo(
        g,
        { x: dx, y: 60 + (i % 3) * 30, opacity: 0, rotation: (i % 2 ? 1 : -1) * 6 },
        {
          x: 0,
          y: 0,
          opacity: 1,
          rotation: 0,
          duration: 1.1,
          ease: "power3.out",
          delay: i * 0.07,
          scrollTrigger: { trigger: g.parentElement, start: "top 75%", once: true },
          onComplete: () => {
            gsap.to(g, {
              y: (i % 2 ? -1 : 1) * 10,
              duration: 5 + (i % 3) * 1.5,
              ease: "sine.inOut",
              yoyo: true,
              repeat: -1,
            });
          },
        },
      );
    });

    // ── confetti drift (the playground's shapes, kept quiet) ──
    document.querySelectorAll<HTMLElement>("[data-im-confetti]").forEach((c, i) => {
      gsap.to(c, {
        y: (i % 2 ? -1 : 1) * 18,
        rotation: (i % 2 ? 1 : -1) * 14,
        duration: 6 + i * 1.3,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
      });
    });

    // ── collage parallax: cards ride at different depths across their
    // chapter's transit (her overlapping-cards feel, transform-only) ──
    if (!window.matchMedia("(max-width: 760px)").matches) {
      document.querySelectorAll<HTMLElement>("[data-im-card]").forEach((card) => {
        const depth = Number(card.dataset.depth ?? 1);
        const sec = card.closest("[data-im-section]");
        if (!sec) return;
        gsap.fromTo(
          card,
          { yPercent: 8 * depth },
          {
            yPercent: -8 * depth,
            ease: "none",
            scrollTrigger: { trigger: sec, start: "top bottom", end: "bottom top", scrub: true },
          },
        );
      });
    }
  }
  void init();

  // P13c hover-life: the two case-chapter cards (PB video card, Shelby on-set)
  // play their loop on hover — the video mounts on FIRST pointerenter
  // (preload="none" keeps the initial load still-only), fades in over its poster,
  // pauses on leave. Fine pointers only; never under reduced motion or Save-Data.
  (() => {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fine = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (reduce || !fine || conn?.saveData) return;
    document.querySelectorAll<HTMLVideoElement>("[data-im-loop]").forEach((video) => {
      const card = video.closest<HTMLElement>(".im-card--link");
      if (!card) return;
      card.addEventListener("pointerenter", () => {
        if (!video.src) video.src = video.dataset.loopSrc!;
        video.play().catch(() => {}); // autoplay refusal → the poster stands
        card.classList.add("is-looping");
      });
      card.addEventListener("pointerleave", () => {
        card.classList.remove("is-looping");
        if (!video.paused) video.pause();
      });
    });
  })();

  // P21b MEME ambient loop: the chapter-03 logo animatic plays only when motion
  // is allowed and the framed card is actually on-screen; the poster underneath
  // is the permanent base layer (reduced-motion / no-JS / autoplay-refused all
  // show the still). Mirrors /venture/meme.astro. Distinct hook (data-im-amb) so
  // the collage hover-life script never grabs it; lazy src (preload="none") like
  // the collage loops — the video mounts on first intersection.
  (() => {
    const fig = document.querySelector<HTMLElement>(".im-meme-loop");
    const video = fig?.querySelector<HTMLVideoElement>("[data-im-amb]");
    if (!fig || !video) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (conn?.saveData) return;
    video.addEventListener("playing", () => fig.classList.add("is-playing"));
    const io = new IntersectionObserver(
      ([entry]) => {
        if (!entry) return;
        if (entry.isIntersecting) {
          if (!video.src) video.src = video.dataset.loopSrc!;
          video.play().catch(() => {}); // refusal → poster stands
        } else if (!video.paused) {
          video.pause();
        }
      },
      { threshold: 0.25 },
    );
    io.observe(fig);
    window.addEventListener("pagehide", () => io.disconnect(), { once: true });
  })();

  // P12.6b story-rail: pointer-drag-to-scroll on fine pointers (desktop). Touch
  // devices use the browser's native swipe — this only enhances mouse/trackpad,
  // where there's otherwise no drag. Fully optional: no-JS keeps native overflow
  // scroll + snap. A drag past ~4px suppresses the ending click so a throw never
  // navigates. User-driven, so it runs under reduced motion too (no auto-motion).
  (() => {
    const rail = document.querySelector<HTMLElement>("[data-im-rail]");
    if (!rail) return;
    const fine = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
    if (!fine) return; // touch = native swipe
    rail.classList.add("is-draggable");
    let down = false;
    let moved = false;
    let startX = 0;
    let startScroll = 0;
    rail.addEventListener("pointerdown", (e) => {
      down = true;
      moved = false;
      startX = e.clientX;
      startScroll = rail.scrollLeft;
    });
    window.addEventListener("pointermove", (e) => {
      if (!down) return;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 4) moved = true;
      rail.scrollLeft = startScroll - dx;
      if (moved) rail.classList.add("is-dragging");
    });
    const end = () => {
      if (!down) return;
      down = false;
      rail.classList.remove("is-dragging");
    };
    window.addEventListener("pointerup", end);
    window.addEventListener("pointercancel", end);
    // swallow the click that terminates a real drag (capture phase, before the
    // card link navigates) — a plain click still passes through untouched.
    rail.addEventListener(
      "click",
      (e) => {
        if (moved) {
          e.preventDefault();
          e.stopPropagation();
        }
      },
      true,
    );
  })();
</script>
