---
/**
 * Entertainment — credibility lane, "the industry" (BUILD-PLAN.md §1.4).
 * Standard Contour Survey tokens (no scoped dialect — §3.3 only names Forge
 * and Adventure lane treatments). Every relationship renders through
 * LegendMark; the visible LegendKey makes the tier symbols decodable.
 * Testimonial #2 (the Pebble Beach car-owner quote, OD-5) sits in the rooms
 * list, framed as the owner's endorsement — never Pebble Beach's.
 */
import Base from "../layouts/Base.astro";
import LegendMark from "../components/LegendMark.astro";
import LegendKey from "../components/LegendKey.astro";
import Testimonial from "../components/Testimonial.astro";
import { PAGES } from "../consts";
import { existsSync } from "node:fs";
import { join } from "node:path";

const p = PAGES.entertainment;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// R8 visual lift — reuse the real industry-room photos (published event
// frames: SeriesFest red carpet + American Film Market panel) already exported
// for the home tableau. Hero band uses the SeriesFest frame; the "rooms"
// section break uses the AFM frame. Build-time existence check (cwd-anchored);
// each band renders only when its image is present. No invented claims — these
// are honest "attended" event photos matching the page's relationship tiers.
const indDir = join(process.cwd(), "public", "media", "home", "industry");
const heroBand = existsSync(join(indDir, "background.avif"))
  ? { avif: `${base}/media/home/industry/background.avif`, webp: `${base}/media/home/industry/background.webp` }
  : undefined;
const roomsBand = existsSync(join(indDir, "midground.avif"))
  ? { avif: `${base}/media/home/industry/midground.avif`, webp: `${base}/media/home/industry/midground.webp` }
  : undefined;
---

<Base title={p.meta.title} description={p.meta.description}>
  <!-- E1 — hero image band (R8). The SeriesFest frame sits behind the headline
       under a legibility scrim; when the image is absent the hero degrades to
       the plain centered treatment. -->
  <section class={`filmtv-hero ${heroBand ? "filmtv-hero--banded" : ""}`}>
    {
      heroBand && (
        <picture class="filmtv-hero__bg" aria-hidden="true">
          <source srcset={heroBand.avif} type="image/avif" />
          <img src={heroBand.webp} alt="" loading="eager" decoding="async" />
        </picture>
      )
    }
    <div class="filmtv-hero__inner mx-auto max-w-3xl space-y-4 p-8 text-center">
      <p class="hud-label">{p.hero.eyebrow}</p>
      <h1 class="text-3xl font-bold sm:text-5xl">{p.hero.headline}</h1>
      <p class="text-lg text-ink">{p.hero.subline}</p>
    </div>
  </section>

  <!-- E2 — MEME (the most formal role) -->
  <section class="mx-auto max-w-3xl space-y-3 border-t border-hairline p-8">
    <h2 class="text-2xl font-bold">{p.meme.heading}</h2>
    <div class="panel p-5">
      <LegendMark proof={p.meme.proof} />
      <p class="mt-2 text-ink">{p.meme.body}</p>
    </div>
  </section>

  <!-- E3 — PitchBoulder feature (primary proof anchor) -->
  <section class="mx-auto max-w-3xl space-y-3 border-t border-hairline p-8">
    <h2 class="text-2xl font-bold">{p.pitchboulder.heading}</h2>
    <div class="panel space-y-3 p-5">
      <LegendMark proof={p.pitchboulder.proof} />
      <Testimonial testimonialId={p.pitchboulder.testimonialId} showProof={false} />
      <a href={`${base}${p.pitchboulder.link.href}`} class="link">
        {p.pitchboulder.link.label} <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <!-- Visual break (R8) — the American Film Market panel frame as a full-width
       band between the PitchBoulder feature and the rooms. One visual break per
       scroll depth; honest published event photo (an attended room). -->
  {
    roomsBand && (
      <div class="filmtv-band" aria-hidden="true">
        <picture>
          <source srcset={roomsBand.avif} type="image/avif" />
          <img src={roomsBand.webp} alt="" loading="lazy" decoding="async" />
        </picture>
      </div>
    )
  }

  <!-- E4 — the rooms; testimonial #2 lives here (OD-5), framed as the car
       owner's endorsement, never attributed to Pebble Beach itself -->
  <section class="mx-auto max-w-3xl space-y-6 border-t border-hairline p-8">
    <h2 class="text-2xl font-bold">{p.rooms.heading}</h2>
    <p class="text-ink">{p.rooms.intro}</p>
    <ul class="space-y-4">
      {
        p.rooms.items.map((room) => (
          <li class="panel space-y-2 p-4">
            <LegendMark proof={room.proof} />
            {"testimonialId" in room && room.testimonialId && (
              <Testimonial testimonialId={room.testimonialId} showProof={false} class="mt-2" />
            )}
          </li>
        ))
      }
    </ul>
    <LegendKey />
  </section>

  <!-- E5 — soft handoff -->
  <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-8 text-center">
    <p class="text-lg italic text-ink">{p.handoff.body}</p>
    <a href={`${base}${p.handoff.cta.href}`} class="btn">{p.handoff.cta.label}</a>
  </section>
</Base>
