---
/**
 * Adventure — credibility lane, "the wild" (BUILD-PLAN.md §1.3). Runs the
 * Adventure dialect via data-lane="adventure" (§3.3/§6 synthesis): flight-line
 * dividers + violet-slate map-insets, borrowed from the Overhead direction
 * into the Contour Survey shell.
 *
 * A1 fullscreen hero is left as a clearly-marked stub for the next dispatch
 * task (Opus 4.8 · high — cinematic ambient loop, poster-first, reduced-
 * motion fallback, §2c/§1.3). A4 gallery uses the same Card container as
 * /work, so Fable 5's upcoming 14islands hover-shader (§2e) has one
 * consistent surface to enhance across both pages.
 */
import Base from "../layouts/Base.astro";
import Card from "../components/Card.astro";
import HeroVideo from "../components/HeroVideo.astro";
import LegendMark from "../components/LegendMark.astro";
import { PAGES, WORK } from "../consts";

const p = PAGES.adventure;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const adventureWork = WORK.filter((item) => item.pillar === "adventure");
---

<Base title={p.meta.title} description={p.meta.description}>
  <div data-lane="adventure">
    <!-- A1 — fullscreen ambient-video hero (§1.3 A1). Poster-first; the
         interim placeholder IS the poster until the real reel/still lands
         (S1/S2) — add `poster` + `sources` to make it play, no markup change. -->
    <HeroVideo
      placeholderLabel="FULLSCREEN VIDEO HERO (§1.3 A1) — the single strongest reel as a muted ambient loop (S1), with a poster still (S2). ≤8s · 720p · ≤1.5MB AV1/H.264, poster ships first (§4)."
    >
      <h1 class="text-4xl font-bold sm:text-6xl">{p.hero.headline}</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-ink">{p.hero.subline}</p>
    </HeroVideo>

    <!-- A2 — the territory -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-8">
      <hr class="flight-line mb-6" aria-hidden="true" />
      <h2 class="text-2xl font-bold">{p.territory.heading}</h2>
      <p class="text-ink">{p.territory.body}</p>
    </section>

    <!-- A3 — Licensed vs Personal nesting -->
    <section class="mx-auto max-w-3xl space-y-8 border-t border-hairline p-8">
      <div class="panel space-y-2 p-5">
        <h2 class="text-xl font-bold">{p.licensed.heading}</h2>
        <p class="text-ink">{p.licensed.body}</p>
        <LegendMark proof={p.licensed.proof} />
      </div>
      <div class="space-y-2">
        <h2 class="text-xl font-bold">{p.personal.heading}</h2>
        <p class="text-ink">{p.personal.body}</p>
      </div>
    </section>

    <!-- A4 — masonry gallery: uniform Card containers (hover-shader lands on
         top of these in a later task, §2e) -->
    <section class="border-t border-hairline p-8">
      <hr class="flight-line mb-6" aria-hidden="true" />
      <h2 class="mx-auto mb-4 max-w-3xl text-2xl font-bold">{p.gallery.heading}</h2>
      <div class="mx-auto grid max-w-3xl grid-cols-2 gap-4 sm:grid-cols-3">
        {
          adventureWork.map((item) => (
            <Card
              mediaRatio="4/5"
              mediaLabel={`${item.title} — grid thumbnail (§2b/§2e)`}
              eyebrow={item.engagement}
              title={item.title}
              meta={item.what}
            />
          ))
        }
      </div>
      <p class="mx-auto mt-4 max-w-3xl text-sm text-ink-muted">{p.gallery.note}</p>
    </section>

    <!-- A5 — soft handoff -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-8 text-center">
      <p class="text-lg italic text-ink">{p.handoff.body}</p>
      <a href={`${base}${p.handoff.cta.href}`} class="btn">{p.handoff.cta.label}</a>
    </section>
  </div>
</Base>
