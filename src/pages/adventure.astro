---
/**
 * Adventure — credibility lane, "the wild" (BUILD-PLAN.md §1.3, amended §9.3
 * + §9.5). Runs the Adventure dialect via data-lane="adventure" (§3.3/§6
 * synthesis): flight-line dividers + violet-slate map-insets.
 *
 * A1 is now the GLOBE HERO (moved here from home, §9.3) — "where the stories
 * are told" is native to this lane. Compact headline + subline + GlobeHero,
 * wrapped in its own <section> so the globe's scroll-handoff retargets to
 * THIS section automatically (GlobeHero.astro targets `root.closest("section")`).
 *
 * Photo-first (§9.5): the gallery is the page's main surface — widened,
 * ready to grow to 20–40 real selects (S2). The ambient reel is now
 * optional/selective and sits below the gallery, not as the page opener.
 */
import Base from "../layouts/Base.astro";
import DistortionLayer from "../components/DistortionLayer.astro";
import GlobeHero from "../components/GlobeHero.astro";
import HeroVideo from "../components/HeroVideo.astro";
import LegendMark from "../components/LegendMark.astro";
import WorldMapBackdrop from "../components/WorldMapBackdrop.astro";
import { PAGES } from "../consts";
import { TERRITORY, TERRITORY_TOTALS } from "../data/territory";
import { getCollection } from "astro:content";

import { existsSync } from "node:fs";
import { join } from "node:path";

const p = PAGES.adventure;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

/* ─────────────────────────────────────────────────────────────────────────
 * P12.4c — "THE TERRITORY" constellation geometry.
 *
 * The map that illustrates the A2 territory copy is NOT a geographic map — it's
 * a surveyor's constellation. Each country is a glowing node; its locations
 * spray around it on a golden-angle (sunflower) spiral so they distribute
 * evenly and organically. Positions are computed here (presentation) so the
 * data file (src/data/territory.ts) stays a clean, typed inventory.
 *
 * Coordinates are percentages of the field box. The USA groups (Colorado, New
 * Mexico) sit in the left column; the Alps groups (Switzerland, Italy) sit to
 * the right — echoing the real world without pretending to be a map.
 * ───────────────────────────────────────────────────────────────────────── */
const TERRITORY_CLUSTERS: Record<string, { cx: number; cy: number; r: number }> = {
  Colorado: { cx: 20, cy: 33, r: 15 },
  "New Mexico": { cx: 20, cy: 79, r: 5 },
  Switzerland: { cx: 55, cy: 30, r: 15 },
  Italy: { cx: 82, cy: 63, r: 14 },
};
const GOLDEN_ANGLE = Math.PI * (3 - Math.sqrt(5)); // ≈137.5°, the sunflower angle
const TERRITORY_YSQUASH = 0.72; // field is wider than tall — squash y so the spiral reads round

function terrSlug(s: string) {
  return s
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
}

const territory = TERRITORY.map((c) => {
  const cfg = TERRITORY_CLUSTERS[c.country];
  const n = c.locations.length;
  const locations = c.locations.map((loc, i) => {
    const frac = (i + 0.5) / n;
    const rad = cfg.r * Math.sqrt(frac);
    const theta = i * GOLDEN_ANGLE;
    const x = cfg.cx + rad * Math.cos(theta);
    const y = cfg.cy + rad * Math.sin(theta) * TERRITORY_YSQUASH;
    // Info chip opens toward the field interior so it never runs off an edge.
    const side = x > 62 ? "left" : x < 30 ? "right" : "up";
    return {
      ...loc,
      slug: terrSlug(`${c.country}-${loc.name}`),
      x: Math.round(x * 100) / 100,
      y: Math.round(y * 100) / 100,
      side,
    };
  });
  return { ...c, slug: terrSlug(c.country), cx: cfg.cx, cy: cfg.cy, locations };
});

// Decorative hairline contour arcs between the cluster centers (quadratic
// béziers in the same 0–100 percentage space; the SVG uses
// preserveAspectRatio="none" so they map straight onto the field). Low-alpha,
// aria-hidden — pure connective linework, no data.
const TERRITORY_ARCS = [
  "M20,33 Q37,12 55,30", // Colorado → Switzerland (the transatlantic bridge)
  "M55,30 Q76,43 82,63", // Switzerland → Italy (the Alps hop)
  "M20,33 Q9,56 20,79", // Colorado → New Mexico (the home column)
];
const AA_HREF = p.aaFunnel.cta.href; // same operator portfolio URL as the gallery (P12.4b)
const outingWord = (n: number) => (n === 1 ? "OUTING" : "OUTINGS");

// Ambient reel: SKIPPED by default (DIRECTION §2.3) — the on-disk loop
// candidates were unverified content. The section renders only if a real reel
// is dropped at public/media/adventure/reel-loop.mp4 (+ poster). No sources =
// no section (not a placeholder box). Checked at build time (frontmatter runs
// server-side); anchored to process.cwd() like Tableaux.astro.
const reelDir = join(process.cwd(), "public", "media", "adventure");
const reelHasLoop = existsSync(join(reelDir, "reel-loop.mp4"));
const reelHasPoster = existsSync(join(reelDir, "reel-poster.avif"));
const reelSources = reelHasLoop
  ? [{ src: `${base}/media/adventure/reel-loop.mp4`, type: "video/mp4" }]
  : [];
const reelPoster = reelHasPoster ? `${base}/media/adventure/reel-poster.avif` : undefined;

// Slug → gallery media map. Round 2 (R3): widths are orientation-aware —
// landscape cards export 800/1400/2200 (3:2), vertical cards 800/1120/1600
// (4:5). A responsive <picture> renders only when the exported set exists.
const GALLERY_WIDTHS = {
  landscape: [800, 1400, 2200],
  vertical: [800, 1120, 1600],
} as const;
function galleryMedia(slug: string, orientation: "landscape" | "vertical") {
  const g = join(process.cwd(), "public", "media", "adventure", "gallery");
  if (!existsSync(join(g, `${slug}-800.avif`))) return undefined;
  const widths = GALLERY_WIDTHS[orientation];
  return {
    avif: widths.map((w) => `${base}/media/adventure/gallery/${slug}-${w}.avif ${w}w`).join(", "),
    webp: widths.map((w) => `${base}/media/adventure/gallery/${slug}-${w}.webp ${w}w`).join(", "),
    src: `${base}/media/adventure/gallery/${slug}-800.webp`,
  };
}

/* ─────────────────────────────────────────────────────────────────────────
 * P12.6 — MICRO TRAVEL STORIES (data-driven).
 *
 * The gallery is now an EVER-EXPANDING set of micro-stories, one markdown file
 * per place under src/content/field-notes/ (the fieldNotes collection). A note
 * becomes a story here when it carries `photos`; the operator adds a place by
 * dropping a file. Same files power /field-notes (the chronological log), so
 * the collection is no longer empty (the build warning is gone).
 *
 * TILE BUDGET (distort-engine.ts ≤20 live-measure rule): each story renders ONE
 * distort tile — its LEAD photo, via Card's .map-inset. Secondary photos (if a
 * story ever ships 2–3) render as plain <picture> OUTSIDE any .map-inset, so
 * they never count as tiles. 7 stories = 7 tiles, well under the 20 that keep
 * the click-to-expand field note lag-free. If this ever nears 20, split the
 * wall into per-territory [data-distort-grid] blocks.
 * ───────────────────────────────────────────────────────────────────────── */
const WALL_ORDER = [
  "matterhorn-zermatt",
  "flatirons-chautauqua",
  "gornergrat-glacier",
  "eldorado-springs",
  "castel-toblino",
  "varenna-lake-como",
  "lac-de-tseuzier",
];
const stories = (await getCollection("fieldNotes", ({ data }) => !data.draft))
  .filter((n) => n.data.photos && n.data.photos.length > 0)
  .sort((a, b) => {
    const ai = WALL_ORDER.indexOf(a.id);
    const bi = WALL_ORDER.indexOf(b.id);
    return (ai < 0 ? 999 : ai) - (bi < 0 ? 999 : bi);
  });

// Mono survey slate: YYYY.MM.DD from UTC parts (matches /field-notes).
const fmtSlate = (d: Date) =>
  `${d.getUTCFullYear()}.${String(d.getUTCMonth() + 1).padStart(2, "0")}.${String(d.getUTCDate()).padStart(2, "0")}`;
---

<Base title={p.meta.title} description={p.meta.description}>
  <div data-lane="adventure">
    <!-- A1 — globe hero (§2a, relocated §9.3). Headline paints first (LCP);
         the globe streams in behind it and the poster covers every fallback
         state. Compact vs. home's old treatment — this is a lane header,
         not a full-bleed moment. -->
    <section class="mx-auto max-w-3xl space-y-6 p-8 text-center">
      <h1 class="text-3xl font-bold sm:text-5xl">{p.hero.headline}</h1>
      <p class="mx-auto max-w-2xl text-lg text-ink">{p.hero.subline}</p>
      <GlobeHero />
    </section>

    <!-- A2 — the territory -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-8">
      <hr class="flight-line mb-6" aria-hidden="true" />
      <h2 class="text-2xl font-bold" data-reveal>{p.territory.heading}</h2>
      <p class="text-ink" data-reveal>{p.territory.body}</p>

      {/* ── P12.4c — THE TERRITORY constellation ──────────────────────────────
          A clickable location-dots map that ILLUSTRATES the copy above: where
          the operator has actually shot, in outings. No new claim sentences —
          every string here is functional data/labels (country + location names,
          outing counts, "License this work →").

          Progressive enhancement model:
            • Base (no-JS / reduced motion): every location is rendered and
              visible — the constellation reads as a static star map, nothing
              needs a click to be seen. Chips (with the license link) reveal on
              hover / focus so keyboard + no-JS users can still reach the link.
            • Enhanced (html.js, motion allowed): the interaction script adds
              `.terr--live`, which collapses each country's locations. Clicking a
              country node sprays its dots out (staggered); clicking another
              country collapses the previous. Clicking a location dot opens its
              info chip. All controls are real <button>s with aria-expanded.

          The <ul> structure IS the plain accessible list the spec asks for:
          country → its locations, each a labelled control with a real license
          link. Under no-JS it renders fully expanded, so it doubles as the
          screen-reader / no-JS fallback list. The decorative SVG arcs are
          aria-hidden. */}
      <figure class="terr" data-reveal aria-labelledby="terr-kicker">
        <figcaption id="terr-kicker" class="terr-kicker hud-label">
          {/* P17 fix — the hardcoded "3 COUNTRIES" undercounted the map's own
              four nodes (Colorado, New Mexico, Switzerland, Italy).
              "TERRITORIES" is the section's own grammar AND stays honest
              (CO + NM share a country); the count now comes from the data so
              it can't drift again. */}
          {TERRITORY_TOTALS.outings} OUTINGS · {TERRITORY_TOTALS.territories} TERRITORIES
        </figcaption>
        <p class="sr-only">
          Where this work was shot, by number of outings. Expand a country to
          list its locations; each links out to the licensing portfolio.
        </p>
        <div class="terr-field">
          {/* P12.6 — faint world-outline backdrop (atmosphere, not a
              re-projection). Sits behind the arcs + nodes; static under no-JS /
              reduced motion. */}
          <WorldMapBackdrop />
          <svg
            class="terr-arcs"
            viewBox="0 0 100 100"
            preserveAspectRatio="none"
            aria-hidden="true"
            focusable="false"
          >
            {TERRITORY_ARCS.map((d) => <path class="terr-arc" d={d} />)}
          </svg>
          <ul class="terr-clusters">
            {
              territory.map((c) => (
                <li class="terr-cluster" style={`--cx:${c.cx};--cy:${c.cy}`} data-country={c.country}>
                  <button
                    type="button"
                    class="terr-country"
                    aria-expanded="true"
                    aria-controls={`terr-locs-${c.slug}`}
                    aria-label={`${c.country}, ${c.outings} outings across ${c.locations.length} locations`}
                  >
                    <span class="terr-dot" aria-hidden="true" />
                    <span class="terr-country-label">
                      {c.label} · {c.outings} {outingWord(c.outings)}
                    </span>
                  </button>
                  <ul class="terr-locations" id={`terr-locs-${c.slug}`}>
                    {c.locations.map((loc, i) => (
                      <li
                        class="terr-loc"
                        style={`--lx:${loc.x};--ly:${loc.y};--i:${i}`}
                        data-side={loc.side}
                      >
                        <button
                          type="button"
                          class="terr-loc-node"
                          aria-expanded="false"
                          aria-controls={`terr-chip-${loc.slug}`}
                          aria-label={`${loc.name}, ${loc.outings} ${loc.outings === 1 ? "outing" : "outings"}`}
                        >
                          <span class="terr-loc-dot" aria-hidden="true" />
                          <span class="terr-loc-label" aria-hidden="true">
                            {loc.name} · {loc.outings}
                          </span>
                        </button>
                        <span class="terr-chip" id={`terr-chip-${loc.slug}`} role="group">
                          <span class="terr-chip-name">{loc.name}</span>
                          <span class="terr-chip-count hud-label">
                            {loc.outings} {outingWord(loc.outings)}
                          </span>
                          <a
                            class="terr-chip-link link"
                            href={AA_HREF}
                            target="_blank"
                            rel="noopener"
                          >
                            License this work <span class="arrow" aria-hidden="true">→</span>
                          </a>
                        </span>
                      </li>
                    ))}
                  </ul>
                </li>
              ))
            }
          </ul>
        </div>
      </figure>
    </section>

    <!-- A3 — Licensed vs Personal nesting -->
    <section class="mx-auto max-w-3xl space-y-8 border-t border-hairline p-8">
      <div class="panel space-y-2 p-5" data-reveal>
        <h2 class="text-xl font-bold">{p.licensed.heading}</h2>
        <p class="text-ink">{p.licensed.body}</p>
        <LegendMark proof={p.licensed.proof} />
      </div>
      <div class="space-y-2" data-reveal>
        <h2 class="text-xl font-bold">{p.personal.heading}</h2>
        <p class="text-ink">{p.personal.body}</p>
      </div>
    </section>

    {/* AA MID-BAND (P12.6) — the licensing weave appears mid-scroll, not only in
        the bottom funnel. Logo + locked-phrasing line + portfolio button.
        ⚠ OPERATOR READ-APPROVAL REQUIRED — one new sentence (staging-only until
        read): the aa-band-line below. The kicker + button label are existing
        approved copy. */}
    <section class="border-t border-hairline p-8">
      <div class="mx-auto max-w-5xl">
        <div class="panel aa-band flex flex-col gap-4 p-6 sm:flex-row sm:items-center sm:justify-between" data-reveal>
          <div class="flex items-center gap-4">
            <img
              src={`${base}/media/adventure/aa-logo.png`}
              alt="Amazing Aerial Agency"
              class="aa-funnel-logo shrink-0"
              width="480"
              height="158"
              loading="lazy"
              decoding="async"
            />
            <div class="space-y-1">
              <p class="hud-label">Licensed through Amazing Aerial Agency</p>
              <p class="aa-band-line max-w-2xl text-sm text-ink">
                The stills here are watermarked previews — license the
                full-resolution frames through Amazing Aerial.
              </p>
            </div>
          </div>
          <a href={p.aaFunnel.cta.href} class="btn shrink-0" target="_blank" rel="noopener">
            {p.aaFunnel.cta.label}
          </a>
        </div>
      </div>
    </section>

    <!-- A4 — THE FLOATING GALLERY WALL (P19), the page's MAIN SURFACE
         (§9.5 photo-first). Each place is a framed painting hung on the void:
         a slim gallery frame + mat + drop shadow, drifting gently (CSS float,
         desynced per painting; static under reduced motion / no-JS). The WHOLE
         painting is a link into its spotlight — the "Super Mario 64 painting"
         jump into the world. Data-driven from the fieldNotes collection; the
         operator grows the wall by adding a markdown file.

         The in-page field-note prose is GONE from /adventure (it now lives on
         the spotlight pages). The license chip moved to the spotlight too, so
         the wall reads as a clean salon hang, not a shop shelf — the mid-page
         AA band + bottom funnel still carry the licensing weave.

         Tile budget: each painting's frame is ONE .map-inset distort tile → 7
         tiles, under the engine's ≤20 live-measure cap (distort-engine.ts). -->
    <section class="border-t border-hairline p-8">
      <hr class="flight-line mb-6" aria-hidden="true" />
      <h2 class="mx-auto mb-6 max-w-5xl text-2xl font-bold">{p.gallery.heading}</h2>
      <div class="painting-wall mx-auto max-w-5xl" data-distort-grid>
        {
          stories.map((story) => {
            const photos = story.data.photos ?? [];
            const lead = photos[0]!;
            const isVertical = lead.orientation === "vertical";
            const media = galleryMedia(lead.slug, lead.orientation);
            const slate = `${fmtSlate(story.data.date)} · ${story.data.location}`;
            const sizes = "(min-width: 1024px) 30vw, (min-width: 640px) 45vw, 90vw";
            return (
              <a
                class={isVertical ? "painting painting--tall" : "painting"}
                href={`${base}/field-notes/${story.id}`}
                data-painting
                data-reveal
                aria-label={`${story.data.title} — ${story.data.location}`}
              >
                {/* Inner carries the frame + shadow + ambient float, so the
                    reveal-entrance transform on the anchor and the float never
                    fight over `transform`. */}
                <div class="painting-inner">
                  <figure class="painting-window map-inset">
                    {media && (
                      <picture>
                        <source type="image/avif" srcset={media.avif} sizes={sizes} />
                        <source type="image/webp" srcset={media.webp} sizes={sizes} />
                        <img
                          src={media.src}
                          alt={lead.alt}
                          class="block w-full"
                          style={`aspect-ratio:${isVertical ? "4/5" : "3/2"};object-fit:cover`}
                          loading="lazy"
                          decoding="async"
                        />
                      </picture>
                    )}
                    {/* Hover affordance — the "jump into the painting" cue (fine
                        pointers). ⚠ OPERATOR READ-APPROVAL REQUIRED — "Enter" is
                        new label copy (staging-only until read). Styled mono
                        directly (NOT .hud-label) so the distort engine's
                        is-distorted label-lift can't override its centering. */}
                    <span class="painting-enter" aria-hidden="true">
                      Enter <span class="arrow">→</span>
                    </span>
                  </figure>
                  <div class="painting-plate">
                    <span class="painting-slate hud-label">{slate}</span>
                    <span class="painting-title">{story.data.title}</span>
                    {/* Persistent affordance for touch (no hover-only cues). */}
                    <span class="painting-cta hud-label" aria-hidden="true">
                      Enter <span class="arrow">→</span>
                    </span>
                  </div>
                </div>
              </a>
            );
          })
        }
      </div>
      <!-- AA funnel outro (operator exclusivity handling): the gallery is a
           teaser referral to the agency that licenses the full collection. -->
      <div class="mx-auto mt-8 max-w-5xl">
        <div class="panel aa-funnel flex flex-col gap-4 p-6 sm:flex-row sm:items-center sm:justify-between" data-reveal>
          <div class="flex items-center gap-4">
            <img
              src={`${base}/media/adventure/aa-logo.png`}
              alt="Amazing Aerial Agency"
              class="aa-funnel-logo shrink-0"
              width="480"
              height="158"
              loading="lazy"
              decoding="async"
            />
            <div class="space-y-1">
              <p class="hud-label">Licensed through Amazing Aerial Agency</p>
              <h3 class="text-lg font-bold">{p.aaFunnel.heading}</h3>
              <p class="max-w-2xl text-sm text-ink">{p.aaFunnel.body}</p>
            </div>
          </div>
          <a href={p.aaFunnel.cta.href} class="btn shrink-0" target="_blank" rel="noopener">
            {p.aaFunnel.cta.label}
          </a>
        </div>
      </div>
    </section>

    <!-- Ambient reel — OPTIONAL / selective (§9.5 / DIRECTION §2.3). SKIPPED by
         default: the only loop candidates on disk are unverified content, so
         per DIRECTION the reel renders NOTHING (not a placeholder box) unless
         real sources are supplied. To activate: set `reelSources` (+ poster)
         below — the section returns with zero other markup change. -->
    {
      reelSources.length > 0 && (
        <section class="border-t border-hairline p-8">
          <HeroVideo
            poster={reelPoster}
            sources={reelSources}
            placeholderLabel="AMBIENT REEL — muted ambient loop, ≤8s · 720p · ≤1.5MB AV1/H.264, poster ships first (§4)."
            class="mx-auto max-w-5xl"
          />
        </section>
      )
    }

    <!-- A5 — soft handoff -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-8 text-center">
      <p class="text-lg italic text-ink">{p.handoff.body}</p>
      <a href={`${base}${p.handoff.cta.href}`} class="btn">{p.handoff.cta.label}</a>
      <!-- P12.4d wayfinder — the field log lives off-nav for now (IA reserves
           /field-notes); this quiet link is its only surface until it earns
           a nav slot. -->
      <p><a href={`${base}/field-notes`} class="link">Read the field notes →</a></p>
    </section>
  </div>

  <!-- §2e hover-distortion (feature-gated; CSS fallback is the default) -->
  <DistortionLayer />
</Base>

<script>
  // ── P19 — "jump into the painting" click transition ──────────────────────
  // Progressive enhancement over a plain link. On a primary click of a painting
  // we briefly zoom it toward the viewer, then navigate — the Super Mario 64
  // dive into the world. Hard-degrades to INSTANT navigation: skipped entirely
  // under reduced motion, on coarse/touch pointers, and for modifier / non-left
  // clicks (so cmd/ctrl/middle-click still open a new tab). A safety timeout
  // guarantees navigation even if the transitionend never fires.
  (() => {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fine = window.matchMedia("(pointer: fine)").matches;
    if (reduce || !fine) return; // instant nav is the baseline everywhere else

    document.addEventListener("click", (e) => {
      const me = e as MouseEvent;
      if (me.button !== 0 || me.metaKey || me.ctrlKey || me.shiftKey || me.altKey) return;
      const painting = (e.target as HTMLElement).closest<HTMLAnchorElement>("a.painting[href]");
      if (!painting || painting.classList.contains("is-entering")) return;
      e.preventDefault();
      const href = painting.href;
      painting.classList.add("is-entering");
      let done = false;
      const go = () => {
        if (done) return;
        done = true;
        window.location.assign(href);
      };
      painting.addEventListener("transitionend", go, { once: true });
      window.setTimeout(go, 420); // fallback ceiling
    });
  })();

  // NOTE: the paintings' ambient float is pure CSS (@keyframes painting-float on
  // .painting-inner, desynced per painting, killed under reduced motion) — no JS
  // engine, so it also breathes on mobile without a transform tug-of-war with
  // the reveal-entrance transform on the anchor.

  // ── P12.4c — THE TERRITORY constellation interaction ─────────────────────
  // Pure progressive enhancement over the static (all-expanded) base. Under
  // reduced motion we do NOTHING: every location stays rendered so nothing
  // needs a click to be seen (the country nodes keep aria-expanded="true" from
  // the markup, matching the visible state). With motion allowed we add
  // `.terr--live`, which lets the CSS collapse each country's locations; the
  // handlers below spray one country's dots at a time and toggle info chips.
  (() => {
    const terr = document.querySelector<HTMLElement>(".terr");
    if (!terr) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const clusters = Array.from(terr.querySelectorAll<HTMLElement>(".terr-cluster"));

    // Enter the live (collapsible) mode and start every country collapsed.
    terr.classList.add("terr--live");
    clusters.forEach((cl) => {
      cl.classList.remove("is-open");
      cl.querySelector<HTMLElement>(".terr-country")?.setAttribute("aria-expanded", "false");
    });

    const closeChips = (keep?: Element | null) =>
      terr.querySelectorAll<HTMLElement>('.terr-loc-node[aria-expanded="true"]').forEach((n) => {
        if (n !== keep) n.setAttribute("aria-expanded", "false");
      });

    terr.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;

      // Country node → expand its locations, collapse every other country.
      const country = target.closest<HTMLElement>(".terr-country");
      if (country) {
        const cluster = country.closest<HTMLElement>(".terr-cluster");
        const willOpen = country.getAttribute("aria-expanded") !== "true";
        clusters.forEach((cl) => {
          const open = cl === cluster && willOpen;
          cl.classList.toggle("is-open", open);
          cl.querySelector<HTMLElement>(".terr-country")?.setAttribute(
            "aria-expanded",
            String(open),
          );
        });
        closeChips(); // any open chip belonged to a country we may have just collapsed
        return;
      }

      // Location dot → toggle its info chip (only one chip open at a time).
      const loc = target.closest<HTMLElement>(".terr-loc-node");
      if (loc) {
        const open = loc.getAttribute("aria-expanded") !== "true";
        closeChips(open ? loc : null);
        loc.setAttribute("aria-expanded", String(open));
      }
    });
  })();
</script>
