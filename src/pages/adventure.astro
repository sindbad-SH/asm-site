---
/**
 * Adventure — credibility lane, "the wild" (BUILD-PLAN.md §1.3, amended §9.3
 * + §9.5). Runs the Adventure dialect via data-lane="adventure" (§3.3/§6
 * synthesis): flight-line dividers + violet-slate map-insets.
 *
 * A1 is now the GLOBE HERO (moved here from home, §9.3) — "where the stories
 * are told" is native to this lane. Compact headline + subline + GlobeHero,
 * wrapped in its own <section> so the globe's scroll-handoff retargets to
 * THIS section automatically (GlobeHero.astro targets `root.closest("section")`).
 *
 * ROUND 5 (2026-07-21, operator consolidation): final order is
 * hero/sales → THE TERRITORY (count-free, coverage places added) → THE FIELD
 * teaser (the gallery wall moved to /adventure/field) → the Medieval Festival
 * spread → FROM THE ARCHIVE (the lane's micro local stories) → close.
 */
import Base from "../layouts/Base.astro";
import DistortionLayer from "../components/DistortionLayer.astro";
import GlobeHero from "../components/GlobeHero.astro";
import LegendMark from "../components/LegendMark.astro";
import WorldMapBackdrop from "../components/WorldMapBackdrop.astro";
import { PAGES, RELATIONSHIP_BY_ID, SITE, WORK, WORK_ARCHIVE, FORGE_SERVICES } from "../consts";
import { TERRITORY } from "../data/territory";
import { getCollection } from "astro:content";

import { existsSync } from "node:fs";
import { join } from "node:path";

const p = PAGES.adventure;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// P29 — CTA hrefs may be external (Calendly direct); only prefix internal routes.
const href = (h: string) => (h.startsWith("http") ? h : `${base}${h}`);
// P29 — the day rate is the aerial service's EXISTING staged floor (FORGE_SERVICES
// 06), rendered verbatim — single-sourced, never restated as a new number.
const aerialSvc = FORGE_SERVICES.find((s) => s.no === "06")!;

/* ─────────────────────────────────────────────────────────────────────────
 * "THE TERRITORY" constellation geometry — now SEATED ON THE WORLD MAP.
 *
 * The constellation shares ONE coordinate frame with WorldMapBackdrop: a 2:1
 * wrapper (.terr-frame) that reproduces the map SVG's `meet` letterbox exactly
 * (aspect-ratio:2/1, max 100%, centered in the 16:9 field). Because that frame
 * IS the rendered map rectangle, a node's position is pure projection math
 * against the equirectangular world (viewBox 0 0 360 180):
 *     left% = (lon + 180) / 360 * 100      top% = (90 − lat) / 180 * 100
 * No JS measurement, no hand-tuned percentages — lon/lat are the source of
 * truth and cx/cy are derived, so the dots land on their true coastline.
 *
 * The label-collision problem (Switzerland↔Italy are ~0.5% apart at world zoom,
 * Colorado↔New Mexico ~3%): each cluster keeps its DOT at the true point, and
 * its LABEL + expanded location list are offset away on a hairline leader —
 * classic cartographic labeling. The per-cluster `labelDir` fans the callouts
 * apart so they never overlap. The location dots are a decorative legend cloud
 * that sprays around that offset callout (NOT geographic pins — we have no
 * per-place lat/lon), so a dense country reads as "many shoots here" without
 * implying wrong coordinates.
 * ───────────────────────────────────────────────────────────────────────── */
type LabelDir = "up-left" | "up-right" | "down-left" | "down-right";
const TERRITORY_CLUSTERS: Record<
  string,
  { lat: number; lon: number; labelDir: LabelDir; sprayR: number }
> = {
  // lat/lon are the ONLY hand values now; cx/cy derive from them below.
  // labelDir: both edge-pairs open INWARD (rightward) so no callout runs off the
  // panel — within each pair the northern dot's label goes up, the southern down,
  // so the two coincident clusters stack cleanly instead of colliding.
  Colorado: { lat: 40.0, lon: -105.3, labelDir: "up-right", sprayR: 6 }, // Boulder (N of NM → up)
  "New Mexico": { lat: 34.5, lon: -106.1, labelDir: "down-right", sprayR: 2 }, // Taos (S → down)
  // Round 5 — California joins as a coverage territory (⚠ OPERATOR-CONFIRM,
  // see territory.ts): LA sits well west of the CO/NM pair, so its callout
  // opens down-LEFT — away from New Mexico's down-right label — and still
  // lands ~10% inside the frame edge.
  California: { lat: 34.05, lon: -118.24, labelDir: "down-left", sprayR: 2 }, // Los Angeles
  // The Alp pair coincides at world zoom, so their up/down callouts share an x —
  // a tighter spray keeps the two clouds from merging (they separate vertically)
  // and keeps Switzerland's dense 24-dot cloud inside the frame.
  Switzerland: { lat: 46.1, lon: 7.9, labelDir: "up-right", sprayR: 4 }, // Valais (N of IT → up)
  Italy: { lat: 45.9, lon: 9.8, labelDir: "down-right", sprayR: 4 }, // Como / Trentino (S → down)
};

// Equirectangular projection into the shared 2:1 frame (percent of frame box).
const lon2x = (lon: number) => ((lon + 180) / 360) * 100;
const lat2y = (lat: number) => ((90 - lat) / 180) * 100;

// Callout bias: the decorative location cloud sprays around a point pushed off
// the dot toward the label side, so the two near-coincident Alp clusters throw
// their clouds apart. dx in x-%, dy in y-% (the frame is 2:1, so a y-% is half
// the pixels of an x-% — see TERRITORY_YSCALE).
const LABEL_BIAS: Record<LabelDir, { dx: number; dy: number }> = {
  "up-left": { dx: -7, dy: -11 },
  "up-right": { dx: 7, dy: -11 },
  "down-left": { dx: -7, dy: 11 },
  "down-right": { dx: 7, dy: 11 },
};

const GOLDEN_ANGLE = Math.PI * (3 - Math.sqrt(5)); // ≈137.5°, the sunflower angle
// The frame is twice as wide as tall, so 1 y-% is half the pixels of 1 x-%.
// Doubling the spiral's y component keeps the decorative cloud round on screen.
const TERRITORY_YSCALE = 2;

function terrSlug(s: string) {
  return s
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
}

const territory = TERRITORY.map((c) => {
  const cfg = TERRITORY_CLUSTERS[c.country];
  const cx = lon2x(cfg.lon);
  const cy = lat2y(cfg.lat);
  const bias = LABEL_BIAS[cfg.labelDir];
  const sx = cx + bias.dx; // spray center — pushed toward the callout
  const sy = cy + bias.dy;
  const n = c.locations.length;
  const locations = c.locations.map((loc, i) => {
    const frac = (i + 0.5) / n;
    const rad = cfg.sprayR * Math.sqrt(frac);
    const theta = i * GOLDEN_ANGLE;
    const x = sx + rad * Math.cos(theta);
    const y = sy + rad * Math.sin(theta) * TERRITORY_YSCALE;
    // Info chip opens toward the frame interior so it never runs off an edge.
    const side = x > 58 ? "left" : x < 42 ? "right" : "down";
    return {
      ...loc,
      slug: terrSlug(`${c.country}-${loc.name}`),
      x: Math.round(x * 100) / 100,
      y: Math.round(y * 100) / 100,
      side,
    };
  });
  return {
    ...c,
    slug: terrSlug(c.country),
    cx: Math.round(cx * 100) / 100,
    cy: Math.round(cy * 100) / 100,
    labelDir: cfg.labelDir,
    locations,
  };
});

// Decorative hairline arcs, REGENERATED from the true positions in the SAME 2:1
// frame. The arcs SVG uses viewBox "0 0 100 100" + preserveAspectRatio="none",
// so x→width and y→height exactly as the CSS percentages do — an (cx,cy)
// endpoint lands precisely on that cluster's dot. Only the small bow constants
// are authored; the endpoints are derived, never hand-placed.
const posOf = (country: string) => {
  const t = territory.find((c) => c.country === country)!;
  return { x: t.cx, y: t.cy };
};
const terrArc = (a: string, b: string, bowX: number, bowY: number) => {
  const p = posOf(a);
  const q = posOf(b);
  const mx = Math.round(((p.x + q.x) / 2 + bowX) * 100) / 100;
  const my = Math.round(((p.y + q.y) / 2 + bowY) * 100) / 100;
  return `M${p.x},${p.y} Q${mx},${my} ${q.x},${q.y}`;
};
const TERRITORY_ARCS = [
  terrArc("Colorado", "Switzerland", 0, -13), // transatlantic bridge (bows north)
  terrArc("Switzerland", "Italy", 3.5, 7), // the short Alps hop (near-coincident pair)
  terrArc("Colorado", "New Mexico", -3, 0), // the home column (bows west)
  terrArc("Colorado", "California", 0, -5), // the coast hop (Round 5 — bows north)
];
const AA_HREF = p.aaFunnel.cta.href; // same operator portfolio URL as the gallery (P12.4b)
// Round 5 NO-COUNT rework: the kicker lists the territory NAMES (self-growing,
// never a number) instead of the retired outings/territories counts.
const TERRITORY_KICKER = territory.map((c) => c.label).join(" · ");

// Ambient reel + the floating gallery wall: MOVED to /adventure/field
// (Round 5 block→subpage pattern). This page keeps a teaser only.

/* ─────────────────────────────────────────────────────────────────────────
 * A4b — MEDIEVAL FESTIVAL IN LOVELAND (Round 3, 2026-07-21).
 *
 * The Knights of Mayhem piece RE-LANED here from the /work wall (operator:
 * "Knights of Mayhem is an adventure story") and BROADENED into one cohesive
 * festival story block: the showcase video (the existing loop + poster export
 * under media/work/knights-of-mayhem/ — path unchanged, no asset churn) stays
 * the feature, ringed by four of the operator's own drone frames of the joust
 * lane and the armored ground-combat arena (baked to media/adventure/festival/
 * by scripts/make-festival-photos.mjs). The attribution line composes from the
 * WORK record — single source, same "For [org] · [what] — [engagement]"
 * grammar the wall used. The aerial-licensing credibility marker renders ONLY
 * via LegendMark (amazing-aerial's verbatim permittedPhrasing).
 * ───────────────────────────────────────────────────────────────────────── */
const knights = WORK.find((w) => w.slug === "knights-of-mayhem");
// (The showcase loop now lives on the full story page, not this teaser.)
// Photo lookup — existence-gated per file, like every other baked set. The
// festival block is now a magazine-cover TEASER (M1 v3, 2026-07-22, operator:
// "the block got too busy — reuse the cover photo + two stills + a CTA, drop
// the inline video"). Two orientations: the vertical cover (widths 800/1120/
// 1600) + the two landscape teaser stills (900/1600).
const festImg = (slug: string, widths: number[]) => {
  const dir = join(process.cwd(), "public", "media", "adventure", "festival");
  const w0 = widths[0]!;
  if (!existsSync(join(dir, `${slug}-${w0}.avif`))) return undefined;
  return {
    avif: widths.map((w) => `${base}/media/adventure/festival/${slug}-${w}.avif ${w}w`).join(", "),
    webp: widths.map((w) => `${base}/media/adventure/festival/${slug}-${w}.webp ${w}w`).join(", "),
    src: `${base}/media/adventure/festival/${slug}-${w0}.webp`,
  };
};
// The teaser's mini magazine cover (same asset as the story page's cover).
const festCover = festImg("cover-charge", [800, 1120, 1600]);
// Two supporting stills — one joust, one combat (the story is the whole
// festival, not just the joust — operator note 2026-07-22).
const FESTIVAL_PHOTOS = [
  { slug: "joust-charge", alt: "Aerial view of a knight on a white horse charging down the jousting lane between festival crowds" },
  { slug: "arena-sails", alt: "Aerial view of the timber combat pen under blue shade sails — armored team bouts, spectators packed at the fence" },
].map((ph) => ({ ...ph, media: festImg(ph.slug, [900, 1600]) })).filter((ph) => ph.media);

/* ─────────────────────────────────────────────────────────────────────────
 * A4c — FROM THE ARCHIVE (Round 4 band, Round 5 roster).
 *
 * The micro local stories not worth a full spread, kept modestly at the
 * bottom of the lane. Round 5 (operator-directed): the band now holds The Art
 * of Brazilian Living, Vybe (MOVED here from /entertainment — operator
 * confirmed), Nordic Daughter, and Something for Tomorrow (the old combined
 * diptych tile SPLIT in two; SfT has no exported tile media yet —
 * ⚠ OPERATOR-CONFIRM, see consts).
 *
 * The lane assignment lives on the DATA (WORK_ARCHIVE[].lane) — this page
 * filters rather than hardcoding slugs, so the two pages can never drift apart
 * or double-render the same tile. Tiles are display-only EXCEPT where a light
 * case page exists (item.href — Vybe): those render the "Read the story →"
 * affordance, links only where content exists. The one honest line per tile is
 * the relationship's permittedPhrasing rendered VERBATIM. Media paths are
 * UNCHANGED (public/media/work/archive/<slug>.*).
 * ───────────────────────────────────────────────────────────────────────── */
const archiveMediaRoot = join(process.cwd(), "public", "media");
const archivePair = (relBase: string) => {
  const has = (ext: string) => existsSync(join(archiveMediaRoot, ...`${relBase}.${ext}`.split("/")));
  const avif = has("avif") ? `${base}/media/${relBase}.avif` : undefined;
  const webp = has("webp") ? `${base}/media/${relBase}.webp` : undefined;
  return avif || webp ? { avif, webp } : undefined;
};
const archive = WORK_ARCHIVE.filter((a) => a.lane === "adventure").map((a) => ({
  item: a,
  media: archivePair(`work/archive/${a.slug}`),
  href: a.href ? `${base}${a.href}` : undefined,
  phrasing: RELATIONSHIP_BY_ID[a.relationshipId]?.permittedPhrasing ?? "",
}));

/* ─────────────────────────────────────────────────────────────────────────
 * A3b — THE FIELD TEASER (Round 5, 2026-07-21, operator-directed).
 *
 * The floating-portraits gallery wall (P19) MOVED to /adventure/field; this
 * page keeps ONE inviting block — copy from consts (⚠ flagged) plus a small
 * strip of the wall's three lead frames as the visual invitation. Same data
 * source (the fieldNotes collection), so the teaser can never drift from the
 * wall it points at.
 * ───────────────────────────────────────────────────────────────────────── */
const TEASER_WIDTHS = {
  landscape: [800, 1400, 2200],
  vertical: [800, 1120, 1600],
} as const;
function galleryMedia(slug: string, orientation: "landscape" | "vertical") {
  const g = join(process.cwd(), "public", "media", "adventure", "gallery");
  if (!existsSync(join(g, `${slug}-800.avif`))) return undefined;
  const widths = TEASER_WIDTHS[orientation];
  return {
    avif: widths.map((w) => `${base}/media/adventure/gallery/${slug}-${w}.avif ${w}w`).join(", "),
    webp: widths.map((w) => `${base}/media/adventure/gallery/${slug}-${w}.webp ${w}w`).join(", "),
    src: `${base}/media/adventure/gallery/${slug}-800.webp`,
  };
}
const TEASER_ORDER = ["matterhorn-zermatt", "bellagio", "flatirons-chautauqua"];
const teaserStories = (await getCollection("fieldNotes", ({ data }) => !data.draft))
  .filter((n) => TEASER_ORDER.includes(n.id) && n.data.photos && n.data.photos.length > 0)
  .sort((a, b) => TEASER_ORDER.indexOf(a.id) - TEASER_ORDER.indexOf(b.id))
  .map((story) => {
    const lead = story.data.photos![0]!;
    return { story, lead, media: galleryMedia(lead.slug, lead.orientation) };
  })
  .filter((t) => t.media);
// M2b (2026-07-22) — a small motion accent for the field teaser: one clean
// vertical drone reel leads the strip so /adventure previews the movement that
// lives on the location pages. Existence-gated; the teaser degrades to the
// still frames if the reel isn't present. Gornergrat = the Matterhorn skyline.
const TEASER_REEL_SLUG = "gornergrat-glacier";
const teaserReelDir = join(process.cwd(), "public", "media", "field-notes", TEASER_REEL_SLUG);
const teaserReel = existsSync(join(teaserReelDir, "loop.mp4"))
  ? {
      src: `${base}/media/field-notes/${TEASER_REEL_SLUG}/loop.mp4`,
      poster: existsSync(join(teaserReelDir, "poster.avif"))
        ? `${base}/media/field-notes/${TEASER_REEL_SLUG}/poster.avif`
        : undefined,
    }
  : undefined;
---

<Base title={p.meta.title} description={p.meta.description}>
  <div data-lane="adventure">
    <!-- A1 — globe hero (§2a, relocated §9.3). Headline paints first (LCP);
         the globe streams in behind it and the poster covers every fallback
         state. Compact vs. home's old treatment — this is a lane header,
         not a full-bleed moment. -->
    <section class="mx-auto max-w-3xl space-y-6 p-8 text-center">
      <!-- P29 buyer-language pairing: the plain buyer term rides above the H1
           so a producer decodes the lane in seconds (consts ⚠ flag). -->
      <p class="hud-label">{p.hero.eyebrow}</p>
      <h1 class="text-3xl font-bold sm:text-5xl">{p.hero.headline}</h1>
      <p class="mx-auto max-w-2xl text-lg text-ink">{p.hero.subline}</p>
      <GlobeHero />
    </section>

    <!-- A1b — HIRE THE OPERATOR (P29 money-now): the production-services
         block, ABOVE the gallery and the AA licensing funnel — the buyer who
         wants to hire the pilot gets a rate, the compliance answer, and a
         direct booking link before any licensing referral. The day rate is
         FORGE_SERVICES 06 verbatim ($2,500/day — repriced P30 against the
         verified $1.5k–$4k commercial band); trust lines are SITE.trust
         (P30 copy rules in consts.ts). -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-8">
      <hr class="flight-line mb-6" aria-hidden="true" />
      <p class="hud-label" data-reveal>{p.hire.kicker}</p>
      <h2 class="text-2xl font-bold" data-reveal>{p.hire.heading}</h2>
      <p class="text-ink" data-reveal>{p.hire.body}</p>
      <div class="panel hire-panel space-y-4 p-6" data-reveal>
        <p class="hire-price">
          <span class="hire-amt">{aerialSvc.price}</span>
          <span class="hire-scope">{p.hire.priceNote}</span>
        </p>
        <ul class="hire-trust">
          <li>{SITE.trust.drone}</li>
          <li>{SITE.trust.travel}</li>
          <li>{SITE.trust.response} · {SITE.trust.base}</li>
        </ul>
        <div class="flex flex-wrap items-center gap-4">
          <a href={p.hire.cta.href} class="btn" rel="noopener">{p.hire.cta.label}</a>
          <a href={`mailto:${SITE.email}`} class="link">{SITE.email}</a>
        </div>
      </div>
    </section>

    <!-- A2 — the territory -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-8">
      <hr class="flight-line mb-6" aria-hidden="true" />
      <h2 class="text-2xl font-bold" data-reveal>{p.territory.heading}</h2>
      <p class="text-ink" data-reveal>{p.territory.body}</p>

      {/* ── P12.4c — THE TERRITORY constellation ──────────────────────────────
          A clickable location-dots map that ILLUSTRATES the copy above: where
          the operator has actually shot, in outings. No new claim sentences —
          every string here is functional data/labels (country + location names,
          outing counts, "License this work →").

          Progressive enhancement model:
            • Base (no-JS / reduced motion): every location is rendered and
              visible — the constellation reads as a static star map, nothing
              needs a click to be seen. Chips (with the license link) reveal on
              hover / focus so keyboard + no-JS users can still reach the link.
            • Enhanced (html.js, motion allowed): the interaction script adds
              `.terr--live`, which collapses each country's locations. Clicking a
              country node sprays its dots out (staggered); clicking another
              country collapses the previous. Clicking a location dot opens its
              info chip. All controls are real <button>s with aria-expanded.

          The <ul> structure IS the plain accessible list the spec asks for:
          country → its locations, each a labelled control with a real license
          link. Under no-JS it renders fully expanded, so it doubles as the
          screen-reader / no-JS fallback list. The decorative SVG arcs are
          aria-hidden. */}
      <figure class="terr" data-reveal aria-labelledby="terr-kicker">
        <figcaption id="terr-kicker" class="terr-kicker hud-label">
          {/* Round 5 NO-COUNT rework — the kicker names the territories
              (derived from the data, self-growing) instead of the retired
              outings/territories counts: a growing body of work is never
              numerized. */}
          {TERRITORY_KICKER}
        </figcaption>
        <p class="sr-only">
          Where this work has been shot. Expand a territory to list its
          locations; aerial-archive locations link out to the licensing
          portfolio, coverage locations link to their story.
        </p>
        <div class="terr-field">
          {/* The shared coordinate frame: a 2:1 wrapper that reproduces the map
              SVG's `meet` letterbox exactly, so the constellation and the world
              behind it live in ONE frame — dots seat on their true coastline by
              pure projection math (see the geometry block above). The parallax
              drift now rides this frame, so map + nodes move locked together. */}
          <div class="terr-frame">
            {/* Faint world-outline backdrop (atmosphere). Fills the frame; the
                interactive country dots now carry the "you-are-here" markers
                (the old in-SVG pings were removed as duplicates). */}
            <WorldMapBackdrop />
            <svg
              class="terr-arcs"
              viewBox="0 0 100 100"
              preserveAspectRatio="none"
              aria-hidden="true"
              focusable="false"
            >
              {TERRITORY_ARCS.map((d) => <path class="terr-arc" d={d} />)}
            </svg>
            <ul class="terr-clusters">
              {
                territory.map((c) => (
                  <li
                    class="terr-cluster"
                    style={`--cx:${c.cx};--cy:${c.cy}`}
                    data-country={c.country}
                    data-label-dir={c.labelDir}
                  >
                    <button
                      type="button"
                      class="terr-country"
                      aria-expanded="true"
                      aria-controls={`terr-locs-${c.slug}`}
                      aria-label={`${c.country} — expand to list its locations`}
                    >
                      <span class="terr-dot" aria-hidden="true" />
                      <span class="terr-leader" aria-hidden="true" />
                      <span class="terr-country-label">{c.label}</span>
                    </button>
                  <ul class="terr-locations" id={`terr-locs-${c.slug}`}>
                    {c.locations.map((loc, i) => (
                      <li
                        class="terr-loc"
                        style={`--lx:${loc.x};--ly:${loc.y};--i:${i}`}
                        data-side={loc.side}
                      >
                        <button
                          type="button"
                          class="terr-loc-node"
                          aria-expanded="false"
                          aria-controls={`terr-chip-${loc.slug}`}
                          aria-label={loc.name}
                        >
                          <span class="terr-loc-dot" aria-hidden="true" />
                          <span class="terr-loc-label" aria-hidden="true">{loc.name}</span>
                        </button>
                        {/* Round 5 — count-free chip: name + the link that
                            proves the place. Aerial-archive dots keep the
                            licensing pointer; coverage dots link to their
                            story page (see territory.ts, ⚠-flagged). */}
                        <span class="terr-chip" id={`terr-chip-${loc.slug}`} role="group">
                          <span class="terr-chip-name">{loc.name}</span>
                          {loc.kind === "coverage" && loc.href ? (
                            <a class="terr-chip-link link" href={`${base}${loc.href}`}>
                              {loc.linkLabel ?? "See the story"} <span class="arrow" aria-hidden="true">→</span>
                            </a>
                          ) : (
                            <a
                              class="terr-chip-link link"
                              href={AA_HREF}
                              target="_blank"
                              rel="noopener"
                            >
                              License this work <span class="arrow" aria-hidden="true">→</span>
                            </a>
                          )}
                        </span>
                      </li>
                    ))}
                  </ul>
                </li>
              ))
            }
            </ul>
          </div>
        </div>
      </figure>
    </section>

    <!-- A3b — THE FIELD teaser (Round 5): the floating-portraits gallery
         moved to /adventure/field (with the licensed/personal nesting and the
         AA licensing weave); this page keeps ONE inviting block — travel
         stories from the field, with the wall's three lead frames as the
         invitation. Copy from consts (⚠ flagged, staging-only until read). -->
    <section class="mx-auto max-w-5xl space-y-4 border-t border-hairline p-8">
      <hr class="flight-line mb-6" aria-hidden="true" />
      <p class="hud-label" data-reveal>{p.fieldTeaser.kicker}</p>
      <h2 class="text-2xl font-bold" data-reveal>{p.fieldTeaser.heading}</h2>
      <p class="max-w-3xl text-ink" data-reveal>{p.fieldTeaser.body}</p>
      {/* M3 — THE FIELD BOARD (2026-07-22, operator: this section is the
          advertisement space for ALL the locales — it should out-premium the
          festival teaser). A dense expedition collage: seven frames from seven
          different outings (baked by scripts/make-fieldboard.mjs + the gallery
          exports), one LIVE reel cell (Gornergrat), each carrying its mono
          location slate; an Amazing Aerial chip closes the set. The whole board
          is one link into /adventure/field. Location names are read straight
          from the source-folder labels — nothing invented. */}
      <a
        class="fieldboard"
        href={`${base}${p.fieldTeaser.cta.href}`}
        aria-label={`${p.fieldTeaser.heading} — ${p.fieldTeaser.cta.label}`}
        data-reveal
      >
        <div class="fb-grid">
          {/* HERO — the graded Matterhorn widescreen (operator-supplied +
              color-graded), 2x2, left. */}
          <figure class="fb-cell fb-cell--hero">
            <picture>
              <source type="image/avif" srcset={[900, 1600].map((w) => `${base}/media/adventure/fieldboard/matterhorn-hero-${w}.avif ${w}w`).join(", ")} sizes="(min-width: 1024px) 48vw, 92vw" />
              <source type="image/webp" srcset={[900, 1600].map((w) => `${base}/media/adventure/fieldboard/matterhorn-hero-${w}.webp ${w}w`).join(", ")} sizes="(min-width: 1024px) 48vw, 92vw" />
              <img src={`${base}/media/adventure/fieldboard/matterhorn-hero-900.webp`} alt="The Matterhorn above the Zermatt valley, its pyramid summit under a wisp of cloud" loading="lazy" decoding="async" />
            </picture>
            <figcaption class="fb-slate hud-label">Matterhorn · Zermatt</figcaption>
          </figure>

          {/* right shoulder: the live reel + a Nesso vertical bracket the hero */}
          {teaserReel && (
            <figure class="fb-cell fb-cell--reel">
              {teaserReel.poster && <img class="fb-reel-poster" src={teaserReel.poster} alt="" loading="lazy" decoding="async" />}
              <video class="fb-reel-loop" data-teaser-reel data-loop-src={teaserReel.src} muted loop playsinline preload="none" aria-hidden="true"></video>
              <figcaption class="fb-slate hud-label">Gornergrat · CH</figcaption>
            </figure>
          )}
          <figure class="fb-cell fb-cell--tall">
            <picture>
              <source type="image/avif" srcset={[700, 1120].map((w) => `${base}/media/adventure/fieldboard/nesso-a-${w}.avif ${w}w`).join(", ")} sizes="(min-width: 1024px) 24vw, 46vw" />
              <source type="image/webp" srcset={[700, 1120].map((w) => `${base}/media/adventure/fieldboard/nesso-a-${w}.webp ${w}w`).join(", ")} sizes="(min-width: 1024px) 24vw, 46vw" />
              <img src={`${base}/media/adventure/fieldboard/nesso-a-700.webp`} alt="The village of Nesso on Lake Como, the Civera bridge over the gorge waterfall and a boat on the water below" loading="lazy" decoding="async" />
            </picture>
            <figcaption class="fb-slate hud-label">Nesso · Lake Como</figcaption>
          </figure>

          {/* lower band: three landscape singles + the second Nesso vertical */}
          {
            [
              { slug: "ouray", w: [900, 1600], cls: "", slate: "Ouray · Colorado", alt: "Aerial of Ouray, Colorado — the town grid boxed in by canyon walls" },
              { slug: "limmernsee", w: [700, 1200], cls: "", slate: "Limmernsee · Glarus", alt: "Cloud pouring over a mountain gorge above the Limmernsee, Switzerland" },
              { slug: "trift", w: [700, 1200], cls: "", slate: "Trift Gorge · Bern", alt: "A glacial river threading the rock gorge below the Trift bridge, Switzerland" },
            ].map((c) => (
              <figure class={`fb-cell ${c.cls}`}>
                <picture>
                  <source type="image/avif" srcset={c.w.map((w) => `${base}/media/adventure/fieldboard/${c.slug}-${w}.avif ${w}w`).join(", ")} sizes="(min-width: 1024px) 24vw, 46vw" />
                  <source type="image/webp" srcset={c.w.map((w) => `${base}/media/adventure/fieldboard/${c.slug}-${w}.webp ${w}w`).join(", ")} sizes="(min-width: 1024px) 24vw, 46vw" />
                  <img src={`${base}/media/adventure/fieldboard/${c.slug}-${c.w[0]}.webp`} alt={c.alt} loading="lazy" decoding="async" />
                </picture>
                <figcaption class="fb-slate hud-label">{c.slate}</figcaption>
              </figure>
            ))
          }
          {/* the Ironton waterfall closes the lower band (operator: one Nesso
              is enough — keep the best, DJI_0129, and restore Ironton). */}
          <figure class="fb-cell">
            <picture>
              <source type="image/avif" srcset={[700, 1200].map((w) => `${base}/media/adventure/fieldboard/ironton-${w}.avif ${w}w`).join(", ")} sizes="(min-width: 1024px) 24vw, 46vw" />
              <source type="image/webp" srcset={[700, 1200].map((w) => `${base}/media/adventure/fieldboard/ironton-${w}.webp ${w}w`).join(", ")} sizes="(min-width: 1024px) 24vw, 46vw" />
              <img src={`${base}/media/adventure/fieldboard/ironton-700.webp`} alt="A waterfall dropping through cliffs above the Ironton forest, Colorado" loading="lazy" decoding="async" />
            </picture>
            <figcaption class="fb-slate hud-label">Ironton · Colorado</figcaption>
          </figure>

          <div class="fb-cell fb-cell--aa panel">
            <img src={`${base}/media/adventure/aa-logo.png`} alt="Amazing Aerial Agency" width="480" height="158" loading="lazy" decoding="async" />
            <p class="hud-label">Full collection · editorial licensing</p>
          </div>
        </div>
        <span class="fb-cta btn" aria-hidden="true">
          {p.fieldTeaser.cta.label} <span class="arrow">→</span>
        </span>
      </a>
      {teaserStories.length === 0 && (
        <p data-reveal>
          <a href={`${base}${p.fieldTeaser.cta.href}`} class="btn">{p.fieldTeaser.cta.label}</a>
        </p>
      )}
    </section>

    <!-- A4b — MEDIEVAL FESTIVAL IN LOVELAND (Round 3): the Knights of Mayhem
         piece, re-laned from /work and broadened into one cohesive festival
         story block — feature video + joust & ground-combat drone frames.
         The attribution line composes from the WORK record (the wall's own
         "For [org] · [what] — [engagement]" grammar); the aerial-licensing
         credibility marker renders via LegendMark (the _AA source folders
         carry these festival frames — the relationship's verbatim phrasing is
         the only way it may be stated). -->
    {
      knights && (
        <section id="festival" class="border-t border-hairline p-8">
          <div class="mx-auto max-w-5xl space-y-4">
            <hr class="flight-line mb-6" aria-hidden="true" />
            <p class="hud-label" data-reveal>{p.festival.kicker}</p>
            <h2 class="text-2xl font-bold" data-reveal>{p.festival.heading}</h2>

            {/* M1 v3 (2026-07-22) — the festival block is a magazine-cover
                TEASER that drives to the full story (Round-5 block→subpage
                pattern). The mini cover reuses the story's cover asset; two
                supporting stills (joust + combat) sit beside the blurb and
                the CTA. The inline feature video was removed (it lived on the
                busy full story page instead). */}
            <div class="fest-teaser">
              {festCover && (
                <a
                  href={`${base}/adventure/steel-and-dust`}
                  class="fest-cover"
                  data-reveal
                  aria-label="Read the full story — Steel & Dust, Field Notes No. 01"
                >
                  <picture>
                    <source type="image/avif" srcset={festCover.avif} sizes="(min-width: 900px) 300px, 60vw" />
                    <source type="image/webp" srcset={festCover.webp} sizes="(min-width: 900px) 300px, 60vw" />
                    <img
                      src={festCover.src}
                      alt="Two armored knights charging each other down the jousting lists — the Steel & Dust cover"
                      class="fest-cover-img"
                      loading="lazy"
                      decoding="async"
                    />
                  </picture>
                  <span class="fest-cover-scrim" aria-hidden="true"></span>
                  <span class="fest-cover-mast hud-label">Field Notes <span class="fest-cover-issue">No. 01</span></span>
                  <span class="fest-cover-title">Steel <span class="fest-cover-amp" aria-hidden="true">&amp;</span> Dust</span>
                  <span class="fest-cover-enter hud-label" aria-hidden="true">Read the story →</span>
                </a>
              )}

              <div class="fest-teaser-body">
                <p class="text-ink" data-reveal>{p.festival.body}</p>

                {FESTIVAL_PHOTOS.length > 0 && (
                  <div class="fest-stills" data-reveal>
                    {FESTIVAL_PHOTOS.map((ph) => (
                      <figure class="fest-still">
                        <picture>
                          <source type="image/avif" srcset={ph.media!.avif} sizes="(min-width: 900px) 28vw, 45vw" />
                          <source type="image/webp" srcset={ph.media!.webp} sizes="(min-width: 900px) 28vw, 45vw" />
                          <img
                            src={ph.media!.src}
                            alt={ph.alt}
                            style="aspect-ratio:16/9;object-fit:cover"
                            class="block w-full"
                            loading="lazy"
                            decoding="async"
                          />
                        </picture>
                      </figure>
                    ))}
                  </div>
                )}

                <p data-reveal>
                  <a href={`${base}/adventure/steel-and-dust`} class="btn">
                    Read the full story — Steel &amp; Dust <span class="arrow" aria-hidden="true">→</span>
                  </a>
                </p>

                <div class="fest-attrib space-y-1" data-reveal>
                  <p class="fest-line">
                    For {knights.forOrg} · {knights.what}
                    {knights.engagement && knights.engagement !== "[confirm]" ? ` — ${knights.engagement}` : ""}
                  </p>
                  <LegendMark proof={{ relationshipId: "amazing-aerial" }} class="fest-aa" />
                </div>
              </div>
            </div>
          </div>
        </section>
      )
    }

    <!-- A4c — FROM THE ARCHIVE (Round 5 roster): the lane's bottom band of
         micro local stories. Deliberately the QUIETEST band on the page —
         small tiles, muted stills, one honest line each (the relationship's
         permittedPhrasing, printed VERBATIM). Tiles link ONLY where a light
         case page exists (Vybe); the rest are display-only. Uses the page's
         own section grammar (hairline rule + flight-line divider + hud-label
         kicker) so it reads as part of /adventure. -->
    {
      archive.length > 0 && (
        <section class="border-t border-hairline p-8">
          <div class="mx-auto max-w-5xl space-y-3">
            <hr class="flight-line mb-6" aria-hidden="true" />
            <p class="hud-label" data-reveal>{p.coverage.kicker}</p>
            <h2 class="text-2xl font-bold" data-reveal>{p.coverage.heading}</h2>
            <p class="max-w-3xl text-ink" data-reveal>{p.coverage.body}</p>
            <div class="arch-grid">
              {archive.map(({ item, media: m, href: ahref, phrasing }) => {
                const Tag = ahref ? "a" : "figure";
                return (
                  <Tag
                    class={`arch-tile${ahref ? " arch-tile--link" : ""}`}
                    href={ahref}
                    data-reveal
                    data-reveal-stagger="60"
                  >
                    <div class="arch-media" aria-hidden="true">
                      {m && (
                        <picture>
                          {m.avif && <source type="image/avif" srcset={m.avif} />}
                          <img src={m.webp ?? m.avif} alt="" loading="lazy" decoding="async" />
                        </picture>
                      )}
                    </div>
                    <div class="arch-meta">
                      <span class="arch-head">
                        <span class="arch-title">{item.title}</span>
                        <span class="arch-date hud-label">{item.date}</span>
                      </span>
                      <span class="arch-line">{phrasing}</span>
                      {ahref && (
                        <span class="arch-cta link" aria-hidden="true">
                          Read the story <span class="arrow">→</span>
                        </span>
                      )}
                    </div>
                  </Tag>
                );
              })}
            </div>
          </div>
        </section>
      )
    }

    <!-- A5 — P29: the close is this lane's OWN buyer action (production →
         Calendly direct), not a consulting handoff. The field-notes wayfinder
         moved to /adventure/field with the gallery (Round 5). -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-8 text-center">
      <p class="text-lg italic text-ink">{p.handoff.body}</p>
      <a href={href(p.handoff.cta.href)} class="btn" rel="noopener">{p.handoff.cta.label}</a>
    </section>
  </div>

  <!-- §2e hover-distortion (feature-gated; CSS fallback is the default) -->
  <DistortionLayer />
</Base>

<style>
  /* ── P29 · A1b hire-the-operator panel — the day rate in the display serif
     (same price grammar as the forge cards), honest scope note beside it, and
     the compliance/logistics answers as a quiet mono list. ── */
