---
/**
 * Adventure — credibility lane, "the wild" (BUILD-PLAN.md §1.3, amended §9.3
 * + §9.5). Runs the Adventure dialect via data-lane="adventure" (§3.3/§6
 * synthesis): flight-line dividers + violet-slate map-insets.
 *
 * A1 is now the GLOBE HERO (moved here from home, §9.3) — "where the stories
 * are told" is native to this lane. Compact headline + subline + GlobeHero,
 * wrapped in its own <section> so the globe's scroll-handoff retargets to
 * THIS section automatically (GlobeHero.astro targets `root.closest("section")`).
 *
 * Photo-first (§9.5): the gallery is the page's main surface — widened,
 * ready to grow to 20–40 real selects (S2). The ambient reel is now
 * optional/selective and sits below the gallery, not as the page opener.
 */
import Base from "../layouts/Base.astro";
import DistortionLayer from "../components/DistortionLayer.astro";
import GlobeHero from "../components/GlobeHero.astro";
import HeroVideo from "../components/HeroVideo.astro";
import LegendMark from "../components/LegendMark.astro";
import WorldMapBackdrop from "../components/WorldMapBackdrop.astro";
import { PAGES, FORGE_SERVICES, RELATIONSHIP_BY_ID, SITE, WORK, WORK_ARCHIVE } from "../consts";
import { TERRITORY, TERRITORY_TOTALS } from "../data/territory";
import { getCollection } from "astro:content";

import { existsSync } from "node:fs";
import { join } from "node:path";

const p = PAGES.adventure;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// P29 — CTA hrefs may be external (Calendly direct); only prefix internal routes.
const href = (h: string) => (h.startsWith("http") ? h : `${base}${h}`);
// P29 — the day rate is the aerial service's EXISTING staged floor (FORGE_SERVICES
// 06), rendered verbatim — single-sourced, never restated as a new number.
const aerialSvc = FORGE_SERVICES.find((s) => s.no === "06")!;

/* ─────────────────────────────────────────────────────────────────────────
 * "THE TERRITORY" constellation geometry — now SEATED ON THE WORLD MAP.
 *
 * The constellation shares ONE coordinate frame with WorldMapBackdrop: a 2:1
 * wrapper (.terr-frame) that reproduces the map SVG's `meet` letterbox exactly
 * (aspect-ratio:2/1, max 100%, centered in the 16:9 field). Because that frame
 * IS the rendered map rectangle, a node's position is pure projection math
 * against the equirectangular world (viewBox 0 0 360 180):
 *     left% = (lon + 180) / 360 * 100      top% = (90 − lat) / 180 * 100
 * No JS measurement, no hand-tuned percentages — lon/lat are the source of
 * truth and cx/cy are derived, so the dots land on their true coastline.
 *
 * The label-collision problem (Switzerland↔Italy are ~0.5% apart at world zoom,
 * Colorado↔New Mexico ~3%): each cluster keeps its DOT at the true point, and
 * its LABEL + expanded location list are offset away on a hairline leader —
 * classic cartographic labeling. The per-cluster `labelDir` fans the callouts
 * apart so they never overlap. The location dots are a decorative legend cloud
 * that sprays around that offset callout (NOT geographic pins — we have no
 * per-place lat/lon), so a dense country reads as "many shoots here" without
 * implying wrong coordinates.
 * ───────────────────────────────────────────────────────────────────────── */
type LabelDir = "up-left" | "up-right" | "down-left" | "down-right";
const TERRITORY_CLUSTERS: Record<
  string,
  { lat: number; lon: number; labelDir: LabelDir; sprayR: number }
> = {
  // lat/lon are the ONLY hand values now; cx/cy derive from them below.
  // labelDir: both edge-pairs open INWARD (rightward) so no callout runs off the
  // panel — within each pair the northern dot's label goes up, the southern down,
  // so the two coincident clusters stack cleanly instead of colliding.
  Colorado: { lat: 40.0, lon: -105.3, labelDir: "up-right", sprayR: 6 }, // Boulder (N of NM → up)
  "New Mexico": { lat: 34.5, lon: -106.1, labelDir: "down-right", sprayR: 2 }, // Taos (S → down)
  // The Alp pair coincides at world zoom, so their up/down callouts share an x —
  // a tighter spray keeps the two clouds from merging (they separate vertically)
  // and keeps Switzerland's dense 24-dot cloud inside the frame.
  Switzerland: { lat: 46.1, lon: 7.9, labelDir: "up-right", sprayR: 4 }, // Valais (N of IT → up)
  Italy: { lat: 45.9, lon: 9.8, labelDir: "down-right", sprayR: 4 }, // Como / Trentino (S → down)
};

// Equirectangular projection into the shared 2:1 frame (percent of frame box).
const lon2x = (lon: number) => ((lon + 180) / 360) * 100;
const lat2y = (lat: number) => ((90 - lat) / 180) * 100;

// Callout bias: the decorative location cloud sprays around a point pushed off
// the dot toward the label side, so the two near-coincident Alp clusters throw
// their clouds apart. dx in x-%, dy in y-% (the frame is 2:1, so a y-% is half
// the pixels of an x-% — see TERRITORY_YSCALE).
const LABEL_BIAS: Record<LabelDir, { dx: number; dy: number }> = {
  "up-left": { dx: -7, dy: -11 },
  "up-right": { dx: 7, dy: -11 },
  "down-left": { dx: -7, dy: 11 },
  "down-right": { dx: 7, dy: 11 },
};

const GOLDEN_ANGLE = Math.PI * (3 - Math.sqrt(5)); // ≈137.5°, the sunflower angle
// The frame is twice as wide as tall, so 1 y-% is half the pixels of 1 x-%.
// Doubling the spiral's y component keeps the decorative cloud round on screen.
const TERRITORY_YSCALE = 2;

function terrSlug(s: string) {
  return s
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
}

const territory = TERRITORY.map((c) => {
  const cfg = TERRITORY_CLUSTERS[c.country];
  const cx = lon2x(cfg.lon);
  const cy = lat2y(cfg.lat);
  const bias = LABEL_BIAS[cfg.labelDir];
  const sx = cx + bias.dx; // spray center — pushed toward the callout
  const sy = cy + bias.dy;
  const n = c.locations.length;
  const locations = c.locations.map((loc, i) => {
    const frac = (i + 0.5) / n;
    const rad = cfg.sprayR * Math.sqrt(frac);
    const theta = i * GOLDEN_ANGLE;
    const x = sx + rad * Math.cos(theta);
    const y = sy + rad * Math.sin(theta) * TERRITORY_YSCALE;
    // Info chip opens toward the frame interior so it never runs off an edge.
    const side = x > 58 ? "left" : x < 42 ? "right" : "down";
    return {
      ...loc,
      slug: terrSlug(`${c.country}-${loc.name}`),
      x: Math.round(x * 100) / 100,
      y: Math.round(y * 100) / 100,
      side,
    };
  });
  return {
    ...c,
    slug: terrSlug(c.country),
    cx: Math.round(cx * 100) / 100,
    cy: Math.round(cy * 100) / 100,
    labelDir: cfg.labelDir,
    locations,
  };
});

// Decorative hairline arcs, REGENERATED from the true positions in the SAME 2:1
// frame. The arcs SVG uses viewBox "0 0 100 100" + preserveAspectRatio="none",
// so x→width and y→height exactly as the CSS percentages do — an (cx,cy)
// endpoint lands precisely on that cluster's dot. Only the small bow constants
// are authored; the endpoints are derived, never hand-placed.
const posOf = (country: string) => {
  const t = territory.find((c) => c.country === country)!;
  return { x: t.cx, y: t.cy };
};
const terrArc = (a: string, b: string, bowX: number, bowY: number) => {
  const p = posOf(a);
  const q = posOf(b);
  const mx = Math.round(((p.x + q.x) / 2 + bowX) * 100) / 100;
  const my = Math.round(((p.y + q.y) / 2 + bowY) * 100) / 100;
  return `M${p.x},${p.y} Q${mx},${my} ${q.x},${q.y}`;
};
const TERRITORY_ARCS = [
  terrArc("Colorado", "Switzerland", 0, -13), // transatlantic bridge (bows north)
  terrArc("Switzerland", "Italy", 3.5, 7), // the short Alps hop (near-coincident pair)
  terrArc("Colorado", "New Mexico", -3, 0), // the home column (bows west)
];
const AA_HREF = p.aaFunnel.cta.href; // same operator portfolio URL as the gallery (P12.4b)
const outingWord = (n: number) => (n === 1 ? "OUTING" : "OUTINGS");

// Ambient reel: SKIPPED by default (DIRECTION §2.3) — the on-disk loop
// candidates were unverified content. The section renders only if a real reel
// is dropped at public/media/adventure/reel-loop.mp4 (+ poster). No sources =
// no section (not a placeholder box). Checked at build time (frontmatter runs
// server-side); anchored to process.cwd() like Tableaux.astro.
const reelDir = join(process.cwd(), "public", "media", "adventure");
const reelHasLoop = existsSync(join(reelDir, "reel-loop.mp4"));
const reelHasPoster = existsSync(join(reelDir, "reel-poster.avif"));
const reelSources = reelHasLoop
  ? [{ src: `${base}/media/adventure/reel-loop.mp4`, type: "video/mp4" }]
  : [];
const reelPoster = reelHasPoster ? `${base}/media/adventure/reel-poster.avif` : undefined;

/* ─────────────────────────────────────────────────────────────────────────
 * A4b — MEDIEVAL FESTIVAL IN LOVELAND (Round 3, 2026-07-21).
 *
 * The Knights of Mayhem piece RE-LANED here from the /work wall (operator:
 * "Knights of Mayhem is an adventure story") and BROADENED into one cohesive
 * festival story block: the showcase video (the existing loop + poster export
 * under media/work/knights-of-mayhem/ — path unchanged, no asset churn) stays
 * the feature, ringed by four of the operator's own drone frames of the joust
 * lane and the armored ground-combat arena (baked to media/adventure/festival/
 * by scripts/make-festival-photos.mjs). The attribution line composes from the
 * WORK record — single source, same "For [org] · [what] — [engagement]"
 * grammar the wall used. The aerial-licensing credibility marker renders ONLY
 * via LegendMark (amazing-aerial's verbatim permittedPhrasing).
 * ───────────────────────────────────────────────────────────────────────── */
const knights = WORK.find((w) => w.slug === "knights-of-mayhem");
const festDir = join(process.cwd(), "public", "media", "work", "knights-of-mayhem");
const festPoster = existsSync(join(festDir, "poster.avif"))
  ? `${base}/media/work/knights-of-mayhem/poster.avif`
  : undefined;
const festSources = existsSync(join(festDir, "loop.mp4"))
  ? [{ src: `${base}/media/work/knights-of-mayhem/loop.mp4`, type: "video/mp4" }]
  : [];
// Photo band — existence-gated per file, like every other baked set.
const festPhoto = (slug: string) => {
  const dir = join(process.cwd(), "public", "media", "adventure", "festival");
  if (!existsSync(join(dir, `${slug}-900.avif`))) return undefined;
  return {
    avif: [900, 1600].map((w) => `${base}/media/adventure/festival/${slug}-${w}.avif ${w}w`).join(", "),
    webp: [900, 1600].map((w) => `${base}/media/adventure/festival/${slug}-${w}.webp ${w}w`).join(", "),
    src: `${base}/media/adventure/festival/${slug}-900.webp`,
  };
};
const FESTIVAL_PHOTOS = [
  { slug: "joust-charge", alt: "Aerial view of a knight on a white horse charging down the jousting lane between festival crowds" },
  { slug: "joust-riders", alt: "Two armored riders in the lists, the white horse in the foreground, crowds along both rails" },
  { slug: "melee-arena", alt: "Aerial view of two armored fighters squaring up in the wooden combat arena, ringed by spectators" },
  { slug: "melee-brawl", alt: "Three simultaneous armored bouts at the corners of the combat arena, seen from above" },
].map((ph) => ({ ...ph, media: festPhoto(ph.slug) })).filter((ph) => ph.media);

/* ─────────────────────────────────────────────────────────────────────────
 * A4c — FROM THE ARCHIVE (Round 4, 2026-07-21, operator-directed).
 *
 * Two tiles moved here off /entertainment's archive band: Nordic Daughter &
 * Something for Tomorrow, and The Art of Brazilian Living. Both read as
 * travel/coverage pieces ("was around here, filmed this") rather than
 * commissioned venture work, so they belong to this lane's record.
 *
 * The lane assignment lives on the DATA (WORK_ARCHIVE[].lane) — this page
 * filters rather than hardcoding slugs, so the two pages can never drift apart
 * or double-render the same tile.
 *
 * Presented MODESTLY on purpose (operator: padding until stronger work
 * replaces them): a small tile grid below the gallery and the festival
 * feature, muted media at rest, no CTA, no inflated framing. The one honest
 * line per tile is the relationship's permittedPhrasing rendered VERBATIM —
 * exactly the contract the /entertainment band used. Media paths are UNCHANGED
 * (public/media/work/archive/<slug>.*) so nothing had to be re-exported.
 * ───────────────────────────────────────────────────────────────────────── */
const archiveMediaRoot = join(process.cwd(), "public", "media");
const archivePair = (relBase: string) => {
  const has = (ext: string) => existsSync(join(archiveMediaRoot, ...`${relBase}.${ext}`.split("/")));
  const avif = has("avif") ? `${base}/media/${relBase}.avif` : undefined;
  const webp = has("webp") ? `${base}/media/${relBase}.webp` : undefined;
  return avif || webp ? { avif, webp } : undefined;
};
const archive = WORK_ARCHIVE.filter((a) => a.lane === "adventure").map((a) => ({
  item: a,
  media: archivePair(`work/archive/${a.slug}`),
  phrasing: RELATIONSHIP_BY_ID[a.relationshipId]?.permittedPhrasing ?? "",
}));

// Slug → gallery media map. Round 2 (R3): widths are orientation-aware —
// landscape cards export 800/1400/2200 (3:2), vertical cards 800/1120/1600
// (4:5). A responsive <picture> renders only when the exported set exists.
const GALLERY_WIDTHS = {
  landscape: [800, 1400, 2200],
  vertical: [800, 1120, 1600],
} as const;
function galleryMedia(slug: string, orientation: "landscape" | "vertical") {
  const g = join(process.cwd(), "public", "media", "adventure", "gallery");
  if (!existsSync(join(g, `${slug}-800.avif`))) return undefined;
  const widths = GALLERY_WIDTHS[orientation];
  return {
    avif: widths.map((w) => `${base}/media/adventure/gallery/${slug}-${w}.avif ${w}w`).join(", "),
    webp: widths.map((w) => `${base}/media/adventure/gallery/${slug}-${w}.webp ${w}w`).join(", "),
    src: `${base}/media/adventure/gallery/${slug}-800.webp`,
  };
}

/* ─────────────────────────────────────────────────────────────────────────
 * P12.6 — MICRO TRAVEL STORIES (data-driven).
 *
 * The gallery is now an EVER-EXPANDING set of micro-stories, one markdown file
 * per place under src/content/field-notes/ (the fieldNotes collection). A note
 * becomes a story here when it carries `photos`; the operator adds a place by
 * dropping a file. Same files power /field-notes (the chronological log), so
 * the collection is no longer empty (the build warning is gone).
 *
 * TILE BUDGET (distort-engine.ts ≤20 live-measure rule): each story renders ONE
 * distort tile — its LEAD photo, via Card's .map-inset. Secondary photos (if a
 * story ever ships 2–3) render as plain <picture> OUTSIDE any .map-inset, so
 * they never count as tiles. 10 stories = 10 tiles, well under the 20 that keep
 * the click-to-expand field note lag-free. If this ever nears 20, split the
 * wall into per-territory [data-distort-grid] blocks.
 * ───────────────────────────────────────────────────────────────────────── */
const WALL_ORDER = [
  "matterhorn-zermatt",
  "bellagio",
  "flatirons-chautauqua",
  "crans-montana",
  "castel-toblino",
  "eldorado-springs",
  "lac-de-tseuzier",
  "varenna-lake-como",
  "lugano",
  "gornergrat-glacier",
];
const stories = (await getCollection("fieldNotes", ({ data }) => !data.draft))
  .filter((n) => n.data.photos && n.data.photos.length > 0)
  .sort((a, b) => {
    const ai = WALL_ORDER.indexOf(a.id);
    const bi = WALL_ORDER.indexOf(b.id);
    return (ai < 0 ? 999 : ai) - (bi < 0 ? 999 : bi);
  });

// Mono survey slate: YYYY.MM.DD from UTC parts (matches /field-notes).
const fmtSlate = (d: Date) =>
  `${d.getUTCFullYear()}.${String(d.getUTCMonth() + 1).padStart(2, "0")}.${String(d.getUTCDate()).padStart(2, "0")}`;
---

<Base title={p.meta.title} description={p.meta.description}>
  <div data-lane="adventure">
    <!-- A1 — globe hero (§2a, relocated §9.3). Headline paints first (LCP);
         the globe streams in behind it and the poster covers every fallback
         state. Compact vs. home's old treatment — this is a lane header,
         not a full-bleed moment. -->
    <section class="mx-auto max-w-3xl space-y-6 p-8 text-center">
      <!-- P29 buyer-language pairing: the plain buyer term rides above the H1
           so a producer decodes the lane in seconds (consts ⚠ flag). -->
      <p class="hud-label">{p.hero.eyebrow}</p>
      <h1 class="text-3xl font-bold sm:text-5xl">{p.hero.headline}</h1>
      <p class="mx-auto max-w-2xl text-lg text-ink">{p.hero.subline}</p>
      <GlobeHero />
    </section>

    <!-- A1b — HIRE THE OPERATOR (P29 money-now): the production-services
         block, ABOVE the gallery and the AA licensing funnel — the buyer who
         wants to hire the pilot gets a rate, the compliance answer, and a
         direct booking link before any licensing referral. The day rate is
         FORGE_SERVICES 06 verbatim ($2,500/day — repriced P30 against the
         verified $1.5k–$4k commercial band); trust lines are SITE.trust
         (P30 copy rules in consts.ts). -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-8">
      <hr class="flight-line mb-6" aria-hidden="true" />
      <p class="hud-label" data-reveal>{p.hire.kicker}</p>
      <h2 class="text-2xl font-bold" data-reveal>{p.hire.heading}</h2>
      <p class="text-ink" data-reveal>{p.hire.body}</p>
      <div class="panel hire-panel space-y-4 p-6" data-reveal>
        <p class="hire-price">
          <span class="hire-amt">{aerialSvc.price}</span>
          <span class="hire-scope">{p.hire.priceNote}</span>
        </p>
        <ul class="hire-trust">
          <li>{SITE.trust.drone}</li>
          <li>{SITE.trust.travel}</li>
          <li>{SITE.trust.response} · {SITE.trust.base}</li>
        </ul>
        <div class="flex flex-wrap items-center gap-4">
          <a href={p.hire.cta.href} class="btn" rel="noopener">{p.hire.cta.label}</a>
          <a href={`mailto:${SITE.email}`} class="link">{SITE.email}</a>
        </div>
      </div>
    </section>

    <!-- A2 — the territory -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-8">
      <hr class="flight-line mb-6" aria-hidden="true" />
      <h2 class="text-2xl font-bold" data-reveal>{p.territory.heading}</h2>
      <p class="text-ink" data-reveal>{p.territory.body}</p>

      {/* ── P12.4c — THE TERRITORY constellation ──────────────────────────────
          A clickable location-dots map that ILLUSTRATES the copy above: where
          the operator has actually shot, in outings. No new claim sentences —
          every string here is functional data/labels (country + location names,
          outing counts, "License this work →").

          Progressive enhancement model:
            • Base (no-JS / reduced motion): every location is rendered and
              visible — the constellation reads as a static star map, nothing
              needs a click to be seen. Chips (with the license link) reveal on
              hover / focus so keyboard + no-JS users can still reach the link.
            • Enhanced (html.js, motion allowed): the interaction script adds
              `.terr--live`, which collapses each country's locations. Clicking a
              country node sprays its dots out (staggered); clicking another
              country collapses the previous. Clicking a location dot opens its
              info chip. All controls are real <button>s with aria-expanded.

          The <ul> structure IS the plain accessible list the spec asks for:
          country → its locations, each a labelled control with a real license
          link. Under no-JS it renders fully expanded, so it doubles as the
          screen-reader / no-JS fallback list. The decorative SVG arcs are
          aria-hidden. */}
      <figure class="terr" data-reveal aria-labelledby="terr-kicker">
        <figcaption id="terr-kicker" class="terr-kicker hud-label">
          {/* P17 fix — the hardcoded "3 COUNTRIES" undercounted the map's own
              four nodes (Colorado, New Mexico, Switzerland, Italy).
              "TERRITORIES" is the section's own grammar AND stays honest
              (CO + NM share a country); the count now comes from the data so
              it can't drift again. */}
          {TERRITORY_TOTALS.outings} OUTINGS · {TERRITORY_TOTALS.territories} TERRITORIES
        </figcaption>
        <p class="sr-only">
          Where this work was shot, by number of outings. Expand a country to
          list its locations; each links out to the licensing portfolio.
        </p>
        <div class="terr-field">
          {/* The shared coordinate frame: a 2:1 wrapper that reproduces the map
              SVG's `meet` letterbox exactly, so the constellation and the world
              behind it live in ONE frame — dots seat on their true coastline by
              pure projection math (see the geometry block above). The parallax
              drift now rides this frame, so map + nodes move locked together. */}
          <div class="terr-frame">
            {/* Faint world-outline backdrop (atmosphere). Fills the frame; the
                interactive country dots now carry the "you-are-here" markers
                (the old in-SVG pings were removed as duplicates). */}
            <WorldMapBackdrop />
            <svg
              class="terr-arcs"
              viewBox="0 0 100 100"
              preserveAspectRatio="none"
              aria-hidden="true"
              focusable="false"
            >
              {TERRITORY_ARCS.map((d) => <path class="terr-arc" d={d} />)}
            </svg>
            <ul class="terr-clusters">
              {
                territory.map((c) => (
                  <li
                    class="terr-cluster"
                    style={`--cx:${c.cx};--cy:${c.cy}`}
                    data-country={c.country}
                    data-label-dir={c.labelDir}
                  >
                    <button
                      type="button"
                      class="terr-country"
                      aria-expanded="true"
                      aria-controls={`terr-locs-${c.slug}`}
                      aria-label={`${c.country}, ${c.outings} outings across ${c.locations.length} locations`}
                    >
                      <span class="terr-dot" aria-hidden="true" />
                      <span class="terr-leader" aria-hidden="true" />
                      <span class="terr-country-label">
                        {c.label} · {c.outings} {outingWord(c.outings)}
                      </span>
                    </button>
                  <ul class="terr-locations" id={`terr-locs-${c.slug}`}>
                    {c.locations.map((loc, i) => (
                      <li
                        class="terr-loc"
                        style={`--lx:${loc.x};--ly:${loc.y};--i:${i}`}
                        data-side={loc.side}
                      >
                        <button
                          type="button"
                          class="terr-loc-node"
                          aria-expanded="false"
                          aria-controls={`terr-chip-${loc.slug}`}
                          aria-label={`${loc.name}, ${loc.outings} ${loc.outings === 1 ? "outing" : "outings"}`}
                        >
                          <span class="terr-loc-dot" aria-hidden="true" />
                          <span class="terr-loc-label" aria-hidden="true">
                            {loc.name} · {loc.outings}
                          </span>
                        </button>
                        <span class="terr-chip" id={`terr-chip-${loc.slug}`} role="group">
                          <span class="terr-chip-name">{loc.name}</span>
                          <span class="terr-chip-count hud-label">
                            {loc.outings} {outingWord(loc.outings)}
                          </span>
                          <a
                            class="terr-chip-link link"
                            href={AA_HREF}
                            target="_blank"
                            rel="noopener"
                          >
                            License this work <span class="arrow" aria-hidden="true">→</span>
                          </a>
                        </span>
                      </li>
                    ))}
                  </ul>
                </li>
              ))
            }
            </ul>
          </div>
        </div>
      </figure>
    </section>

    <!-- A3 — Licensed vs Personal nesting -->
    <section class="mx-auto max-w-3xl space-y-8 border-t border-hairline p-8">
      <div class="panel space-y-2 p-5" data-reveal>
        <h2 class="text-xl font-bold">{p.licensed.heading}</h2>
        <p class="text-ink">{p.licensed.body}</p>
        <LegendMark proof={p.licensed.proof} />
      </div>
      <div class="space-y-2" data-reveal>
        <h2 class="text-xl font-bold">{p.personal.heading}</h2>
