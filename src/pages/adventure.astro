    color: color-mix(in srgb, var(--color-accent, #38f8ec) 55%, transparent);
  }

  /* ── A4b · the festival TEASER (M1 v3): a mini magazine cover beside the
     blurb, two supporting stills, and a CTA into the full story. Compact by
     design — the old inline video + four-up grid moved to the story page. ── */
  .fest-teaser {
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 300px) minmax(0, 1fr);
    align-items: start;
    margin-top: 0.5rem;
  }
  @media (max-width: 780px) {
    .fest-teaser {
      grid-template-columns: 1fr;
    }
  }
  /* the mini cover — the story's cover asset, magazine-dressed and clickable */
  .fest-cover {
    position: relative;
    display: block;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 10px;
    background: var(--color-elevated, #1c2530);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.4);
    text-decoration: none;
  }
  @media (max-width: 780px) {
    .fest-cover {
      max-width: 340px;
    }
  }
  .fest-cover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ease-survey, ease);
  }
  .fest-cover-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(10, 13, 18, 0.55) 0%, transparent 32%),
      linear-gradient(to top, rgba(10, 13, 18, 0.82) 0%, transparent 46%);
  }
  .fest-cover-mast {
    position: absolute;
    top: 14px;
    left: 16px;
    right: 16px;
    font-family: var(--font-display-condensed);
    font-size: 1.05rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.5);
  }
  .fest-cover-issue {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.24em;
    color: var(--color-accent, #38f8ec);
    vertical-align: 30%;
  }
  .fest-cover-title {
    position: absolute;
    left: 16px;
    right: 16px;
    bottom: 34px;
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 640;
    font-size: clamp(1.9rem, 4.6vw, 2.4rem);
    line-height: 0.98;
    color: #fff;
  }
  .fest-cover-amp {
    color: var(--color-accent, #38f8ec);
    font-style: italic;
    font-weight: 420;
  }
  .fest-cover-enter {
    position: absolute;
    left: 16px;
    bottom: 14px;
    font-size: 0.55rem;
    color: color-mix(in srgb, #fff 78%, transparent);
  }
  @media (prefers-reduced-motion: no-preference) {
    .fest-cover:hover .fest-cover-img {
      transform: scale(1.04);
    }
  }
  .fest-cover:focus-visible {
    outline: 2px solid var(--color-accent, #38f8ec);
    outline-offset: 3px;
  }
  .fest-teaser-body {
    display: grid;
    gap: 1rem;
    align-content: start;
  }
  .fest-teaser-body > p:first-child {
    max-width: 46ch;
  }
  .fest-stills {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, 1fr);
  }
  @media (max-width: 480px) {
    .fest-stills {
      grid-template-columns: 1fr;
    }
  }
  .fest-still {
    margin: 0;
    overflow: hidden;
    border-radius: 10px;
    background: color-mix(in srgb, var(--color-surface, #171b22) 70%, transparent);
  }
  .fest-attrib {
    padding-top: 0.4rem;
  }
  .fest-line {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    color: var(--color-ink-muted, #8a9a96);
  }
  .fest-attrib :global(.fest-aa) {
    font-size: 0.85rem;
    color: var(--color-ink-muted, #8a9a96);
  }

  /* ── A4c · FROM THE ARCHIVE (Round 4) — the page's quietest band. Small
     tiles (max ~300px), stills muted at rest, mono metadata. No hover lift and
     no CTA: these are display-only records, not features. ── */
  .arch-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 300px));
    margin-top: 0.6rem;
  }
  .arch-tile {
    margin: 0;
    display: grid;
    gap: 0.5rem;
    align-content: start;
    padding: 0.8rem;
    border: 1px solid color-mix(in srgb, #ffffff 9%, transparent);
    border-radius: 10px;
    background: color-mix(in srgb, #ffffff 2%, transparent);
  }
  .arch-media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-surface, #171b22) 70%, transparent);
  }
  .arch-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* quieter than the gallery paintings — the archive sits back */
    filter: saturate(0.8) brightness(0.84);
  }
  .arch-meta {
    display: grid;
    gap: 0.3rem;
  }
  .arch-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.6rem;
  }
  .arch-title {
    font-weight: 600;
    font-size: 0.9rem;
    line-height: 1.25;
    color: #eef5fa;
  }
  .arch-date {
    flex: none;
    font-size: 0.56rem;
    letter-spacing: 0.14em;
    color: var(--color-ink-muted, #8a9a96);
  }
  .arch-line {
    font-size: 0.74rem;
    line-height: 1.4;
    color: var(--color-ink-muted, #8a9a96);
  }
  /* Round 5 — linked archive tiles (a case page exists, e.g. Vybe): the same
     quiet tile, plus the site's link affordance and a gentle lift on hover. */
  .arch-tile--link {
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 380ms var(--ease-survey, ease),
      border-color 380ms ease;
  }
  .arch-tile--link:hover,
  .arch-tile--link:focus-visible {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, #ffffff 26%, transparent);
  }
  .arch-tile--link:hover .arch-media img {
    filter: saturate(1) brightness(0.95);
  }
  .arch-cta {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  @media (prefers-reduced-motion: reduce) {
    .arch-tile--link {
      transition: none;
    }
    .arch-tile--link:hover {
      transform: none;
    }
  }

  /* ── A3b · THE FIELD teaser (Round 5) — one inviting block: the wall's three
     lead frames as a strip, the whole panel a single link into /adventure/field.
     The strip dims slightly at rest and wakes on hover; the chamfered .btn kit
     carries the call. ── */
  /* ── M3 · THE FIELD BOARD — a dense expedition collage: varied cell sizes,
        slight alternating tilts, mono location slates, one LIVE reel cell, an
        AA chip. The whole board is one link; hover wakes the color and levels
        the tilt (soft, never clipping). ── */
  .fieldboard {
    display: grid;
    gap: 1.1rem;
    justify-items: center;
    text-decoration: none;
    color: inherit;
  }
  .fb-grid {
    display: grid;
    width: 100%;
    gap: 12px;
    /* mobile default: a simple 2-col flow (explicit placement kicks in ≥860px) */
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: minmax(120px, auto);
  }
  /* M3.1 — deliberate BALANCED placement (operator: balance the sides). A 4×4
     board: the graded Matterhorn hero CENTERED at top, a tall cell on each
     edge (reel left, Nesso right), a second Nesso anchoring the lower-left, the
     three landscape singles across the middle, and a wide AA chip as the
     footer. DOM order = hero, reel, nesso-a, ouray, limmernsee, trift, nesso-b,
     aa. */
  @media (min-width: 860px) {
    .fb-grid {
      grid-template-columns: repeat(4, 1fr);
      /* three uniform image rows + a short auto footer row for the AA band */
      grid-template-rows: repeat(3, clamp(7rem, 10.5vw, 9rem)) auto;
    }
    .fb-cell:nth-child(1) { grid-area: 1 / 2 / 3 / 4; } /* hero — centered 2×2 */
    .fb-cell:nth-child(2) { grid-area: 1 / 1 / 3 / 2; } /* reel — left edge */
    .fb-cell:nth-child(3) { grid-area: 1 / 4 / 3 / 5; } /* nesso — right edge */
    .fb-cell:nth-child(4) { grid-area: 3 / 1 / 4 / 2; } /* ouray */
    .fb-cell:nth-child(5) { grid-area: 3 / 2 / 4 / 3; } /* limmernsee */
    .fb-cell:nth-child(6) { grid-area: 3 / 3 / 4 / 4; } /* trift */
    .fb-cell:nth-child(7) { grid-area: 3 / 4 / 4 / 5; } /* ironton */
    .fb-cell:nth-child(8) { grid-area: 4 / 1 / 5 / 5; } /* AA chip — full-width footer */
  }
  .fb-cell {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, #ffffff 10%, transparent);
    background: color-mix(in srgb, var(--color-surface, #171b22) 70%, transparent);
    box-shadow: 0 14px 34px -18px rgba(0, 0, 0, 0.6);
  }
  .fb-cell img,
  .fb-cell video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .fb-cell picture {
    display: block;
    position: absolute;
    inset: 0;
  }
  /* size rhythm: a 2x2 hero, two tall portraits, the rest single cells */
  .fb-cell--hero {
    grid-column: span 2;
    grid-row: span 2;
  }
  .fb-cell--tall,
  .fb-cell--reel {
    grid-row: span 2;
  }
  /* alternating tilt at rest — the salon-hang energy; levels on board hover */
  .fb-cell:nth-child(odd) {
    transform: rotate(-0.55deg);
  }
  .fb-cell:nth-child(even) {
    transform: rotate(0.5deg);
  }
  .fb-cell,
  .fb-cell img {
    transition:
      transform 700ms var(--ease-survey, ease),
      filter 500ms var(--ease-survey, ease);
  }
  .fb-cell img {
    filter: saturate(0.9) brightness(0.92);
  }
  .fieldboard:hover .fb-cell,
  .fieldboard:focus-visible .fb-cell {
    transform: rotate(0deg);
  }
  .fieldboard:hover .fb-cell img,
  .fieldboard:focus-visible .fb-cell img {
    filter: saturate(1) brightness(1);
  }
  /* the mono location slate riding each frame */
  .fb-slate {
    position: absolute;
    left: 10px;
    bottom: 8px;
    z-index: 2;
    margin: 0;
    padding: 0.28rem 0.5rem;
    font-size: 0.52rem;
    letter-spacing: 0.18em;
    border-radius: 3px;
    background: color-mix(in srgb, var(--color-base, #141922) 68%, transparent);
    color: color-mix(in srgb, #ffffff 82%, transparent);
    backdrop-filter: blur(3px);
  }
  /* the live reel cell — poster-first, loop fades in when playing */
  .fb-reel-poster,
  .fb-reel-loop {
    position: absolute;
    inset: 0;
  }
  .fb-reel-loop {
    opacity: 0;
    transition: opacity 500ms var(--ease-survey, ease);
    pointer-events: none;
  }
  .fb-cell--reel.is-playing .fb-reel-loop {
    opacity: 1;
  }
  /* the AA chip — a full-width footer band: logo + licensing line in a row */
  .fb-cell--aa {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.6rem 1.1rem;
    padding: 0.9rem 1rem;
    text-align: center;
  }
  .fb-cell--aa img {
    width: auto;
    height: clamp(30px, 4.5vw, 42px);
    object-fit: contain;
  }
  .fb-cell--aa .hud-label {
    font-size: 0.56rem;
  }
  /* the tilt/level animation shouldn't rotate the wide footer band */
  .fb-cell--aa {
    transform: none !important;
  }
  .fb-cta {
    margin-top: 0.25rem;
  }
  @media (max-width: 860px) {
    .fb-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: minmax(110px, auto);
    }
  }
  @media (max-width: 640px) {
    .field-teaser-strip {
      grid-template-columns: 1fr;
    }
  }
  .field-teaser-frame {
    margin: 0;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, #ffffff 10%, transparent);
    background: color-mix(in srgb, var(--color-surface, #171b22) 70%, transparent);
  }
  .field-teaser-frame img {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    filter: saturate(0.92) brightness(0.92);
    transition:
      filter 500ms var(--ease-survey, ease),
      transform 900ms var(--ease-survey, ease);
  }
  .field-teaser:hover .field-teaser-frame img,
  .field-teaser:focus-visible .field-teaser-frame img {
    filter: saturate(1) brightness(1);
    transform: scale(1.03);
  }
  .field-teaser-cta {
    justify-self: start;
  }
  @media (prefers-reduced-motion: reduce) {
    .field-teaser-frame img {
      transition: none;
    }
    .field-teaser:hover .field-teaser-frame img {
      transform: none;
    }
  }
</style>

<script>
  // ── A4b — the festival block is now a static teaser (M1 v3); the showcase
  // ambient loop moved to the full story page (/adventure/steel-and-dust), so
  // this page no longer runs a festival video observer.

  // ── M2b — the field-teaser PiP reel: poster-first, IO-gated autoplay of the
  // small corner loop (reduced-motion / no-JS / Save-Data / autoplay-refused
  // all hold the poster still). ──
  (() => {
    const video = document.querySelector<HTMLVideoElement>("[data-teaser-reel]");
    const box = video?.closest<HTMLElement>(".fb-cell--reel");
    if (!box || !video) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (conn?.saveData) return;
    video.addEventListener("playing", () => box.classList.add("is-playing"));
    const io = new IntersectionObserver(
      ([entry]) => {
        if (!entry) return;
        if (entry.isIntersecting) {
          if (!video.src) video.src = video.dataset.loopSrc!;
          video.play().catch(() => {});
        } else if (!video.paused) {
          video.pause();
        }
      },
      { threshold: 0.25 },
    );
    io.observe(box);
    window.addEventListener("pagehide", () => io.disconnect(), { once: true });
  })();

  // ── P19 — the "jump into the painting" click transition moved to
  // /adventure/field with the gallery wall (Round 5).

  // ── P12.4c — THE TERRITORY constellation interaction ─────────────────────
  // Pure progressive enhancement over the static (all-expanded) base. Under
  // reduced motion we do NOTHING: every location stays rendered so nothing
  // needs a click to be seen (the country nodes keep aria-expanded="true" from
  // the markup, matching the visible state). With motion allowed we add
  // `.terr--live`, which lets the CSS collapse each country's locations; the
  // handlers below spray one country's dots at a time and toggle info chips.
  (() => {
    const terr = document.querySelector<HTMLElement>(".terr");
    if (!terr) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const clusters = Array.from(terr.querySelectorAll<HTMLElement>(".terr-cluster"));

    // Enter the live (collapsible) mode and start every country collapsed.
    terr.classList.add("terr--live");
    clusters.forEach((cl) => {
      cl.classList.remove("is-open");
      cl.querySelector<HTMLElement>(".terr-country")?.setAttribute("aria-expanded", "false");
    });

    const closeChips = (keep?: Element | null) =>
      terr.querySelectorAll<HTMLElement>('.terr-loc-node[aria-expanded="true"]').forEach((n) => {
        if (n !== keep) n.setAttribute("aria-expanded", "false");
      });

    terr.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;

      // Country node → expand its locations, collapse every other country.
      const country = target.closest<HTMLElement>(".terr-country");
      if (country) {
        const cluster = country.closest<HTMLElement>(".terr-cluster");
        const willOpen = country.getAttribute("aria-expanded") !== "true";
        clusters.forEach((cl) => {
          const open = cl === cluster && willOpen;
          cl.classList.toggle("is-open", open);
          cl.querySelector<HTMLElement>(".terr-country")?.setAttribute(
            "aria-expanded",
            String(open),
          );
        });
        closeChips(); // any open chip belonged to a country we may have just collapsed
        return;
      }

      // Location dot → toggle its info chip (only one chip open at a time).
      const loc = target.closest<HTMLElement>(".terr-loc-node");
      if (loc) {
        const open = loc.getAttribute("aria-expanded") !== "true";
        closeChips(open ? loc : null);
        loc.setAttribute("aria-expanded", String(open));
      }
    });
  })();

  // ── THE TERRITORY — world-frame parallax ─────────────────────────────────
  // Subtle vertical drift of the WHOLE frame (world map + constellation move
  // LOCKED together, so a dot never separates from its coastline). Ownership
  // moved here from WorldMapBackdrop: the map now fills a 2:1 frame with no
  // internal letterbox to absorb, so the frame is the thing that drifts.
  // rAF-throttled; bails entirely under reduced motion (var default 0px →
  // static). No-JS never runs it. On mobile the frame is static and the map is
  // hidden, so the CSS `transform:none` there makes any --wm-shift a no-op.
  (() => {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const frames = Array.from(document.querySelectorAll<HTMLElement>(".terr-frame"));
    if (!frames.length) return;
    const AMP = 10; // px — at/under the site's other drift amplitudes
    let ticking = false;

    const update = () => {
      ticking = false;
      const vh = window.innerHeight || 1;
      for (const frame of frames) {
        const r = frame.getBoundingClientRect();
        if (r.bottom < 0 || r.top > vh) continue; // offscreen — skip
        const progress = (r.top + r.height / 2 - vh / 2) / (vh / 2 + r.height / 2);
        frame.style.setProperty("--wm-shift", `${(-progress * AMP).toFixed(1)}px`);
      }
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();
  })();
</script>
