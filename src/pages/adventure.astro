---
/**
 * Adventure — credibility lane, "the wild" (V-3, V2-PLAN §2 Work B).
 *
 * A PRE-FILTERED lane view of the shared WorkWall, wrapped in the lane's own
 * hero beats: the globe hero (§9.3 — "where the stories are told" is native
 * here), the territory + licensed/personal sections, and the AA funnel outro.
 * Only the old bespoke gallery is replaced — its tiles, hover-distortion, warm
 * amber dialect, and field-note flyouts now come from WorkWall (pillar
 * "adventure"), so the wall is ONE engine across /work, /adventure, /entertainment.
 *
 * The adventure dialect is applied by the page shell (data-lane="adventure",
 * flight-line dividers + violet-slate map-insets) and by WorkWall's own
 * data-lane-dialect="wild" (warm amber captions, field-note flyouts kept).
 */
import Base from "../layouts/Base.astro";
import WorkWall from "../components/WorkWall.astro";
import GlobeHero from "../components/GlobeHero.astro";
import HeroVideo from "../components/HeroVideo.astro";
import LegendMark from "../components/LegendMark.astro";
import { PAGES } from "../consts";

import { existsSync } from "node:fs";
import { join } from "node:path";

const p = PAGES.adventure;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Ambient reel: SKIPPED by default (DIRECTION §2.3) — renders only if a real
// reel is dropped at public/media/adventure/reel-loop.mp4 (+ poster). Checked
// at build time (frontmatter runs server-side), anchored to process.cwd().
const reelDir = join(process.cwd(), "public", "media", "adventure");
const reelHasLoop = existsSync(join(reelDir, "reel-loop.mp4"));
const reelHasPoster = existsSync(join(reelDir, "reel-poster.avif"));
const reelSources = reelHasLoop
  ? [{ src: `${base}/media/adventure/reel-loop.mp4`, type: "video/mp4" }]
  : [];
const reelPoster = reelHasPoster ? `${base}/media/adventure/reel-poster.avif` : undefined;
---

<Base title={p.meta.title} description={p.meta.description}>
  <div data-lane="adventure">
    <!-- A1 — globe hero (relocated §9.3). Headline paints first (LCP); the globe
         streams in behind it, the poster covers every fallback state. -->
    <section class="mx-auto max-w-3xl space-y-6 p-8 text-center">
      <h1 class="text-3xl font-bold sm:text-5xl">{p.hero.headline}</h1>
      <p class="mx-auto max-w-2xl text-lg text-ink">{p.hero.subline}</p>
      <GlobeHero />
    </section>

    <!-- A2 — the territory -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-8">
      <hr class="flight-line mb-6" aria-hidden="true" />
      <h2 class="text-2xl font-bold" data-reveal>{p.territory.heading}</h2>
      <p class="text-ink" data-reveal>{p.territory.body}</p>
    </section>

    <!-- A3 — Licensed vs Personal nesting -->
    <section class="mx-auto max-w-3xl space-y-8 border-t border-hairline p-8">
      <div class="panel space-y-2 p-5" data-reveal>
        <h2 class="text-xl font-bold">{p.licensed.heading}</h2>
        <p class="text-ink">{p.licensed.body}</p>
        <LegendMark proof={p.licensed.proof} />
      </div>
      <div class="space-y-2" data-reveal>
        <h2 class="text-xl font-bold">{p.personal.heading}</h2>
        <p class="text-ink">{p.personal.body}</p>
      </div>
    </section>

    <!-- A4 — the field: the shared wall, pre-filtered to the wild. The warm
         amber dialect + field-note flyouts now come from WorkWall; the AA
         funnel outro below is unchanged. -->
    <div class="border-t border-hairline">
      <hr class="flight-line mx-auto max-w-5xl" aria-hidden="true" />
      <WorkWall pillar="adventure" heading={p.gallery.heading} />

      <!-- AA funnel outro (operator exclusivity handling): the wall is a teaser
           referral to the agency that licenses the full collection. Ledger
           phrasing verbatim, adjacent to the real AA mark. -->
      <div class="mx-auto mt-4 max-w-5xl px-6 pb-8 sm:px-8">
        <div class="panel aa-funnel flex flex-col gap-4 p-6 sm:flex-row sm:items-center sm:justify-between" data-reveal>
          <div class="flex items-center gap-4">
            <img
              src={`${base}/media/adventure/aa-logo.png`}
              alt="Amazing Aerial Agency"
              class="aa-funnel-logo shrink-0"
              width="480"
              height="158"
              loading="lazy"
              decoding="async"
            />
            <div class="space-y-1">
              <p class="hud-label">Licensed through Amazing Aerial Agency</p>
              <h3 class="text-lg font-bold">{p.aaFunnel.heading}</h3>
              <p class="max-w-2xl text-sm text-ink">{p.aaFunnel.body}</p>
            </div>
          </div>
          <a href={p.aaFunnel.cta.href} class="btn shrink-0" rel="noopener">
            {p.aaFunnel.cta.label}
          </a>
        </div>
      </div>
    </div>

    <!-- Ambient reel — OPTIONAL / selective (§9.5). SKIPPED unless real sources
         are supplied (set reelSources + poster above). -->
    {
      reelSources.length > 0 && (
        <section class="border-t border-hairline p-8">
          <HeroVideo
            poster={reelPoster}
            sources={reelSources}
            placeholderLabel="AMBIENT REEL — muted ambient loop, ≤8s · 720p · ≤1.5MB AV1/H.264, poster ships first (§4)."
            class="mx-auto max-w-5xl"
          />
        </section>
      )
    }

    <!-- A5 — soft handoff -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-8 text-center">
      <p class="text-lg italic text-ink">{p.handoff.body}</p>
      <a href={`${base}${p.handoff.cta.href}`} class="btn">{p.handoff.cta.label}</a>
    </section>
  </div>
</Base>

<script>
  // Field-note toggle (R3.4) — one delegated listener; the grid-rows CSS does
  // the expand/collapse. No-JS renders every note open (CSS), so this is pure
  // enhancement. The note sits outside .map-inset, so the wall hover warp is
  // untouched. (WorkWall renders the same field-note markup in the wild lane.)
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>(".field-note-toggle");
    if (!btn) return;
    const note = btn.closest<HTMLElement>("[data-field-note]");
    if (!note) return;
    const open = note.classList.toggle("is-open");
    btn.setAttribute("aria-expanded", String(open));
  });
</script>
