---
import Base from "../layouts/Base.astro";
import Placeholder from "../components/Placeholder.astro";
import LegendMark from "../components/LegendMark.astro";
import { PAGES, WORK } from "../consts";

const p = PAGES.adventure;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const adventureWork = WORK.filter((item) => item.pillar === "adventure");
---

<Base title={p.meta.title} description={p.meta.description}>
  <!-- A1 — fullscreen hero (Phase 4 build, §2c/§1.3) -->
  <section class="space-y-4 p-8 text-center">
    <Placeholder ratio="21/9" label="FULLSCREEN VIDEO HERO (Phase 4, §2c) — the single strongest reel, ambient loop, poster-first" />
    <h1 class="text-3xl font-bold sm:text-5xl">{p.hero.headline}</h1>
    <p class="mx-auto max-w-2xl text-lg">{p.hero.subline}</p>
  </section>

  <!-- A2 — the territory -->
  <section class="mx-auto max-w-3xl space-y-4 border-t border-current/20 p-8">
    <h2 class="text-2xl font-bold">{p.territory.heading}</h2>
    <p>{p.territory.body}</p>
  </section>

  <!-- A3 — Licensed vs Personal nesting -->
  <section class="mx-auto max-w-3xl space-y-8 border-t border-current/20 p-8">
    <div class="space-y-2">
      <h2 class="text-xl font-bold">{p.licensed.heading}</h2>
      <p>{p.licensed.body}</p>
      <LegendMark proof={p.licensed.proof} />
    </div>
    <div class="space-y-2">
      <h2 class="text-xl font-bold">{p.personal.heading}</h2>
      <p>{p.personal.body}</p>
    </div>
  </section>

  <!-- A4 — masonry gallery (Phase 4 hover texture, §2e; static grid here) -->
  <section class="border-t border-current/20 p-8">
    <h2 class="mx-auto mb-4 max-w-3xl text-2xl font-bold">{p.gallery.heading}</h2>
    <div class="mx-auto grid max-w-3xl grid-cols-2 gap-4 sm:grid-cols-3">
      {
        adventureWork.map((item) => (
          <Placeholder ratio="4/5" label={`${item.title} — ${item.what}`} />
        ))
      }
    </div>
    <p class="mx-auto mt-4 max-w-3xl text-sm opacity-70">{p.gallery.note}</p>
  </section>

  <!-- A5 — soft handoff -->
  <section class="mx-auto max-w-3xl space-y-4 border-t border-current/20 p-8 text-center">
    <p class="text-lg italic">{p.handoff.body}</p>
    <a href={`${base}${p.handoff.cta.href}`} class="inline-block rounded border border-current px-4 py-2">
      {p.handoff.cta.label}
    </a>
  </section>
</Base>
