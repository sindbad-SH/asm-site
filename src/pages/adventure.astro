<script>
  // ── A4b — festival feature ambient loop: plays only when motion is allowed
  // and the figure is on-screen; the poster underneath is the permanent base
  // layer (reduced-motion / no-JS / Save-Data / autoplay-refused all show the
  // still). Same IO-gated pattern as the venture ambient loops. ──
  (() => {
    const video = document.querySelector<HTMLVideoElement>("[data-fest-loop]");
    const box = video?.closest<HTMLElement>(".fest-video");
    if (!box || !video) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (conn?.saveData) return;
    video.addEventListener("playing", () => box.classList.add("is-playing"));
    const io = new IntersectionObserver(
      ([entry]) => {
        if (!entry) return;
        if (entry.isIntersecting) {
          if (!video.src) video.src = video.dataset.loopSrc!;
          video.play().catch(() => {}); // refusal → poster stands
        } else if (!video.paused) {
          video.pause();
        }
      },
      { threshold: 0.25 },
    );
    io.observe(box);
    window.addEventListener("pagehide", () => io.disconnect(), { once: true });
  })();

  // ── P19 — "jump into the painting" click transition ──────────────────────
  // Progressive enhancement over a plain link. On a primary click of a painting
  // we briefly zoom it toward the viewer, then navigate — the Super Mario 64
  // dive into the world. Hard-degrades to INSTANT navigation: skipped entirely
  // under reduced motion, on coarse/touch pointers, and for modifier / non-left
  // clicks (so cmd/ctrl/middle-click still open a new tab). A safety timeout
  // guarantees navigation even if the transitionend never fires.
  (() => {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fine = window.matchMedia("(pointer: fine)").matches;
    if (reduce || !fine) return; // instant nav is the baseline everywhere else

    document.addEventListener("click", (e) => {
      const me = e as MouseEvent;
      if (me.button !== 0 || me.metaKey || me.ctrlKey || me.shiftKey || me.altKey) return;
      const painting = (e.target as HTMLElement).closest<HTMLAnchorElement>("a.painting[href]");
      if (!painting || painting.classList.contains("is-entering")) return;
      e.preventDefault();
      const href = painting.href;
      painting.classList.add("is-entering");
      let done = false;
      const go = () => {
        if (done) return;
        done = true;
        window.location.assign(href);
      };
      painting.addEventListener("transitionend", go, { once: true });
      window.setTimeout(go, 420); // fallback ceiling
    });
  })();

  // NOTE: the paintings' ambient float is pure CSS (@keyframes painting-float on
  // .painting-inner, desynced per painting, killed under reduced motion) — no JS
  // engine, so it also breathes on mobile without a transform tug-of-war with
  // the reveal-entrance transform on the anchor.

  // ── P12.4c — THE TERRITORY constellation interaction ─────────────────────
  // Pure progressive enhancement over the static (all-expanded) base. Under
  // reduced motion we do NOTHING: every location stays rendered so nothing
  // needs a click to be seen (the country nodes keep aria-expanded="true" from
  // the markup, matching the visible state). With motion allowed we add
  // `.terr--live`, which lets the CSS collapse each country's locations; the
  // handlers below spray one country's dots at a time and toggle info chips.
  (() => {
    const terr = document.querySelector<HTMLElement>(".terr");
    if (!terr) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const clusters = Array.from(terr.querySelectorAll<HTMLElement>(".terr-cluster"));

    // Enter the live (collapsible) mode and start every country collapsed.
    terr.classList.add("terr--live");
    clusters.forEach((cl) => {
      cl.classList.remove("is-open");
      cl.querySelector<HTMLElement>(".terr-country")?.setAttribute("aria-expanded", "false");
    });

    const closeChips = (keep?: Element | null) =>
      terr.querySelectorAll<HTMLElement>('.terr-loc-node[aria-expanded="true"]').forEach((n) => {
        if (n !== keep) n.setAttribute("aria-expanded", "false");
      });

    terr.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;

      // Country node → expand its locations, collapse every other country.
      const country = target.closest<HTMLElement>(".terr-country");
      if (country) {
        const cluster = country.closest<HTMLElement>(".terr-cluster");
        const willOpen = country.getAttribute("aria-expanded") !== "true";
        clusters.forEach((cl) => {
          const open = cl === cluster && willOpen;
          cl.classList.toggle("is-open", open);
          cl.querySelector<HTMLElement>(".terr-country")?.setAttribute(
            "aria-expanded",
            String(open),
          );
        });
        closeChips(); // any open chip belonged to a country we may have just collapsed
        return;
      }

      // Location dot → toggle its info chip (only one chip open at a time).
      const loc = target.closest<HTMLElement>(".terr-loc-node");
      if (loc) {
        const open = loc.getAttribute("aria-expanded") !== "true";
        closeChips(open ? loc : null);
        loc.setAttribute("aria-expanded", String(open));
      }
    });
  })();

  // ── THE TERRITORY — world-frame parallax ─────────────────────────────────
  // Subtle vertical drift of the WHOLE frame (world map + constellation move
  // LOCKED together, so a dot never separates from its coastline). Ownership
  // moved here from WorldMapBackdrop: the map now fills a 2:1 frame with no
  // internal letterbox to absorb, so the frame is the thing that drifts.
  // rAF-throttled; bails entirely under reduced motion (var default 0px →
  // static). No-JS never runs it. On mobile the frame is static and the map is
  // hidden, so the CSS `transform:none` there makes any --wm-shift a no-op.
  (() => {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const frames = Array.from(document.querySelectorAll<HTMLElement>(".terr-frame"));
    if (!frames.length) return;
    const AMP = 10; // px — at/under the site's other drift amplitudes
    let ticking = false;

    const update = () => {
      ticking = false;
      const vh = window.innerHeight || 1;
      for (const frame of frames) {
        const r = frame.getBoundingClientRect();
        if (r.bottom < 0 || r.top > vh) continue; // offscreen — skip
        const progress = (r.top + r.height / 2 - vh / 2) / (vh / 2 + r.height / 2);
        frame.style.setProperty("--wm-shift", `${(-progress * AMP).toFixed(1)}px`);
      }
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();
  })();
</script>
