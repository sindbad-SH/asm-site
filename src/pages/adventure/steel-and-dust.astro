---
/**
 * /adventure/steel-and-dust — STEEL & DUST, Field Notes No. 01 (M1 v2,
 * 2026-07-22, operator notes applied).
 *
 * The festival block's FULL STORY subpage (Round-5 block→subpage pattern) and
 * the first magazine-grade coverage piece — the template for future marquee
 * stories. v2 changes, per the operator:
 *
 *   COVER → A NEWSSTAND: the 4:5 cover was lonely on desktop, so it now
 *   hangs center-stage with two smaller "inside this issue" plates tucked
 *   behind its shoulders (pen melee · procession). Mobile keeps the single
 *   cover; the plates reappear as a small strip below it.
 *
 *   VIDEO MOVED UP: the story order is cover → open → SHOWCASE LOOP → the
 *   rest. (Operator rule: in any story, the video is the first visual after
 *   the opening text.)
 *
 *   DE-BOXED SPREAD: chapter numerals ghosted behind the text column, a
 *   full-bleed arena band, the pull quote overlapping the media above it,
 *   an asymmetric two-up (staggered, unequal), and the pageant frame hung
 *   at a slight tilt — editorial texture instead of stacked rectangles.
 *
 *   COPY = JOURNALISM: researched facts folded in (The Savage Woods,
 *   Charlie Andrews / NatGeo 2011 — sources in consts) instead of prose
 *   that re-describes the photos.
 *
 * HONESTY: attribution composes from the WORK record; the aerial-licensing
 * note renders ONLY via LegendMark (verbatim permittedPhrasing). All visible
 * copy lives in consts (PAGES.adventure.steelDust — ⚠ staging-only until the
 * operator reads it).
 */
import Base from "../../layouts/Base.astro";
import { PAGES, WORK } from "../../consts";
import { existsSync } from "node:fs";
import { join } from "node:path";

const sd = PAGES.adventure.steelDust;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const knights = WORK.find((w) => w.slug === "knights-of-mayhem");

// Baked festival media (make-festival-photos.mjs + make-steel-dust.mjs) —
// existence-gated per file like every other baked set.
const festDir = join(process.cwd(), "public", "media", "adventure", "festival");
const WIDTHS = { landscape: [900, 1600], vertical: [800, 1120, 1600] } as const;
function photo(slug: string, orientation: keyof typeof WIDTHS) {
  const w0 = orientation === "vertical" ? 800 : 900;
  if (!existsSync(join(festDir, `${slug}-${w0}.avif`))) return undefined;
  const widths = WIDTHS[orientation];
  return {
    avif: widths.map((w) => `${base}/media/adventure/festival/${slug}-${w}.avif ${w}w`).join(", "),
    webp: widths.map((w) => `${base}/media/adventure/festival/${slug}-${w}.webp ${w}w`).join(", "),
    src: `${base}/media/adventure/festival/${slug}-${w0}.webp`,
  };
}
const cover = photo("cover-charge", "vertical");
const joustCharge = photo("joust-charge", "landscape");
const joustRiders = photo("joust-riders", "landscape");
const meleeArena = photo("melee-arena", "landscape");
const meleeBrawl = photo("melee-brawl", "landscape");
const arenaSails = photo("arena-sails", "landscape");
const lanePageant = photo("lane-pageant", "vertical");
const fieldWide = photo("field-wide", "landscape");
const plates = sd.cover.plates
  .map((p) => ({ ...p, media: photo(p.slug, "vertical") }))
  .filter((p) => p.media);

// Showcase ambient loop (shared asset with /adventure's A4b feature —
// public/media/work/knights-of-mayhem/, poster-first, IO-gated).
const loopDir = join(process.cwd(), "public", "media", "work", "knights-of-mayhem");
const loopPoster = existsSync(join(loopDir, "poster.avif"))
  ? `${base}/media/work/knights-of-mayhem/poster.avif`
  : undefined;
const loopSrc = existsSync(join(loopDir, "loop.mp4"))
  ? `${base}/media/work/knights-of-mayhem/loop.mp4`
  : undefined;
---

<Base title={sd.meta.title} description={sd.meta.description}>
  <div data-lane="adventure">
    <!-- ── MOVEMENT 1 · THE NEWSSTAND ─────────────────────────────────── -->
    <section class="sd-stage" aria-label={`${sd.cover.masthead} — ${sd.meta.title}`}>
      <div class="sd-stand">
        {
          plates[0] && (
            <figure class="sd-plate sd-plate--l" data-reveal aria-hidden="true">
              <picture>
                <source type="image/avif" srcset={plates[0].media!.avif} sizes="300px" />
                <source type="image/webp" srcset={plates[0].media!.webp} sizes="300px" />
                <img src={plates[0].media!.src} alt="" loading="lazy" decoding="async" />
              </picture>
              <figcaption class="hud-label">{plates[0].label}</figcaption>
            </figure>
          )
        }

        <div class="sd-cover" data-reveal>
          {
            cover && (
              <picture>
                <source type="image/avif" srcset={cover.avif} sizes="(min-width: 640px) 600px, 92vw" />
                <source type="image/webp" srcset={cover.webp} sizes="(min-width: 640px) 600px, 92vw" />
                <img
                  src={cover.src}
                  alt="Two armored knights charging each other down the jousting lists, crowds along both rails, the Front Range foothills behind"
                  class="sd-cover-img"
                  fetchpriority="high"
                  decoding="async"
                />
              </picture>
            )
          }
          <div class="sd-scrim" aria-hidden="true"></div>

          <!-- factual corner slates -->
          <p class="sd-corner sd-corner--tl hud-label">{sd.cover.issue}</p>
          <p class="sd-corner sd-corner--tr hud-label sd-accent">{sd.cover.location}</p>

          <!-- masthead in the sky band -->
          <header class="sd-masthead">
            <p class="sd-masthead-word">{sd.cover.masthead}</p>
            <p class="sd-masthead-credit hud-label">{sd.cover.credit}</p>
          </header>

          <!-- coordinates spine — the surveyor's voice, factual -->
          <p class="sd-coords hud-label" aria-hidden="true">{sd.cover.coords}</p>

          <!-- title block set into the dirt band -->
          <div class="sd-titleblock">
            <p class="hud-label sd-accent">{sd.cover.storyLabel}</p>
            <h1 class="sd-title">
              {sd.cover.titleA} <span class="sd-amp" aria-hidden="true">&amp;</span><span class="sr-only">and</span>
              {sd.cover.titleB}
            </h1>
            <p class="sd-deck">{sd.cover.deck}</p>
            <ul class="sd-teasers" role="list">
              {sd.cover.teasers.map((t) => <li class="hud-label">{t}</li>)}
            </ul>
          </div>
        </div>

        {
          plates[1] && (
            <figure class="sd-plate sd-plate--r" data-reveal aria-hidden="true">
              <picture>
                <source type="image/avif" srcset={plates[1].media!.avif} sizes="300px" />
                <source type="image/webp" srcset={plates[1].media!.webp} sizes="300px" />
                <img src={plates[1].media!.src} alt="" loading="lazy" decoding="async" />
              </picture>
              <figcaption class="hud-label">{plates[1].label}</figcaption>
            </figure>
          )
        }
      </div>
      <p class="sd-cue hud-label" aria-hidden="true">{sd.cover.scrollCue} ↓</p>
    </section>

    <!-- ── MOVEMENT 2 · THE FIELD REPORT ──────────────────────────────── -->
    <article class="border-t border-hairline sd-report">
      <!-- standfirst + open -->
      <header class="sd-col sd-chapter" data-chapter="01">
        <hr class="flight-line mb-6" aria-hidden="true" />
        <p class="hud-label" data-reveal>{sd.slate}</p>
        <p class="hud-label sd-accent" data-reveal>{sd.byline}</p>
        <p class="sd-lede" data-reveal>{sd.lede}</p>
      </header>

      <div class="sd-col space-y-6">
        {sd.paragraphs.map((para) => <p class="text-lg text-ink" data-reveal>{para}</p>)}
      </div>

      <!-- THE VIDEO — the first visual after the open (operator rule) -->
      {
        loopPoster && loopSrc && (
          <section class="mx-auto max-w-5xl px-8 pt-8">
            <figure class="sd-photo" data-reveal>
              <div class="sd-video">
                <img class="sd-poster" src={loopPoster} alt="" loading="lazy" decoding="async" />
                <video class="sd-loop" data-sd-loop data-loop-src={loopSrc} muted loop playsinline preload="none" aria-hidden="true" />
              </div>
              <figcaption class="sd-cap hud-label sd-cap-row">
                <span>{sd.captions.loop}</span>
                {sd.fullFilm.href && (
                  <a class="sd-film-link link" href={sd.fullFilm.href} target="_blank" rel="noopener">
                    {sd.fullFilm.label} <span class="arrow" aria-hidden="true">↗</span>
                  </a>
                )}
              </figcaption>
            </figure>
          </section>
        )
      }
      <div class="sd-col space-y-6 pt-8">
        <p class="text-lg text-ink" data-reveal>{sd.afterVideo}</p>
      </div>

      <!-- PASS ONE — the lists: asymmetric, staggered two-up -->
      <section class="mx-auto max-w-5xl px-8 pt-10 sd-chapter" data-chapter="01">
        <p class="hud-label sd-accent sd-chapter-label" data-reveal>{sd.chapters.lists}</p>
        {
          (joustCharge || joustRiders) && (
            <div class="sd-stagger">
              {joustCharge && (
                <figure class="sd-photo sd-stagger-a" data-reveal>
                  <picture>
                    <source type="image/avif" srcset={joustCharge.avif} sizes="(min-width: 1024px) 58vw, 90vw" />
                    <source type="image/webp" srcset={joustCharge.webp} sizes="(min-width: 1024px) 58vw, 90vw" />
                    <img src={joustCharge.src} alt="Aerial view of a knight on a white horse charging down the jousting lane between festival crowds" style="aspect-ratio:16/9;object-fit:cover" class="block w-full" loading="lazy" decoding="async" />
                  </picture>
                  <figcaption class="sd-cap hud-label">{sd.captions.joustCharge}</figcaption>
                </figure>
              )}
              {joustRiders && (
                <figure class="sd-photo sd-stagger-b" data-reveal data-reveal-stagger="80">
                  <picture>
                    <source type="image/avif" srcset={joustRiders.avif} sizes="(min-width: 1024px) 34vw, 80vw" />
                    <source type="image/webp" srcset={joustRiders.webp} sizes="(min-width: 1024px) 34vw, 80vw" />
                    <img src={joustRiders.src} alt="Two armored riders in the lists, the white horse in the foreground, crowds along both rails" style="aspect-ratio:4/3;object-fit:cover" class="block w-full" loading="lazy" decoding="async" />
                  </picture>
                  <figcaption class="sd-cap hud-label">{sd.captions.joustRiders}</figcaption>
                </figure>
              )}
            </div>
          )
        }
      </section>

      <!-- pull quote — overlaps the stagger above -->
      <section class="sd-col sd-pull-wrap">
        <blockquote class="sd-pull panel" data-reveal>{sd.pullQuote}</blockquote>
      </section>

      <!-- PASS TWO — the pen: prose, then a FULL-BLEED band -->
      <section class="sd-col space-y-6 sd-chapter" data-chapter="02">
        <p class="hud-label sd-accent sd-chapter-label" data-reveal>{sd.chapters.arena}</p>
        <p class="text-lg text-ink" data-reveal>{sd.arena}</p>
      </section>
      {
        arenaSails && (
          <figure class="sd-bleed" data-reveal>
            <picture>
              <source type="image/avif" srcset={arenaSails.avif} sizes="100vw" />
              <source type="image/webp" srcset={arenaSails.webp} sizes="100vw" />
              <img
                src={arenaSails.src}
                alt="Aerial view of the timber combat pen under blue shade sails — armored team bouts mid-fight, spectators packed at the fence"
                loading="lazy"
                decoding="async"
              />
            </picture>
            <figcaption class="sd-cap sd-bleed-cap hud-label">{sd.captions.arenaSails}</figcaption>
          </figure>
        )
      }
      {
        (meleeArena || meleeBrawl) && (
          <section class="mx-auto max-w-5xl px-8 pt-4">
            <div class="sd-stagger sd-stagger--flip">
              {meleeArena && (
                <figure class="sd-photo sd-stagger-b" data-reveal>
                  <picture>
                    <source type="image/avif" srcset={meleeArena.avif} sizes="(min-width: 1024px) 34vw, 80vw" />
                    <source type="image/webp" srcset={meleeArena.webp} sizes="(min-width: 1024px) 34vw, 80vw" />
                    <img src={meleeArena.src} alt="Aerial view of two armored fighters squaring up in the wooden combat arena, a marshal in yellow between them" style="aspect-ratio:4/3;object-fit:cover" class="block w-full" loading="lazy" decoding="async" />
                  </picture>
                  <figcaption class="sd-cap hud-label">{sd.captions.meleeArena}</figcaption>
                </figure>
              )}
              {meleeBrawl && (
                <figure class="sd-photo sd-stagger-a" data-reveal data-reveal-stagger="80">
                  <picture>
                    <source type="image/avif" srcset={meleeBrawl.avif} sizes="(min-width: 1024px) 58vw, 90vw" />
                    <source type="image/webp" srcset={meleeBrawl.webp} sizes="(min-width: 1024px) 58vw, 90vw" />
                    <img src={meleeBrawl.src} alt="Three simultaneous armored bouts at the corners of the combat arena, seen from above" style="aspect-ratio:16/9;object-fit:cover" class="block w-full" loading="lazy" decoding="async" />
                  </picture>
                  <figcaption class="sd-cap hud-label">Three bouts at once at the corners of the pen.</figcaption>
                </figure>
              )}
            </div>
          </section>
        )
      }

      <!-- PASS THREE — the grounds: tilted pageant frame beside prose + log -->
      <section class="mx-auto max-w-5xl px-8 pt-10 sd-chapter" data-chapter="03">
        <p class="hud-label sd-accent sd-chapter-label" data-reveal>{sd.chapters.grounds}</p>
        <div class="sd-duo">
          {
            lanePageant && (
              <figure class="sd-photo sd-tilt" data-reveal>
                <picture>
                  <source type="image/avif" srcset={lanePageant.avif} sizes="(min-width: 1024px) 40vw, 90vw" />
                  <source type="image/webp" srcset={lanePageant.webp} sizes="(min-width: 1024px) 40vw, 90vw" />
                  <img
                    src={lanePageant.src}
                    alt="Aerial view of the festival procession walking the jousting lane between the crowds"
                    style="aspect-ratio:4/5;object-fit:cover"
                    class="block w-full"
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
                <figcaption class="sd-cap hud-label">{sd.captions.lanePageant}</figcaption>
              </figure>
            )
          }
          <div class="space-y-6">
            <p class="text-lg text-ink" data-reveal>{sd.pageant}</p>
            <div class="panel sd-log" data-reveal>
              <p class="hud-label sd-accent">{sd.fieldLog.heading}</p>
              <dl>
                {
                  sd.fieldLog.rows.map((row) => (
                    <div class="sd-log-row">
                      <dt class="hud-label">{row.label}</dt>
                      <dd>{row.value}</dd>
                    </div>
                  ))
                }
              </dl>
            </div>
          </div>
        </div>
      </section>

      <!-- closing beat: the whole field -->
      {
        fieldWide && (
          <section class="mx-auto max-w-5xl px-8 pt-10">
            <figure class="sd-photo" data-reveal>
              <picture>
                <source type="image/avif" srcset={fieldWide.avif} sizes="(min-width: 1280px) 1100px, 90vw" />
                <source type="image/webp" srcset={fieldWide.webp} sizes="(min-width: 1280px) 1100px, 90vw" />
                <img
                  src={fieldWide.src}
                  alt="Wide aerial view of the whole tournament ground — tents, the jousting lists, the combat arena, and the festival crowd"
                  style="aspect-ratio:16/9;object-fit:cover"
                  class="block w-full"
                  loading="lazy"
                  decoding="async"
                />
              </picture>
              <figcaption class="sd-cap hud-label">{sd.captions.fieldWide}</figcaption>
            </figure>
          </section>
        )
      }

      <!-- sign-off: the honest WORK-record line + the Amazing Aerial editorial
           licensing band (operator rule 2026-07-22: logo + link wherever this
           coverage's licensing is referenced). -->
      <footer class="sd-col pt-8 pb-8">
        {knights && (
          <p class="sd-attrib">
            For {knights.forOrg} · {knights.what}
            {knights.engagement && knights.engagement !== "[confirm]" ? ` — ${knights.engagement}` : ""}
          </p>
        )}
        <div class="sd-editorial panel" data-reveal>
          <img
            src={`${base}/media/adventure/aa-logo.png`}
            alt="Amazing Aerial Agency"
            class="sd-aa-logo"
            width="480"
            height="158"
            loading="lazy"
            decoding="async"
          />
          <div class="sd-editorial-body">
            <p class="hud-label sd-accent">Licensed through Amazing Aerial Agency</p>
            <p class="sd-editorial-note">{sd.editorial.note}</p>
            <p>
              <a class="link" href={sd.editorial.cta.href} target="_blank" rel="noopener">
                {sd.editorial.cta.label} <span class="arrow" aria-hidden="true">↗</span>
              </a>
            </p>
          </div>
        </div>
      </footer>
    </article>

    <!-- close — the lane's spine -->
    <section class="mx-auto max-w-3xl space-y-4 border-t border-hairline p-8 text-center">
      <p><a href={`${base}/adventure/field`} class="link">More from the field →</a></p>
      <p><a href={`${base}/adventure`} class="link"><span class="arrow" aria-hidden="true">←</span> Back to Adventure Stories</a></p>
    </section>
  </div>
</Base>

<style>
  /* ── THE NEWSSTAND · center cover + two tucked plates ──────────────────
     Desktop: the plates hang behind the cover's shoulders, slightly rotated
     — a rack of issues, not a lone box. Mobile: plates drop into a small
     strip under the cover. Accent stays SCARCE. */
  .sd-stage {
    display: grid;
    justify-items: center;
    align-content: center;
    gap: 1.25rem;
    min-height: 100svh;
    padding: 5.5rem 1rem 2rem;
    overflow-x: clip;
  }
  .sd-stand {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .sd-cover {
    position: relative;
    z-index: 2;
    width: min(92vw, 600px);
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 10px;
    background: var(--color-elevated);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.55);
  }
  .sd-plate {
    display: none;
    margin: 0;
  }
  @media (min-width: 1024px) {
    .sd-plate {
      display: block;
      position: relative;
      z-index: 1;
      width: clamp(200px, 22vw, 300px);
      flex: 0 0 auto;
    }
    .sd-plate img {
      display: block;
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      border-radius: 8px;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }
    .sd-plate figcaption {
      margin-top: 0.55rem;
      font-size: 0.55rem;
      text-align: center;
    }
    .sd-plate--l {
      transform: rotate(-2.5deg) translateY(1.5rem);
      margin-right: -2.25rem;
    }
    .sd-plate--r {
      transform: rotate(2.5deg) translateY(1.5rem);
      margin-left: -2.25rem;
    }
  }
  /* mobile strip: plates return as a modest two-up under the cover */
  @media (max-width: 1023px) {
    .sd-stand {
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .sd-plate {
      display: block;
      width: calc(46% - 0.375rem);
    }
    .sd-plate img {
      display: block;
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      border-radius: 8px;
    }
    .sd-plate figcaption {
      margin-top: 0.4rem;
      font-size: 0.52rem;
      text-align: center;
    }
    .sd-plate--l {
      order: 2;
    }
    .sd-plate--r {
      order: 3;
    }
  }
  /* corner crop marks — the print-proof voice */
  .sd-cover::before,
  .sd-cover::after {
    content: "";
    position: absolute;
    width: 18px;
    height: 18px;
    z-index: 3;
    pointer-events: none;
    opacity: 0.8;
  }
  .sd-cover::before {
    top: 10px;
    left: 10px;
    border-top: 1px solid var(--color-accent-deep);
    border-left: 1px solid var(--color-accent-deep);
  }
  .sd-cover::after {
    bottom: 10px;
    right: 10px;
    border-bottom: 1px solid var(--color-accent-deep);
    border-right: 1px solid var(--color-accent-deep);
  }
  .sd-cover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* the slow settle — one breath, soft, never clipping (motion-gated) */
  @media (prefers-reduced-motion: no-preference) {
    html.js .sd-cover-img {
      animation: sd-settle 2400ms cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    @keyframes sd-settle {
      from {
        transform: scale(1.045);
      }
      to {
        transform: scale(1);
      }
    }
  }
  .sd-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(to bottom, rgba(10, 13, 18, 0.62) 0%, rgba(10, 13, 18, 0.18) 22%, transparent 38%),
      linear-gradient(to top, rgba(10, 13, 18, 0.86) 0%, rgba(10, 13, 18, 0.45) 26%, transparent 52%);
  }
  .sd-corner {
    position: absolute;
    top: 14px;
    z-index: 2;
    font-size: 0.58rem;
  }
  .sd-corner--tl {
    left: 18px;
  }
  .sd-corner--tr {
    right: 18px;
  }
  .sd-accent {
    color: var(--color-accent);
  }
  .sd-masthead {
    position: absolute;
    top: 8.5%;
    left: 0;
    right: 0;
    z-index: 2;
    text-align: center;
  }
  .sd-masthead-word {
    font-family: var(--font-display-condensed);
    font-size: clamp(1.9rem, 8.5vw, 3.3rem);
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #fff;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
  }
  .sd-masthead-credit {
    margin-top: 0.45rem;
    font-size: 0.55rem;
    letter-spacing: 0.34em;
    color: color-mix(in srgb, #fff 72%, transparent);
  }
  .sd-coords {
    position: absolute;
    right: 16px;
    top: 50%;
    z-index: 2;
    transform: translateY(-50%);
    writing-mode: vertical-rl;
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    color: var(--color-accent-deep);
  }
  .sd-titleblock {
    position: absolute;
    left: 20px;
    right: 20px;
    bottom: 18px;
    z-index: 2;
    display: grid;
    gap: 0.5rem;
  }
  .sd-title {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 640;
    font-size: clamp(2.6rem, 11vw, 4.4rem);
    line-height: 0.98;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .sd-amp {
    color: var(--color-accent);
    font-style: italic;
    font-weight: 420;
  }
  .sd-deck {
    max-width: 36ch;
    font-family: var(--font-display);
