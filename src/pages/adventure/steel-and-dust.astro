<script>
  // ── showcase ambient loop: plays only when motion is allowed and the
  // figure is on-screen; the poster underneath is the permanent base layer
  // (reduced-motion / no-JS / Save-Data / autoplay-refused all show the
  // still). Same IO-gated pattern as /adventure's A4b feature. ──
  (() => {
    const video = document.querySelector<HTMLVideoElement>("[data-sd-loop]");
    const box = video?.closest<HTMLElement>(".sd-video");
    if (!box || !video) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (conn?.saveData) return;
    video.addEventListener("playing", () => box.classList.add("is-playing"));
    const io = new IntersectionObserver(
      ([entry]) => {
        if (!entry) return;
        if (entry.isIntersecting) {
          if (!video.src) video.src = video.dataset.loopSrc!;
          video.play().catch(() => {}); // refusal → poster stands
        } else if (!video.paused) {
          video.pause();
        }
      },
      { threshold: 0.25 },
    );
    io.observe(box);
    window.addEventListener("pagehide", () => io.disconnect(), { once: true });
  })();
</script>
