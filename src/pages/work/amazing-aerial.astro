---
/**
 * /work/amazing-aerial — the Amazing Aerial HIGHLIGHTS REEL (P-work, 2026-07-12).
 * Linked from the work-wall's single AA flagship tile. This is a DIFFERENT page
 * from /venture/amazing-aerial (the agency STORY) — the two cross-link; keep both.
 *
 * ⚠ OPERATOR READ-APPROVAL REQUIRED — every heading / caption / CTA label below
 * is new copy (staging-only until read). The ONLY relationship statement is the
 * LOCKED permitted phrasing, rendered verbatim via <LegendMark> and the reel
 * caption ("Aerial work licensed through Amazing Aerial Agency"). Never
 * "represented exclusively", never ownership — contributor / licensed-through /
 * "an official agent with the collection" only.
 *
 * Assets: the still highlights REUSE the already-baked dual-brand (AA + ASM)
 * watermarked gallery exports — the watermarks ARE the story. The three motion
 * clips are muted, autoplay-in-view web loops (poster-first: reduced-motion /
 * no-JS / Save-Data / autoplay-refused all land on the still). Baked by
 * scripts/make-aa-highlights.mjs.
 */
import Base from "../../layouts/Base.astro";
import LegendMark from "../../components/LegendMark.astro";
import { PAGES } from "../../consts";
import { existsSync } from "node:fs";
import { join } from "node:path";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const aa = PAGES.adventure.licensed; // the locked licensed-relationship block
const AA_PORTFOLIO = PAGES.adventure.aaFunnel.cta.href;

// ── still highlights: reuse the baked gallery exports, existence-gated ──
const g = join(process.cwd(), "public", "media", "adventure", "gallery");
const GALLERY_WIDTHS = [800, 1120, 1400, 1600, 2200];
function frame(slug: string) {
  if (!existsSync(join(g, `${slug}-800.avif`))) return undefined;
  const widths = GALLERY_WIDTHS.filter((w) => existsSync(join(g, `${slug}-${w}.avif`)));
  const set = (ext: string) =>
    widths.map((w) => `${base}/media/adventure/gallery/${slug}-${w}.${ext} ${w}w`).join(", ");
  return { avif: set("avif"), webp: set("webp"), src: `${base}/media/adventure/gallery/${slug}-800.webp` };
}
// 6–9 of the strongest, picked by review (peaks / turquoise lakes / castles /
// Front Range). Existence-gated, so a missing export just drops that shot.
const shots = [
  "matterhorn-zermatt-01",
  "gornergrat-glacier-01",
  "lac-de-tseuzier-01",
  "crans-montana-01",
  "castel-toblino-01",
  "varenna-lake-como-01",
  "bellagio-01",
  "eldorado-springs-01",
  "flatirons-chautauqua-03",
]
  .map((slug) => frame(slug))
  .filter((f): f is NonNullable<typeof f> => !!f);

// ── motion clips: muted web loops + poster fallbacks, existence-gated ──
const c = join(process.cwd(), "public", "media", "work", "amazing-aerial", "clips");
function clip(slug: string, caption: string, alt: string) {
  if (!existsSync(join(c, `${slug}.mp4`))) return undefined;
  return {
    mp4: `${base}/media/work/amazing-aerial/clips/${slug}.mp4`,
    posterAvif: `${base}/media/work/amazing-aerial/clips/${slug}-poster.avif`,
    posterWebp: `${base}/media/work/amazing-aerial/clips/${slug}-poster.webp`,
    caption,
    alt,
  };
}
const clips = [
  clip("matterhorn", "The Matterhorn · Zermatt", "Aerial of the Matterhorn's pyramid summit above the Zermatt valley"),
  clip("lac-de-tseuzier", "Lac de Tseuzier · Valais", "Aerial of the turquoise Lac de Tseuzier reservoir and dam in the Swiss Alps"),
  clip("ironton", "The San Juans · Colorado", "Aerial of snow-capped San Juan peaks above a green pine valley in Colorado"),
].filter((x): x is NonNullable<typeof x> => !!x);

const CTAS = [
  { label: "License the collection", href: AA_PORTFOLIO, external: true, primary: true },
  { label: "The agency story", href: `${base}/venture/amazing-aerial`, external: false },
  { label: "Back to the work", href: `${base}/work`, external: false },
];
---

<Base
  title="Top shots with Amazing Aerial"
  description="A highlights reel of our aerial work — expedition frames from the Alps and Colorado, licensed through Amazing Aerial Agency."
>
  <main class="reel">
    <article class="reel-inner">
      <a href={`${base}/work`} class="link reel-back">← Work</a>

      <p class="hud-label reel-slate" data-reveal>
        <span data-decode>AMAZING AERIAL · HIGHLIGHTS</span>
      </p>
      <h1 class="reel-title" data-reveal>Top shots with Amazing Aerial.</h1>
      <p class="reel-lead" data-reveal>
        A reel of the aerial work — the frames we chase, from the Front Range to the Alps, and the agency
        that takes them to market.
      </p>
      <div class="reel-proof" data-reveal>
        <LegendMark proof={aa.proof} />
      </div>

      {
        shots.length > 0 && (
          <section class="reel-section" data-reveal>
            <h2 class="hud-label reel-h2">The stills</h2>
            <div class="reel-stills">
              {shots.map((s) => (
                <div class="reel-shot">
                  <picture>
                    <source type="image/avif" srcset={s.avif} sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw" />
                    <source type="image/webp" srcset={s.webp} sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw" />
                    <img src={s.src} alt="" loading="lazy" decoding="async" />
                  </picture>
                </div>
              ))}
            </div>
          </section>
        )
      }

      {
        clips.length > 0 && (
          <section class="reel-section" data-reveal>
            <h2 class="hud-label reel-h2">In motion</h2>
            <div class="reel-clips">
              {clips.map((cl) => (
                <figure class="reel-clip" data-reel-clip>
                  <picture>
                    <source type="image/avif" srcset={cl.posterAvif} />
                    <img class="reel-poster" src={cl.posterWebp} alt={cl.alt} loading="lazy" decoding="async" />
                  </picture>
                  <video class="reel-vid" data-reel-loop data-src={cl.mp4} muted loop playsinline preload="none" />
                  <figcaption class="hud-label reel-clip-cap">{cl.caption}</figcaption>
                </figure>
              ))}
            </div>
          </section>
        )
      }

      <p class="hud-label reel-license">Aerial work licensed through Amazing Aerial Agency</p>

      <nav class="reel-ctas" data-reveal>
        {
          CTAS.map((cta) => (
            <a
              href={cta.href}
              class={`reel-cta${cta.primary ? " reel-cta--primary" : ""}`}
              rel={cta.external ? "noopener" : undefined}
              target={cta.external ? "_blank" : undefined}
            >
              <span>{cta.label}</span>
              <span class="arrow" aria-hidden="true">→</span>
            </a>
          ))
        }
      </nav>
      <a href={`${base}/work`} class="link reel-back">← Work</a>
    </article>
  </main>
</Base>

<style>
  .reel {
    background: #0e131c;
    min-height: 100svh;
  }
  .reel-inner {
    max-width: 60rem;
    margin-inline: auto;
    padding: 7rem 2rem 6rem;
    display: grid;
    gap: 1.4rem;
  }
  .reel-back {
    justify-self: start;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .reel-slate {
    letter-spacing: 0.26em;
    color: color-mix(in srgb, #d9f2ec 75%, transparent);
    margin: 0;
  }
  .reel-title {
    font-family: var(--font-display);
    font-weight: 560;
    font-style: italic;
    font-size: clamp(2rem, 4.2vw, 3.4rem);
    line-height: 1.12;
    color: #f2f4f8;
  }
  .reel-lead {
    font-family: var(--font-sans);
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.65;
    color: color-mix(in srgb, #eef2f5 86%, transparent);
    max-width: 46rem;
  }

  .reel-section {
    margin-top: 1.2rem;
    display: grid;
    gap: 0.9rem;
  }
  .reel-h2 {
    margin: 0;
    letter-spacing: 0.24em;
    color: color-mix(in srgb, #d9f2ec 70%, transparent);
  }

  /* stills — masonry columns, native aspects, watermarks are the story */
  .reel-stills {
    columns: 3;
    column-gap: 0.7rem;
  }
  .reel-shot {
    break-inside: avoid;
    margin-bottom: 0.7rem;
    border-radius: 6px;
    overflow: hidden;
    background: color-mix(in srgb, #ffffff 4%, transparent);
  }
  .reel-shot img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* clips — muted autoplay-in-view loops; poster is the permanent base layer */
  .reel-clips {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.7rem;
  }
  .reel-clip {
    position: relative;
    margin: 0;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, #ffffff 12%, transparent);
    background: color-mix(in srgb, #ffffff 4%, transparent);
  }
  .reel-poster,
  .reel-vid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .reel-vid {
    opacity: 0;
    transition: opacity 600ms var(--ease-survey, ease);
  }
  .reel-clip.is-playing .reel-vid {
    opacity: 1;
  }
  .reel-clip-cap {
    position: absolute;
    left: 0.8rem;
    bottom: 0.7rem;
    margin: 0;
    z-index: 2;
    letter-spacing: 0.16em;
    color: color-mix(in srgb, #f4fbfa 90%, transparent);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.7);
  }

  .reel-license {
    margin: 0.4rem 0 0;
    letter-spacing: 0.18em;
    color: color-mix(in srgb, #d9f2ec 58%, transparent);
  }

  /* CTA row — shared button grammar */
  .reel-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    border-top: 1px solid color-mix(in srgb, #ffffff 12%, transparent);
    padding-top: 1.4rem;
    margin-top: 0.4rem;
  }
  .reel-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 44px;
    padding: 0.7rem 1.15rem;
    border: 1px solid color-mix(in srgb, #ffffff 22%, transparent);
    border-radius: 2px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, #eef2f5 88%, transparent);
    transition:
      border-color var(--dur-hover, 160ms) var(--ease-swift),
      color var(--dur-hover, 160ms) var(--ease-swift),
      box-shadow var(--dur-hover, 160ms) var(--ease-swift);
  }
  .reel-cta--primary {
    border-color: var(--color-accent-deep, #1e8f8a);
    color: #f2f4f8;
  }
  .reel-cta .arrow {
    display: inline-block;
    transition: transform var(--dur-hover, 160ms) var(--ease-swift);
  }
  .reel-cta:hover,
  .reel-cta:focus-visible {
    border-color: var(--color-accent, #38f8ec);
    color: var(--color-accent, #38f8ec);
    box-shadow: 0 0 24px -6px color-mix(in srgb, var(--color-accent, #38f8ec) 55%, transparent);
  }
  .reel-cta:hover .arrow,
  .reel-cta:focus-visible .arrow {
    transform: translateX(6px);
  }

  @media (max-width: 1024px) {
    .reel-stills {
      columns: 2;
    }
    .reel-clips {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .reel-stills {
      columns: 1;
    }
    .reel-cta {
      flex: 1 1 100%;
      justify-content: space-between;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .reel-vid {
      transition: none;
    }
    .reel-cta .arrow {
      transition: none;
    }
  }
</style>

<script>
  // Decode-in the mono slate (matches the venture page).
  const mountDecodeLabels = () => import("../../lib/decode-text").then(({ mountDecode }) => mountDecode(document));
  if ("requestIdleCallback" in window) requestIdleCallback(mountDecodeLabels, { timeout: 3000 });
  else setTimeout(mountDecodeLabels, 1500);

  // Muted highlight loops — play ONLY when motion is allowed and the clip is on
  // screen; the poster underneath is the permanent base layer, so reduced-motion
  // / no-JS / Save-Data / autoplay-refused all just show the still. Lazy: the
  // src mounts on first intersection (preload="none" keeps initial load light).
  (() => {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) return;
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (conn?.saveData) return;

    const clips = [...document.querySelectorAll<HTMLElement>("[data-reel-clip]")];
    if (!clips.length || !("IntersectionObserver" in window)) return;

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const wrap = entry.target as HTMLElement;
          const video = wrap.querySelector<HTMLVideoElement>("[data-reel-loop]");
          if (!video) continue;
          if (entry.isIntersecting) {
            if (!video.src) video.src = video.dataset.src!; // lazy mount
            video.addEventListener("playing", () => wrap.classList.add("is-playing"), { once: true });
            video.play().catch(() => {}); // refusal → poster stands
          } else if (!video.paused) {
            video.pause();
          }
        }
      },
      { threshold: 0.25 },
    );
    clips.forEach((cl) => io.observe(cl));
    window.addEventListener("pagehide", () => io.disconnect(), { once: true });
  })();
</script>
