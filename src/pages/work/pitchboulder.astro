---
/**
 * PitchBoulder — the first case study and the template's proof-of-concept
 * (BUILD-PLAN.md §2c/§1.5). All structure lives in CaseStudy.astro; a future
 * case is this same three lines with different data + a real video id.
 */
import Base from "../../layouts/Base.astro";
import CaseStudy from "../../components/CaseStudy.astro";
import { PAGES } from "../../consts";

const study = PAGES.work.caseStudies.pitchboulder;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// commercialVideoId stays undefined until Sindbad supplies the YouTube id (S3).
---

<Base title={study.meta.title} description={study.meta.description}>
  <CaseStudy study={study} base={base} />
</Base>
