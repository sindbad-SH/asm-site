---
/**
 * PitchBoulder — the first case study and the template's proof-of-concept
 * (BUILD-PLAN.md §2c/§1.5). All structure lives in CaseStudy.astro; a future
 * case is this same three lines with different data + a real video id.
 */
import Base from "../../layouts/Base.astro";
import CaseStudy from "../../components/CaseStudy.astro";
import { PAGES } from "../../consts";

const study = PAGES.work.caseStudies.pitchboulder;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// The embed his live site already uses (COPY.md §3 / DIRECTION §2.5).
const commercialVideoId = "n7k-Bwu3KIU";
// Hook poster = a representative frame from the commercial (builder-pick, t=28:
// the PitchBoulder brand lockup over the room). Context still = the published
// event frame. Both are his own published assets.
const hookPoster = `${base}/media/work/pitchboulder/hook-poster.avif`;
const contextImage = `${base}/media/work/pitchboulder/context.avif`;
// BTS: no PitchBoulder BTS footage exists → section hidden (DIRECTION §2.5/§2.7).
---

<Base title={study.meta.title} description={study.meta.description}>
  <CaseStudy
    study={study}
    base={base}
    commercialVideoId={commercialVideoId}
    hookPoster={hookPoster}
    contextImage={contextImage}
  />
</Base>
