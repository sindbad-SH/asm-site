---
/**
 * Shelby / Pebble Beach — the second case study (DIRECTION §2.6, COPY.md §4).
 * Proof that the CaseStudy.astro template scales: same component, no new
 * layout — this page is data + prop wiring, exactly like pitchboulder.astro.
 *
 * Honesty rails: relationship tier = `attended`; the proof line (rendered by
 * CaseStudy via study.work.proof) carries the only status claim; prose never
 * implies an official Pebble Beach engagement. Testimonial (Jack Bell) is
 * RESERVED per operator (COPY.md §2.2) — the case data omits testimonialId, so
 * the Words chapter + rail link do not render.
 */
import Base from "../../layouts/Base.astro";
import CaseStudy from "../../components/CaseStudy.astro";
import { PAGES } from "../../consts";
import { existsSync } from "node:fs";
import { join } from "node:path";

const study = PAGES.work.caseStudies.shelbyPebbleBeach;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Hook = ambient loop cut from the 4K master (MEDIA-GUIDE Worked Example 1 Step
// 3, crf 40 → 1.20MB) over a poster that IS the loop's frame 0. Context still =
// a builder-picked lawn frame (t=66, the blue Cobra with the coastline behind).
const mediaDir = join(process.cwd(), "public", "media", "work", "shelby-pebble-beach");
const hookPoster = `${base}/media/work/shelby-pebble-beach/poster.avif`;
const hookSources = existsSync(join(mediaDir, "loop.mp4"))
  ? [{ src: `${base}/media/work/shelby-pebble-beach/loop.mp4`, type: "video/mp4" }]
  : [];
const contextImage = `${base}/media/work/shelby-pebble-beach/context.avif`;

// Real-photo gallery (P13f) — the operator's own photographs of the restored
// 1967 Shelby Cobra 427 at the 2025 Pebble Beach Concours (car beauty, crew at
// work, engine detail, event context), baked by scripts/make-shelby-photos.mjs
// into photos/. These REPLACE the old video frame-grab scrub as the chapter's
// visual proof; the scrub props are no longer wired. Rendered only when the
// exports exist on disk (same optional-media contract). Order = gallery order.
const photosDir = join(mediaDir, "photos");
const photosBase = existsSync(join(photosDir, "beauty-front-1600.webp"))
  ? `${base}/media/work/shelby-pebble-beach/photos/`
  : undefined;
const photos = photosBase
  ? [
      { slug: "beauty-front", alt: "The restored blue 1967 Shelby Cobra 427, hood raised, on the show lawn at sunrise with the coastline behind" },
      { slug: "dawn-flare", alt: "Low front three-quarter view of the blue Cobra catching sun flare at dawn" },
      { slug: "on-set", alt: "The crew filming the Cobra at first light on the fairway" },
      { slug: "paddock", alt: "The Cobra in the pre-dawn staging paddock among other classic cars" },
      { slug: "crew", alt: "The three-person crew beside the blue Cobra, a silver Cobra and the bay behind" },
      { slug: "engine", alt: "The Cobra's engine bay open, hands at work, spectators looking on" },
      { slug: "lawn", alt: "Elevated view of the Cobra on the lawn ringed by the Concours crowd and the coastline" },
      { slug: "morning-crowd", alt: "The Cobra on the lawn under a dramatic morning sky with attendees nearby" },
      { slug: "heritage", alt: "The blue Cobra beside the white competition Cobras on the show field" },
      { slug: "signage", alt: "The Pebble Beach Concours d'Elegance lettering and clock at the entrance" },
    ]
  : [];

// Full film — already public-embedded on the live site (DIRECTION §2.6).
const fullFilmVideoId = "SvIIXnM2R70";
---

<Base title={study.meta.title} description={study.meta.description}>
  <CaseStudy
    study={study}
    base={base}
    hookPoster={hookPoster}
    hookSources={hookSources}
    contextImage={contextImage}
    photos={photos}
    photosBase={photosBase}
    fullFilmVideoId={fullFilmVideoId}
  />
</Base>
