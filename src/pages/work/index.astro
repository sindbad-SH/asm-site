---
/**
 * /work — P4 (V1-UPGRADE-PLAN): THE WALL. Resn's dark work-wall grammar
 * (media-first tiles, hover-life, lane filters) with Sindbad's spin: instead
 * of Resn's uniform near-vertical tiles, the wall LEANS INTO the library's
 * mixed form factors — wide aerials get wide tiles, true verticals get tall
 * tiles, the two case studies get cinematic feature tiles — composed as an
 * art-directed asymmetric mosaic (deterministic spans by shape, dense-packed,
 * never random).
 *
 * Kept from R3.9 unchanged in spirit:
 *   - filters are pure enhancement: every tile visible by default (the no-JS
 *     baseline), buttons inert without JS
 *   - FLIP animates survivors between mosaic positions on filter
 *   - attribution-first honesty: forOrg · what · engagement all verbatim from
 *     consts on every tile; the AA band stays
 *
 * Hover-life ladder (fine pointers only, never under reduced motion or
 *   Save-Data): case tiles with a loop export play it on hover (mounted on
 *   first pointerenter, paused on leave); all tiles get the slow media lift.
 *   Touch: meta strips are simply always on.
 *
 * Styles live in this page's scoped block ON PURPOSE (P3/P4 land in parallel;
 * global.css is P3's to extend this round).
 */
import Base from "../../layouts/Base.astro";
import DistortionLayer from "../../components/DistortionLayer.astro";
import { PAGES, WORK, PILLARS } from "../../consts";
import { existsSync } from "node:fs";
import { join } from "node:path";

const p = PAGES.work;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Slug → grid media (unchanged from R3.9/Task 5): responsive exports from the
// shared gallery folder, orientation-aware widths, every file existence-gated
// at build so nothing can 404.
function gridMedia(slug: string, orientation: "landscape" | "vertical" = "landscape") {
  const g = join(process.cwd(), "public", "media", "adventure", "gallery");
  if (!existsSync(join(g, `${slug}-800.avif`))) return undefined;
  const widths = (orientation === "vertical" ? [800, 1120, 1600] : [800, 1400, 2200]).filter((w) =>
    existsSync(join(g, `${slug}-${w}.avif`)),
  );
  return {
    avif: widths.map((w) => `${base}/media/adventure/gallery/${slug}-${w}.avif ${w}w`).join(", "),
    webp: widths.map((w) => `${base}/media/adventure/gallery/${slug}-${w}.webp ${w}w`).join(", "),
    src: `${base}/media/adventure/gallery/${slug}-800.webp`,
  };
}

// Case-study feature media: poster still (+ optional hover loop). Existence-
// gated per file — a tile only ever references media that shipped.
function caseMedia(slug: string) {
  const dir = join(process.cwd(), "public", "media", "work", slug);
  const posterName = ["poster", "hook-poster", "context"].find((n) => existsSync(join(dir, `${n}.avif`)));
  if (!posterName) return undefined;
  return {
    avif: `${base}/media/work/${slug}/${posterName}.avif`,
    webp: existsSync(join(dir, `${posterName}.webp`)) ? `${base}/media/work/${slug}/${posterName}.webp` : undefined,
    loop: existsSync(join(dir, "loop.mp4")) ? `${base}/media/work/${slug}/loop.mp4` : undefined,
  };
}

// The mosaic's shape grammar (the P4 spin): every tile declares the form that
// MAXIMIZES its media — case studies read cinematic, true verticals stay
// tall, aerial landscapes stay wide. Deterministic, art-directed, no random.
type Shape = "feature" | "wide" | "tall";
const tiles = WORK.map((item, i) => {
  const isCase = !!item.href;
  const shape: Shape = isCase ? "feature" : item.orientation === "vertical" ? "tall" : "wide";
  return {
    item,
    index: String(i + 1).padStart(3, "0"),
    shape,
    media: isCase ? undefined : gridMedia(item.slug, item.orientation ?? "landscape"),
    caseArt: isCase ? caseMedia(item.slug) : undefined,
    pillarName: PILLARS.find((pl) => pl.id === item.pillar)?.name ?? item.pillar,
  };
});

const presentPillars = new Set(WORK.map((item) => item.pillar));
const filters = [
  { id: "all", label: "All" },
  ...PILLARS.filter((pillar) => presentPillars.has(pillar.id)).map((pillar) => ({
    id: pillar.id,
    label: pillar.name,
  })),
] as const;
---

<Base title={p.meta.title} description={p.meta.description}>
  <section class="mx-auto max-w-3xl space-y-4 p-8">
    <h1 class="text-3xl font-bold" data-reveal>{p.intro.heading}</h1>
    <p class="text-ink" data-reveal>{p.intro.body}</p>
  </section>

  <!-- Lane filters — inert without JS; every tile already shows. -->
  <div class="wall-rail">
    <div class="flex flex-wrap gap-2" role="group" aria-label="Filter by lane" data-work-filters>
      {
        filters.map((f) => (
          <button
            type="button"
            class="btn-quiet border border-hairline px-3 py-1.5"
            data-filter={f.id}
            aria-pressed={f.id === "all" ? "true" : "false"}
          >
            {f.label}
          </button>
        ))
      }
    </div>
  </div>

  <section class="wall-rail py-8">
    <div class="wall" data-distort-grid data-work-grid>
      {
        tiles.map(({ item, index, shape, media, caseArt, pillarName }) => {
          const Tag = item.href ? "a" : "div";
          return (
            <Tag
              class={`wtile wtile--${shape}`}
              href={item.href ? `${base}${item.href}` : undefined}
              data-pillar={item.pillar}
              data-reveal
              data-reveal-stagger="50"
            >
              <figure class="wtile-media" aria-hidden="true">
                {media && (
                  <picture>
                    <source type="image/avif" srcset={media.avif} sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 34vw" />
                    <source type="image/webp" srcset={media.webp} sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 34vw" />
                    <img src={media.src} alt="" loading="lazy" decoding="async" />
                  </picture>
                )}
                {caseArt && (
                  <picture>
                    <source type="image/avif" srcset={caseArt.avif} />
                    <img src={caseArt.webp ?? caseArt.avif} alt="" loading="lazy" decoding="async" />
                  </picture>
                )}
                {!media && !caseArt && <div class="wtile-placeholder placeholder" />}
                {caseArt?.loop && (
                  <video class="wtile-loop" data-tile-loop data-loop-src={caseArt.loop} muted loop playsinline preload="none" />
                )}
              </figure>
              <span class="wtile-index">{index}</span>
              <span class="wtile-tag">{pillarName}</span>
              <figcaption class="wtile-meta">
                <span class="wtile-title">{item.title}</span>
                <span class="wtile-line">
                  For {item.forOrg} · {item.what} — {item.engagement}
                </span>
                {item.href && <span class="wtile-cta">See the work →</span>}
              </figcaption>
            </Tag>
          );
        })
      }
    </div>
    <p class="mx-auto mt-4 max-w-3xl text-sm text-ink-muted" data-work-empty hidden>
      Nothing in this lane yet.
    </p>
    <!-- AA-attribution band (R3.2b) — unchanged: the honest frame around the
         licensed adventure work, shown regardless of filter. -->
    <div class="mx-auto mt-8 max-w-3xl">
      <div class="panel aa-work-band p-4">
        <img
          src={`${base}/media/adventure/aa-logo.png`}
          alt="Amazing Aerial Agency"
          width="480"
          height="158"
          loading="lazy"
          decoding="async"
        />
        <p class="hud-label">Aerial work licensed through Amazing Aerial Agency</p>
      </div>
    </div>
  </section>

  <!-- §2e hover-distortion (feature-gated; CSS fallback is the default) -->
  <DistortionLayer />
</Base>

<style>
  /* ── the wall's stage: wider than the prose rail, contained for cq units ── */
  .wall-rail {
    margin-inline: auto;
    width: min(100%, 1440px);
    padding-inline: 2rem;
  }
  section.wall-rail {
    container-type: inline-size;
  }

  /* ── the mosaic. 6 columns desktop / 4 tablet / stacked mobile; row unit is
        derived from the column width (container query units) so every span
        keeps its intended shape at any viewport. dense flow packs the
        asymmetry into a solid wall — the composition IS the spans below. ── */
  .wall {
    --wall-gap: 10px;
    display: grid;
    gap: var(--wall-gap);
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: calc((100cqw - 2 * 2rem - 5 * var(--wall-gap)) / 6 * 0.66);
    grid-auto-flow: dense;
  }
  /* shape grammar: the tile fits the media, never the other way round */
  .wtile--feature {
    grid-column: span 4;
    grid-row: span 3;
  } /* ≈ 2:1 cinematic */
  .wtile--wide {
    grid-column: span 3;
    grid-row: span 3;
  } /* ≈ 3:2 aerial */
  .wtile--tall {
    grid-column: span 2;
    grid-row: span 5;
  } /* ≈ 3:5 portrait */

  @media (max-width: 1024px) {
    .wall {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: calc((100cqw - 2 * 2rem - 3 * var(--wall-gap)) / 4 * 0.66);
    }
    .wtile--feature {
      grid-column: span 4;
      grid-row: span 3;
    }
    .wtile--wide {
      grid-column: span 2;
      grid-row: span 2;
    }
    .wtile--tall {
      grid-column: span 2;
      grid-row: span 4;
    }
  }
  @media (max-width: 640px) {
    .wall {
      display: flex;
      flex-direction: column;
    }
    .wtile--feature {
      aspect-ratio: 16 / 9;
    }
    .wtile--wide {
      aspect-ratio: 3 / 2;
    }
    .wtile--tall {
      aspect-ratio: 3 / 4;
    }
  }

  /* ── a tile: media-first, chrome-quiet, life on hover ── */
  .wtile {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 10px;
    background: color-mix(in srgb, var(--color-surface, #171b22) 70%, transparent);
    isolation: isolate;
  }
  .wtile-media,
  .wtile-media picture,
  .wtile-media img,
  .wtile-placeholder,
  .wtile-loop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
  }
  .wtile-media img,
  .wtile-loop {
    object-fit: cover;
    transition: transform 900ms var(--ease-survey);
  }
  .wtile-loop {
    opacity: 0;
    transition:
      opacity 500ms var(--ease-survey),
      transform 900ms var(--ease-survey);
    pointer-events: none;
  }
  .wtile.is-looping .wtile-loop {
    opacity: 1;
  }

  /* corner instruments: index + lane tag, always on, quiet */
  .wtile-index,
  .wtile-tag {
    position: absolute;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(238, 245, 250, 0.82);
    text-shadow: 0 1px 6px rgba(6, 10, 18, 0.6);
  }
  .wtile-index {
    top: 10px;
    left: 12px;
  }
  .wtile-tag {
    top: 10px;
    right: 12px;
  }

  /* the meta strip: attribution-first, verbatim strings. Hover-risen on fine
     pointers, ALWAYS on where hover doesn't exist (touch) — honesty is not
     a hover state. */
  .wtile-meta {
    position: absolute;
    z-index: 2;
    inset-inline: 0;
    bottom: 0;
    display: grid;
    gap: 2px;
    padding: 2rem 14px 12px;
    background: linear-gradient(to top, rgba(9, 12, 19, 0.86), rgba(9, 12, 19, 0.42) 60%, transparent);
  }
  .wtile-title {
    font-weight: 600;
    font-size: 0.95rem;
    color: #eef5fa;
    line-height: 1.25;
  }
  .wtile-line {
    font-size: 0.74rem;
    color: rgba(238, 245, 250, 0.72);
    line-height: 1.35;
  }
  .wtile-cta {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent, #38f8ec);
  }
  @media (hover: hover) and (pointer: fine) {
    .wtile-meta {
      opacity: 0;
      transform: translateY(8px);
      transition:
        opacity 380ms var(--ease-survey),
        transform 380ms var(--ease-survey);
    }
    .wtile:hover .wtile-meta,
    .wtile:focus-visible .wtile-meta {
      opacity: 1;
      transform: none;
    }
    .wtile:hover .wtile-media img,
    .wtile:hover .wtile-loop {
      transform: scale(1.045);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .wtile-media img,
    .wtile-loop,
    .wtile-meta {
      transition: none;
    }
    .wtile:hover .wtile-media img,
    .wtile:hover .wtile-loop {
      transform: none;
    }
  }
</style>

<script>
  // Filter enhancement only — every tile starts visible (see file header).
  import { gsap } from "gsap";

  const grid = document.querySelector<HTMLElement>("[data-work-grid]");
  const bar = document.querySelector<HTMLElement>("[data-work-filters]");
  const empty = document.querySelector<HTMLElement>("[data-work-empty]");
  if (grid && bar) {
    const cards = [...grid.querySelectorAll<HTMLElement>("[data-pillar]")];
    const buttons = [...bar.querySelectorAll<HTMLButtonElement>("[data-filter]")];
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function applyFilter(filter: string) {
      let visibleCount = 0;
      cards.forEach((card) => {
        const show = filter === "all" || card.dataset.pillar === filter;
        card.classList.toggle("hidden", !show);
        if (show) visibleCount++;
      });
      if (empty) empty.hidden = visibleCount > 0;
    }

    // R3.9 filter FLIP, unchanged: survivors animate between mosaic positions;
    // if the plugin import fails, the instant toggle is already correct.
    let FlipMod: typeof import("gsap/Flip") | null = null;
    let flipFailed = false;

    bar.addEventListener("click", async (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-filter]");
      if (!btn) return;
      const filter = btn.dataset.filter!;
      buttons.forEach((b) => b.setAttribute("aria-pressed", String(b === btn)));

      if (!FlipMod && !flipFailed && !reduce) {
        try {
          FlipMod = await import("gsap/Flip");
          gsap.registerPlugin(FlipMod.Flip);
        } catch {
          flipFailed = true;
        }
      }

      if (FlipMod && !reduce) {
        const state = FlipMod.Flip.getState(cards);
        applyFilter(filter);
        FlipMod.Flip.from(state, {
          duration: 0.45,
          ease: "power2.out", // = --ease-swift
          absolute: true,
          onEnter: (els) => gsap.fromTo(els, { opacity: 0, scale: 0.96 }, { opacity: 1, scale: 1, duration: 0.25 }),
          onLeave: (els) => gsap.to(els, { opacity: 0, scale: 0.96, duration: 0.2 }),
        });
      } else {
        applyFilter(filter);
      }
    });
  }

  // P4 hover-life: case tiles with a loop export play it on hover. The video
  // mounts on FIRST pointerenter (preload="none" keeps the wall's initial
  // load still-only), fades in over its poster, pauses on leave. Fine
  // pointers only; never under reduced motion or Save-Data.
  (() => {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fine = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (reduce || !fine || conn?.saveData) return;
    document.querySelectorAll<HTMLVideoElement>("[data-tile-loop]").forEach((video) => {
      const tile = video.closest<HTMLElement>(".wtile");
      if (!tile) return;
      tile.addEventListener("pointerenter", () => {
        if (!video.src) video.src = video.dataset.loopSrc!;
        video.play().catch(() => {}); // autoplay refusal → the poster stands
        tile.classList.add("is-looping");
      });
      tile.addEventListener("pointerleave", () => {
        tile.classList.remove("is-looping");
        if (!video.paused) video.pause();
      });
    });
  })();
</script>
