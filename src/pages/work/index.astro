---
/**
 * /work — "Work Stories" (name still being chosen; DO NOT rename). The wall,
 * simplified to the real engagements after the P-work (2026-07-12) edit.
 *
 * What changed this round (operator direction):
 *   1. FILTER BUG FIXED. The lane buttons toggled Tailwind's `.hidden` utility,
 *      but Tailwind v4 emits utilities inside `@layer utilities`, and Astro's
 *      scoped `.wtile { display:block }` is UNLAYERED — an unlayered rule beats
 *      ANY layered one regardless of specificity, so `.hidden` never took and
 *      every tile stayed visible. Fix: a scoped `.wtile.hidden { display:none }`
 *      (also unlayered, higher specificity) actually hides. The JS is unchanged.
 *   2. Knights of Mayhem RE-LANED venture → adventure (it's an adventure story).
 *      The only two VENTURE tiles are now Shelby/Pebble Beach + PitchBoulder.
 *   3. The watermarked Amazing Aerial gallery stills were REMOVED from the wall
 *      (they belong on /adventure). One AA FLAGSHIP tile replaces them, linking
 *      to the new highlights reel at /work/amazing-aerial. Its line is the AA
 *      relationship's permittedPhrasing, VERBATIM (lockedAttribution).
 *   4. The Pebble tile shows a real photo AT REST (the logo frame), not just on
 *      hover — caseMedia() now prefers a `tile.*` face over `poster.*`.
 *   5. A quiet "from the archive" band (Gigs Go Green, Vybe) rounds out the
 *      bottom — honest one-liners, dated from the source files, links nowhere.
 *
 * Honesty: attribution-first — every tile carries its status verbatim from
 * consts (LegendMark-style phrasing for the AA + archive relationships; the
 * composed "For [org] · [what] — [engagement]" line for the rest). Filters are
 * pure enhancement: every tile visible by default (no-JS baseline).
 */
import Base from "../../layouts/Base.astro";
import DistortionLayer from "../../components/DistortionLayer.astro";
import { PAGES, WORK, WORK_ARCHIVE, PILLARS, RELATIONSHIP_BY_ID, LEGEND } from "../../consts";
import { existsSync } from "node:fs";
import { join } from "node:path";

const p = PAGES.work;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Slug → grid media: responsive exports from the shared gallery folder,
// orientation-aware widths, every file existence-gated at build so nothing 404s.
// (Kept for any future non-case gallery item; the current wall is all cases.)
function gridMedia(slug: string, orientation: "landscape" | "vertical" = "landscape") {
  const g = join(process.cwd(), "public", "media", "adventure", "gallery");
  if (!existsSync(join(g, `${slug}-800.avif`))) return undefined;
  const widths = (orientation === "vertical" ? [800, 1120, 1600] : [800, 1400, 2200]).filter((w) =>
    existsSync(join(g, `${slug}-${w}.avif`)),
  );
  return {
    avif: widths.map((w) => `${base}/media/adventure/gallery/${slug}-${w}.avif ${w}w`).join(", "),
    webp: widths.map((w) => `${base}/media/adventure/gallery/${slug}-${w}.webp ${w}w`).join(", "),
    src: `${base}/media/adventure/gallery/${slug}-800.webp`,
  };
}

// Case-study feature media: an always-visible face (+ optional hover loop).
// Preference order: a purpose-made `tile.*` beats the case-page `poster.*`, so
// the index tile can show a different frame than the case hero (the Pebble tile
// uses its logo photo; its case page keeps the clean beauty poster). Existence-
// gated per file — a tile only ever references media that shipped.
function caseMedia(slug: string) {
  const dir = join(process.cwd(), "public", "media", "work", slug);
  const posterName = ["tile", "poster", "hook-poster", "context"].find((n) =>
    existsSync(join(dir, `${n}.avif`)),
  );
  if (!posterName) return undefined;
  return {
    avif: `${base}/media/work/${slug}/${posterName}.avif`,
    webp: existsSync(join(dir, `${posterName}.webp`)) ? `${base}/media/work/${slug}/${posterName}.webp` : undefined,
    loop: existsSync(join(dir, "loop.mp4")) ? `${base}/media/work/${slug}/loop.mp4` : undefined,
  };
}

// Archive-band still: a single frame per older project (public/media/work/archive/).
function archiveMedia(slug: string) {
  const dir = join(process.cwd(), "public", "media", "work", "archive");
  if (!existsSync(join(dir, `${slug}.avif`))) return undefined;
  return {
    avif: `${base}/media/work/archive/${slug}.avif`,
    webp: existsSync(join(dir, `${slug}.webp`)) ? `${base}/media/work/archive/${slug}.webp` : undefined,
  };
}

const tiles = WORK.map((item, i) => {
  const caseArt = caseMedia(item.slug);
  const isCase = !!item.href || !!caseArt;
  // A licensed relationship (Amazing Aerial) may ONLY be stated in its verbatim
  // permittedPhrasing — never a composed "For … · … — …" line.
  const attribution =
    item.lockedAttribution && item.relationshipId
      ? RELATIONSHIP_BY_ID[item.relationshipId]?.permittedPhrasing
      : undefined;
  return {
    item,
    index: String(i + 1).padStart(3, "0"),
    media: isCase ? undefined : gridMedia(item.slug, item.orientation ?? "landscape"),
    caseArt: isCase ? caseArt : undefined,
    attribution,
    pillarName: PILLARS.find((pl) => pl.id === item.pillar)?.name ?? item.pillar,
  };
});

const presentPillars = new Set(WORK.map((item) => item.pillar));
const filters = [
  { id: "all", label: "All" },
  ...PILLARS.filter((pillar) => presentPillars.has(pillar.id)).map((pillar) => ({
    id: pillar.id,
    label: pillar.name,
  })),
] as const;

// Archive band — honest one-liners rendered verbatim from consts.
const archive = WORK_ARCHIVE.map((a) => {
  const rel = RELATIONSHIP_BY_ID[a.relationshipId];
  return {
    item: a,
    media: archiveMedia(a.slug),
    symbol: rel ? LEGEND[rel.tier].symbol : "",
    tierLabel: rel ? LEGEND[rel.tier].label : "",
    phrasing: rel?.permittedPhrasing ?? "",
  };
});
---

<Base title={p.meta.title} description={p.meta.description}>
  <section class="mx-auto max-w-3xl space-y-4 p-8">
    <h1 class="text-3xl font-bold" data-reveal>{p.intro.heading}</h1>
    <p class="text-ink" data-reveal>{p.intro.body}</p>
  </section>

  <!-- Lane filters — inert without JS; every tile already shows. -->
  <div class="wall-rail">
    <div class="flex flex-wrap gap-2" role="group" aria-label="Filter by lane" data-work-filters>
      {
        filters.map((f) => (
          <button
            type="button"
            class="btn-quiet border border-hairline px-3 py-1.5"
            data-filter={f.id}
            aria-pressed={f.id === "all" ? "true" : "false"}
          >
            {f.label}
          </button>
        ))
      }
    </div>
  </div>

  <section class="wall-rail py-8">
    <div class="wall" data-distort-grid data-work-grid>
      {
        tiles.map(({ item, index, media, caseArt, attribution, pillarName }) => {
          const Tag = item.href ? "a" : "div";
          return (
            <Tag
              class={`wtile${item.href ? " wtile--link" : ""}`}
              href={item.href ? `${base}${item.href}` : undefined}
              data-pillar={item.pillar}
              data-reveal
              data-reveal-stagger="50"
            >
              <figure class="wtile-media" aria-hidden="true">
                {media && (
                  <picture>
                    <source type="image/avif" srcset={media.avif} sizes="(max-width: 640px) 100vw, 48vw" />
                    <source type="image/webp" srcset={media.webp} sizes="(max-width: 640px) 100vw, 48vw" />
                    <img src={media.src} alt="" loading="lazy" decoding="async" />
                  </picture>
                )}
                {caseArt && (
                  <picture>
                    <source type="image/avif" srcset={caseArt.avif} />
                    <img
                      src={caseArt.webp ?? caseArt.avif}
                      alt=""
                      loading="lazy"
                      decoding="async"
                      style={item.objectPosition ? `object-position:${item.objectPosition}` : undefined}
                    />
                  </picture>
                )}
                {!media && !caseArt && <div class="wtile-placeholder placeholder" />}
                {caseArt?.loop && (
                  <video class="wtile-loop" data-tile-loop data-loop-src={caseArt.loop} muted loop playsinline preload="none" />
                )}
              </figure>
              <span class="wtile-index">{index}</span>
              <span class="wtile-tag">{pillarName}</span>
              <figcaption class="wtile-meta">
                <span class="wtile-title">{item.title}</span>
                {attribution ? (
                  <span class="wtile-line wtile-line--locked">{attribution}</span>
                ) : (
                  <span class="wtile-line">
                    For {item.forOrg} · {item.what} — {item.engagement}
                  </span>
                )}
              </figcaption>
              {/* ⚠ OPERATOR READ-APPROVAL REQUIRED — visible CTA labels ("Read the story",
                  and "See the highlights" for the Amazing Aerial flagship), staging-only.
                  Pulled OUT of the hover-hidden meta strip so the click-through is always
                  visible (mobile has no hover), as a bordered mono button. */}
              {item.href && (
                <span class="wtile-cta">
                  {item.cta ?? "Read the story"} <span class="arrow" aria-hidden="true">→</span>
                </span>
              )}
            </Tag>
          );
        })
      }
    </div>
    <p class="mx-auto mt-4 max-w-3xl text-sm text-ink-muted" data-work-empty hidden>
      Nothing in this lane yet.
    </p>
  </section>

  <!-- ═══ FROM THE ARCHIVE — quieter band of older projects (unfiltered) ═══
       ⚠ OPERATOR READ-APPROVAL REQUIRED — the "From the archive" kicker and each
       tile's title + date are new visible copy (staging-only). The honest
       one-liner under each is its relationship's permittedPhrasing, VERBATIM. -->
  {
    archive.length > 0 && (
      <section class="wall-rail archive-rail">
        <div class="archive">
          <p class="hud-label archive-kicker">From the archive</p>
          <div class="archive-grid">
            {archive.map(({ item, media, symbol, tierLabel, phrasing }) => (
              <div class="atile" data-archive>
                <figure class="atile-media" aria-hidden="true">
                  {media ? (
                    <picture>
                      <source type="image/avif" srcset={media.avif} />
                      <img src={media.webp ?? media.avif} alt="" loading="lazy" decoding="async" />
                    </picture>
                  ) : (
                    <div class="wtile-placeholder placeholder" />
                  )}
                </figure>
                <div class="atile-meta">
                  <span class="atile-head">
                    <span class="atile-title">{item.title}</span>
                    <span class="atile-date">{item.date}</span>
                  </span>
                  <span class="atile-line">
                    <span class="atile-sym" aria-hidden="true">{symbol}</span>
                    <span class="sr-only">{tierLabel}: </span>
                    {phrasing}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- §2e hover-distortion (feature-gated; CSS fallback is the default) -->
  <DistortionLayer />
</Base>

<style>
  /* ── the wall's stage: wider than the prose rail, contained for cq units ── */
  .wall-rail {
    margin-inline: auto;
    width: min(100%, 1440px);
    padding-inline: 2rem;
  }

  /* ── the wall. Simplified to a clean two-up card grid (the mosaic's mixed
        form factors were for the many-tile gallery; the wall is now the real
        engagements). Uniform 16:9 cinematic cards; one column on phones. The
        logo/branded tile faces (Pebble, Amazing Aerial) are native 16:9, so a
        16:9 card shows them WHOLE — no crop, every logo stays in frame. ── */
  .wall {
    --wall-gap: 14px;
    display: grid;
    gap: var(--wall-gap);
    grid-template-columns: repeat(2, 1fr);
  }
  @media (max-width: 640px) {
    .wall {
      grid-template-columns: 1fr;
    }
  }

  /* ── a tile: media-first, chrome-quiet, life on hover ── */
  .wtile {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 10px;
    background: color-mix(in srgb, var(--color-surface, #171b22) 70%, transparent);
    isolation: isolate;
  }
  /* FILTER HIDE — must be unlayered + higher specificity than `.wtile`
     (Tailwind's `.hidden` is layered and loses to any unlayered scoped rule). */
  .wtile.hidden {
    display: none;
  }
  /* a newly-revealed tile fades + lifts in (JS adds .is-entering on show) */
  @keyframes wtile-enter {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .wtile.is-entering {
    animation: wtile-enter 320ms var(--ease-survey, ease) both;
  }
  @media (prefers-reduced-motion: reduce) {
    .wtile.is-entering {
      animation: none;
    }
  }
  .wtile-media,
  .wtile-media picture,
  .wtile-media img,
  .wtile-placeholder,
  .wtile-loop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
  }
  .wtile-media img,
  .wtile-loop {
    object-fit: cover;
    transition: transform 900ms var(--ease-survey);
  }
  .wtile-loop {
    opacity: 0;
    transition:
      opacity 500ms var(--ease-survey),
      transform 900ms var(--ease-survey);
    pointer-events: none;
  }
  .wtile.is-looping .wtile-loop {
    opacity: 1;
  }

  /* corner instruments: index + lane tag, always on, quiet */
  .wtile-index,
  .wtile-tag {
    position: absolute;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(238, 245, 250, 0.82);
    text-shadow: 0 1px 6px rgba(6, 10, 18, 0.6);
  }
  .wtile-index {
    top: 10px;
    left: 12px;
  }
  .wtile-tag {
    top: 10px;
    right: 12px;
  }

  /* the meta strip: attribution-first, verbatim strings. Hover-risen on fine
     pointers, ALWAYS on where hover doesn't exist (touch) — honesty is not
     a hover state. */
  .wtile-meta {
    position: absolute;
    z-index: 2;
    inset-inline: 0;
    bottom: 0;
    display: grid;
    gap: 2px;
    padding: 2rem 14px 12px;
    background: linear-gradient(to top, rgba(9, 12, 19, 0.86), rgba(9, 12, 19, 0.42) 60%, transparent);
  }
  .wtile-title {
    font-weight: 600;
    font-size: 0.95rem;
    color: #eef5fa;
    line-height: 1.25;
  }
  .wtile-line {
    font-size: 0.74rem;
    color: rgba(238, 245, 250, 0.72);
    line-height: 1.35;
  }
  .wtile-line--locked {
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }
  /* the click-through: a bordered mono button, ALWAYS visible (not a hover
     state — mobile has no hover), pinned bottom-right with its own backdrop so
     it stays legible over any frame. Shared button grammar: 1px border, Space
     Mono caps, arrow slides 6px on hover, accent hover. */
  .wtile-cta {
    position: absolute;
    z-index: 3;
    right: 12px;
    bottom: 12px;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 44px;
    padding: 0.55rem 0.9rem;
    border: 1px solid color-mix(in srgb, var(--color-accent, #38f8ec) 60%, transparent);
    border-radius: 3px;
    background: color-mix(in srgb, #090c13 74%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #eef5fa;
    text-shadow: 0 1px 6px rgba(6, 10, 18, 0.6);
    transition:
      border-color var(--dur-hover, 160ms) var(--ease-swift),
      color var(--dur-hover, 160ms) var(--ease-swift),
      box-shadow var(--dur-hover, 160ms) var(--ease-swift);
  }
  .wtile-cta .arrow {
    display: inline-block;
    transition: transform var(--dur-hover, 160ms) var(--ease-swift);
  }
  /* reserve the button's corner so the attribution line never runs under it */
  .wtile--link .wtile-meta {
    padding-right: 10.5rem;
  }
  @media (hover: hover) and (pointer: fine) {
    .wtile:hover .wtile-cta,
    .wtile:focus-visible .wtile-cta {
      border-color: var(--color-accent, #38f8ec);
      color: var(--color-accent, #38f8ec);
      box-shadow: 0 0 20px -6px color-mix(in srgb, var(--color-accent, #38f8ec) 60%, transparent);
    }
    .wtile:hover .wtile-cta .arrow,
    .wtile:focus-visible .wtile-cta .arrow {
      transform: translateX(6px);
    }
  }
  @media (max-width: 640px) {
    .wtile--link .wtile-meta {
      padding-right: 9rem; /* reserve the pinned button's corner on narrow tiles */
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .wtile-cta .arrow {
      transition: none;
    }
  }
  @media (hover: hover) and (pointer: fine) {
    .wtile-meta {
      opacity: 0;
      transform: translateY(8px);
      transition:
        opacity 380ms var(--ease-survey),
        transform 380ms var(--ease-survey);
    }
    .wtile:hover .wtile-meta,
    .wtile:focus-visible .wtile-meta {
      opacity: 1;
      transform: none;
    }
    .wtile:hover .wtile-media img,
    .wtile:hover .wtile-loop {
      transform: scale(1.045);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .wtile-media img,
    .wtile-loop,
    .wtile-meta {
      transition: none;
    }
    .wtile:hover .wtile-media img,
    .wtile:hover .wtile-loop {
      transform: none;
    }
  }

  /* ── FROM THE ARCHIVE — a quieter, smaller band. Narrower rail than the wall,
        muted media at rest (restored on hover), mono kicker. Older projects,
        honestly labeled — not competing with the live work above. ── */
  .archive-rail {
    width: min(100%, 880px);
    margin-top: 2.5rem;
  }
  .archive {
    border-top: 1px solid color-mix(in srgb, #ffffff 12%, transparent);
    padding-top: 1.4rem;
  }
  .archive-kicker {
    margin: 0 0 1rem;
    letter-spacing: 0.28em;
    color: color-mix(in srgb, var(--color-ink-muted, #8a9a96) 90%, transparent);
  }
  .archive-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, 1fr);
  }
  @media (max-width: 640px) {
    .archive-grid {
      grid-template-columns: 1fr;
    }
  }
  .atile {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, #ffffff 10%, transparent);
    background: color-mix(in srgb, var(--color-surface, #171b22) 60%, transparent);
    isolation: isolate;
  }
  .atile-media,
  .atile-media picture,
  .atile-media img,
  .atile .wtile-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
  }
  .atile-media img {
    object-fit: cover;
    /* muted at rest — the archive is quieter than the live wall */
    filter: saturate(0.82) brightness(0.82);
    opacity: 0.92;
    transition:
      filter 400ms var(--ease-survey),
      opacity 400ms var(--ease-survey),
      transform 900ms var(--ease-survey);
  }
  @media (hover: hover) and (pointer: fine) {
    .atile:hover .atile-media img {
      filter: saturate(1) brightness(0.95);
      opacity: 1;
      transform: scale(1.03);
    }
  }
  .atile-meta {
    position: absolute;
    z-index: 2;
    inset-inline: 0;
    bottom: 0;
    display: grid;
    gap: 3px;
    padding: 1.6rem 12px 10px;
    background: linear-gradient(to top, rgba(9, 12, 19, 0.9), rgba(9, 12, 19, 0.45) 62%, transparent);
  }
  .atile-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.6rem;
  }
  .atile-title {
    font-weight: 600;
    font-size: 0.9rem;
    color: #eef5fa;
    line-height: 1.2;
  }
  .atile-date {
    flex: none;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    color: rgba(238, 245, 250, 0.6);
  }
  .atile-line {
    font-size: 0.72rem;
    line-height: 1.35;
    color: rgba(238, 245, 250, 0.72);
  }
  .atile-sym {
    color: var(--color-accent-deep, #1e8f8a);
    margin-right: 0.3rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .atile-media img {
      transition: none;
    }
    .atile:hover .atile-media img {
      transform: none;
    }
  }
</style>

<script>
  // Filter enhancement only — every tile starts visible (see file header).
  // The toggle is a plain class flip: `.wtile.hidden { display:none }` is
  // scoped + unlayered, so it actually removes the tile from the grid (Tailwind
  // v4's layered `.hidden` alone could not). Survivors that stay get a quick
  // fade-in for polish; no GSAP Flip reflow (its absolute-mode leave handling
  // left hidden tiles stuck visible — correctness of the filter beats the
  // animation, which added little for a handful of tiles).
  const grid = document.querySelector<HTMLElement>("[data-work-grid]");
  const bar = document.querySelector<HTMLElement>("[data-work-filters]");
  const empty = document.querySelector<HTMLElement>("[data-work-empty]");
  if (grid && bar) {
    const cards = [...grid.querySelectorAll<HTMLElement>("[data-pillar]")];
    const buttons = [...bar.querySelectorAll<HTMLButtonElement>("[data-filter]")];
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function applyFilter(filter: string) {
      let visibleCount = 0;
      cards.forEach((card) => {
        const wasHidden = card.classList.contains("hidden");
        const show = filter === "all" || card.dataset.pillar === filter;
        card.classList.toggle("hidden", !show);
        // fade a newly-revealed tile in (fine pointers, motion allowed only)
        if (show && wasHidden && !reduce) {
          card.classList.remove("is-entering");
          void card.offsetWidth; // restart the animation
          card.classList.add("is-entering");
        }
        if (show) visibleCount++;
      });
      if (empty) empty.hidden = visibleCount > 0;
    }

    bar.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-filter]");
      if (!btn) return;
      buttons.forEach((b) => b.setAttribute("aria-pressed", String(b === btn)));
      applyFilter(btn.dataset.filter!);
    });
  }

  // Hover-life: case tiles with a loop export play it on hover. The video
  // mounts on FIRST pointerenter (preload="none" keeps the wall's initial
  // load still-only), fades in over its poster, pauses on leave. Fine
  // pointers only; never under reduced motion or Save-Data.
  (() => {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fine = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (reduce || !fine || conn?.saveData) return;
    document.querySelectorAll<HTMLVideoElement>("[data-tile-loop]").forEach((video) => {
      const tile = video.closest<HTMLElement>(".wtile");
      if (!tile) return;
      tile.addEventListener("pointerenter", () => {
        if (!video.src) video.src = video.dataset.loopSrc!;
        video.play().catch(() => {}); // autoplay refusal → the poster stands
        tile.classList.add("is-looping");
      });
      tile.addEventListener("pointerleave", () => {
        tile.classList.remove("is-looping");
        if (!video.paused) video.pause();
      });
    });
  })();
</script>
