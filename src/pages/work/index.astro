---
/**
 * /work — the Resn-grammar work wall (V-3, V2-PLAN §2 "Work — the wall").
 *
 * The full cross-lane wall: near-black ground with a faint contour texture,
 * a "FILTER / All work ⌄" dropdown (All work / The wild / The market /
 * The industry), a 2-column wall of live media tiles running the existing
 * WebGL hover-distortion, captions in small caps (TITLE / forOrg) + the honest
 * engagement label. All of that machinery lives in the shared WorkWall
 * component — /adventure and /entertainment mount the SAME component
 * pre-filtered.
 *
 * Progressive enhancement is owned by WorkWall: no-JS shows every tile, the
 * filter is JS-only sugar. The AA-attribution band (Ledger phrasing + real AA
 * mark) stays here, always visible and honest regardless of filter.
 */
import Base from "../../layouts/Base.astro";
import WorkWall from "../../components/WorkWall.astro";
import { PAGES } from "../../consts";

const p = PAGES.work;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title={p.meta.title} description={p.meta.description}>
  <!-- Wall opener — mono chapter label decodes in (Ascent grammar), giant
       heading, honest intro. All copy verbatim from PAGES.work.intro. -->
  <section class="mx-auto max-w-5xl space-y-4 px-6 pt-16 pb-4 sm:px-8">
    <p class="hud-label ch-no" data-decode data-reveal>WORK · THE FIELD</p>
    <h1 class="wall-title" data-reveal>{p.intro.heading}</h1>
    <p class="max-w-2xl text-ink" data-reveal>{p.intro.body}</p>
  </section>

  <!-- The wall — full cross-lane view (no pillar prop → FILTER dropdown on). -->
  <WorkWall />

  <!-- AA-attribution band (R3.2b / PARTNER-LOGO RULE) — real Amazing Aerial
       mark + the Ledger phrasing verbatim. Always shown (the phrasing is
       accurate regardless of filter), adjacent to the mark as the rule requires. -->
  <div class="mx-auto mt-4 max-w-5xl px-6 pb-16 sm:px-8">
    <div class="panel aa-work-band p-4">
      <img
        src={`${base}/media/adventure/aa-logo.png`}
        alt="Amazing Aerial Agency"
        width="480"
        height="158"
        loading="lazy"
        decoding="async"
      />
      <p class="hud-label">Aerial work licensed through Amazing Aerial Agency</p>
    </div>
  </div>
</Base>
