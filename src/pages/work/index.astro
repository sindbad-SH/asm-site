---
/**
 * /work — "Industry Stories": the film & entertainment industry lane
 * (Round 3, 2026-07-21 — operator-directed lane redistribution).
 *
 * WHAT THIS PAGE NOW IS: the lane he works in and covers — anchored by MEME
 * (top billing: the org he's affiliated with, where the content will grow),
 * then the SeriesFest + American Film Market coverage shelf, then a
 * conservative close that sells presence + coverage and points the
 * production/consulting money questions at the lanes that own them.
 *
 * WHAT LEFT (moved, never discarded — each piece lives in its true lane):
 *   • Shelby / Pebble Beach → /entertainment (it already carried the full
 *     chapter-02 feature + the Jack Bell testimonial; corporate event
 *     coverage for a private client = venture lane). Case page URL unchanged.
 *   • PitchBoulder → /entertainment (chapter 01 — its slot now carries the
 *     actual commercial embed, not just the hover loop). Case page unchanged.
 *   • Knights of Mayhem → /adventure (broadened into the "Medieval Festival
 *     in Loveland" feature block).
 *   • The AA flagship tile → /adventure (the AA bands there now link the
 *     highlights reel; /work/amazing-aerial URL unchanged).
 *   • The "from the archive" band → /entertainment (early gig/event coverage
 *     is venture-storytelling-natured, not film-industry work).
 *
 * HONESTY (unchanged contract): every relationship claim renders through
 * LegendMark (verbatim permittedPhrasing); coverage tile slate/title strings
 * are copied verbatim from their article pages; prose never upgrades a status.
 * The MEME ambient loop mirrors /venture/meme.astro's poster-first gating.
 */
import Base from "../../layouts/Base.astro";
import LegendMark from "../../components/LegendMark.astro";
import { PAGES } from "../../consts";
import { existsSync, statSync } from "node:fs";
import { join } from "node:path";

const p = PAGES.work;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (h: string) => (h.startsWith("http") ? h : `${base}${h}`);

// build-time media gating (repo convention): a tile only renders media that
// shipped. Coverage tiles reuse each article's own hero-900 export.
const mediaRoot = join(process.cwd(), "public", "media");
const media = (rel: string) => (existsSync(join(mediaRoot, ...rel.split("/"))) ? `${base}/media/${rel}` : undefined);
const pair = (relBase: string) => {
  const avif = media(`${relBase}.avif`);
  const webp = media(`${relBase}.webp`);
  return avif || webp ? { avif, webp } : undefined;
};
const mtimeV = (rel: string) => {
  try {
    return `?v=${Math.round(statSync(join(mediaRoot, ...rel.split("/"))).mtimeMs).toString(36)}`;
  } catch {
    return "";
  }
};
const bust = (relBase: string, pr: ReturnType<typeof pair>) =>
  pr
    ? {
        avif: pr.avif ? pr.avif + mtimeV(`${relBase}.avif`) : undefined,
        webp: pr.webp ? pr.webp + mtimeV(`${relBase}.webp`) : undefined,
      }
    : undefined;

// MEME anchor media — the org's own logo animatic, SAME processed loop the
// /venture/meme article and /entertainment ch.03 carry (reused, existence-
// gated, poster-first). No new asset.
const memeLoop = media("venture/meme/meme-loop.mp4")
  ? {
      mp4: `${base}/media/venture/meme/meme-loop.mp4${mtimeV("venture/meme/meme-loop.mp4")}`,
      poster: bust("venture/meme/meme-poster", pair("venture/meme/meme-poster")),
    }
  : undefined;

// Coverage shelf tiles — each resolves its article's hero export.
const tiles = p.coverage.items.map((item, i) => {
  const slug = item.href.replace(/^\/venture\//, "");
  return {
    ...item,
    index: String(i + 1).padStart(2, "0"),
    img: bust(`venture/${slug}/hero-900`, pair(`venture/${slug}/hero-900`)),
  };
});
// The shelf states each event relationship ONCE (verbatim phrasing), not per
// tile — SeriesFest and AFM share the same honest line.
const shelfProofIds = [...new Set(p.coverage.items.map((i) => i.relationshipId))];
---

<Base title={p.meta.title} description={p.meta.description}>
  <section class="mx-auto max-w-3xl space-y-4 p-8">
    <!-- Lane pairing: same eyebrow grammar as /adventure and /entertainment. -->
    <p class="hud-label" data-reveal>{p.eyebrow}</p>
    <h1 class="text-3xl font-bold" data-reveal>{p.intro.heading}</h1>
    <p class="text-ink" data-reveal>{p.intro.body}</p>
  </section>

  <!-- ═══ W2 · MEME — TOP BILLING (the anchor of the lane) ═══
       ⚠ OPERATOR READ-APPROVAL REQUIRED — heading/body/growth copy is new
       (staging-only until read; see consts). The status claim renders ONLY
       via LegendMark, verbatim. -->
  <section class="mx-auto max-w-5xl border-t border-hairline p-8">
    <p class="hud-label mb-4" data-reveal>{p.meme.kicker}</p>
    <div class="anchor-panel panel" data-reveal>
      {
        memeLoop && (
          <figure class="anchor-media" aria-hidden="true">
            <picture>
              {memeLoop.poster?.avif && <source type="image/avif" srcset={memeLoop.poster.avif} />}
              <img
                class="anchor-poster"
                src={memeLoop.poster?.webp ?? memeLoop.poster?.avif}
                alt=""
                loading="lazy"
                decoding="async"
              />
            </picture>
            <video
              class="anchor-loop"
              data-anchor-loop
              data-loop-src={memeLoop.mp4}
              muted
              loop
              playsinline
              preload="none"
            ></video>
          </figure>
        )
      }
      <div class="anchor-copy space-y-4">
        <h2 class="text-2xl font-bold">{p.meme.heading}</h2>
        <LegendMark proof={p.meme.proof} />
        <p class="text-ink">{p.meme.body}</p>
        <p class="anchor-growth">{p.meme.growth}</p>
        <div class="flex flex-wrap items-center gap-4">
          {
            p.meme.ctas.map((cta, i) =>
              i === 0 ? (
                <a href={href(cta.href)} class="btn">
                  {cta.label}
                </a>
              ) : (
                <a href={cta.href} class="link" target="_blank" rel="noopener">
                  {cta.label} <span class="arrow" aria-hidden="true">→</span>
                </a>
              ),
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ W3 · THE COVERAGE SHELF — SeriesFest + American Film Market ═══
       Tiles keep the wall's wtile grammar (16:9 cinematic cards, corner
       instruments, always-visible CTA); slate/title strings verbatim from the
       article pages. The honest status line renders ONCE per relationship
       below the shelf heading — never upgraded per tile. -->
  <section class="wall-rail py-8 border-t border-hairline">
    <div class="mx-auto mb-6 max-w-3xl space-y-3">
      <h2 class="text-2xl font-bold" data-reveal>{p.coverage.heading}</h2>
      <p class="text-ink" data-reveal>{p.coverage.intro}</p>
      <ul class="shelf-proofs" aria-label="How close each relationship is">
        {
          shelfProofIds.map((id) => (
            <li data-reveal>
              <LegendMark proof={{ relationshipId: id }} />
            </li>
          ))
        }
      </ul>
    </div>
    <div class="wall">
      {
        tiles.map((tile) => (
          <a class="wtile wtile--link" href={`${base}${tile.href}`} data-reveal data-reveal-stagger="50">
            <figure class="wtile-media" aria-hidden="true">
              {tile.img ? (
                <picture>
                  {tile.img.avif && <source type="image/avif" srcset={tile.img.avif} />}
                  <img src={tile.img.webp ?? tile.img.avif} alt="" loading="lazy" decoding="async" />
                </picture>
              ) : (
                <div class="wtile-placeholder placeholder" />
              )}
            </figure>
            <span class="wtile-index">{tile.index}</span>
            <figcaption class="wtile-meta">
              <span class="wtile-slate">{tile.slate}</span>
              <span class="wtile-title">{tile.title}</span>
            </figcaption>
            <span class="wtile-cta">
              Read the story <span class="arrow" aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ═══ W4 · THE CLOSE — conservative industry-lane framing: presence +
       coverage here; production/consulting money questions route to the lanes
       that own those offers. ⚠ OPERATOR READ-APPROVAL REQUIRED — new copy
       (staging-only until read; see consts). -->
  <section class="mx-auto max-w-3xl space-y-5 border-t border-hairline p-8 text-center">
    <h2 class="text-2xl font-bold" data-reveal>{p.close.headline}</h2>
    <p class="text-ink" data-reveal>{p.close.body}</p>
    <a href={p.close.cta.href} class="btn" rel="noopener" data-reveal>{p.close.cta.label}</a>
    <ul class="close-lanes" data-reveal>
      {
        p.close.lanes.map((lane) => (
          <li>
            <a href={href(lane.href)} class="link">
              {lane.label} <span class="arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Base>

<style>
  /* ── the shelf's stage: wider than the prose rail ── */
  .wall-rail {
    margin-inline: auto;
    width: min(100%, 1440px);
    padding-inline: 2rem;
  }

  /* ── W2 · the MEME anchor panel: media beside copy, loop over poster ── */
  .anchor-panel {
    display: grid;
    gap: 1.5rem;
    padding: 1.5rem;
  }
  @media (min-width: 860px) {
    .anchor-panel {
      grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
      align-items: center;
      padding: 2rem;
    }
  }
  .anchor-media {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, #ffffff 14%, transparent);
    background: color-mix(in srgb, #ffffff 4%, transparent);
    box-shadow: 0 0 34px -12px color-mix(in srgb, var(--color-accent, #38f8ec) 38%, transparent);
  }
  .anchor-poster {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .anchor-loop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 500ms var(--ease-survey, ease);
    pointer-events: none;
  }
  .anchor-media.is-playing .anchor-loop {
    opacity: 1;
  }
  .anchor-growth {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    line-height: 1.5;
    color: var(--color-ink-muted, #8a9a96);
  }

  /* ── W3 · the shelf proofs — the honest status lines, quiet mono ── */
  .shelf-proofs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--color-ink-muted, #8a9a96);
  }

  /* ── the coverage shelf: the wall's two-up 16:9 card grammar, kept ── */
  .wall {
    --wall-gap: 14px;
    display: grid;
    gap: var(--wall-gap);
    grid-template-columns: repeat(2, 1fr);
  }
  @media (max-width: 640px) {
    .wall {
      grid-template-columns: 1fr;
    }
  }
  .wtile {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 10px;
    background: color-mix(in srgb, var(--color-surface, #171b22) 70%, transparent);
    isolation: isolate;
  }
  .wtile-media,
  .wtile-media picture,
  .wtile-media img,
  .wtile-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
  }
  .wtile-media img {
    object-fit: cover;
    transition: transform 900ms var(--ease-survey);
  }

  /* corner instrument: index, always on, quiet */
  .wtile-index {
    position: absolute;
    z-index: 2;
    top: 10px;
    left: 12px;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(238, 245, 250, 0.82);
    text-shadow: 0 1px 6px rgba(6, 10, 18, 0.6);
  }

  /* the meta strip: slate + title. Hover-risen on fine pointers, ALWAYS on
     where hover doesn't exist (touch). */
  .wtile-meta {
    position: absolute;
    z-index: 2;
    inset-inline: 0;
    bottom: 0;
    display: grid;
    gap: 2px;
    padding: 2rem 14px 12px;
    background: linear-gradient(to top, rgba(9, 12, 19, 0.86), rgba(9, 12, 19, 0.42) 60%, transparent);
  }
  .wtile-slate {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(238, 245, 250, 0.66);
  }
  .wtile-title {
    font-weight: 600;
    font-size: 0.95rem;
    color: #eef5fa;
    line-height: 1.25;
  }
  /* the click-through: bordered mono button, ALWAYS visible, pinned
     bottom-right — the wall's shared button grammar. */
  .wtile-cta {
    position: absolute;
    z-index: 3;
    right: 12px;
    bottom: 12px;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 44px;
    padding: 0.55rem 0.9rem;
    border: 1px solid color-mix(in srgb, var(--color-accent, #38f8ec) 60%, transparent);
    border-radius: 3px;
    background: color-mix(in srgb, #090c13 74%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #eef5fa;
    text-shadow: 0 1px 6px rgba(6, 10, 18, 0.6);
    transition:
      border-color var(--dur-hover, 160ms) var(--ease-swift),
      color var(--dur-hover, 160ms) var(--ease-swift),
      box-shadow var(--dur-hover, 160ms) var(--ease-swift);
  }
  .wtile-cta .arrow {
    display: inline-block;
    transition: transform var(--dur-hover, 160ms) var(--ease-swift);
  }
  /* reserve the button's corner so the title never runs under it */
  .wtile--link .wtile-meta {
    padding-right: 10.5rem;
  }
  @media (max-width: 640px) {
    .wtile--link .wtile-meta {
      padding-right: 9rem;
    }
  }
  @media (hover: hover) and (pointer: fine) {
    .wtile:hover .wtile-cta,
    .wtile:focus-visible .wtile-cta {
      border-color: var(--color-accent, #38f8ec);
      color: var(--color-accent, #38f8ec);
      box-shadow: 0 0 20px -6px color-mix(in srgb, var(--color-accent, #38f8ec) 60%, transparent);
    }
    .wtile:hover .wtile-cta .arrow,
    .wtile:focus-visible .wtile-cta .arrow {
      transform: translateX(6px);
    }
    .wtile-meta {
      opacity: 0;
      transform: translateY(8px);
      transition:
        opacity 380ms var(--ease-survey),
        transform 380ms var(--ease-survey);
    }
    .wtile:hover .wtile-meta,
    .wtile:focus-visible .wtile-meta {
      opacity: 1;
      transform: none;
    }
    .wtile:hover .wtile-media img {
      transform: scale(1.045);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .wtile-media img,
    .wtile-meta,
    .wtile-cta .arrow {
      transition: none;
    }
    .wtile:hover .wtile-media img {
      transform: none;
    }
  }

  /* ── W4 · the close's lane pointers ── */
  .close-lanes {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
    font-size: 0.92rem;
  }
</style>

<script>
  // MEME anchor ambient loop: plays only when motion is allowed and the panel
  // is on-screen; the poster underneath is the permanent base layer (reduced-
  // motion / no-JS / Save-Data / autoplay-refused all show the still). Mirrors
  // /venture/meme.astro and /entertainment ch.03 — lazy src, IO-gated.
  (() => {
    const video = document.querySelector<HTMLVideoElement>("[data-anchor-loop]");
    const fig = video?.closest<HTMLElement>(".anchor-media");
    if (!fig || !video) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (conn?.saveData) return;
    video.addEventListener("playing", () => fig.classList.add("is-playing"));
    const io = new IntersectionObserver(
      ([entry]) => {
        if (!entry) return;
        if (entry.isIntersecting) {
          if (!video.src) video.src = video.dataset.loopSrc!;
          video.play().catch(() => {}); // refusal → poster stands
        } else if (!video.paused) {
          video.pause();
        }
      },
      { threshold: 0.25 },
    );
    io.observe(fig);
    window.addEventListener("pagehide", () => io.disconnect(), { once: true });
  })();
</script>
