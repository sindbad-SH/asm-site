---
/**
 * /work/vybe — a LIGHT case page for the Vybe event coverage (P-work-2,
 * 2026-07-12). Linked from the work-wall's archive band. Same venture-article
 * family grammar as /venture/ko-law-workshops + the Amazing Aerial reel: dark
 * ground, mono slate, italic title, LegendMark proof, a few short paragraphs, a
 * media band (a muted web-loop clip + stills), prominent CTAs, ← back to /work.
 *
 * ⚠ OPERATOR READ-APPROVAL REQUIRED — every heading / caption / paragraph / CTA
 * label below is NEW copy, staging-only until read. The ONLY relationship
 * statement is the LOCKED permittedPhrasing, rendered verbatim via <LegendMark>
 * ("vybe" → "event coverage for Vybe"). The prose describes Vybe factually — a
 * Denver arts / music / dance collective ("Vibrate Your Best Energy", verified
 * from the brand's own public channels) — and states plainly that I covered a
 * few of their events. NO affiliation and NO client relationship is claimed for
 * anyone (per operator direction the "made for a friend" note was dropped).
 *
 * Media (scripts/make-archive-media.mjs, existence-gated): a 2023 golden-hour
 * festival aerial (hero + a muted loop of the arch approach) and two 2024 Boogie
 * Lights frames (stage + live painting).
 */
import Base from "../../layouts/Base.astro";
import LegendMark from "../../components/LegendMark.astro";
import { existsSync, statSync } from "node:fs";
import { join } from "node:path";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// ── media (existence-gated, cache-busted like the rest of the site) ──
const MDIR = join(process.cwd(), "public", "media", "work", "vybe");
const CDIR = join(MDIR, "clips");
const bust = (rel: string) => {
  try {
    return `?v=${Math.round(statSync(join(MDIR, rel)).mtimeMs).toString(36)}`;
  } catch {
    return "";
  }
};
function still(name: string) {
  if (!existsSync(join(MDIR, `${name}.avif`))) return undefined;
  return {
    avif: `${base}/media/work/vybe/${name}.avif${bust(`${name}.avif`)}`,
    webp: existsSync(join(MDIR, `${name}.webp`))
      ? `${base}/media/work/vybe/${name}.webp${bust(`${name}.webp`)}`
      : undefined,
  };
}
function clip(slug: string, caption: string, alt: string) {
  if (!existsSync(join(CDIR, `${slug}.mp4`))) return undefined;
  return {
    mp4: `${base}/media/work/vybe/clips/${slug}.mp4${bust(`clips/${slug}.mp4`)}`,
    posterAvif: `${base}/media/work/vybe/clips/${slug}-poster.avif`,
    posterWebp: `${base}/media/work/vybe/clips/${slug}-poster.webp`,
    caption,
    alt,
  };
}

const hero = still("hero");
const stills = [
  { s: still("still-stage"), alt: "A 2024 Boogie Lights performance under stage lights." },
  { s: still("still-art"), alt: "Live painting at the 2024 Boogie Lights event." },
].filter((x): x is { s: NonNullable<ReturnType<typeof still>>; alt: string } => !!x.s);

const clips = [
  clip("vybe-fest", "The 2023 festival · from the air", "Golden-hour aerial of the 2023 Vybe outdoor festival, approaching a rainbow balloon arch."),
].filter((x): x is NonNullable<typeof x> => !!x);

// ── THE ARTICLE (all new sentences — see the approval note above) ──
const ARTICLE = {
  slate: "VYBE · EVENT COVERAGE · 2023–2024",
  title: "Covering the Vybe events.",
  paragraphs: [
    "Vybe — short for Vibrate Your Best Energy — is a Denver arts, music, and dance collective that builds immersive, playful community events.",
    "We covered a few of them: an outdoor festival by the water in 2023, and the 2024 Boogie Lights show under the lights. Just coverage — the aerials, the stage, the room — cut into something that keeps.",
  ],
};

const CTAS = [
  { label: "Back to the work", href: `${base}/work`, primary: true },
  { label: "The Gigs Go Green story", href: `${base}/work/gigs-go-green`, primary: false },
];
---

<Base
  title="Vybe — event coverage"
  description="Event coverage for Vybe, a Denver arts and music collective — a 2023 outdoor festival from the air and the 2024 Boogie Lights show, in frames and a short clip."
>
  <main class="case">
    <article class="case-inner">
      <a href={`${base}/work`} class="link case-back">← Work</a>

      <p class="hud-label case-slate" data-reveal>
        <span data-decode>{ARTICLE.slate}</span>
      </p>
      <h1 class="case-title" data-reveal>{ARTICLE.title}</h1>
      <div class="case-proof" data-reveal>
        <LegendMark proof={{ relationshipId: "vybe" }} showName={false} />
      </div>

      {
        hero && (
          <figure class="case-hero" data-reveal>
            <picture>
              <source type="image/avif" srcset={hero.avif} />
              <img
                src={hero.webp ?? hero.avif}
                alt="Golden-hour aerial of the 2023 Vybe outdoor festival beside a pond, colorful canopies below."
                loading="eager"
                decoding="async"
              />
            </picture>
          </figure>
        )
      }

      {ARTICLE.paragraphs.map((para) => <p class="case-para" data-reveal>{para}</p>)}

      {
        clips.length > 0 && (
          <section class="case-section" data-reveal>
            <h2 class="hud-label case-h2">In motion</h2>
            <div class="case-clips">
              {clips.map((cl) => (
                <figure class="case-clip" data-clip>
                  <picture>
                    <source type="image/avif" srcset={cl.posterAvif} />
                    <img class="case-clip-poster" src={cl.posterWebp} alt={cl.alt} loading="lazy" decoding="async" />
                  </picture>
                  <video class="case-clip-vid" data-clip-loop data-src={cl.mp4} muted loop playsinline preload="none" />
                  <figcaption class="hud-label case-clip-cap">{cl.caption}</figcaption>
                </figure>
              ))}
            </div>
          </section>
        )
      }

      {
        stills.length > 0 && (
          <section class="case-section" data-reveal>
            <h2 class="hud-label case-h2">Frames · Boogie Lights, 2024</h2>
            <div class="case-stills">
              {stills.map(({ s, alt }) => (
                <figure class="case-still">
                  <picture>
                    <source type="image/avif" srcset={s.avif} />
                    <img src={s.webp ?? s.avif} alt={alt} loading="lazy" decoding="async" />
                  </picture>
                </figure>
              ))}
            </div>
          </section>
        )
      }

      <nav class="case-ctas" data-reveal>
        {
          CTAS.map((c) => (
            <a href={c.href} class={`case-cta${c.primary ? " case-cta--primary" : ""}`}>
              <span>{c.label}</span>
              <span class="arrow" aria-hidden="true">→</span>
            </a>
          ))
        }
      </nav>
      <a href={`${base}/work`} class="link case-back">← Work</a>
    </article>
  </main>
</Base>

<style>
  .case {
    background: #0e131c;
    min-height: 100svh;
  }
  .case-inner {
    max-width: 52rem;
    margin-inline: auto;
    padding: 7rem 2rem 6rem;
    display: grid;
    gap: 1.4rem;
  }
  .case-back {
    justify-self: start;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .case-slate {
    letter-spacing: 0.24em;
    color: color-mix(in srgb, #d9f2ec 75%, transparent);
    margin: 0;
  }
  .case-title {
    font-family: var(--font-display);
    font-weight: 560;
    font-style: italic;
    font-size: clamp(2rem, 4.2vw, 3.4rem);
    line-height: 1.12;
    color: #f2f4f8;
  }

  .case-hero {
    margin: 0.4rem 0 0;
    border-radius: 8px;
    overflow: hidden;
    background: color-mix(in srgb, #ffffff 4%, transparent);
  }
  .case-hero img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .case-para {
    font-family: var(--font-sans);
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.65;
    color: color-mix(in srgb, #eef2f5 86%, transparent);
    max-width: 44rem;
  }

  .case-section {
    margin-top: 1.2rem;
    display: grid;
    gap: 0.9rem;
  }
  .case-h2 {
    margin: 0;
    letter-spacing: 0.24em;
    color: color-mix(in srgb, #d9f2ec 70%, transparent);
  }

  /* clips — muted autoplay-in-view loops; poster is the permanent base layer
     (gating pattern shared with the Amazing Aerial reel). A single 16:9 clip,
     centered and width-capped so it doesn't dominate. */
  .case-clips {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.8rem;
    max-width: 40rem;
  }
  .case-clip {
    position: relative;
    margin: 0;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, #ffffff 12%, transparent);
    background: color-mix(in srgb, #ffffff 4%, transparent);
  }
  .case-clip-poster,
  .case-clip-vid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .case-clip-vid {
    opacity: 0;
    transition: opacity 600ms var(--ease-survey, ease);
  }
  .case-clip.is-playing .case-clip-vid {
    opacity: 1;
  }
  .case-clip-cap {
    position: absolute;
    left: 0.8rem;
    bottom: 0.7rem;
    margin: 0;
    z-index: 2;
    letter-spacing: 0.14em;
    color: color-mix(in srgb, #f4fbfa 92%, transparent);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.7);
  }

  /* stills — the 2024 Boogie Lights frames are portrait (shot vertical); a
     two-up grid, cropped to a uniform 4:5 so the band stays tidy. */
  .case-stills {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
    max-width: 40rem;
  }
  .case-still {
    margin: 0;
    border-radius: 8px;
    overflow: hidden;
    background: color-mix(in srgb, #ffffff 4%, transparent);
  }
  .case-still img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  /* CTA row — shared button grammar */
  .case-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    border-top: 1px solid color-mix(in srgb, #ffffff 12%, transparent);
    padding-top: 1.4rem;
    margin-top: 0.6rem;
  }
  .case-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 44px;
    padding: 0.7rem 1.15rem;
    border: 1px solid color-mix(in srgb, #ffffff 22%, transparent);
    border-radius: 2px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, #eef2f5 88%, transparent);
    text-decoration: none;
    transition:
      border-color var(--dur-hover, 160ms) var(--ease-swift),
      color var(--dur-hover, 160ms) var(--ease-swift),
      box-shadow var(--dur-hover, 160ms) var(--ease-swift);
  }
  .case-cta--primary {
    border-color: var(--color-accent-deep, #1e8f8a);
    color: #f2f4f8;
  }
  .case-cta .arrow {
    display: inline-block;
    transition: transform var(--dur-hover, 160ms) var(--ease-swift);
  }
  .case-cta:hover,
  .case-cta:focus-visible {
    border-color: var(--color-accent, #38f8ec);
    color: var(--color-accent, #38f8ec);
    box-shadow: 0 0 24px -6px color-mix(in srgb, var(--color-accent, #38f8ec) 55%, transparent);
  }
  .case-cta:hover .arrow,
  .case-cta:focus-visible .arrow {
    transform: translateX(6px);
  }

  @media (max-width: 640px) {
    .case-stills {
      grid-template-columns: repeat(2, 1fr);
    }
    .case-cta {
      flex: 1 1 100%;
      justify-content: space-between;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .case-clip-vid {
      transition: none;
    }
    .case-cta .arrow {
      transition: none;
    }
  }
</style>

<script>
  // enhancement only: decode the slate label (matches the sibling article pages)
  const mountDecode = () => import("../../lib/decode-text").then(({ mountDecode }) => mountDecode(document));
  if ("requestIdleCallback" in window) requestIdleCallback(mountDecode, { timeout: 3000 });
  else setTimeout(mountDecode, 1500);

  // Muted loops — play ONLY when motion is allowed and the clip is on screen;
  // the poster underneath is the permanent base layer (reduced-motion / no-JS /
  // Save-Data / autoplay-refused → still). Lazy mount on first intersection.
  // Copied from /work/amazing-aerial.
  (() => {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) return;
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (conn?.saveData) return;

    const clips = [...document.querySelectorAll<HTMLElement>("[data-clip]")];
    if (!clips.length || !("IntersectionObserver" in window)) return;

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const wrap = entry.target as HTMLElement;
          const video = wrap.querySelector<HTMLVideoElement>("[data-clip-loop]");
          if (!video) continue;
          if (entry.isIntersecting) {
            if (!video.src) video.src = video.dataset.src!;
            video.addEventListener("playing", () => wrap.classList.add("is-playing"), { once: true });
            video.play().catch(() => {});
          } else if (!video.paused) {
            video.pause();
          }
        }
      },
      { threshold: 0.25 },
    );
    clips.forEach((cl) => io.observe(cl));
    window.addEventListener("pagehide", () => io.disconnect(), { once: true });
  })();
</script>
