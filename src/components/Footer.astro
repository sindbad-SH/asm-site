---
/**
 * Footer in the system voice — hairline top rule, mono hud labels, muted ink.
 * Email + socials from SITE ([confirm] values render visibly inert, never
 * guessed links — the audit gate catches them before production).
 */
import { SITE, NAV } from "../consts";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const socialEntries = Object.entries(SITE.socials);
---

<footer class="border-t border-hairline px-5 py-8 text-sm">
  <div class="mx-auto flex max-w-5xl flex-wrap items-start justify-between gap-8">
    <div class="space-y-1">
      <p class="text-peak">{SITE.person} — {SITE.persona}</p>
      <p class="hud-label">{SITE.location}</p>
      <p>
        <a href={`mailto:${SITE.email}`} class="text-ink-muted hover:text-accent">{SITE.email}</a>
      </p>
      <p class="pt-2">
        <a href={`${base}/privacy`} class="hud-label hover:text-accent">Privacy</a>
      </p>
      <!-- P30 — quiet persistent way back into the /world experience: a
           delight-invite in the footer's hud grammar, deliberately NOT a nav
           item (it never competes with the money lanes). -->
      <p>
        <a href={`${base}/world`} class="hud-label world-invite hover:text-accent">✦ Fly the world</a>
      </p>
    </div>
    <nav aria-label="Footer">
      <ul class="space-y-1.5">
        {
          NAV.map((item) => (
            <li>
              <a href={`${base}${item.href}`} class="text-ink-muted hover:text-accent">
                {item.label}
                {/* P29 buyer-language pairing (NAV.buyer) — em-dash pairing */}
                {item.buyer && <span class="footer-buyer"> — {item.buyer}</span>}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <ul class="space-y-1.5">
      {
        socialEntries.map(([platform, url]) => (
          <li>
            {url === "[confirm]" ? (
              <span aria-disabled="true" class="hud-label opacity-60">
                {platform} [confirm]
              </span>
            ) : (
              <a href={url} class="text-ink-muted capitalize hover:text-accent" rel="me noopener">
                {platform}
              </a>
            )}
          </li>
        ))
      }
    </ul>
  </div>
  <!-- P29 — sitewide trust row (SITE.trust — P30 copy rules in consts.ts) +
       the direct booking link, so every page terminates on a call-to-action
       with the logistics answered beside it. -->
  <div class="footer-trust mx-auto mt-8 flex max-w-5xl flex-wrap items-center justify-between gap-4 border-t border-hairline pt-5">
    <ul class="footer-trust-list">
      <li>{SITE.trust.drone}</li>
      <li>{SITE.trust.response}</li>
      <li>{SITE.trust.base}</li>
      <li>{SITE.trust.travel}</li>
    </ul>
    <a href={SITE.bookACall} class="btn" rel="noopener">Book a call</a>
  </div>
</footer>

<style>
  /* P30 — the world invite glints softly toward the accent; an easter-egg
     whisper, not a button. */
  .world-invite {
    color: color-mix(in srgb, var(--color-accent, #5eead4) 55%, currentColor);
  }
  .footer-buyer {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: color-mix(in srgb, currentColor 62%, transparent);
  }
  .footer-trust-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0;
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted, #8a9a96);
  }
  .footer-trust-list li + li::before {
    content: "·";
    margin-inline: 0.6rem;
    color: color-mix(in srgb, currentColor 55%, transparent);
  }
</style>
