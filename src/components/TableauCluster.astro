---
/**
 * TableauCluster (R5) — the "wild" chapter reimagined as a CLUSTER OF SMALLER
 * FLOATING SHOTS instead of one full-bleed layered scene. 4–6 bright stills +
 * one live loop drift at different parallax rates around/behind the headline as
 * you scroll (the KPR "things moving and popping around you" feel). Scrims are
 * cut way down — the imagery is bright and visible; text legibility comes from
 * a small local backdrop behind the copy column, not from blacking out photos.
 *
 * Motion is driven by the SAME GSAP/ScrollTrigger + Lenis engine as the other
 * tableaux (Tableaux.astro initCluster) — no new library. Each [data-float]
 * carries a data-rate (parallax amplitude, % of viewport) so far shots drift
 * slower than near ones. Text never parallaxes (DIRECTION §1.2).
 *
 * Fallbacks: reduced motion / no-JS / mobile → the shots render in their final
 * composed positions (static), bright and visible; only the drift is dropped.
 * The live loop mounts lazily on wide viewports only (P5), poster-first.
 */
import LegendMark from "./LegendMark.astro";
import type { TableauChapter as TChapter } from "../consts";

interface Props {
  chapter: TChapter;
  index: number;
  base: string;
  nodeId?: string;
  /** Which shots exist on disk (build-time checked in Tableaux.astro). Each
   *  carries `ar` — the image's TRUE `W / H` ratio read at build time (P12.6) —
   *  so the card takes the photo's native aspect instead of a hardcoded box,
   *  and object-fit:cover no longer crops (the ratios now match). */
  shots: {
    peak?: { avif: string; webp: string; ar?: string };
    valley?: { avif: string; webp: string; ar?: string };
    lake?: { avif: string; webp: string; ar?: string };
    ridge?: { avif: string; webp: string; ar?: string };
    loop?: { mp4: string; poster: string; ar?: string };
  };
  /** Ambient drift amplitude for this cluster's floats (R3.5 wire-up map:
   *  wild 1.0, market/industry 0.9). */
  driftAmp?: number;
}
const { chapter, index, base, nodeId, shots, driftAmp = 1.0 } = Astro.props;
// P3 — three-digit editorial chapter index (001/002/003); presentational only.
const no = String(index + 1).padStart(3, "0");
const ampAttr = String(driftAmp);
// P3 — per-chapter accent tint (see TableauChapter.astro for the rationale).
const tintDeg = [0, 14, -18][index] ?? 0;
---

<article
  class="cluster"
  data-tableau
  data-cluster
  data-chapter={chapter.terrain}
  data-trail-node={nodeId}
  style={`--chapter-tint:${tintDeg}deg`}
>
  <div class="cluster-stage" data-cluster-stage>
    <!-- Floating shots. Positions/sizes are set in CSS by slot; each drifts at
         its own data-rate. Order back→front so nearer shots sit above. -->
    {
      shots.valley && (
        <figure
          class="float float--valley"
          data-float
          data-rate="6"
          data-drift
          data-drift-amp={ampAttr}
          style={shots.valley.ar ? `--ar:${shots.valley.ar}` : undefined}
        >
          <picture>
            <source srcset={shots.valley.avif} type="image/avif" />
            <img src={shots.valley.webp} alt="" loading="lazy" decoding="async" />
          </picture>
        </figure>
      )
    }
    {
      shots.loop ? (
        <figure
          class="float float--loop"
          data-float
          data-rate="9"
          data-drift
          data-drift-amp={ampAttr}
          style={shots.loop.ar ? `--ar:${shots.loop.ar}` : undefined}
        >
          <video
            class="float-loop"
            data-cluster-loop-video
            data-src={shots.loop.mp4}
            muted
            loop
            playsinline
            preload="none"
            poster={shots.loop.poster}
            width="800"
            height="540"
            aria-hidden="true"
          />
        </figure>
      ) : (
        shots.lake && (
          <figure
            class="float float--loop"
            data-float
            data-rate="9"
            data-drift
            data-drift-amp={ampAttr}
            style={shots.lake.ar ? `--ar:${shots.lake.ar}` : undefined}
          >
            <picture>
              <source srcset={shots.lake.avif} type="image/avif" />
              <img src={shots.lake.webp} alt="" loading="lazy" decoding="async" />
            </picture>
          </figure>
        )
      )
    }
    {
      shots.peak && (
        <figure
          class="float float--peak"
          data-float
          data-rate="13"
          data-drift
          data-drift-amp={ampAttr}
          style={shots.peak.ar ? `--ar:${shots.peak.ar}` : undefined}
        >
          <picture>
            <source srcset={shots.peak.avif} type="image/avif" />
            <img src={shots.peak.webp} alt="" loading="lazy" decoding="async" />
          </picture>
        </figure>
      )
    }
    {
      shots.ridge && (
        <figure
          class="float float--ridge"
          data-float
          data-rate="16"
          data-drift
          data-drift-amp={ampAttr}
          style={shots.ridge.ar ? `--ar:${shots.ridge.ar}` : undefined}
        >
          <picture>
            <source srcset={shots.ridge.avif} type="image/avif" />
            <img src={shots.ridge.webp} alt="" loading="lazy" decoding="async" />
          </picture>
        </figure>
      )
    }
    {
      /* the lake as a small extra near-shot when the loop occupies its slot */
      shots.loop && shots.lake && (
        <figure
          class="float float--lake"
          data-float
          data-rate="19"
          data-drift
          data-drift-amp={ampAttr}
          style={shots.lake.ar ? `--ar:${shots.lake.ar}` : undefined}
        >
          <picture>
            <source srcset={shots.lake.avif} type="image/avif" />
            <img src={shots.lake.webp} alt="" loading="lazy" decoding="async" />
          </picture>
        </figure>
      )
    }

    <!-- Copy column — never parallaxes; sits on a small local backdrop for
         legibility (not a full-frame scrim). -->
    <div class="cluster-content tableau-content" data-tableau-content>
      {/* P3 — numbered editorial slate (same grammar as TableauChapter): mono
          index + hairline rule + terrain label as a DECODE target. */}
      <p class="chapter-slate hud-label">
        <span class="chapter-index">{no}</span>
        <span class="chapter-rule" aria-hidden="true"></span>
        <span class="chapter-label" data-decode>{chapter.terrain}</span>
      </p>
      <h2 class="cluster-headline tableau-headline" data-tableau-headline>{chapter.headline}</h2>
      <div class="tableau-reveal">
        <p class="mx-auto max-w-md text-lg text-ink">{chapter.body}</p>
        <LegendMark proof={chapter.proof} class="justify-center" />
        <a href={`${base}${chapter.link.href}`} class="btn">{chapter.link.label}</a>
      </div>
    </div>
  </div>
</article>
