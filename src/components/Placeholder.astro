---
/**
 * Dimensioned, intent-annotated media slot — v1 KEEP pattern. Now framed as a
 * design-system `.map-inset` so greybox pages preview the real media
 * treatment (peak hairline, elevated ground, mono caption) while remaining
 * unmistakably a placeholder (dashed inner rule). Replaced slot-for-slot by
 * real media in Phase 6 (BUILD-PLAN.md §7.1).
 */
interface Props {
  ratio?: string;
  label: string;
  class?: string;
}
const { ratio = "16/10", label, class: klass = "" } = Astro.props;
---

<figure class={`map-inset ${klass}`}>
  <div
    class="grid place-items-center border border-dashed border-current/25 topo-lines"
    style={`aspect-ratio:${ratio}`}
  >
    <span class="hud-label max-w-prose px-4 py-3 text-center normal-case">{label}</span>
  </div>
  <figcaption class="sr-only">{label}</figcaption>
</figure>
