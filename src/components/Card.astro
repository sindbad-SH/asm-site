---
/**
 * Card — the uniform container (§3 component library; Clay Boan "rigid
 * container" model, research-brief §7 KEEP): one shape holds every arena's
 * work so wildly different content reads as one system. Every slot below is
 * optional — the container never changes shape, only what fills it.
 */
import Placeholder from "./Placeholder.astro";
import LegendMark from "./LegendMark.astro";
import type { ProofLine } from "../consts";

/** Responsive media set for a card — MEDIA-GUIDE Worked Example 2 Step 3.
 *  `avif`/`webp` are full srcset strings (800/1400/2200w); `src` is the default
 *  (800w webp) fallback. When supplied, a real <picture> replaces the
 *  placeholder; absent → the placeholder path is unchanged. */
export interface CardMedia {
  avif: string;
  webp: string;
  src: string;
}

interface Props {
  href?: string;
  mediaRatio?: string;
  mediaLabel?: string;
  /** Real responsive media — renders instead of the placeholder when present. */
  mediaSrc?: CardMedia;
  /** Alt text for real media (decorative fallback if omitted). */
  mediaAlt?: string;
  eyebrow?: string;
  title: string;
  meta?: string;
  proof?: ProofLine;
  ctaLabel?: string;
  class?: string;
  /** Rendered as data-pillar — a hook for JS filtering (e.g. /work's lane filters). */
  pillar?: string;
  /** Field note (R3.4) — a first-person location story rendered as a collapsible
   *  block after card-meta, OUTSIDE .map-inset (hover warp untouched). */
  fieldNote?: string;
  /** Ships the field note expanded (Matterhorn). Others collapsed. */
  fieldNoteOpen?: boolean;
  /** Opt the card into the reveal engine (R3.9/R3.10 cascades) — sets
   *  [data-reveal] + optional per-element stagger on the card root. */
  reveal?: boolean;
  revealStagger?: number;
}
const {
  href,
  mediaRatio = "4/5",
  mediaLabel,
  mediaSrc,
  mediaAlt = "",
  eyebrow,
  title,
  meta,
  proof,
  ctaLabel,
  class: klass = "",
  pillar,
  fieldNote,
  fieldNoteOpen = false,
  reveal = false,
  revealStagger,
} = Astro.props;

const Tag = href ? "a" : "div";
// Responsive sizes: 2-col on phones, 3-col on the adventure grid, ≤2-col on the
// work grid — the 800w select is the render target in every case (§4 budget).
const sizes = "(min-width: 1024px) 30vw, (min-width: 640px) 45vw, 50vw";
---

<Tag
  href={href}
  class={`card ${klass}`}
  data-pillar={pillar}
  data-reveal={reveal ? "" : undefined}
  data-reveal-stagger={reveal && revealStagger ? String(revealStagger) : undefined}
>
  {
    mediaSrc ? (
      <figure class="map-inset" style={`overflow:clip`}>
        <picture>
          <source type="image/avif" srcset={mediaSrc.avif} sizes={sizes} />
          <source type="image/webp" srcset={mediaSrc.webp} sizes={sizes} />
          <img
            src={mediaSrc.src}
            alt={mediaAlt}
            class="block w-full"
            style={`aspect-ratio:${mediaRatio};object-fit:cover`}
            loading="lazy"
            decoding="async"
          />
        </picture>
      </figure>
    ) : (
      mediaLabel && <Placeholder ratio={mediaRatio} label={mediaLabel} />
    )
  }
  {eyebrow && <p class="card-eyebrow">{eyebrow}</p>}
  <h3 class="card-title">{title}</h3>
  {meta && <p class="card-meta">{meta}</p>}
  {/* Field note (R3.4) — collapsible; Matterhorn ships open. Sits OUTSIDE
      .map-inset so the gallery hover warp is unaffected. No-JS: open. */}
  {fieldNote && (
    <div class={`field-note ${fieldNoteOpen ? "is-open" : ""}`} data-field-note>
      <button type="button" class="field-note-toggle" aria-expanded={fieldNoteOpen ? "true" : "false"}>
        <span class="hud-label">Field note</span>
        <span class="fn-glyph" aria-hidden="true">+</span>
      </button>
      <div class="field-note-body">
        <div><p>{fieldNote}</p></div>
      </div>
    </div>
  )}
  {/* showName=false: the card's own title already names the org — the
      proof line here only needs to state the status. */}
  {proof && <LegendMark proof={proof} showName={false} class="text-sm" />}
  {ctaLabel && (
    <span class="link mt-1">
      {ctaLabel} <span class="arrow" aria-hidden="true">→</span>
    </span>
  )}
</Tag>
