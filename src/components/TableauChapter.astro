---
/**
 * One tableau chapter (§2b). Structure is uniform across all three chapters
 * so the engine in Tableaux.astro drives them identically — the whole point
 * of "engine + exemplar": replicating a chapter means supplying a `layers`
 * set, nothing more.
 *
 *   layers present → full parallax chapter (the wild exemplar)
 *   layers absent  → a clearly-marked REPLICATION STUB (copy still renders so
 *                    the page stays coherent; only the parallax art is missing)
 */
import LegendMark from "./LegendMark.astro";
import type { TableauChapter as TChapter } from "../consts";

export interface TableauLayer {
  depth: number; // 0 (far, slow) .. 1 (near, fast)
  label: string; // annotated shot-list slot — what art belongs here
}

/** A layer's real art, once dropped in — see MEDIA-GUIDE.md "Home tableaux". */
export interface TableauImage {
  avif: string;
  webp: string;
}

interface Props {
  chapter: TChapter;
  index: number;
  layers?: readonly TableauLayer[];
  /** Parallel to `layers` by index; `null`/missing entries keep that layer's
   * placeholder — MEDIA-GUIDE self-service: drop the files in, no code edit. */
  images?: readonly (TableauImage | null)[];
  base: string;
  /** Pillar slug — the survey-trail anchor for this chapter's portal node. */
  nodeId?: string;
}
const { chapter, index, layers, images, base, nodeId } = Astro.props;
const isStub = !layers || layers.length === 0;
// P3 — three-digit editorial chapter index (001/002/003). Presentational only
// (a numeral, not a copy claim), so it's composed here rather than in consts.ts.
const no = String(index + 1).padStart(3, "0");
// P3 — per-chapter accent tint. A hue rotation off the base --color-accent,
// keyed to the chapter index so each terrain reads with its own faint temper
// without inventing new palette tokens. Applied only where the markup already
// carries an accent (the slate rule + index), never to body copy.
const tintDeg = [0, 14, -18][index] ?? 0;
---

<article
  class="tableau"
  data-tableau
  data-chapter={chapter.terrain}
  data-trail-node={nodeId}
  style={`--chapter-tint:${tintDeg}deg`}
>
  <div class="tableau-pin">
    {
      isStub ? (
        <div class="tableau-layer" data-depth="0.5">
          <div class="tableau-ph tableau-ph--stub">
            <span class="hud-label normal-case">
              REPLICATION STUB — “{chapter.terrain}”. Replicate the wild chapter: add a 3-layer set
              for this chapter to LAYER_SETS in Tableaux.astro (background → midground → foreground
              cut-out). The engine and copy already work; only the parallax art is missing.
            </span>
          </div>
        </div>
      ) : (
        layers.map((layer, i) => (
          <div class="tableau-layer" data-depth={layer.depth} data-layer={i}>
            {images?.[i] ? (
              <picture>
                <source srcset={images[i]!.avif} type="image/avif" />
                <img
                  class="tableau-img"
                  src={images[i]!.webp}
                  alt=""
                  loading={i === 0 && index === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
              </picture>
            ) : (
              <div class="tableau-ph">
                <span class="hud-label normal-case">{layer.label}</span>
              </div>
            )}
          </div>
        ))
      )
    }

    <div class="tableau-content" data-tableau-content>
      {/* P3 — numbered editorial slate: mono chapter index + hairline rule +
          the terrain label as a DECODE target. The index is a presentational
          numeral; the label copy is chapter.terrain verbatim from consts. The
          rule + index carry the per-chapter accent tint. */}
      <p class="chapter-slate hud-label">
        <span class="chapter-index">{no}</span>
        <span class="chapter-rule" aria-hidden="true"></span>
        <span class="chapter-label" data-decode>{chapter.terrain}</span>
      </p>
      <h2 class="tableau-headline" data-tableau-headline>{chapter.headline}</h2>
      <div class="tableau-reveal">
        <p class="mx-auto max-w-xl text-lg text-ink">{chapter.body}</p>
        <LegendMark proof={chapter.proof} class="justify-center" />
        <a href={`${base}${chapter.link.href}`} class="btn tableau-cta">
          <span>{chapter.link.label}</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</article>

<style>
  /* Chapter CTA — the shared prominent-button grammar layered onto the global
     .btn base: keeps the 1px border / Space Mono caps / accent hover / glow, and
     adds a 6px arrow slide + a guaranteed ≥44px tap target. */
  .tableau-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0.7rem 1.2rem;
  }
  .tableau-cta .arrow {
    display: inline-block;
    transition: transform var(--dur-hover, 160ms) var(--ease-swift);
  }
  .tableau-cta:hover .arrow,
  .tableau-cta:focus-visible .arrow {
    transform: translateX(6px);
  }
  @media (prefers-reduced-motion: reduce) {
    .tableau-cta .arrow {
      transition: none;
    }
  }
</style>
