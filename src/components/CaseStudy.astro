---
/**
 * CaseStudy — the Immersive-Garden walkthrough template (BUILD-PLAN.md §2c).
 * The quality bar for every future case: full-bleed hook → sticky survey
 * chapter rail → reasoning-first chapters (the strategy behind each piece,
 * Noguier model) → honest outcome (never an invented metric) → testimonial →
 * a single CTA. Data-driven from CaseStudyData, so a future case is data + a
 * three-line page.
 *
 * Reads as a plain no-JS document first: semantic <article>, chapters in
 * order, rail is jump-links, media degrades to posters. The rail scroll-spy,
 * hook video, BTS scrub, and reveals are all progressive enhancement.
 */
import type { CaseStudyData } from "../consts";
import HeroVideo, { type VideoSource } from "./HeroVideo.astro";
import LegendMark from "./LegendMark.astro";
import Testimonial from "./Testimonial.astro";
import ScrubSequence from "./ScrubSequence.astro";
import YouTubeEmbed from "./YouTubeEmbed.astro";
import Placeholder from "./Placeholder.astro";

interface Props {
  study: CaseStudyData;
  base: string;
  /** Real video id for the commercial once supplied (S3); [confirm] until then. */
  commercialVideoId?: string;
  /** Full-film YouTube embed id (Shelby case §2.6). Optional — rendered as a
   *  second embed under the commercial slot when supplied. */
  fullFilmVideoId?: string;
  /** Hook media (MEDIA-GUIDE §4). A poster still alone, or a poster + ambient
   *  loop sources; absent → the annotated placeholder poster is kept. */
  hookPoster?: string;
  hookSources?: readonly VideoSource[];
  /** Optional client logo rendered beside the case hook (R3.2c). Only supplied
   *  when a real logo asset exists on disk (PARTNER-LOGO RULE, consts.ts). */
  hookLogo?: string;
  /** Alt text for hookLogo (the client name). */
  hookLogoAlt?: string;
  /** Context still (MEDIA-GUIDE §5) — swaps the CONTEXT STILL placeholder for a
   *  real <img> when supplied; absent → placeholder kept. */
  contextImage?: string;
  /** BTS scrub sequence (§2.7 / DIRECTION §2c). Rendered ONLY when count > 0 —
   *  an optional-media section that renders nothing (not a placeholder box)
   *  when absent. */
  btsFramesBase?: string;
  btsCount?: number;
  btsPoster?: string;
  /** Real-photo gallery (P13f). An optional mixed-aspect still set rendered in
   *  "The Work" chapter — supplied only when real exports exist on disk. Each
   *  entry is a semantic slug + alt; the component builds the avif/webp srcset
   *  from photosBase. Absent → nothing renders (same optional-media contract as
   *  the BTS scrub). */
  photos?: readonly { slug: string; alt: string }[];
  photosBase?: string;
}
const {
  study,
  base,
  commercialVideoId,
  fullFilmVideoId,
  hookPoster,
  hookSources = [],
  hookLogo,
  hookLogoAlt = "",
  contextImage,
  btsFramesBase,
  btsCount = 0,
  btsPoster,
  photos = [],
  photosBase,
} = Astro.props;

// The "Words" chapter only exists when the case supplies a testimonialId — a
// RESERVED testimonial (Shelby / Jack Bell, COPY.md §2.2) omits it, so the rail
// must not carry a dead jump-link to a section that isn't rendered.
const rail = [
  { id: "context", label: "Context" },
  { id: "ask", label: "The Ask" },
  { id: "work", label: "The Work" },
  { id: "outcome", label: "Outcome" },
  ...(study.testimonialId ? [{ id: "words", label: "Words" }] : []),
];

// An honest-outcome slot still awaiting Sindbad's real content renders as a
// visible pending marker, never as fabricated copy. Keeps the literal
// "[confirm]" in the output so the audit gate still catches it.
const isPending = (body: string) => body.trim() === "[confirm]";
---

<article class="case">
  <!-- Hook — full-bleed (§2c). The case's h1 lives here. Real poster/loop when
       supplied; absent → the annotated placeholder poster (unchanged). -->
  <HeroVideo
    poster={hookPoster}
    sources={hookSources}
    placeholderLabel="HOOK MEDIA (§2c) — PitchBoulder commercial still or a short ambient loop (S3). Poster ships first."
  >
    {hookLogo && <img src={hookLogo} alt={hookLogoAlt} class="case-hook-logo" loading="eager" decoding="async" />}
    <h1 class="text-4xl font-bold sm:text-6xl">{study.hook}</h1>
  </HeroVideo>

  <!-- Sticky survey chapter rail (desktop; jump-links without JS) -->
  <nav class="case-rail" aria-label="Chapters">
    <ol>
      {
        rail.map((item, i) => (
          <li>
            <a href={`#${item.id}`} data-rail-link={item.id}>
              <span class="tick" aria-hidden="true" />
              <span class="no">{String(i + 1).padStart(2, "0")}</span>
              <span class="label">{item.label}</span>
            </a>
          </li>
        ))
      }
    </ol>
  </nav>

  <!-- 01 · Context -->
  <section id="context" class="case-chapter" data-chapter>
    <div class="case-chapter__inner space-y-4">
      <p class="hud-label">01 · Context</p>
      <h2 class="text-2xl font-bold" data-reveal>{study.context.heading}</h2>
      {
        isPending(study.context.body) ? (
          <p class="case-pending">[confirm] — who PitchBoulder is, in Sindbad's words (S3)</p>
        ) : (
          <p class="text-lg text-ink" data-reveal>{study.context.body}</p>
        )
      }
      {
        contextImage ? (
          <figure class="map-inset mt-4">
            <img
              src={contextImage}
              alt=""
              class="block w-full"
              style="aspect-ratio:16/9;object-fit:cover"
              width="1600"
              height="900"
              loading="lazy"
              decoding="async"
            />
          </figure>
        ) : (
          <Placeholder ratio="16/9" class="mt-4" label="CONTEXT STILL — a PitchBoulder event frame (S3)" />
        )
      }
    </div>
  </section>

  <!-- 02 · The Ask -->
  <section id="ask" class="case-chapter" data-chapter>
    <div class="case-chapter__inner space-y-4">
      <p class="hud-label">02 · The Ask</p>
      <h2 class="text-2xl font-bold" data-reveal>{study.ask.heading}</h2>
      {
        isPending(study.ask.body) ? (
          <p class="case-pending">[confirm] — what they needed, in Sindbad's words (S3)</p>
        ) : (
          <p class="text-lg text-ink" data-reveal>{study.ask.body}</p>
        )
      }
    </div>
  </section>

  <!-- 03 · The Work — the rich chapter: BTS scrub + commercial + proof -->
  <section id="work" class="case-chapter" data-chapter>
    <div class="case-chapter__inner space-y-6">
      <p class="hud-label">03 · The Work</p>
      <h2 class="text-2xl font-bold" data-reveal>{study.work.heading}</h2>
      <p class="text-lg text-ink" data-reveal>{study.work.body}</p>
      <LegendMark proof={study.work.proof} />
    </div>

    <!-- BTS scroll-scrub moment (§2c). OPTIONAL-media (DIRECTION §2.7): rendered
         ONLY when a real count > 0 is supplied — otherwise nothing renders (no
         dashed placeholder box on this money surface). Hard cap: one scrub per
         page (§1.1 P4). -->
    {
      btsCount > 0 && btsFramesBase && (
        <ScrubSequence
          framesBase={btsFramesBase}
          frameExt="webp"
          count={btsCount}
          poster={btsPoster}
          placeholderLabel="BTS SCRUB (§2c/§4) — behind-the-scenes of the commercial as a scroll-scrubbed sequence."
        />
      )
    }

    {/* Real-photo gallery (P13f) — mixed-aspect masonry (.gallery-wall), each
        still in a peak-hairline .map-inset frame (site photography voice, §3.1).
        Native aspects, lazy, no claim copy. Renders only when photos supplied. */}
    {
      photos.length > 0 && photosBase && (
        <div class="case-chapter__inner space-y-3">
          <p class="hud-label">The stills</p>
          <div class="gallery-wall">
            {photos.map((p) => (
              <figure class="map-inset gallery-card">
                <picture>
                  <source
                    type="image/avif"
                    srcset={`${photosBase}${p.slug}-900.avif 900w, ${photosBase}${p.slug}-1600.avif 1600w`}
                    sizes="(min-width: 768px) 33vw, 50vw"
                  />
                  <source
                    type="image/webp"
                    srcset={`${photosBase}${p.slug}-900.webp 900w, ${photosBase}${p.slug}-1600.webp 1600w`}
                    sizes="(min-width: 768px) 33vw, 50vw"
                  />
                  <img
                    src={`${photosBase}${p.slug}-1600.webp`}
                    alt={p.alt}
                    class="block w-full"
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
              </figure>
            ))}
          </div>
        </div>
      )
    }

    {
      (commercialVideoId || !fullFilmVideoId) && (
        <div class="case-chapter__inner space-y-3">
          <p class="hud-label">The commercial</p>
          <YouTubeEmbed
            videoId={commercialVideoId}
            title="The commercial"
            placeholderLabel="COMMERCIAL — YouTube embed, click-to-load facade (S3). Supply the video id; full video is never self-hosted (§4)."
          />
        </div>
      )
    }

    {
      fullFilmVideoId && (
        <div class="case-chapter__inner space-y-3">
          <p class="hud-label">The film</p>
          <YouTubeEmbed
            videoId={fullFilmVideoId}
            title="The film"
            placeholderLabel="FILM — YouTube embed, click-to-load facade (§4)."
          />
        </div>
      )
    }
  </section>

  <!-- 04 · Outcome — honest, never an invented metric -->
  <section id="outcome" class="case-chapter" data-chapter>
    <div class="case-chapter__inner space-y-4">
      <p class="hud-label">04 · Outcome</p>
      <h2 class="text-2xl font-bold" data-reveal>{study.outcome.heading}</h2>
      {
        isPending(study.outcome.body) ? (
          <p class="case-pending">
            [confirm] — a plain honest statement or one real metric, never invented (S3)
          </p>
        ) : (
          <p class="text-lg text-ink" data-reveal>{study.outcome.body}</p>
        )
      }
    </div>
  </section>

  <!-- 05 · Words — the testimonial. Rendered only when the case supplies a
       testimonialId; a RESERVED testimonial (e.g. Shelby / Jack Bell, COPY.md
       §2.2) omits the field and the whole chapter, asserting nothing. -->
  {
    study.testimonialId && (
      <section id="words" class="case-chapter" data-chapter>
        <div class="case-chapter__inner">
          <p class="hud-label mb-4">05 · Words</p>
          <Testimonial testimonialId={study.testimonialId} class="panel p-6" />
        </div>
      </section>
    )
  }

  <!-- Single CTA -->
  <section class="case-chapter">
    <div class="case-chapter__inner space-y-4 text-center">
      <a href={`${base}${study.cta.href}`} class="btn case-cta">
        <span>{study.cta.label}</span>
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</article>

<style>
  /* Case CTA — the shared prominent-button grammar on the global .btn base: keeps
     the border / mono caps / accent hover / glow, adds the 6px arrow slide and a
     guaranteed ≥44px tap target, consistent with the work-wall + tableaux CTAs. */
  .case-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0.7rem 1.3rem;
  }
  .case-cta .arrow {
    display: inline-block;
    transition: transform var(--dur-hover, 160ms) var(--ease-swift);
  }
  .case-cta:hover .arrow,
  .case-cta:focus-visible .arrow {
    transform: translateX(6px);
  }
  @media (prefers-reduced-motion: reduce) {
    .case-cta .arrow {
      transition: none;
    }
  }
</style>

<script>
  // Rail scroll-spy — light the chapter crossing the viewport's middle band.
  // Pure enhancement: without JS the rail links still jump to each chapter.
  const links = new Map<string, HTMLElement>();
  document.querySelectorAll<HTMLElement>("[data-rail-link]").forEach((a) => {
    const id = a.dataset.railLink;
    if (id) links.set(id, a);
  });
  const chapters = document.querySelectorAll<HTMLElement>("[data-chapter]");
  if (links.size && chapters.length && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            links.forEach((a) => a.classList.remove("is-active"));
            links.get(e.target.id)?.classList.add("is-active");
          }
        }
      },
      { rootMargin: "-45% 0px -45% 0px", threshold: 0 },
    );
    chapters.forEach((s) => io.observe(s));
  }
</script>
