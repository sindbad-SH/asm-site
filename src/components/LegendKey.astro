---
/**
 * The visible legend key (BUILD-PLAN.md §3.4), styled as an actual map
 * legend: elevated panel, hairline border, surveyor's mono voice. Appears
 * wherever tier symbols are plotted (Home H4, /entertainment, /work) so the
 * notation is always decodable — the honesty system made publicly legible.
 */
import { LEGEND } from "../consts";

const tiers = Object.values(LEGEND);
---

<div class="legend-key">
  <p class="legend-title">Legend</p>
  <ul class="mt-2 space-y-1.5 text-sm">
    {
      tiers.map((tier) => (
        <li class="flex items-center gap-2.5">
          <span aria-hidden="true" class="grid w-5 place-items-center font-mono text-accent-deep">
            {tier.symbol}
          </span>
          <span class="text-ink-muted">{tier.label}</span>
        </li>
      ))
    }
  </ul>
</div>
