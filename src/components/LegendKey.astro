---
/**
 * The visible legend key (BUILD-PLAN.md §3.4), styled as an actual map
 * legend: elevated panel, hairline border, surveyor's mono voice.
 *
 * P23 (2026-07-12) — RETIRED FROM RENDER site-wide. The operator no longer
 * wants the tier decoder advertised; each proof line now states its true
 * status in words (LegendMark) without a symbol/key. This component is left
 * intact and unused so the decision is fully reversible — re-import it to
 * restore the key. It formerly rendered on Home H4, /about, and /entertainment.
 */
import { LEGEND } from "../consts";

const tiers = Object.values(LEGEND);
---

<div class="legend-key">
  <p class="legend-title">Legend</p>
  <ul class="mt-2 space-y-1.5 text-sm">
    {
      tiers.map((tier) => (
        <li class="flex items-center gap-2.5">
          <span aria-hidden="true" class="grid w-5 place-items-center font-mono text-accent-deep">
            {tier.symbol}
          </span>
          <span class="text-ink-muted">{tier.label}</span>
        </li>
      ))
    }
  </ul>
</div>
