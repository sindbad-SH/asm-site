---
/**
 * The map-legend honesty device (BUILD-PLAN.md §3.4) — the ONLY channel
 * through which a relationship's status may be stated. Resolves a ProofLine
 * and prints `permittedPhrasing` VERBATIM after the relationship's name.
 *
 * P23 (2026-07-12) — the VISIBLE tier symbol (●/○/◆/△) is retired site-wide:
 * the operator wants each line to state its true status in WORDS without
 * advertising which tier it is. The tier is still resolved (kept for the
 * sr-only label + future reversibility) but the marker glyph no longer
 * renders. The phrasing text is UNCHANGED and still verbatim. Component API
 * is unchanged so no call site breaks. Never paraphrase this output; change
 * `context` in consts.ts if framing must vary.
 */
import { LEGEND, RELATIONSHIP_BY_ID, type ProofLine } from "../consts";

interface Props {
  proof: ProofLine;
  /** Hide the org name when surrounding copy already names it (e.g. a heading). */
  showName?: boolean;
  class?: string;
}
const { proof, showName = true, class: klass = "" } = Astro.props;
const relationship = RELATIONSHIP_BY_ID[proof.relationshipId];

if (!relationship) {
  throw new Error(`LegendMark: unknown relationshipId "${proof.relationshipId}"`);
}

const tier = LEGEND[relationship.tier];
// Avoid "MEME — Board Chair, MEME (…)" duplication when phrasing starts with the name.
const nameShown = showName && !relationship.permittedPhrasing.startsWith(relationship.name);
---

<p class={`legend-mark ${klass}`}>
  <span>
    <span class="sr-only">{tier.label}: </span>
    {proof.context && <span class="phrasing">{proof.context} </span>}
    {nameShown && <span class="name">{relationship.name}</span>}
    {nameShown && <span class="phrasing"> · </span>}
    <span class="phrasing">{relationship.permittedPhrasing}</span>
  </span>
</p>
