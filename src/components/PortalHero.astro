---
/**
 * The Portal Hero (BUILD-PLAN.md §9.2) — the home page's signature, built
 * from the brand logo-sting reference: the mark alone on a void → the mark
 * becomes a WINDOW as an aurora-lit mountain night rises through it → full
 * scene → (on scroll-out) the mark re-forms. A→B→A, bookended, exactly the
 * sting's structure. Content (kicker/h1/subline/CTA) goes in the slot and
 * holds still throughout ("one thing moves at a time" — the sting brief).
 *
 * Layer stack (bottom→top):
 *   1. .portal-scene   — the beauty-shot still (frame-grabbed from the
 *                        horizontal sting → AVIF 26KB + WebP fallback)
 *   2. .portal-void    — the --hero-void curtain; its DISSOLVE does the true
 *                        full reveal (the mark's interior is partially
 *                        transparent, so a pure mask-zoom could never fully
 *                        clear the viewport — same reason the sting itself is
 *                        dissolve-driven, "no hard cuts")
 *   3. .portal-window  — RETIRED from the intro at P1.5 (kept in markup at
 *                        opacity:0): revealing the scene through the mark's
 *                        own mountain silhouette read as shape flip-flops.
 *                        The intro is now one continuous cross-dissolve —
 *                        mark bloom + void thinning, no masked pass.
 *   4. .portal-mark    — the solid mark (state A / ghost re-form)
 *   5. scrim + content
 *
 * One proxy p (0 = closed/state A, 1 = open/endcard) drives render(p):
 * intro tween runs 0→1 on load (0.8s hold + dissolve-through); a scrubbed
 * ScrollTrigger runs 1→0 as the hero exits — the bookend handoff into the
 * tableaux (replacing the globe's old handoff).
 *
 * States & fallbacks:
 *   - no-JS default        → ENDCARD (scene + solid mark ghost + headline)
 *   - html.js              → state A (void + solid mark); intro plays when
 *                            the chunk lands
 *   - reduced motion       → CSS forces the endcard back; script bails
 *   - chunk-load failure   → 4s inline watchdog forces .portal-forced endcard
 *   - ?portal=static       → endcard, no animation (QA)
 *   - ?portal=nogl         → skip the WebGL tier, DOM ladder only (QA)
 *
 * P1 (V1-UPGRADE-PLAN): the scene's top tier is now a WebGL 2.5D world
 * (src/lib/portal-scene-3d.ts) — the still/video depth-displaced by
 * media/home/portal-depth.png, GPU stars + foreground motes + drifting haze,
 * camera swaying at idle and answering the cursor. It mounts at idle inside
 * .portal-world (so render(p)'s transform still owns settle/recede) and
 * fades in via .portal-gl-live; the DOM video keeps playing UNDERNEATH as
 * the scene's texture source. Every refusal path lands on the pre-P1 DOM
 * ladder unchanged.
 * Debug: window.__PORTAL { p(), set(p) } — set() drives render directly
 * (harness tabs pause rAF; render is deterministic).
 *
 * HONESTY NOTE (§9.2): the scene is BRAND ART — the logo's world, from the
 * AI-generated sting. It lives here as brand identity and must never appear
 * in Work/Adventure gallery contexts where it could read as shot footage.
 *
 * The 9:16 sting mp4 (1.26MB) remains available as a mobile poster-first
 * alternative (§9.2 "decide at build by feel") — not used at launch: the
 * live composite is one code path and works at every aspect.
 */
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// P1.4 — CACHE-BUSTED media URLs. public/ assets keep their filenames across
// re-exports, so a returning browser can hold the OLD poster while the GL
// tier shows the NEW one — during the intro the two copies alternate through
// the mask/void layers and the scene visibly "changes mountains" mid-reveal
// (Sindbad's round-4 report). Versioning by file mtime makes every layer pull
// the same, current bytes; the suffix changes automatically whenever
// scripts/make-portal-loop.mjs re-exports. cwd-anchored like all build-time
// media checks (see Tableaux.astro).
import { statSync } from "node:fs";
import { join } from "node:path";
const homeMedia = join(process.cwd(), "public", "media", "home");
const v = (file: string) => {
  try {
    return `?v=${Math.round(statSync(join(homeMedia, file)).mtimeMs).toString(36)}`;
  } catch {
    return "";
  }
};
const scene = {
  avif: `${base}/media/home/portal-scene.avif${v("portal-scene.avif")}`,
  webp: `${base}/media/home/portal-scene.webp${v("portal-scene.webp")}`,
};
const mark = `${base}/logo-mark.png`;

// LP-1 living portrait — a sparse twinkle field, generated at build with a
// seeded PRNG so the star positions are STABLE across builds (no diff churn).
// Confined to the sky band and kept clear of the ridgeline (bottom) and the
// centred headline/mark column. Positions are % of the 1280×720 scene.
const mulberry32 = (seed: number) => () => {
  seed |= 0;
  seed = (seed + 0x6d2b79f5) | 0;
  let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
  t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
  return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
};
const rng = mulberry32(20260704);
const stars = Array.from({ length: 34 }, () => {
  let x = 50;
  let y = 30;
  for (let tries = 0; tries < 14; tries++) {
    x = 3 + rng() * 94;
    y = 3 + rng() * 55; // sky only
    if (!(x > 33 && x < 67 && y > 24)) break; // clear the headline column
  }
  return {
    x: x.toFixed(2),
    y: y.toFixed(2),
    size: (1 + rng() * 1.6).toFixed(2),
    o0: (0.16 + rng() * 0.2).toFixed(2),
    o1: (0.68 + rng() * 0.3).toFixed(2),
    dur: (2.6 + rng() * 2.8).toFixed(2),
    delay: (rng() * 5).toFixed(2),
  };
});
---

<section
  class="portal"
  data-portal
  data-mark-src={mark}
  data-loop-src={`${base}/media/home/portal-loop.mp4${v("portal-loop.mp4")}`}
  data-depth-src={`${base}/media/home/portal-depth.png${v("portal-depth.png")}`}
>
  <div class="portal-stage">
    <!-- 1 · the living world (still + ambient overlays; scales as one group) -->
    <div class="portal-world" data-portal-world>
      <picture>
        <source srcset={scene.avif} type="image/avif" />
        <img
          class="portal-scene"
          src={scene.webp}
          alt=""
          width="1920"
          height="1080"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          data-portal-scene
        />
      </picture>

      <!-- LP-1 living portrait, primary: the looping living-painting render.
           Now the 4K-sourced 1080p H.264 loop (~4.5MB) — a seamless 12.1s
           tail→head crossfade cut at the frame where the aurora returns to
           the brand S-pose (scripts note: built from the Higgsfield 4K master).
           No src in markup — the engine mounts it at idle on wide viewports
           only, so no-JS / reduced-motion / save-data / mobile never download
           a byte. Its first frame IS the poster still below, so the fade-in
           is pixel-continuous. -->
      <video
        class="portal-loop"
        data-portal-loop
        muted
        loop
        playsinline
        preload="none"
        width="2560"
        height="1440"
        aria-hidden="true"></video>

      <!-- LP-1 living portrait, fallback: additive light over the still,
           keyed to p. Runs when the video can't (mobile, save-data, autoplay
           blocked, file missing) — the still below stays the no-JS /
           reduced-motion / swappable-media base either way. -->
      <div class="portal-life" data-portal-life aria-hidden="true">
        <div class="portal-aurora"></div>
        <div class="portal-stars">
          {
            stars.map((s) => (
              <span
                class="portal-star"
                style={`left:${s.x}%;top:${s.y}%;width:${s.size}px;height:${s.size}px;--o0:${s.o0};--o1:${s.o1};--tw:${s.dur}s;--twd:${s.delay}s`}
              />
            ))
          }
        </div>
        <div class="portal-haze"></div>
      </div>
    </div>

    <!-- 2 · the void curtain -->
    <div class="portal-void" data-portal-void aria-hidden="true"></div>

    <!-- 3 · the scene through the mark (the window) -->
    <div class="portal-window" data-portal-window aria-hidden="true" style={`background-image: image-set(url(${scene.avif}) type("image/avif"), url(${scene.webp}) type("image/webp"))`}></div>

    <!-- 4 · the solid mark -->
    <img class="portal-mark" src={mark} alt="" width="512" height="512" loading="eager" decoding="async" data-portal-mark />

    <!-- 5 · legibility scrim + content -->
    <div class="portal-scrim" data-portal-scrim aria-hidden="true"></div>
    <div class="portal-content" data-portal-content>
      <slot />
    </div>
  </div>
</section>

<!-- Watchdog OUTSIDE the engine chunk (mirrors the site's 4s reveal watchdog):
     if html.js put us in state A but the engine chunk never starts (network /
     script failure), force the endcard so the scene can never stay hidden. -->
<script is:inline>
  setTimeout(() => {
    const el = document.querySelector("[data-portal]");
    if (el && !el.hasAttribute("data-portal-live")) el.classList.add("portal-forced");
  }, 4000);
</script>

<script>
  import { gsap } from "gsap";
  import type { PortalSceneController } from "../lib/portal-scene-3d";

  const root = document.querySelector<HTMLElement>("[data-portal]");
  if (root) init(root);

  function init(root: HTMLElement) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const params = new URLSearchParams(location.search);
    const worldEl = root.querySelector<HTMLElement>("[data-portal-world]")!;
    const loopEl = root.querySelector<HTMLVideoElement>("[data-portal-loop]")!;
    const lifeEl = root.querySelector<HTMLElement>("[data-portal-life]")!;
    const voidEl = root.querySelector<HTMLElement>("[data-portal-void]")!;
    const markEl = root.querySelector<HTMLElement>("[data-portal-mark]")!;
    const scrimEl = root.querySelector<HTMLElement>("[data-portal-scrim]")!;
    const contentEl = root.querySelector<HTMLElement>("[data-portal-content]")!;

    // reduced motion / QA flag → the endcard, nothing animates. (Reduced
    // motion is also CSS-forced; the class covers the ?portal=static QA path,
    // where the media query doesn't apply.)
    if (reduce || params.get("portal") === "static") {
      root.setAttribute("data-portal-live", "static"); // disarm the watchdog
      root.classList.add("portal-forced");
      return;
    }
    root.setAttribute("data-portal-live", "true");

    // P1.5 — the logo-window accent is RETIRED from the intro. Revealing the
    // scene through the mark's own mountain-silhouette mask made the reveal
    // read as shape flip-flops (logo-mountains → wide scene → logo-mountains
    // → wide scene; Sindbad round 5: "disorienting… should look more
    // seamless"). The .portal-window layer stays in the markup at its
    // endcard-safe opacity:0; the intro is now ONE continuous cross-dissolve
    // (mark bloom + void thinning, nothing changes shape mid-reveal).
    window.addEventListener("resize", () => render(proxy.p));

    // sub-range helper: 0→1 across [a,b] of p
    const seg = (p: number, a: number, b: number) => Math.min(1, Math.max(0, (p - a) / (b - a)));

    const proxy = { p: 0 };
    // R3.6a §4.3 — the world recedes on scroll-out (0→8%); render() composes it
    // into the world transform. Module-scope so the bookend onUpdate can set it.
    let exitY = 0;
    // Living-portrait ladder (P1): WebGL 2.5D scene (top tier) > video loop >
    // still + CSS overlays > still. videoLive flips once the loop is actually
    // rendering frames; glLive once the WebGL scene has mounted. The overlays
    // stand down when either upper tier carries the life (doubling them would
    // over-glow).
    let videoLive = false;
    let glLive = false;
    let gl: PortalSceneController | null = null;
    // Drive the living layers (video loop + CSS overlay fallback). `active` is
    // true while the hero is open and near the top; the intro drives it by p,
    // the scroll-out bookend by scroll position. Pausing off-screen keeps the
    // loop cheap; backgrounded tabs are throttled natively too. (An
    // IntersectionObserver gate was tried but is redundant here.)
    function setLiving(active: boolean) {
      root.classList.toggle("portal-ambient", active);
      gl?.setActive(active); // the WebGL scene's rAF runs only while living
      if (loopEl.src) {
        if (active && loopEl.paused) loopEl.play().catch(() => {}); // autoplay may be blocked → overlays carry it
        else if (!active && !loopEl.paused) loopEl.pause();
      }
    }
    function render(p: number) {
      // solid mark holds, then dissolves (ghost re-forms on reverse). R6 — the
      // mark grows a touch more as it dissolves (scale 1 → ~1.16 across the fade
      // window) so the scroll-scrubbed exit reads as a cinematic bloom into the
      // scene, not an instant pop-out.
      // P1.5 — one continuous cross-dissolve: the mark blooms + fades WHILE
      // the void thins and the world rises through underneath it. The bloom
      // window is a touch longer than pre-P1.5 so mark and scene genuinely
      // overlap — the eye tracks one move, not a sequence of layers.
      markEl.style.opacity = String(1 - seg(p, 0.22, 0.62));
      markEl.style.transform = `translate(-50%, -50%) scale(${1 + seg(p, 0.22, 0.62) * 0.16 + p * 0.03})`;
      // the void dissolve IS the reveal — it starts under the mark's bloom
      voidEl.style.opacity = String(1 - seg(p, 0.28, 0.9));
      const settleScale = 1.08 - 0.08 * p;
      // the world (still + living overlays) settles as it rises through, and on
      // scroll-out RECEDES by exitY (§4.3) — composed into the one transform.
      worldEl.style.transform = `translateY(${exitY}%) scale(${settleScale})`;
      // R3.6a §4.2 — content arrival fires once the scene is essentially open
      // (add-only; the 4s watchdog's .portal-forced covers engine failure).
      if (p > 0.55) root.classList.add("portal-arrived");
      // P1.5 — GL canvas fade waits out the reveal (glLive guard keeps this
      // safe before revealGl is defined; render(0) runs earlier than it)
      if (glLive) revealGl();
      // living portrait fades in only once the scene is essentially open, so
      // the intro dissolve and the scroll-out bookend both stay clean; once
      // the video loop is rendering, the CSS overlays stand down entirely
      lifeEl.style.opacity = videoLive || glLive ? "0" : String(seg(p, 0.82, 1));
      setLiving(p > 0.8);
      scrimEl.style.opacity = String(seg(p, 0.5, 1));
    }
    render(0);

    // mount the living scene at idle: wide viewports only (§9.7 — mobile keeps
    // the weightless CSS overlays over the still; the 16:9 crop hides most of
    // the aurora-S there anyway) and never under Save-Data. preload="none" +
    // src-at-idle keeps the ~1MB clip off the LCP path.
    //
    // P1: the WebGL 2.5D scene is the new top tier — depth-parallax on the
    // scene texture, GPU star field, foreground motes, drifting haze, camera
    // that sways at idle and answers the cursor. The three.js chunk loads at
    // idle only; ANY refusal (no WebGL, software rasterizer, missing depth
    // map, ?portal=nogl, chunk failure) falls through to the DOM video path
    // unchanged. The video still mounts under GL — as the scene's texture.
    const wideAndUnsaved = () => {
      const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
      return !conn?.saveData && window.matchMedia("(min-width: 768px)").matches;
    };
    const mountVideo = (onPlaying: () => void) => {
      loopEl.addEventListener("playing", () => {
        if (videoLive) return;
        videoLive = true;
        onPlaying();
        render(proxy.p); // stands the CSS overlays down
      });
      loopEl.src = root.dataset.loopSrc!;
      setLiving(proxy.p > 0.8); // starts playback if we're already open
    };
    // add the canvas fade class only once the reveal is essentially done —
    // called from mountScene (already-open case) and render() (mid-intro case)
    const revealGl = () => {
      if (glLive && proxy.p > 0.9) root.classList.add("portal-gl-live");
    };
    // GPU context lost mid-visit → stand the DOM tiers back up seamlessly:
    // the loop (if it was playing) or the CSS overlays over the still.
    const glFallback = () => {
      gl = null;
      glLive = false;
      root.classList.remove("portal-gl-live");
      if (videoLive && loopEl.readyState >= 2) root.classList.add("portal-video-live");
      render(proxy.p);
    };
    let sceneMounted = false;
    const mountScene = async () => {
      // idempotent: the idle mount and the QA forceLoop surface can both call
      // this — a second run would stack a second canvas + video listener
      if (sceneMounted) return;
      sceneMounted = true;
      if (!wideAndUnsaved()) return;
      if (params.get("portal") !== "nogl") {
        try {
          const { mountPortalScene } = await import("../lib/portal-scene-3d");
          gl = await mountPortalScene({
            worldEl,
            stillEl: root.querySelector<HTMLImageElement>("[data-portal-scene]")!,
            videoEl: loopEl,
            depthSrc: root.dataset.depthSrc!,
            onContextLost: glFallback,
          });
        } catch {
          gl = null; // engine chunk/init failure → DOM ladder, as before P1
        }
      }
      if (gl) {
        glLive = true;
        // P1.5 — the canvas fade-in WAITS for the intro: its own 900ms fade
        // landing mid-dissolve was one more cross-fade during the reveal.
        // revealGl() runs now if the scene is already open, else render(p)
        // fires it the moment p clears the void (0.9).
        revealGl();
        render(proxy.p); // overlays stand down
        gl.setActive(proxy.p > 0.8);
        mountVideo(() => gl?.useVideo()); // loop becomes the scene texture; DOM video stays hidden
      } else {
        mountVideo(() => root.classList.add("portal-video-live")); // CSS fades the loop in over the identical poster frame
      }
    };

    // intro: the sting's opening — hold on the mark (now with a subtle BREATH,
    // R3.6a §4.1), then dissolve through. The breath runs on the compositor via
    // a direct transform write during the 0.8s hold; render(p) overwrites the
    // mark transform from p=0.2 on, so the handoff is seamless (breath amplitude
    // 1.5% is below the dissolve-scale ramp).
    let introKilled = false;
    const intro = gsap.timeline();
    intro
      .to(markEl, {
        duration: 0.8,
        ease: "sine.inOut",
        onUpdate: function () {
          markEl.style.transform = `translate(-50%, -50%) scale(${1 + 0.015 * Math.sin(this.progress() * Math.PI)})`;
        },
      }, 0)
      .to(proxy, { p: 1, duration: 2.0, ease: "power2.inOut", onUpdate: () => render(proxy.p) }, 0.8);

    // scroll-out (LP-2 + R6): the living scene RECEDES with the section while
    // the content fades for a clean handoff into the tableaux. R6 — the load-in
    // MARK no longer evaporates instantly on first scroll: instead of snapping
    // the intro to fully-open, we HAND its remaining progress to the scroll and
    // scrub the mark's exit (scale up + fade) over the first ~50vh, so the logo
    // dissolves cinematically with scroll distance rather than popping out of
    // existence. If the intro already finished (mark long gone) this is a no-op.
    const smooth = (x: number) => x * x * (3 - 2 * x); // smoothstep — eases the content fade
    const FADE_FROM = 0.12; // let the hero scroll a touch before the content dims
    const FADE_TO = 0.72; // content fully handed off by ~70% of the exit
    // R6 mark-exit window: 0 → 1 over the first ~55% of the hero's scroll-out
    // (~55vh given a 100vh hero), the graceful scroll-scrubbed logo dissolve.
    const MARK_EXIT_TO = 0.55;
    let introScrubbed = false;
    const mountBookend = async () => {
      try {
        const { ScrollTrigger } = await import("gsap/ScrollTrigger");
        gsap.registerPlugin(ScrollTrigger);
        ScrollTrigger.create({
          trigger: root,
          start: "top top",
          end: "bottom top",
          scrub: true,
          onUpdate: (self) => {
            // First scroll: stop the timed intro but DON'T snap the mark away.
            // Capture where the intro had reached (pAtScroll) and scrub the rest
            // of the mark's dissolve across the scroll distance below.
            if (self.progress > 0.0005 && !introKilled) {
              intro.kill();
              introKilled = true;
              introScrubbed = proxy.p < 0.999; // was the mark still (partly) present?
              (proxy as { pStart?: number }).pStart = proxy.p;
            }
            if (introScrubbed) {
              // scrub p from where the intro left off → 1 across the exit window,
              // so the mark scales up + dissolves smoothly with scroll (R6).
              const pStart = (proxy as { pStart?: number }).pStart ?? proxy.p;
              const k = smooth(Math.min(1, self.progress / MARK_EXIT_TO));
              proxy.p = pStart + (1 - pStart) * k;
              render(proxy.p);
              if (proxy.p > 0.999) introScrubbed = false; // done — leave it open
            }
            const exit = smooth(Math.min(1, Math.max(0, (self.progress - FADE_FROM) / (FADE_TO - FADE_FROM))));
            contentEl.style.opacity = String(1 - exit);

            // R3.6a §4.3 — the A→B→A bookend, now actually visible:
            // (1) the world recedes 0→8% over the exit, and
            // (2) the mark GHOST re-forms over the last quarter of the exit (the
            //     sting's endcard). Only when the load-in mark is already gone
            //     (introScrubbed false), so this never fights the R6 mark-exit
            //     scrub. render() re-applies exitY via the world transform.
            exitY = smooth(self.progress) * 8;
            const ghost = smooth(Math.min(1, Math.max(0, (self.progress - 0.78) / 0.22)));
            if (!introScrubbed && proxy.p > 0.999) {
              markEl.style.opacity = String(ghost * 0.22);
              markEl.style.transform = `translate(-50%, -50%) scale(${1.19 - 0.16 * ghost})`;
            }
            render(proxy.p); // re-render with the new exitY (cheap; transform-only)

            setLiving(self.progress < 0.6); // pause the loop / overlays once mostly scrolled away
          },
        });
      } catch {
        /* bookend is enhancement; the intro already ran */
      }
    };
    const mountEnhancements = () => {
      void mountBookend();
      void mountScene();
    };
    if ("requestIdleCallback" in window) {
      requestIdleCallback(mountEnhancements, { timeout: 2500 });
    } else {
      setTimeout(mountEnhancements, 1200);
    }

    // QA surface (harness tabs pause rAF; render(p) is deterministic)
    (window as unknown as Record<string, unknown>).__PORTAL = {
      p: () => proxy.p,
      set: (v: number) => {
        if (!introKilled) {
          intro.kill();
          introKilled = true;
        }
        proxy.p = v;
        render(v);
      },
      video: () => ({
        mounted: !!loopEl.src,
        live: videoLive,
        paused: loopEl.paused,
        readyState: loopEl.readyState,
      }),
      gl: () => (gl ? gl.stats() : { live: false, glLive }),
      // QA: draw n deterministic GL frames (harness tabs pause rAF)
      glRender: (n = 1, dt = 1 / 60) => {
        for (let i = 0; i < n; i++) gl?.renderOnce(dt);
      },
      forceLoop: () => void mountScene(), // QA: mount regardless of idle timing
    };
  }
</script>
