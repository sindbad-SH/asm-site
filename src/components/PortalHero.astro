---
/**
 * The Portal Hero (BUILD-PLAN.md §9.2) — the home page's signature, built
 * from the brand logo-sting reference: the mark alone on a void → the mark
 * becomes a WINDOW as an aurora-lit mountain night rises through it → full
 * scene → (on scroll-out) the mark re-forms. A→B→A, bookended, exactly the
 * sting's structure. Content (kicker/h1/subline/CTA) goes in the slot and
 * holds still throughout ("one thing moves at a time" — the sting brief).
 *
 * Layer stack (bottom→top):
 *   1. .portal-scene   — the beauty-shot still (frame-grabbed from the
 *                        horizontal sting → AVIF 26KB + WebP fallback)
 *   2. .portal-void    — the --hero-void curtain; its DISSOLVE does the true
 *                        full reveal (the mark's interior is partially
 *                        transparent, so a pure mask-zoom could never fully
 *                        clear the viewport — same reason the sting itself is
 *                        dissolve-driven, "no hard cuts")
 *   3. .portal-window  — the scene again, masked by the logo alpha; its
 *                        mask-size GROWS during the open (the portal accent)
 *                        and it fades out at the end, handing to layer 1
 *   4. .portal-mark    — the solid mark (state A / ghost re-form)
 *   5. scrim + content
 *
 * One proxy p (0 = closed/state A, 1 = open/endcard) drives render(p):
 * intro tween runs 0→1 on load (0.8s hold + dissolve-through); a scrubbed
 * ScrollTrigger runs 1→0 as the hero exits — the bookend handoff into the
 * tableaux (replacing the globe's old handoff).
 *
 * States & fallbacks:
 *   - no-JS default        → ENDCARD (scene + solid mark ghost + headline)
 *   - html.js              → state A (void + solid mark); intro plays when
 *                            the chunk lands
 *   - reduced motion       → CSS forces the endcard back; script bails
 *   - chunk-load failure   → 4s inline watchdog forces .portal-forced endcard
 *   - ?portal=static       → endcard, no animation (QA)
 * Debug: window.__PORTAL { p(), set(p) } — set() drives render directly
 * (harness tabs pause rAF; render is deterministic).
 *
 * HONESTY NOTE (§9.2): the scene is BRAND ART — the logo's world, from the
 * AI-generated sting. It lives here as brand identity and must never appear
 * in Work/Adventure gallery contexts where it could read as shot footage.
 *
 * The 9:16 sting mp4 (1.26MB) remains available as a mobile poster-first
 * alternative (§9.2 "decide at build by feel") — not used at launch: the
 * live composite is one code path and works at every aspect.
 */
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const scene = {
  avif: `${base}/media/home/portal-scene.avif`,
  webp: `${base}/media/home/portal-scene.webp`,
};
const mark = `${base}/logo-mark.png`;

// LP-1 living portrait — a sparse twinkle field, generated at build with a
// seeded PRNG so the star positions are STABLE across builds (no diff churn).
// Confined to the sky band and kept clear of the ridgeline (bottom) and the
// centred headline/mark column. Positions are % of the 1280×720 scene.
const mulberry32 = (seed: number) => () => {
  seed |= 0;
  seed = (seed + 0x6d2b79f5) | 0;
  let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
  t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
  return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
};
const rng = mulberry32(20260704);
const stars = Array.from({ length: 34 }, () => {
  let x = 50;
  let y = 30;
  for (let tries = 0; tries < 14; tries++) {
    x = 3 + rng() * 94;
    y = 3 + rng() * 55; // sky only
    if (!(x > 33 && x < 67 && y > 24)) break; // clear the headline column
  }
  return {
    x: x.toFixed(2),
    y: y.toFixed(2),
    size: (1 + rng() * 1.6).toFixed(2),
    o0: (0.16 + rng() * 0.2).toFixed(2),
    o1: (0.68 + rng() * 0.3).toFixed(2),
    dur: (2.6 + rng() * 2.8).toFixed(2),
    delay: (rng() * 5).toFixed(2),
  };
});
---

<section class="portal" data-portal data-mark-src={mark} data-loop-src={`${base}/media/home/portal-loop.mp4`}>
  <div class="portal-stage">
    <!-- 1 · the living world (still + ambient overlays; scales as one group) -->
    <div class="portal-world" data-portal-world>
      <picture>
        <source srcset={scene.avif} type="image/avif" />
        <img
          class="portal-scene"
          src={scene.webp}
          alt=""
          width="1280"
          height="720"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          data-portal-scene
        />
      </picture>

      <!-- LP-1 living portrait, primary: the looping living-painting render
           (seamless tail→head crossfade of the brand sting scene, ~13s ≤1MB).
           No src in markup — the engine mounts it at idle on wide viewports
           only, so no-JS / reduced-motion / save-data / mobile never download
           a byte. Its first frame IS the poster still below, so the fade-in
           is pixel-continuous. -->
      <video
        class="portal-loop"
        data-portal-loop
        muted
        loop
        playsinline
        preload="none"
        width="1280"
        height="720"
        aria-hidden="true"></video>

      <!-- LP-1 living portrait, fallback: additive light over the still,
           keyed to p. Runs when the video can't (mobile, save-data, autoplay
           blocked, file missing) — the still below stays the no-JS /
           reduced-motion / swappable-media base either way. -->
      <div class="portal-life" data-portal-life aria-hidden="true">
        <div class="portal-aurora"></div>
        <div class="portal-stars">
          {
            stars.map((s) => (
              <span
                class="portal-star"
                style={`left:${s.x}%;top:${s.y}%;width:${s.size}px;height:${s.size}px;--o0:${s.o0};--o1:${s.o1};--tw:${s.dur}s;--twd:${s.delay}s`}
              />
            ))
          }
        </div>
        <div class="portal-haze"></div>
      </div>
    </div>

    <!-- 2 · the void curtain -->
    <div class="portal-void" data-portal-void aria-hidden="true"></div>

    <!-- 3 · the scene through the mark (the window) -->
    <div class="portal-window" data-portal-window aria-hidden="true" style={`background-image: image-set(url(${scene.avif}) type("image/avif"), url(${scene.webp}) type("image/webp"))`}></div>

    <!-- 4 · the solid mark -->
    <img class="portal-mark" src={mark} alt="" width="512" height="512" loading="eager" decoding="async" data-portal-mark />

    <!-- 5 · legibility scrim + content -->
    <div class="portal-scrim" data-portal-scrim aria-hidden="true"></div>
    <div class="portal-content" data-portal-content>
      <slot />
    </div>
  </div>
</section>

<!-- Watchdog OUTSIDE the engine chunk (mirrors the site's 4s reveal watchdog):
     if html.js put us in state A but the engine chunk never starts (network /
     script failure), force the endcard so the scene can never stay hidden. -->
<script is:inline>
  setTimeout(() => {
    const el = document.querySelector("[data-portal]");
    if (el && !el.hasAttribute("data-portal-live")) el.classList.add("portal-forced");
  }, 4000);
</script>

<script>
  import { gsap } from "gsap";

  const root = document.querySelector<HTMLElement>("[data-portal]");
  if (root) init(root);

  function init(root: HTMLElement) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const params = new URLSearchParams(location.search);
    const stage = root.querySelector<HTMLElement>(".portal-stage")!;
    const worldEl = root.querySelector<HTMLElement>("[data-portal-world]")!;
    const loopEl = root.querySelector<HTMLVideoElement>("[data-portal-loop]")!;
    const lifeEl = root.querySelector<HTMLElement>("[data-portal-life]")!;
    const voidEl = root.querySelector<HTMLElement>("[data-portal-void]")!;
    const windowEl = root.querySelector<HTMLElement>("[data-portal-window]")!;
    const markEl = root.querySelector<HTMLElement>("[data-portal-mark]")!;
    const scrimEl = root.querySelector<HTMLElement>("[data-portal-scrim]")!;
    const contentEl = root.querySelector<HTMLElement>("[data-portal-content]")!;

    // reduced motion / QA flag → the endcard, nothing animates. (Reduced
    // motion is also CSS-forced; the class covers the ?portal=static QA path,
    // where the media query doesn't apply.)
    if (reduce || params.get("portal") === "static") {
      root.setAttribute("data-portal-live", "static"); // disarm the watchdog
      root.classList.add("portal-forced");
      return;
    }
    root.setAttribute("data-portal-live", "true");

    // mask geometry — the window opens from mark-size to past the viewport
    windowEl.style.setProperty("-webkit-mask-image", `url(${root.dataset.markSrc})`);
    windowEl.style.setProperty("mask-image", `url(${root.dataset.markSrc})`);
    let S0 = 0;
    let SF = 0;
    const measure = () => {
      const r = stage.getBoundingClientRect();
      S0 = Math.min(r.width, r.height) * 0.38; // the sting's mark ≈ 38% of frame
      SF = Math.hypot(r.width, r.height) * 2.2;
    };
    measure();
    window.addEventListener("resize", () => {
      measure();
      render(proxy.p);
    });

    // sub-range helper: 0→1 across [a,b] of p
    const seg = (p: number, a: number, b: number) => Math.min(1, Math.max(0, (p - a) / (b - a)));

    const proxy = { p: 0 };
    // Living-portrait ladder: video loop (primary) > still + CSS overlays
    // (fallback) > still (base). videoLive flips once the loop is actually
    // rendering frames; the overlays stand down then (the video already IS
    // the living aurora — doubling them would over-glow).
    let videoLive = false;
    // Drive the living layers (video loop + CSS overlay fallback). `active` is
    // true while the hero is open and near the top; the intro drives it by p,
    // the scroll-out bookend by scroll position. Pausing off-screen keeps the
    // loop cheap; backgrounded tabs are throttled natively too. (An
    // IntersectionObserver gate was tried but is redundant here.)
    function setLiving(active: boolean) {
      root.classList.toggle("portal-ambient", active);
      if (loopEl.src) {
        if (active && loopEl.paused) loopEl.play().catch(() => {}); // autoplay may be blocked → overlays carry it
        else if (!active && !loopEl.paused) loopEl.pause();
      }
    }
    function render(p: number) {
      // solid mark holds, then dissolves (ghost re-forms on reverse)
      markEl.style.opacity = String(1 - seg(p, 0.2, 0.5));
      markEl.style.transform = `translate(-50%, -50%) scale(${1 + p * 0.05})`;
      // the window: in as the mark fades, out as the void finishes (hand-off)
      const wIn = seg(p, 0.15, 0.35);
      const wOut = 1 - seg(p, 0.85, 1);
      windowEl.style.opacity = String(Math.min(wIn, wOut));
      const size = S0 + (SF - S0) * seg(p, 0.2, 1);
      windowEl.style.setProperty("-webkit-mask-size", `${size}px`);
      windowEl.style.setProperty("mask-size", `${size}px`);
      // the void dissolve = the true reveal
      voidEl.style.opacity = String(1 - seg(p, 0.45, 0.95));
      // the world (still + living overlays) settles as it rises through
      worldEl.style.transform = `scale(${1.08 - 0.08 * p})`;
      // living portrait fades in only once the scene is essentially open, so
      // the intro dissolve and the scroll-out bookend both stay clean; once
      // the video loop is rendering, the CSS overlays stand down entirely
      lifeEl.style.opacity = videoLive ? "0" : String(seg(p, 0.82, 1));
      setLiving(p > 0.8);
      scrimEl.style.opacity = String(seg(p, 0.5, 1));
    }
    render(0);

    // mount the living-painting loop at idle: wide viewports only (§9.7 —
    // mobile keeps the weightless CSS overlays over the still; the 16:9 crop
    // hides most of the aurora-S there anyway) and never under Save-Data.
    // preload="none" + src-at-idle keeps the ~1MB clip off the LCP path.
    const mountLoop = () => {
      const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
      if (conn?.saveData || !window.matchMedia("(min-width: 768px)").matches) return;
      loopEl.addEventListener("playing", () => {
        if (videoLive) return;
        videoLive = true;
        root.classList.add("portal-video-live"); // CSS fades the loop in over the identical poster frame
        render(proxy.p); // stands the CSS overlays down
      });
      loopEl.src = root.dataset.loopSrc!;
      setLiving(proxy.p > 0.8); // starts playback if we're already open
    };

    // intro: the sting's opening — hold on the mark, then dissolve through
    let introKilled = false;
    const intro = gsap.to(proxy, {
      p: 1,
      duration: 2.0,
      delay: 0.8,
      ease: "power2.inOut",
      onUpdate: () => render(proxy.p),
    });

    // scroll-out (LP-2): the living scene simply RECEDES with the section — it
    // stays whole (p=1) and scrolls away like any hero, while the content fades
    // for a clean handoff into the tableaux and the loop pauses once the hero
    // is mostly gone. The mark deliberately does NOT re-form over the scene on
    // scroll: with the living video as the star, a logo blooming back over it
    // (behind the still-present headline) read as wrong. Streams in at idle;
    // scroll before then simply leaves the open scene (safe).
    const smooth = (x: number) => x * x * (3 - 2 * x); // smoothstep — eases the content fade
    const FADE_FROM = 0.12; // let the hero scroll a touch before the content dims
    const FADE_TO = 0.72; // content fully handed off by ~70% of the exit
    const mountBookend = async () => {
      try {
        const { ScrollTrigger } = await import("gsap/ScrollTrigger");
        gsap.registerPlugin(ScrollTrigger);
        ScrollTrigger.create({
          trigger: root,
          start: "top top",
          end: "bottom top",
          scrub: true,
          onUpdate: (self) => {
            // first scroll: settle the intro to fully-open and leave it there
            if (self.progress > 0.001 && !introKilled) {
              intro.kill();
              introKilled = true;
              proxy.p = 1;
              render(1);
            }
            const exit = smooth(Math.min(1, Math.max(0, (self.progress - FADE_FROM) / (FADE_TO - FADE_FROM))));
            contentEl.style.opacity = String(1 - exit);
            setLiving(self.progress < 0.6); // pause the loop / overlays once mostly scrolled away
          },
        });
      } catch {
        /* bookend is enhancement; the intro already ran */
      }
    };
    const mountEnhancements = () => {
      void mountBookend();
      mountLoop();
    };
    if ("requestIdleCallback" in window) {
      requestIdleCallback(mountEnhancements, { timeout: 2500 });
    } else {
      setTimeout(mountEnhancements, 1200);
    }

    // QA surface (harness tabs pause rAF; render(p) is deterministic)
    (window as unknown as Record<string, unknown>).__PORTAL = {
      p: () => proxy.p,
      set: (v: number) => {
        if (!introKilled) {
          intro.kill();
          introKilled = true;
        }
        proxy.p = v;
        render(v);
      },
      video: () => ({
        mounted: !!loopEl.src,
        live: videoLive,
        paused: loopEl.paused,
        readyState: loopEl.readyState,
      }),
      forceLoop: () => mountLoop(), // QA: mount regardless of idle timing
    };
  }
</script>
