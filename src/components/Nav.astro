---
/**
 * Top nav — the capped 6-item nav (BUILD-PLAN.md §1.0) in the system voice:
 * mono hud labels, hairline rule, logo as the map's "title cartouche"
 * (top-left, §3.1). The active page marker uses accent — a sanctioned use
 * (the "you-are-here" signal). Forge the Saga owns the single CTA button.
 */
import { NAV, SITE, PRIMARY_CTA } from "../consts";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = new URL(Astro.request.url).pathname.replace(import.meta.env.BASE_URL, "/");
---

<header class="flex flex-wrap items-center justify-between gap-4 border-b border-hairline px-5 py-4">
  <a href={`${base}/`} class="flex items-center gap-3">
    <img src={`${base}/logo-mark.png`} alt="" class="h-8 w-auto" />
    <span class="font-display text-lg text-peak">{SITE.name}</span>
  </a>
  <!--
    Always visible by default — this is the no-JS nav. MobileMenu.astro's
    script hides it (adding .hidden) ONLY once JS confirms a narrow viewport;
    without JS it stays visible and wraps, imperfect but fully functional.
  -->
  <nav aria-label="Primary" data-nav-links>
    <ul class="nav-links flex flex-wrap items-center gap-x-4 gap-y-2 xl:gap-5">
      {
        NAV.map((item) => {
          const isCurrent = path === item.href || path.startsWith(`${item.href}/`);
          return (
            <li class="nav-item">
              <a
                href={`${base}${item.href}`}
                aria-current={isCurrent ? "page" : undefined}
                class={`hud-label transition-colors ${isCurrent ? "text-accent" : "hover:text-ink"}`}
              >
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
  <a href={`${base}${PRIMARY_CTA.href}`} class="btn hidden lg:inline-block">{PRIMARY_CTA.label}</a>

  <!-- Hidden until MobileMenu's script confirms JS + narrow viewport. -->
  <button
    type="button"
    class="menu-toggle hidden"
    data-menu-toggle
    aria-controls="fs-menu"
    aria-expanded="false"
    aria-label="Open menu"
  >
    <span class="bar" aria-hidden="true"></span>
  </button>
</header>

<style>
  /* P17a — separators between nav items (operator: the repeated "…Stories"
     labels blend into a sentence). A survey-tick slash in the hairline color,
     drawn as a pseudo-element so it's purely presentational (never read by
     screen readers, never a hit target). Sits between items only — no leading
     or trailing tick. The mobile menu is a different component (unaffected). */
  .nav-item + .nav-item {
    display: flex;
    align-items: center;
  }
  .nav-item + .nav-item::before {
    content: "/";
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: color-mix(in srgb, currentColor 32%, transparent);
    margin-right: 1rem;
    transform: skewX(-8deg);
    pointer-events: none;
  }
  @media (min-width: 1024px) and (max-width: 1279px) {
    .nav-item + .nav-item::before {
      margin-right: 0.7rem;
    }
  }
  @media (min-width: 1280px) {
    .nav-item + .nav-item::before {
      margin-right: 1.25rem;
    }
  }

  /* P12.6b — the appended "Stories" nav labels lengthen the inline desktop row.
     The inline list goes live at ≥1024px (MobileMenu collapses it below that),
     so in the tight 1024–1279 band we compress the whole header — nav tracking +
     size, the wordmark, and the header's own gap/padding — enough that logo +
     the six full labels + the CTA all hold ONE row instead of wrapping. Labels
     stay full per operator; only spacing shrinks. Everything eases back to the
     system voice once there's room at ≥1280px. */
  @media (min-width: 1024px) and (max-width: 1279px) {
    header {
      padding-inline: 0.9rem;
      column-gap: 0.7rem;
    }
    /* the wordmark next to the logo mark */
    header > a > span {
      font-size: 1rem;
    }
    .nav-links {
      column-gap: 0.7rem;
    }
    .nav-links .hud-label {
      letter-spacing: 0.04em;
      font-size: 0.62rem;
    }
  }
  @media (min-width: 1280px) {
    .nav-links .hud-label {
      letter-spacing: 0.16em;
      font-size: 0.7rem;
    }
  }
</style>
