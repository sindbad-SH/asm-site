---
/**
 * Three-pillar scroll tableaux (§2b) — the home page's narrative body, the
 * KPR-style "chapters revealed as you scroll" model. Each chapter pins while
 * its parallax layers drift (transform/opacity only — NO WebGL), the headline
 * rises in masked lines, and a contour line draws between chapters.
 *
 * Fallbacks (§2b):
 *   • reduced motion → engine no-ops; CSS renders static, everything visible.
 *   • no-JS         → same static layout (html.js-gated hiding never applies).
 *   • mobile        → no pin/parallax; masked reveals only (avoids mobile pin
 *                     jank). Handled at runtime by width check.
 *
 * The engine is generic over [data-tableau]; a chapter is "full" or "stub"
 * purely by whether it has a layer set below — so replication is data, not
 * code.
 */
import TableauChapter, { type TableauLayer, type TableauImage } from "./TableauChapter.astro";
import TableauCluster from "./TableauCluster.astro";
import ContourDivider from "./ContourDivider.astro";
import { PAGES, PILLARS } from "../consts";
import { existsSync } from "node:fs";
import { join } from "node:path";
import { SITE_ROOT } from "../lib/site-root";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const chapters = PAGES.home.tableaux;

// R5/R3.6b — a chapter renders as a FLOATING SHOT CLUSTER (TableauCluster) when
// its cluster assets exist on disk, replacing the old full-bleed layered scene.
// Generalized in R3.6b from wild-only to any chapter dir (wild|market|industry):
// a chapter clusters when its public/media/home/<slug>/cluster/ has >=2 shots.
// Build-time check (frontmatter runs server-side), anchored to cwd.
function clusterShot(slug: string, id: string) {
  const dir = join(SITE_ROOT, "public", "media", "home", slug, "cluster");
  const has = existsSync(join(dir, `${id}.avif`)) && existsSync(join(dir, `${id}.webp`));
  return has
    ? { avif: `${base}/media/home/${slug}/cluster/${id}.avif`, webp: `${base}/media/home/${slug}/cluster/${id}.webp` }
    : undefined;
}
function clusterShotsFor(slug: string) {
  const wildDir = join(SITE_ROOT, "public", "media", "home", "wild");
  const hasLoop =
    slug === "wild" &&
    existsSync(join(wildDir, "matterhorn-loop.mp4")) &&
    existsSync(join(wildDir, "matterhorn-loop-poster.avif"));
  return {
    peak: clusterShot(slug, "peak"),
    valley: clusterShot(slug, "valley"),
    lake: clusterShot(slug, "lake"),
    ridge: clusterShot(slug, "ridge"),
    loop: hasLoop
      ? {
          mp4: `${base}/media/home/wild/matterhorn-loop.mp4`,
          poster: `${base}/media/home/wild/matterhorn-loop-poster.avif`,
        }
      : undefined,
  };
}
// A chapter's cluster is "live" when at least 2 of its shots exist (valley/lake/
// ridge/peak/loop); else that chapter falls back to the classic layered scene.
function clusterLiveFor(shots: ReturnType<typeof clusterShotsFor>) {
  const n = [shots.peak, shots.valley, shots.lake, shots.ridge, shots.loop].filter(Boolean).length;
  return n >= 2;
}
// Map chapter terrain → media slug (the wild/market/industry dir names).
const terrainSlug = (terrain: string) => terrain.toLowerCase().replace(/^the\s+/, "");

// Media self-service (MEDIA-GUIDE.md "Home tableaux"): each layer's real art
// lives at public/media/home/<slug>/<layer>.{avif,webp}. Checked at BUILD
// TIME (this component runs server-side) — if both files for a layer exist,
// that layer renders the real image; if not, its annotated placeholder shows.
// No code change is ever needed to "wire in" a photo — dropping the files in
// is the whole action, exactly like every other slot in MEDIA-GUIDE.md.
// Anchored to process.cwd() (the project root `astro build`/`astro dev` are
// always invoked from), NOT import.meta.url — the production build bundles
// this frontmatter into dist/.prerender/chunks/, so an import.meta.url-
// relative path resolves against the wrong (bundled) location once built.
const LAYER_NAMES = ["background", "midground", "foreground"] as const;
function findLayerImages(terrain: string): (TableauImage | null)[] {
  const slug = terrain.toLowerCase().replace(/^the\s+/, "");
  const dir = join(SITE_ROOT, "public", "media", "home", slug);
  return LAYER_NAMES.map((name) => {
    const hasAvif = existsSync(join(dir, `${name}.avif`));
    const hasWebp = existsSync(join(dir, `${name}.webp`));
    if (!hasAvif || !hasWebp) return null; // partial fill-in keeps that layer's placeholder
    return {
      avif: `${base}/media/home/${slug}/${name}.avif`,
      webp: `${base}/media/home/${slug}/${name}.webp`,
    };
  });
}

// Map each chapter's terrain to its pillar slug so the survey trail (§3.3)
// can anchor a portal node to the real pillar section.
const pillarByTerrain = Object.fromEntries(PILLARS.map((p) => [p.terrain.toLowerCase(), p.id]));

// ── LAYER_SETS — art-direction layer descriptors, keyed by chapter terrain.
// All three chapters are now fully built, mirroring "the wild" exemplar's
// structure exactly (3 layers: background 0.15 → midground 0.45 →
// foreground 0.85 alpha cut-out). Lane art direction per brief §6 Option 3
// layout logic: the market = the ordered, built environment (city
// street-grid); the industry = the coastline / stage-lights sprawl at
// night. Interim assets are AI-generated per BUILD-PLAN.md §5B (G1) until
// real footage/stills replace them slot-for-slot in Phase 6.
const LAYER_SETS: Record<string, readonly TableauLayer[] | null> = {
  "The wild": [
    { depth: 0.15, label: "WILD · BACKGROUND — distant ridgeline & sky, full-bleed (§2b · ≤180KB AVIF)" },
    { depth: 0.45, label: "WILD · MIDGROUND — mid ridge / valley haze (§2b)" },
    { depth: 0.85, label: "WILD · FOREGROUND — near rock or figure, alpha cut-out (§2b)" },
  ],
  "The market": [
    { depth: 0.15, label: "MARKET · BACKGROUND — city skyline at dusk, full-bleed (§2b · ≤180KB AVIF)" },
    { depth: 0.45, label: "MARKET · MIDGROUND — ordered street-grid / built environment, haze (§2b)" },
    { depth: 0.85, label: "MARKET · FOREGROUND — a desk, a deck, a founder at work, alpha cut-out (§2b)" },
  ],
  "The industry": [
    { depth: 0.15, label: "INDUSTRY · BACKGROUND — coastline or skyline at night, full-bleed (§2b · ≤180KB AVIF)" },
    { depth: 0.45, label: "INDUSTRY · MIDGROUND — stage-lights sprawl / venue glow, haze (§2b)" },
    { depth: 0.85, label: "INDUSTRY · FOREGROUND — a camera, a badge, a set in motion, alpha cut-out (§2b)" },
  ],
};
---

<section class="tableaux" data-tableaux aria-label="Three terrains, one craft">
  {
    chapters.map((chapter, i) => {
      const slug = terrainSlug(chapter.terrain);
      const shots = clusterShotsFor(slug);
      const clusterLive = clusterLiveFor(shots);
      // Drift amp per the R3.5 wire-up map: wild 1.0, market/industry 0.9.
      const driftAmp = slug === "wild" ? 1.0 : 0.9;
      const nodeId = pillarByTerrain[chapter.terrain.toLowerCase()];
      return (
        <Fragment>
          {i > 0 && <ContourDivider class="mx-auto max-w-3xl px-8" />}
          {clusterLive ? (
            <TableauCluster
              chapter={chapter}
              index={i}
              base={base}
              nodeId={nodeId}
              shots={shots}
              driftAmp={driftAmp}
            />
          ) : (
            <TableauChapter
              chapter={chapter}
              index={i}
              layers={LAYER_SETS[chapter.terrain] ?? undefined}
              images={LAYER_SETS[chapter.terrain] ? findLayerImages(chapter.terrain) : undefined}
              base={base}
              nodeId={nodeId}
            />
          )}
        </Fragment>
      );
    })
  }
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { splitLines } from "../lib/split-lines";
  import { ensureSmoothScroll } from "../lib/smooth-scroll";

  const section = document.querySelector<HTMLElement>("[data-tableaux]");
  if (section) void initTableaux(section);

  async function initTableaux(section: HTMLElement) {
    // reduced motion → leave the static CSS layout untouched (§2b fallback)
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    gsap.registerPlugin(ScrollTrigger);
    const lenis = await ensureSmoothScroll();
    if (lenis) lenis.on("scroll", () => ScrollTrigger.update());

    // measure line breaks only once fonts are settled
    if (document.fonts?.ready) await document.fonts.ready;

    const mobile = window.matchMedia("(max-width: 640px)").matches;

    // R5 — floating shot clusters (the "wild" chapter). Not pinned: the shots
    // drift at their own rates as the section scrolls past, bright and visible.
    section.querySelectorAll<HTMLElement>("[data-cluster]").forEach((cluster) => {
      const content = cluster.querySelector<HTMLElement>("[data-tableau-content]");
      const headline = cluster.querySelector<HTMLElement>("[data-tableau-headline]");
      if (content && headline) splitLines(headline);

      // content reveal, once
      if (content) {
        ScrollTrigger.create({
          trigger: cluster,
          start: "top 72%",
          once: true,
          onEnter: () => content.classList.add("is-revealed"),
        });
      }

      // lazy-mount the live loop on wide viewports only (P5), poster-first
      const loopVideo = cluster.querySelector<HTMLVideoElement>("[data-cluster-loop-video]");
      if (loopVideo && !mobile) {
        const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
        const mount = () => {
          if (conn?.saveData) return;
          const src = loopVideo.dataset.src;
          if (src && !loopVideo.src) {
            loopVideo.src = src;
            loopVideo.play().catch(() => {});
          }
        };
        const io = new IntersectionObserver(
          (entries) => entries.forEach((e) => (e.isIntersecting ? mount() : loopVideo.pause())),
          { rootMargin: "0px" },
        );
        io.observe(cluster);
      }

      // float parallax — each shot drifts at its data-rate (% of viewport),
      // split symmetrically (+half → −half) over the section's scroll. Text
      // (data-tableau-content) is excluded — it never parallaxes.
      if (mobile) return;
      const floats = cluster.querySelectorAll<HTMLElement>("[data-float]");
      const tl = gsap.timeline({
        scrollTrigger: { trigger: cluster, start: "top bottom", end: "bottom top", scrub: true },
      });
      floats.forEach((f) => {
        const rate = Number(f.dataset.rate) || 8;
        const amp = Math.min(rate, 24) / 2; // cap at 24% (DIRECTION §1.2)
        tl.fromTo(f, { yPercent: amp }, { yPercent: -amp, ease: "none" }, 0);
      });

      // R3.6b §3.1 — cluster shot ENTRANCE POP: on first entry the floats scale
      // in from a random scatter (never a row-by-row grid arrival). Runs BEFORE
      // drift mounts (idle), so the two never fight.
      ScrollTrigger.create({
        trigger: cluster,
        start: "top 78%",
        once: true,
        onEnter: () =>
          gsap.from(floats, {
            scale: 0.92,
            opacity: 0,
            duration: 0.9,
            ease: "power2.out", // = --ease-arrival
            stagger: { each: 0.11, from: "random" },
          }),
      });
    });

    // R3.5 — mount the ambient drift engine on ALL [data-drift] on the page at
    // idle (cluster floats + the H6 about-teaser portrait card). Zero bytes/work
    // on the LCP path; the engine hard-gates itself off under reduced motion /
    // <=640px. Scoped to document so the about-teaser card (outside [data-tableaux])
    // is included — the engine is idempotent per element.
    const mountAmbient = () =>
      import("../lib/drift-engine").then(({ mountDrift }) => mountDrift(document));
    if ("requestIdleCallback" in window) requestIdleCallback(mountAmbient, { timeout: 3000 });
    else setTimeout(mountAmbient, 1500);

    section.querySelectorAll<HTMLElement>("[data-tableau]:not([data-cluster])").forEach((tableau) => {
      const pin = tableau.querySelector<HTMLElement>(".tableau-pin");
      const content = tableau.querySelector<HTMLElement>("[data-tableau-content]");
      const headline = tableau.querySelector<HTMLElement>("[data-tableau-headline]");
      if (!pin || !content) return;

      if (headline) splitLines(headline);

      // masked-line + content reveal, once, as the chapter enters
      ScrollTrigger.create({
        trigger: pin,
        start: "top 78%",
        once: true,
        onEnter: () => content.classList.add("is-revealed"),
      });

      // mobile: reveals only, no pin/parallax (§2b) — avoids mobile pin jank
      if (mobile) return;

      const layers = pin.querySelectorAll<HTMLElement>("[data-depth]");
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: pin,
          start: "top top",
          end: "+=90%",
          pin: true,
          scrub: true,
          anticipatePin: 1,
        },
      });
      // DIRECTION §1.1 P2 amplitudes (total travel over one viewport of scroll):
      // background 8% (6–10% band), midground 14% (12–16%), foreground 21%
      // (18–24%). Keyed to layer index (bg→mid→fg), not the raw depth value, so
      // the caps are exact. Split symmetrically (+half → −half). Scale
      // 1.04 → 1.0 on the BACKGROUND ONLY. Text layers are excluded (they live
      // in [data-tableau-content], not [data-depth]).
      const TRAVEL = [8, 14, 21]; // % of viewport, per layer index
      layers.forEach((layer, i) => {
        const amp = (TRAVEL[i] ?? TRAVEL[TRAVEL.length - 1]!) / 2;
        tl.fromTo(layer, { yPercent: amp }, { yPercent: -amp, ease: "none" }, 0);
        if (i === 0) tl.fromTo(layer, { scale: 1.04 }, { scale: 1, ease: "none" }, 0);
      });
    });

    ScrollTrigger.refresh();
    section.dataset.ready = "true"; // watchdog milestone (see inline fallback below)
  }
</script>

<script is:inline>
  // Fallback watchdog (mirrors the reveal-engine + Portal Hero pattern in
  // Base.astro): the tableaux headlines/body/CTA are hidden under html.js and
  // only un-hidden by the module engine above. If that engine never reaches its
  // ready milestone within 4s — its chunk 404s, a mid-init throw, or
  // document.fonts.ready hangs — force the §2b static fallback so the home
  // page's narrative body can never stay invisible. No-op once the engine boots
  // (and redundant-but-harmless under reduced motion, which CSS already shows).
  (() => {
    const section = document.querySelector("[data-tableaux]");
    if (!section) return;
    setTimeout(() => {
      if (section.dataset.ready === "true") return;
      section.querySelectorAll(".tableau-headline").forEach((el) => el.classList.add("is-split"));
      section.querySelectorAll(".tableau-content").forEach((el) => el.classList.add("is-revealed"));
    }, 4000);
  })();
</script>
