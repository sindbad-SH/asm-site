---
/**
 * THE GATE + AT ALTITUDE (V2-PLAN.md §2, V-1) — the Ascent's opening.
 *
 * Ritual (KPR threshold × the ASM sting × Everswap elegance):
 *   000 · THE GATE — void ground; the ASM mark is a WINDOW with the living
 *         aurora-S world visible inside it; a Space Mono altimeter ticks
 *         0 → 4,478m (the Matterhorn, from the field notes) while the hero
 *         media reaches ready. Then the window EXPANDS past the viewport —
 *         you pass THROUGH the mark into the world.
 *   AT ALTITUDE — full-bleed living painting (video loop ladder from v1:
 *         loop > CSS aurora/star overlays > still). The wordmark engraves
 *         itself in Fraunces IN THE SKY BEHIND THE PEAK (Everswap occlusion:
 *         an SVG ridge mask hides the letters where the mountain stands).
 *         Kicker + H1 + scroll cue settle in; the chapter rail appears.
 *
 * States & fallbacks (v1 discipline, binding):
 *   - no-JS default      → ENDCARD: world + engraved wordmark + content.
 *   - html.js            → gate state; engine runs the ritual.
 *   - reduced motion     → CSS forces the endcard; script bails.
 *   - chunk failure      → 4s inline watchdog forces .ascent-open.
 *   - ?ascent=static     → endcard (QA).
 *   - scroll during gate → skip straight to open (never trap the visitor).
 * Debug: window.__ASCENT { p(), set(v), skip(), video() }.
 *
 * Scroll-out: the world stays WHOLE (p holds 1) and recedes with the section;
 * content fades; the loop pauses off-screen. The mark NEVER re-forms over the
 * scene (v1 lesson, taste memory).
 *
 * HONESTY: the scene is AI-generated BRAND ART (the logo's world) — hero/
 * endcard use only, never gallery context.
 */
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const scene = {
  avif: `${base}/media/home/portal-scene.avif`,
  webp: `${base}/media/home/portal-scene.webp`,
};
const mark = `${base}/logo-mark.png`;

// Seeded star field for the CSS-overlay tier (same PRNG pattern as v1 —
// stable across builds, sky-band only, clear of the wordmark column).
const mulberry32 = (seed: number) => () => {
  seed |= 0;
  seed = (seed + 0x6d2b79f5) | 0;
  let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
  t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
  return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
};
const rng = mulberry32(20260706);
const stars = Array.from({ length: 30 }, () => {
  let x = 50;
  let y = 25;
  for (let tries = 0; tries < 14; tries++) {
    x = 3 + rng() * 94;
    y = 3 + rng() * 50;
    if (!(x > 30 && x < 70 && y > 18)) break;
  }
  return {
    x: x.toFixed(2),
    y: y.toFixed(2),
    size: (1 + rng() * 1.5).toFixed(2),
    o0: (0.15 + rng() * 0.2).toFixed(2),
    o1: (0.65 + rng() * 0.3).toFixed(2),
    dur: (2.8 + rng() * 2.6).toFixed(2),
    delay: (rng() * 5).toFixed(2),
  };
});

// Ridge occlusion polygon (viewBox 0 0 1280 720, traced against the poster's
// central peak + flanking ridgeline; tuned in-browser). The wordmark group is
// masked by (white sky − this black ridge), so letters vanish behind rock.
const RIDGE =
  "M0,720 L0,585 L96,556 L170,568 L252,520 L342,470 L398,505 L470,545 L540,568 L586,520 L634,468 L652,436 L666,420 L688,452 L724,512 L790,556 L862,588 L948,540 L1030,486 L1092,522 L1180,576 L1280,604 L1280,720 Z";
---

<section class="ascent" data-ascent data-mark-src={mark}>
  <div class="ascent-stage">
    <!-- 1 · the living world (v1 ladder: loop > overlays > still) -->
    <div class="ascent-world" data-world>
      <picture>
        <source srcset={scene.avif} type="image/avif" />
        <img
          class="ascent-scene"
          src={scene.webp}
          alt=""
          width="1280"
          height="720"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          data-scene
        />
      </picture>
      <video
        class="ascent-loop"
        data-loop
        muted
        loop
        playsinline
        preload="none"
        width="1280"
        height="720"
        aria-hidden="true"
        data-loop-src={`${base}/media/home/portal-loop.mp4`}></video>
      <div class="ascent-life" data-life aria-hidden="true">
        <div class="ascent-aurora"></div>
        <div class="ascent-stars">
          {
            stars.map((s) => (
              <span
                class="ascent-star"
                style={`left:${s.x}%;top:${s.y}%;width:${s.size}px;height:${s.size}px;--o0:${s.o0};--o1:${s.o1};--tw:${s.dur}s;--twd:${s.delay}s`}
              />
            ))
          }
        </div>
      </div>
    </div>

    <!-- 2 · the engraved wordmark, occluded by the ridge (Everswap move) -->
    <svg
      class="ascent-wordmark"
      viewBox="0 0 1280 720"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
      data-wordmark
    >
      <defs>
        <mask id="ascent-sky" maskUnits="userSpaceOnUse">
          <rect x="0" y="0" width="1280" height="720" fill="white"></rect>
          <path d={RIDGE} fill="black" style="filter: blur(3px)"></path>
        </mask>
      </defs>
      <g class="wordmark-lines" mask="url(#ascent-sky)">
        <text x="640" y="262" text-anchor="middle" class="wm wm-1">ADVENTURE</text>
        <text x="640" y="376" text-anchor="middle" class="wm wm-2">STORYTELLING</text>
        <text x="640" y="490" text-anchor="middle" class="wm wm-3">MEDIA</text>
      </g>
    </svg>

    <!-- 3 · the gate (void + mark-window + altimeter) — sits above everything -->
    <div class="ascent-gate" data-gate aria-hidden="true">
      <div class="gate-window" data-gate-window style={`background-image: image-set(url(${scene.avif}) type("image/avif"), url(${scene.webp}) type("image/webp"))`}>
      </div>
      <img class="gate-mark" src={mark} alt="" width="512" height="512" loading="eager" decoding="async" data-gate-mark />
      <p class="gate-counter" data-gate-counter><span data-alt>0000</span>M</p>
    </div>

    <!-- 4 · content: kicker, the real H1, scroll cue -->
    <div class="ascent-content" data-content>
      <p class="hud-label">Every story, taken as far as it goes.</p>
      <h1 class="ascent-h1">
        The StorySmith. I forge stories for the wild, the market, and the industry.
      </h1>
      <p class="ascent-cue" data-cue>Scroll to begin the ascent</p>
    </div>
  </div>
</section>

<!-- Watchdog OUTSIDE the engine chunk (v1 pattern): if html.js armed the gate
     but the engine never starts, force the endcard — nothing stays hidden. -->
<script is:inline>
  setTimeout(() => {
    const el = document.querySelector("[data-ascent]");
    if (el && !el.hasAttribute("data-ascent-live")) el.classList.add("ascent-open", "ascent-forced");
  }, 4000);
</script>

<script>
  import { gsap } from "gsap";

  const root = document.querySelector<HTMLElement>("[data-ascent]");
  if (root) init(root);

  function init(root: HTMLElement) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const params = new URLSearchParams(location.search);
    const q = <T extends HTMLElement>(s: string) => root.querySelector<T>(s)!;
    const worldEl = q("[data-world]");
    const loopEl = q<HTMLVideoElement>("[data-loop]");
    const lifeEl = q("[data-life]");
    const gateEl = q("[data-gate]");
    const gateWin = q("[data-gate-window]");
    const gateMark = q("[data-gate-mark]");
    const altEl = q("[data-alt]");
    const contentEl = q("[data-content]");

    if (reduce || params.get("ascent") === "static") {
      root.setAttribute("data-ascent-live", "static");
      root.classList.add("ascent-open");
      return;
    }
    root.setAttribute("data-ascent-live", "true");
    root.classList.add("ascent-gated"); // arms gate-state CSS (below html.js gate)

    // ── mask geometry for the mark window (v1 portal math) ──
    gateWin.style.setProperty("-webkit-mask-image", `url(${root.dataset.markSrc})`);
    gateWin.style.setProperty("mask-image", `url(${root.dataset.markSrc})`);
    let S0 = 0;
    let SF = 0;
    const stage = q(".ascent-stage");
    const measure = () => {
      const r = stage.getBoundingClientRect();
      S0 = Math.min(r.width, r.height) * 0.36;
      SF = Math.hypot(r.width, r.height) * 2.2;
    };
    measure();
    window.addEventListener("resize", () => {
      measure();
      render(proxy.p);
    });

    const seg = (p: number, a: number, b: number) => Math.min(1, Math.max(0, (p - a) / (b - a)));
    const proxy = { p: 0 };
    let videoLive = false;

    function setLiving(active: boolean) {
      root.classList.toggle("ascent-ambient", active);
      if (loopEl.src) {
        if (active && loopEl.paused) loopEl.play().catch(() => {});
        else if (!active && !loopEl.paused) loopEl.pause();
      }
    }

    // p: 0 = gate closed (window at mark size), 1 = fully through (open world)
    function render(p: number) {
      const size = S0 + (SF - S0) * seg(p, 0.1, 1);
      gateWin.style.setProperty("-webkit-mask-size", `${size}px`);
      gateWin.style.setProperty("mask-size", `${size}px`);
      gateEl.style.opacity = String(1 - seg(p, 0.75, 1)); // void+window hand off to the real world
      gateMark.style.opacity = String(1 - seg(p, 0.05, 0.35));
      gateMark.style.transform = `translate(-50%, -50%) scale(${1 + p * 0.06})`;
      worldEl.style.transform = `scale(${1.06 - 0.06 * p})`;
      lifeEl.style.opacity = videoLive ? "0" : String(seg(p, 0.7, 1));
      setLiving(p > 0.8);
      if (p >= 0.999 && !root.classList.contains("ascent-open")) {
        root.classList.add("ascent-open"); // wordmark engrave + content settle (CSS-driven)
        gateEl.style.pointerEvents = "none";
      }
    }
    render(0);

    // ── the altimeter: ticks with real readiness, lands at 4478 ──
    const ALT_TARGET = 4478;
    let ready = 0; // 0..1 real readiness signal
    const altProxy = { v: 0 };
    const altTick = gsap.to(altProxy, {
      v: 1,
      duration: 2.2,
      ease: "power2.inOut",
      paused: true,
      onUpdate: () => {
        altEl.textContent = String(Math.round(ALT_TARGET * altProxy.v)).padStart(4, "0");
      },
      onComplete: openGate,
    });

    // poster is already eager; count the loop's mount as the readiness beat.
    // Never wait on the network to open the gate (cap ~2.4s total).
    const mountLoop = () => {
      const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
      if (conn?.saveData || !window.matchMedia("(min-width: 768px)").matches) {
        ready = 1;
        return;
      }
      loopEl.addEventListener("playing", () => {
        if (videoLive) return;
        videoLive = true;
        root.classList.add("ascent-video-live");
        render(proxy.p);
      });
      loopEl.src = loopEl.dataset.loopSrc!;
      ready = 1; // metadata suffices; the poster covers any gap (pixel-identical frame 0)
    };
    mountLoop();
    altTick.play();

    // ── opening: pass through the mark ──
    let opened = false;
    function openGate() {
      if (opened) return;
      opened = true;
      // a hidden/backgrounded tab gets no smooth rAF — don't perform a ritual
      // nobody can watch; land on the open world for their return
      if (document.hidden) {
        forceOpen();
        return;
      }
      gsap.to(proxy, {
        p: 1,
        duration: 1.9,
        ease: "power3.inOut",
        onUpdate: () => render(proxy.p),
      });
    }
    // hard-open: kills tweens, lands the final state (wall-clock safe)
    function forceOpen() {
      opened = true;
      altTick.kill();
      gsap.killTweensOf(proxy);
      altEl.textContent = String(ALT_TARGET);
      proxy.p = 1;
      render(1);
    }
    // scroll or click skips the ritual — never trap the visitor
    const skip = () => {
      altTick.progress(1); // fires onComplete → openGate
    };
    window.addEventListener("wheel", skip, { once: true, passive: true });
    window.addEventListener("touchmove", skip, { once: true, passive: true });
    gateEl.addEventListener("click", skip, { once: true });
    // WALL-CLOCK BACKSTOPS (v1 watchdog discipline): rAF is throttled or fully
    // suspended in background tabs — GSAP's ticker (and thus the ritual) can
    // stall indefinitely there. Timers still fire (~1s clamp), so: begin the
    // opening by 3s no matter what, and be fully open by 6.5s no matter what.
    setTimeout(() => {
      if (!opened) skip();
    }, 3000);
    setTimeout(() => {
      if (proxy.p < 1) forceOpen();
    }, 6500);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden && proxy.p < 1) forceOpen();
    });

    // ── scroll-out: the world recedes WHOLE; content fades; loop pauses ──
    const smooth = (x: number) => x * x * (3 - 2 * x);
    const FADE_FROM = 0.1;
    const FADE_TO = 0.7;
    const mountScrollOut = async () => {
      try {
        const { ScrollTrigger } = await import("gsap/ScrollTrigger");
        gsap.registerPlugin(ScrollTrigger);
        ScrollTrigger.create({
          trigger: root,
          start: "top top",
          end: "bottom top",
          scrub: true,
          onUpdate: (self) => {
            const exit = smooth(
              Math.min(1, Math.max(0, (self.progress - FADE_FROM) / (FADE_TO - FADE_FROM))),
            );
            contentEl.style.opacity = String(1 - exit);
            setLiving(self.progress < 0.6 && proxy.p > 0.8);
          },
        });
      } catch {
        /* enhancement only */
      }
    };
    if ("requestIdleCallback" in window) requestIdleCallback(() => void mountScrollOut(), { timeout: 2500 });
    else setTimeout(() => void mountScrollOut(), 1200);

    // QA (harness tabs starve rAF; render(p) is deterministic)
    (window as unknown as Record<string, unknown>).__ASCENT = {
      p: () => proxy.p,
      set: (v: number) => {
        opened = true;
        altTick.kill();
        proxy.p = v;
        render(v);
      },
      skip,
      video: () => ({ mounted: !!loopEl.src, live: videoLive, paused: loopEl.paused }),
    };
  }
</script>

<style>
  .ascent-stage {
    position: relative;
    min-height: 100svh;
    overflow: clip;
    isolation: isolate;
    background: var(--hero-void, #101020);
  }

  /* ── the world ── */
  .ascent-world {
    position: absolute;
    inset: 0;
    z-index: 0;
    will-change: transform;
    transform-origin: center;
  }
  .ascent-scene,
  .ascent-loop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ascent-loop {
    opacity: 0;
    transition: opacity 700ms var(--ease-survey);
    pointer-events: none;
  }
  :global(.ascent-video-live) .ascent-loop {
    opacity: 1;
  }
  .ascent-life {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 1; /* endcard/no-JS: static light, motion paused */
  }
  .ascent-aurora {
    position: absolute;
    inset: 0;
    mix-blend-mode: screen;
    filter: blur(40px);
    opacity: 0.7;
  }
  .ascent-aurora::before,
  .ascent-aurora::after {
    content: "";
    position: absolute;
    animation-play-state: paused;
  }
  .ascent-aurora::before {
    left: 34%;
    top: -6%;
    width: 38%;
    height: 76%;
    background: radial-gradient(
      48% 40% at 50% 50%,
      rgba(86, 240, 212, 0.48),
      rgba(70, 205, 185, 0.19) 46%,
      transparent 72%
    );
    transform: rotate(16deg);
    animation: ascent-aurora-a 19s ease-in-out infinite alternate;
  }
  .ascent-aurora::after {
    left: 52%;
    top: 3%;
    width: 38%;
    height: 62%;
    background: radial-gradient(
      46% 42% at 50% 50%,
      rgba(126, 156, 255, 0.34),
      rgba(96, 220, 205, 0.15) 50%,
      transparent 74%
    );
    transform: rotate(-13deg);
    animation: ascent-aurora-b 25s ease-in-out infinite alternate;
  }
  .ascent-stars {
    position: absolute;
    inset: 0;
  }
  .ascent-star {
    position: absolute;
    border-radius: 50%;
    background: #e6efff;
    opacity: var(--o0);
    box-shadow: 0 0 6px 1px rgba(180, 214, 255, 0.5);
    animation: ascent-twinkle var(--tw) ease-in-out var(--twd) infinite alternate;
    animation-play-state: paused;
  }
  :global(.ascent-ambient) .ascent-aurora::before,
  :global(.ascent-ambient) .ascent-aurora::after,
  :global(.ascent-ambient) .ascent-star {
    animation-play-state: running;
  }
  @keyframes ascent-aurora-a {
    0% {
      transform: rotate(16deg) translate(-1%, 0) scale(1);
      opacity: 0.58;
    }
    100% {
      transform: rotate(13deg) translate(3%, 2%) scale(1.06);
      opacity: 0.92;
    }
  }
  @keyframes ascent-aurora-b {
    0% {
      transform: rotate(-13deg) translate(1%, 0) scale(1.02);
      opacity: 0.4;
    }
    100% {
      transform: rotate(-16deg) translate(-2%, 3%) scale(1.08);
      opacity: 0.78;
    }
  }
  @keyframes ascent-twinkle {
    from {
      opacity: var(--o0);
    }
    to {
      opacity: var(--o1);
    }
  }

  /* ── the wordmark (engraved, occluded by the ridge) ── */
  .ascent-wordmark {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .wm {
    font-family: var(--font-display);
    font-size: 118px;
    font-weight: 400;
    letter-spacing: 0.045em;
    fill: transparent;
    stroke: color-mix(in srgb, var(--color-peak) 82%, transparent);
    stroke-width: 1.1;
    /* visible by default — the no-JS endcard is complete (v1 discipline);
       hidden ONLY while a JS-driven gate is actually in progress */
    opacity: 0.9;
  }
  :global(html.js) :global(.ascent-gated):not(:global(.ascent-open)) .wm {
    opacity: 0;
  }
  /* engrave-in: a mask sweep per line, staggered (runs on .ascent-open) */
  :global(.ascent-open) .wm {
    opacity: 0.9;
    transition: opacity 400ms var(--ease-survey);
  }
  :global(.ascent-open) .wm-1 {
    animation: wm-engrave 1500ms var(--ease-survey) 150ms both;
  }
  :global(.ascent-open) .wm-2 {
    animation: wm-engrave 1500ms var(--ease-survey) 420ms both;
  }
  :global(.ascent-open) .wm-3 {
    animation: wm-engrave 1500ms var(--ease-survey) 690ms both;
  }
  @keyframes wm-engrave {
    from {
      opacity: 0;
      stroke-dashoffset: 8;
      stroke-dasharray: 2 6;
    }
    60% {
      stroke-dasharray: 6 2;
    }
    to {
      opacity: 0.9;
      stroke-dasharray: none;
      stroke-dashoffset: 0;
    }
  }

  /* ── the gate ── */
  .ascent-gate {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: var(--hero-void, #101020);
    opacity: 0; /* endcard/no-JS default: no gate */
    pointer-events: none;
    display: grid;
    place-items: center;
  }
  :global(html.js) :global(.ascent-gated) .ascent-gate {
    opacity: 1;
    pointer-events: auto;
  }
  .gate-window {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: 36vmin;
    mask-size: 36vmin;
  }
  .gate-mark {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(36vmin, 320px);
    height: auto;
    transform: translate(-50%, -50%);
    opacity: 0.95;
    filter: drop-shadow(0 0 18px color-mix(in srgb, var(--color-accent) 28%, transparent));
    pointer-events: none;
  }
  .gate-counter {
    position: absolute;
    bottom: 7svh;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    color: var(--color-ink-muted);
  }

  /* ── content ── */
  .ascent-content {
    position: absolute;
    left: 50%;
    bottom: 5.5svh;
    transform: translateX(-50%);
    z-index: 2;
    width: min(46rem, calc(100vw - 3rem));
    text-align: center;
    display: grid;
    gap: 0.9rem;
    justify-items: center;
  }
  .ascent-h1 {
    font-size: clamp(1.15rem, 2.6vw, 1.6rem);
    font-weight: 500;
    line-height: 1.35;
    color: var(--color-ink);
    text-shadow: 0 1px 18px color-mix(in srgb, var(--hero-void, #101020) 70%, transparent);
  }
  .ascent-cue {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--color-ink-muted);
    animation: cue-drift 2.6s ease-in-out infinite alternate;
    animation-play-state: paused;
  }
  :global(.ascent-ambient) .ascent-cue {
    animation-play-state: running;
  }
  @keyframes cue-drift {
    from {
      transform: translateY(0);
      opacity: 0.65;
    }
    to {
      transform: translateY(5px);
      opacity: 1;
    }
  }
  /* content hidden during the gate, settles in on open */
  :global(html.js) :global(.ascent-gated):not(:global(.ascent-open)) .ascent-content {
    opacity: 0;
    transform: translateX(-50%) translateY(1.2rem);
  }
  .ascent-content {
    transition:
      opacity 900ms var(--ease-survey) 600ms,
      transform 900ms var(--ease-survey) 600ms;
  }

  /* reduced motion: everything still, everything visible */
  @media (prefers-reduced-motion: reduce) {
    .ascent-aurora::before,
    .ascent-aurora::after,
    .ascent-star,
    .ascent-cue {
      animation: none !important;
    }
    .ascent-gate {
      opacity: 0 !important;
      pointer-events: none !important;
    }
    .wm {
      opacity: 0.9 !important;
      animation: none !important;
    }
    .ascent-content {
      opacity: 1 !important;
      transform: translateX(-50%) !important;
    }
  }
</style>
