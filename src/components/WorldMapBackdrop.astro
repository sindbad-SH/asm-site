---
/**
 * WorldMapBackdrop — the faint world behind THE TERRITORY constellation.
 *
 * ATMOSPHERE, NOT A RE-PROJECTION. This layer is a hairline equirectangular
 * world outline (real coastlines + a 30° graticule) in the page's cartography
 * grammar, at very low opacity in the resting contour color. It is now seated
 * inside `.terr-frame` (adventure.astro) — a 2:1 wrapper — so with the SVG's own
 * 2:1 viewBox and `preserveAspectRatio="xMidYMid meet"` it fills that frame
 * with NO internal letterbox. The interactive constellation lives in the SAME
 * frame, so the country dots seat on their true coastline by pure projection
 * math (left% = (lon+180)/360*100, top% = (90−lat)/180*100).
 *
 * ACCURATE COASTLINES: the land path is BAKED from a real dataset — Natural
 * Earth 1:110m land (world-atlas TopoJSON) — by scripts/make-world-map.mjs,
 * which converts it to this exact equirectangular projection. Vite inlines the
 * baked string at build via `?raw`, so there is NO runtime/network fetch;
 * re-bake with `node scripts/make-world-map.mjs` if the geometry ever changes.
 *
 * PROJECTION: equirectangular, viewBox "0 0 360 180", x = lon + 180 and
 * y = 90 − lat (1 SVG unit = 1°). Antarctica dropped; ~22 KB inline, no raster.
 *
 * NO "you-are-here" PINGS: the old in-SVG pings (Colorado / Switzerland / Italy)
 * were removed — the interactive country dots now sit at the exact same
 * projected pixels (verified to within ~0.08%), so the pings were duplicate
 * markers. If a distinct static "you-are-here" halo is ever wanted again, add it
 * as a ring on the constellation dot in adventure.astro, not here.
 *
 * MOTION: the section's subtle vertical parallax is owned by `.terr-frame`
 * (adventure.astro), which drifts the whole frame — map + nodes locked
 * together. This component is now static (no self-transform, no script), which
 * keeps map and dots from ever separating during scroll. The edge-fade mask
 * still softens the coastlines into the frame borders.
 */
import LAND from "../../scripts/world-map-path.txt?raw"; // baked by make-world-map.mjs

// 30° graticule.
const MERIDIANS = [30, 60, 90, 120, 150, 180, 210, 240, 270, 300, 330];
const PARALLELS = [30, 60, 120, 150]; // 90 (equator) is drawn separately, brighter
---

<div class="wm" aria-hidden="true">
  <svg
    class="wm-svg"
    viewBox="0 0 360 180"
    preserveAspectRatio="xMidYMid meet"
    focusable="false"
  >
    <g class="wm-graticule">
      {MERIDIANS.map((x) => <line x1={x} y1="0" x2={x} y2="180" />)}
      {PARALLELS.map((y) => <line x1="0" y1={y} x2="360" y2={y} />)}
    </g>
    <line class="wm-equator" x1="0" y1="90" x2="360" y2="90" />
    <path class="wm-land" d={LAND} fill-rule="evenodd" />
  </svg>
</div>

<style>
  /* Fills the shared 2:1 frame (adventure.astro's .terr-frame). Sits behind the
     arcs (z-index 1) and the nodes (z-index 4). A soft edge mask fades the
     coastlines into the frame borders so the world never ends on a hard line. */
  .wm {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    border-radius: 2px;
    pointer-events: none;
    -webkit-mask-image: radial-gradient(
      ellipse 92% 88% at 50% 50%,
      #000 62%,
      transparent 100%
    );
    mask-image: radial-gradient(ellipse 92% 88% at 50% 50%, #000 62%, transparent 100%);
  }
  .wm-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .wm-graticule line {
    stroke: var(--color-accent-deep);
    stroke-width: 0.35;
    vector-effect: non-scaling-stroke;
    opacity: 0.1;
  }
  .wm-equator {
    stroke: var(--color-accent-deep);
    stroke-width: 0.5;
    vector-effect: non-scaling-stroke;
    opacity: 0.16;
    stroke-dasharray: 1.5 3;
  }
  .wm-land {
    fill: color-mix(in srgb, var(--color-accent-deep) 22%, transparent);
    stroke: var(--color-accent-deep);
    stroke-width: 0.5;
    vector-effect: non-scaling-stroke;
    opacity: 0.5;
  }
</style>
